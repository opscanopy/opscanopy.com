# Cloudflare Static Assets headers (copied verbatim into dist/ by Astro).
#
# /_astro/* filenames are content-hashed by the build, so they are immutable —
# without this rule Cloudflare serves them with max-age=0,must-revalidate and
# every repeat navigation revalidates every asset.
#
# CSP notes:
#  - 'unsafe-inline' script-src: the theme/no-flash init, nav, and playground
#    boot scripts are inline Astro islands.
#  - 'wasm-unsafe-eval': Pagefind (/search) and /alertlint-wasm-demo load WebAssembly.
#  - googletagmanager/google-analytics: GA4 (Consent Mode v2, default-denied —
#    see Layout.astro). connect-src is otherwise 'self', which enforces the
#    "your input never leaves the browser" guarantee at the platform level.

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Pagefind: the loader (pagefind.js), entry manifest, language metas and wasm
# are NOT content-hashed and are regenerated on every deploy — they must revalidate,
# or a cached entry would reference index/fragment hashes a redeploy deleted
# (breaking /search for up to the TTL). The index/fragment chunks ARE
# content-hashed, so they get the same immutable treatment as /_astro/*.
/pagefind/*
  Cache-Control: public, max-age=0, must-revalidate

/pagefind/index/*
  Cache-Control: public, max-age=31536000, immutable

/pagefind/fragment/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://www.googletagmanager.com; connect-src 'self' https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com; img-src 'self' data: https://*.google-analytics.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; font-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'
