---
/**
 * /search — site-wide search over the Pagefind index built by `npm run build`
 * (postbuild: `pagefind --site dist` → dist/pagefind/).
 *
 * The interactive body (form/results/script) is the shared SearchPage
 * component — see src/components/SearchPage.astro — so this page owns only
 * Shell wiring. Pagefind indexes per <html lang> into separate sub-indexes,
 * auto-selected by this page's own lang, so SearchPage searches English
 * pages here and each locale mirror searches its own pages automatically.
 *
 * noindex/noAlternates/searchIndex={false} regardless of locale: this is a
 * utility page, never meant to be crawled or appear in Pagefind's own
 * results, so there is no SEO reason to advertise hreflang alternates
 * between the 5 copies even though they now all exist.
 */
import Shell from '../components/Shell.astro';
import SearchPage from '../components/SearchPage.astro';
---

<Shell
  title="Search — OpsCanopy"
  description="Search every OpsCanopy tool, guide, and blog post."
  canonical="/search"
  noindex={true}
  noAlternates={true}
  searchIndex={false}
>
  <SearchPage />
</Shell>
