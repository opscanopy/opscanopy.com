---
/**
 * Regex Log Tester — the tool page (primary SEO surface).
 * Paste a regular expression and sample log lines, see live matches, capture
 * groups and named groups — entirely in the browser. No server, no signup.
 *
 * Imports the interactive island (RegexLogTesterPlayground, self-mounting) plus
 * the brand primitives. JSON-LD (SoftwareApplication + FAQPage) is assembled in
 * frontmatter and handed to Shell via the `jsonLd` prop.
 */
import Shell from '../components/Shell.astro';
import RegexLogTesterPlayground from '../components/RegexLogTesterPlayground.astro';
import CodeBlock from '../components/CodeBlock.astro';
import ToolHero from '../components/ToolHero.astro';
import ToolPipeline from '../components/ToolPipeline.astro';
import FaqList from '../components/FaqList.astro';
import ToolCrossLinks from '../components/ToolCrossLinks.astro';
import { site, navLinks } from '../data/site';
import { getTool } from '../data/tools';
import { softwareAppLd, faqPageLd } from '../lib/jsonld';

const tool = getTool('regex-log-tester');

const pagePath = '/regex-log-tester';
const pageUrl = `${site.url}${pagePath}`;

// ── FAQ content — single source for both the rendered section and FAQPage LD ─
const faqs = [
  {
    q: 'What is the Regex Log Tester?',
    a: 'It’s a free, browser-based tool for testing a regular expression against real log lines. You paste a pattern and a block of sample logs, and it highlights every match, lists each capture group, and names any named groups — line by line. It’s built specifically for the log-parsing patterns you write for Loki, Promtail, Grafana Agent, Fluent Bit, Logstash and friends.',
  },
  {
    q: 'Does my data ever leave my browser?',
    a: 'No. The tester runs 100% client-side using your browser’s own regex engine. Your pattern and log lines are evaluated in the page — nothing is uploaded to a server, and there’s no account or signup. You can safely paste internal or sensitive log samples.',
  },
  {
    q: 'Which regex flavor does it use?',
    a: 'It uses the JavaScript (ECMAScript) regular-expression engine built into your browser, so syntax like \\d, character classes, anchors, alternation, named groups ((?<name>…)) and flags such as g, i, m and s all behave exactly as they do in JavaScript. The flavor differs in places from RE2 (used by Go-based log agents like Loki and Promtail) and PCRE, so always confirm a pattern in your target engine before shipping it.',
  },
  {
    q: 'How do I capture fields like timestamp, level and message?',
    a: 'Use named capture groups. Wrap each field you want to extract in (?<name>…) — for example (?<ts>\\S+) (?<level>\\w+) (?<msg>.*). The tester lists every named group it captured per matching line, which mirrors how Loki’s pattern/regexp parsers and Promtail’s regex stage turn matches into labels.',
  },
  {
    q: 'Why isn’t my pattern matching across multiple lines?',
    a: 'By default the dot (.) does not match newlines, and ^/$ match the start and end of the whole input rather than each line. Add the m flag so ^ and $ anchor to each line, and the s (dotAll) flag if you need . to span newlines. The tester evaluates each log line independently, which matches how most log agents apply a regex per line.',
  },
  {
    q: 'Can it warn me about catastrophic backtracking?',
    a: 'The tester runs your pattern with a guard so a pathological expression won’t freeze the tab, and it surfaces an error instead of hanging. It still pays to avoid nested quantifiers on overlapping classes (the classic (a+)+ shape) — those can be slow in any engine, not just in the browser.',
  },
];

// ── JSON-LD: SoftwareApplication ─────────────────────────────────────────────
const softwareApp = softwareAppLd({
  name: tool?.name ?? 'Regex Log Tester',
  description:
    'Test a regular expression against real log lines and see live matches, capture groups and named groups. Built for log parsing, runs entirely in your browser — no server, no signup.',
  url: pageUrl,
  subCategory: 'Logs',
  featureList: [
    'Live regex matching against pasted log lines',
    'Numbered capture groups and named groups per line',
    'Standard flags: g, i, m, s and more',
    '100% client-side, no upload, no signup',
  ],
  keywords: tool?.keywords.join(', '),
});

// ── JSON-LD: FAQPage (mirrors the rendered FAQ) ──────────────────────────────
const faqPage = faqPageLd(faqs);

// ── HOW IT WORKS pipeline ────────────────────────────────────────────────────
const pipeline = [
  {
    title: 'Compile the pattern.',
    body: 'Your expression and flags are compiled with the browser’s native regex engine — the same one your front-end code already runs on.',
  },
  {
    title: 'Split the log lines.',
    body: 'The sample block is split into individual lines so each one is tested on its own, exactly as a per-line log agent would apply it.',
  },
  {
    title: 'Match every line.',
    body: 'Each line is scanned for matches. With the global flag, every match on a line is found, not just the first.',
  },
  {
    title: 'Extract the groups.',
    body: 'For each match the tester pulls out numbered capture groups and any named groups, ready to read as fields.',
  },
  {
    title: 'Render live.',
    body: 'Matches are highlighted in place and groups are listed beneath, updating as you edit — all without leaving the page.',
  },
];

// ── Example: a regex for structured app logs ─────────────────────────────────
const patternExample = `^(?<ts>\\d{4}-\\d{2}-\\d{2}T\\S+)\\s+
(?<level>INFO|WARN|ERROR)\\s+
(?<logger>[\\w.]+)\\s+-\\s+
(?<msg>.*)$`;

// ── Example: sample log lines to test against ────────────────────────────────
const logLinesExample = `2026-06-08T09:14:02Z INFO  app.checkout - order 4821 placed
2026-06-08T09:14:05Z WARN  app.payment  - retrying charge for order 4821
2026-06-08T09:14:07Z ERROR app.payment  - charge failed: gateway timeout
2026-06-08T09:14:09Z INFO  app.checkout - order 4821 cancelled`;

// ── Example: common flags cheat-sheet ────────────────────────────────────────
const flagsExample = `g   global    find every match on a line, not just the first
i   ignore    case-insensitive matching (ERROR == error)
m   multiline ^ and $ anchor to each line, not the whole input
s   dotAll    . also matches newline characters
u   unicode   treat the pattern as a sequence of code points`;
---

<Shell
  title="Regex Log Tester — Match Patterns Against Log Lines Online"
  description="Paste a regex and sample log lines to see live matches, capture groups and named groups. Built for log parsing, runs entirely in your browser."
  canonical="/regex-log-tester"
  jsonLd={[softwareApp, faqPage]}
>
  <!-- ════════════════════════════════════════════════════════════════════
       1) HERO — compact, mesh gradient behind
       ════════════════════════════════════════════════════════════════════ -->
  <ToolHero
    eyebrow="Regex Log Tester · Logs"
    badges={[
      { label: 'Runs in your browser', variant: 'live' },
      { label: 'No signup', variant: 'neutral' },
      { label: 'Free & open', variant: 'neutral' },
    ]}
  >
    <Fragment slot="headline">Test your log regex against real lines.</Fragment>
    <Fragment slot="lead">
      Paste a regular expression and sample <span translate="no">Loki</span>,
      <span translate="no">Promtail</span> or <span translate="no">Fluent Bit</span> log lines, and
      see every match, capture group and named group light up live in your browser.
    </Fragment>
  </ToolHero>

  <!-- ════════════════════════════════════════════════════════════════════
       2) THE PLAYGROUND
       ════════════════════════════════════════════════════════════════════ -->
  <section id="playground" class="scroll-mt-24 bg-canvas-soft pt-8 pb-20 sm:pb-24">
    <div class="container-page">
      <h2 class="sr-only">Regex Log Tester playground</h2>
      <RegexLogTesterPlayground />
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       3) WHY IT EXISTS — the gap
       ════════════════════════════════════════════════════════════════════ -->
  <section id="why" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
        <div>
          <p class="eyebrow">The Gap</p>
          <h2 class="display-lg mt-3 text-balance text-ink">
            Get the pattern right before it ships.
          </h2>
        </div>
        <div class="space-y-4">
          <p class="body-md text-pretty text-body">
            A log-parsing regex usually fails quietly. You ship a
            <span class="code-mono text-ink" translate="no">regexp</span> stage or a
            <span class="code-mono text-ink" translate="no">pattern</span> parser, deploy it, and only
            later notice a field never populated or a whole stream of lines slipped through. The
            feedback loop runs through a pipeline and a dashboard instead of through the pattern in
            front of you.
          </p>
          <p class="body-md text-pretty text-body">
            This tester closes that loop. Paste the exact lines you’re parsing, watch the matches and
            named groups resolve as you edit, and fix the expression in seconds — before it reaches a
            config file. It’s the quick scratchpad that the big regex playgrounds aren’t: line-oriented,
            tuned for logs, and private by default.
          </p>
          <p class="body-sm text-mute">
            New to capture groups? Jump to <a class="link-inline" href="#syntax">the syntax notes</a> or
            try the <a class="link-inline" href="#playground">live playground</a> above.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       4) HOW IT WORKS — numbered pipeline
       ════════════════════════════════════════════════════════════════════ -->
  <ToolPipeline
    id="how-it-works"
    eyebrow="The Pipeline"
    heading="How it works."
    lead="Five deterministic steps run on every edit — all inside your browser tab, every time."
    steps={pipeline}
  />

  <!-- ════════════════════════════════════════════════════════════════════
       5) SYNTAX — pattern + log lines + flags docs
       ════════════════════════════════════════════════════════════════════ -->
  <section id="syntax" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Syntax</p>
        <h2 class="display-lg mt-3 text-ink">A pattern, your lines, the flags.</h2>
        <p class="body-md mx-auto mt-3 max-w-xl text-pretty text-body">
          The tester takes two inputs — a regular expression and a block of log lines — and applies
          the standard <span translate="no">JavaScript</span> flags. If you have written a parser for
          any log agent, this will feel familiar.
        </p>
      </div>

      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-2">
        <div class="min-w-0">
          <h3 class="display-sm text-ink">The pattern</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            Name the fields you want to extract with
            <span class="code-mono text-ink" translate="no">(?&lt;name&gt;…)</span> capture groups.
            The tester lists each named group it captured, the same way
            <span translate="no">Loki</span>’s
            <span class="code-mono text-ink" translate="no">pattern</span> /
            <span class="code-mono text-ink" translate="no">regexp</span> parsers and
            <span translate="no">Promtail</span>’s regex stage turn matches into labels.
          </p>
          <CodeBlock lang="regex" filename="pattern.re" code={patternExample} />
        </div>

        <div class="min-w-0">
          <h3 class="display-sm text-ink">The log lines</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            Paste the real lines you’re parsing — one per row. Each line is tested on its own, so a
            match or miss on one line never affects the next. Drop in a representative mix of
            <span class="code-mono text-ink" translate="no">INFO</span>,
            <span class="code-mono text-ink" translate="no">WARN</span> and
            <span class="code-mono text-ink" translate="no">ERROR</span> samples to confirm the
            pattern generalises.
          </p>
          <CodeBlock lang="log" filename="sample.log" code={logLinesExample} />
        </div>
      </div>

      <div class="mx-auto mt-8 max-w-5xl">
        <h3 class="display-sm text-ink">The flags</h3>
        <p class="body-sm mt-2 mb-4 max-w-2xl text-pretty text-body">
          Flags change how the engine reads your pattern. For per-line log parsing, the two you’ll
          reach for most are <span class="code-mono text-ink" translate="no">m</span> (so anchors hug
          each line) and <span class="code-mono text-ink" translate="no">i</span> (case-insensitive
          levels).
        </p>
        <CodeBlock lang="text" filename="flags.txt" code={flagsExample} />
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       6) NOTE — honest engine callout (RE2 vs ECMAScript)
       ════════════════════════════════════════════════════════════════════ -->
  <section class="bg-canvas-soft">
    <div class="container-page py-12 sm:py-16">
      <div class="card-soft mx-auto max-w-3xl p-6">
        <p class="eyebrow">A Note on Flavors</p>
        <p class="body-md mt-3 text-pretty text-body">
          This tester uses your browser’s <strong class="font-medium text-ink"
            ><span translate="no">JavaScript</span> (ECMAScript)</strong
          > regex engine. Many log agents — <span translate="no">Loki</span>,
          <span translate="no">Promtail</span> and the <span translate="no">Grafana Agent</span> — are
          written in <span translate="no">Go</span> and use the
          <span translate="no">RE2</span> engine, which deliberately omits backreferences and
          lookaround for guaranteed-linear performance.
          <span translate="no">PCRE</span>-based tools differ again. The core syntax — classes,
          anchors, quantifiers and named groups — is shared, so this is an excellent first pass; just
          confirm anything exotic in your target engine before you ship it.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       7) FAQ
       ════════════════════════════════════════════════════════════════════ -->
  <FaqList faqs={faqs} />

  <!-- ════════════════════════════════════════════════════════════════════
       Cross-links
       ════════════════════════════════════════════════════════════════════ -->
  <ToolCrossLinks>
    <Fragment slot="lead">
      The <span translate="no">Regex Log Tester</span> is one tool in
      <span translate="no">{site.name}</span> — a growing canopy of browser-based validators,
      converters and testers that never touch a server.
    </Fragment>
    <Fragment slot="links">
      Parsing <span translate="no">Loki</span> logs? Pair this with
      <a class="link-inline" href="/loki-alert-rule-tester">AlertLint</a>, the
      <span translate="no">promtool</span>-style unit tester for <span translate="no">Loki</span>
      alert rules — or browse the full
      <a class="link-inline" href={navLinks[0].href}>tools directory</a>.
    </Fragment>
    <Fragment slot="disclaimer">
      Not affiliated with or endorsed by <span translate="no">Grafana Labs</span>.
      <span translate="no">Loki</span>, <span translate="no">Promtail</span> and
      <span translate="no">Grafana</span> are trademarks of <span translate="no">Raintank, Inc.</span>
    </Fragment>
  </ToolCrossLinks>
</Shell>
