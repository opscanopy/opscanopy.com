---
/**
 * Practice Tests category page (/tests/<category>/) — the test list.
 *
 * Indexed + in the sitemap + Pagefind. getStaticPaths joins the content
 * collection to derive per-test question counts (content-derived, never
 * hand-written). Live tests link to the test-taking page; draft tests render
 * as a non-link "Coming soon". A boot script stamps "Best {pct}%" badges from
 * `oc-tests-v1` (progressive enhancement — static markup is the cold state).
 *
 * Modelled on learn/roadmaps/[slug].astro (breadcrumb + getStaticPaths).
 */
import { getCollection } from 'astro:content';
import Shell from '../../../components/Shell.astro';
import {
  liveCategories,
  testsInCategory,
  liveTestsInCategory,
  testKey,
} from '../../../data/tests';
import { accentGradients } from '../../../data/tools';
import { breadcrumbLd, itemListLd } from '../../../lib/jsonld';
import { site } from '../../../data/site';

export async function getStaticPaths() {
  const files = await getCollection('practiceTestQuestions');
  // Question count per test key, content-derived.
  const countByKey = new Map(
    files.map((f) => [`${f.data.category}/${f.data.test}`, f.data.questions.length]),
  );
  return liveCategories.map((category) => {
    const rows = testsInCategory(category.slug).map((t) => ({
      test: t,
      questionCount: countByKey.get(testKey(t.categorySlug, t.slug)) ?? 0,
    }));
    return { params: { category: category.slug }, props: { category, rows } };
  });
}

const { category, rows } = Astro.props;

// Header stat — M = total questions across LIVE tests only.
const liveTestCount = liveTestsInCategory(category.slug).length;
const liveQuestionTotal = rows
  .filter((r) => r.test.status === 'live')
  .reduce((sum, r) => sum + r.questionCount, 0);

const [g1, g2] = accentGradients[category.accent] ?? accentGradients.develop;
const bannerStyle = `background-image:linear-gradient(135deg, color-mix(in srgb, ${g1} 35%, var(--color-canvas-soft-2)), color-mix(in srgb, ${g2} 35%, var(--color-canvas-soft-2)))`;
const iconStyle = `color:color-mix(in srgb, ${g1} 70%, var(--color-ink))`;

const canonical = `/tests/${category.slug}`;
const jsonLd = [
  breadcrumbLd([
    { name: 'Home', item: `${site.url}/` },
    { name: 'Practice Tests', item: `${site.url}/tests/` },
    { name: category.shortName, item: `${site.url}${canonical}/` },
  ]),
  itemListLd(
    rows
      .filter((r) => r.test.status === 'live')
      .map((r) => ({
        name: r.test.name,
        url: `${site.url}/tests/${category.slug}/${r.test.slug}/`,
      })),
  ),
];
---
<Shell
  title={`${category.shortName} Practice Tests — OpsCanopy`}
  description={category.description}
  canonical={canonical}
  jsonLd={jsonLd}
  noAlternates
>
  <section class="bg-canvas-soft">
    <div class="container-page pb-16 pt-10 sm:pb-24">
      <nav aria-label="Breadcrumb" class="mb-2">
        <ol role="list" class="caption flex flex-wrap items-center gap-x-1.5 text-mute">
          <li><a href="/" class="hover:text-ink">Home</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/tests/" class="hover:text-ink">Practice Tests</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-body" aria-current="page">{category.shortName}</li>
        </ol>
      </nav>

      <div class="flex max-w-[52rem] items-start gap-5">
        <span
          class="hidden size-16 shrink-0 place-items-center rounded-xl border-b border-hairline sm:grid"
          style={bannerStyle}
          aria-hidden="true"
        >
          <svg width="40" height="40" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style={iconStyle}><Fragment set:html={category.icon} /></svg>
        </span>
        <div class="min-w-0">
          <p class="eyebrow">Certification</p>
          <h1 class="display-lg mt-2 text-balance text-ink">{category.name}</h1>
        </div>
      </div>
      <p class="body-lg mt-4 max-w-[45rem] text-pretty text-body">{category.description}</p>

      <div class="mt-9 max-w-[52rem]">
        <div class="flex items-baseline justify-between gap-3">
          <p class="eyebrow text-mute">Available tests</p>
          <p class="badge-mono text-mute">
            {liveTestCount} test{liveTestCount === 1 ? '' : 's'} · {liveQuestionTotal} questions
          </p>
        </div>
        <ul role="list" class="mt-3.5 flex flex-col gap-3.5">
          {
            rows.map(({ test, questionCount }) => {
              const isLive = test.status === 'live';
              const href = `/tests/${category.slug}/${test.slug}/`;
              return (
                <li>
                  <div
                    class="card flex flex-wrap items-center gap-x-5 gap-y-4 px-6 py-5 shadow-subtle"
                    data-test-row
                    data-key={testKey(test.categorySlug, test.slug)}
                  >
                    <div class="min-w-0 flex-1 basis-80">
                      <h3 class="display-sm text-ink">{test.name}</h3>
                      <div class="mt-2.5 flex flex-wrap items-center gap-1.5">
                        {isLive && (
                          <span class="badge badge-mono">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" /></svg>
                            {questionCount} question{questionCount === 1 ? '' : 's'}
                          </span>
                        )}
                        {isLive && test.minutes && (
                          <span class="badge badge-mono">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" /></svg>
                            ~{test.minutes} min
                          </span>
                        )}
                        {isLive && <span class="badge badge-mono">Pass {test.passThreshold}%</span>}
                        {isLive ? (
                          <span class="badge tests-best-badge" data-best-badge hidden>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6M18 9h1.5a2.5 2.5 0 0 0 0-5H18M4 22h16M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22M18 2H6v7a6 6 0 0 0 12 0V2Z" /></svg>
                            <span data-best-badge-text></span>
                          </span>
                        ) : (
                          <span class="badge badge-mono">Coming soon</span>
                        )}
                      </div>
                    </div>
                    {isLive ? (
                      <a class="btn btn-primary btn-sm shrink-0" href={href} data-start-link>
                        <span data-start-label>Start test</span>
                      </a>
                    ) : (
                      <span class="btn btn-secondary btn-sm shrink-0" aria-disabled="true">Coming soon</span>
                    )}
                  </div>
                </li>
              );
            })
          }
        </ul>
      </div>
    </div>
  </section>
</Shell>

<style>
  .tests-best-badge {
    border: 1px solid color-mix(in srgb, var(--color-warning-deep) 35%, transparent);
    background: var(--color-warning-soft);
    color: var(--color-warning-deep);
    font-weight: 600;
  }
</style>

<script>
  import { parseProgress, bestFor, PROGRESS_KEY } from '../../../lib/tests/progress';

  function boot(): void {
    let progress;
    try {
      progress = parseProgress(localStorage.getItem(PROGRESS_KEY));
    } catch {
      return; // storage blocked — leave the cold static markup as-is
    }

    document.querySelectorAll<HTMLElement>('[data-test-row]').forEach((row) => {
      const key = row.dataset.key ?? '';
      const attempt = bestFor(progress, key);
      if (!attempt) return;
      const badge = row.querySelector<HTMLElement>('[data-best-badge]');
      const text = row.querySelector<HTMLElement>('[data-best-badge-text]');
      if (badge && text) {
        text.textContent = `Best ${attempt.bestPct}%`;
        badge.hidden = false;
      }
      // A returning learner has taken this test — the CTA becomes "Retake test"
      // (never "Resume review": we store no answers, so review can't resume).
      const label = row.querySelector<HTMLElement>('[data-start-label]');
      if (label) label.textContent = 'Retake test';
    });
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
