---
/**
 * Practice Tests hub (/tests) — the certification category grid.
 *
 * Indexed + in the sitemap + Pagefind. Everything renders perfectly with JS or
 * storage blocked: the static markup IS the cold-start / first-visit state. A
 * small boot script reads `oc-tests-v1` and stamps per-test "Best {pct}%"
 * badges on the cards where a stored best exists (progressive enhancement).
 *
 * Modelled on learn/index.astro + mission-90/index.astro.
 */
import Shell from '../../components/Shell.astro';
import { liveCategories, liveTestsInCategory } from '../../data/tests';
import { accentGradients } from '../../data/tools';
import { breadcrumbLd, itemListLd } from '../../lib/jsonld';
import { site } from '../../data/site';

// Per-category view-model: icon wash + live-test count + card href.
const cards = liveCategories.map((category) => {
  const [g1, g2] = accentGradients[category.accent] ?? accentGradients.develop;
  const liveCount = liveTestsInCategory(category.slug).length;
  return {
    category,
    href: `/tests/${category.slug}/`,
    liveCount,
    bannerStyle: `background-image:linear-gradient(135deg, color-mix(in srgb, ${g1} 35%, var(--color-canvas-soft-2)), color-mix(in srgb, ${g2} 35%, var(--color-canvas-soft-2)))`,
    iconStyle: `color:color-mix(in srgb, ${g1} 70%, var(--color-ink))`,
  };
});

const canonical = '/tests';
const jsonLd = [
  breadcrumbLd([
    { name: 'Home', item: `${site.url}/` },
    { name: 'Practice Tests', item: `${site.url}/tests/` },
  ]),
  itemListLd(
    cards.map((c) => ({ name: c.category.name, url: `${site.url}${c.href}` })),
  ),
];
---
<Shell
  title="Free Certification Practice Tests — OpsCanopy"
  description="Free, browser-based multiple-choice practice tests for DevOps certifications. Realistic scenario questions, instant scoring, per-question explanations, and your best score saved locally — no signup, no paywall."
  canonical={canonical}
  jsonLd={jsonLd}
  noAlternates
>
  <section class="bg-canvas-soft">
    <div class="container-page py-16 sm:py-24">
      <div class="mx-auto max-w-3xl text-center">
        <p class="eyebrow">Practice Tests · Certification prep</p>
        <h1 class="display-lg mt-3.5 text-balance text-ink">Free certification practice tests</h1>
        <p class="body-lg mt-4 text-pretty text-body">
          Sharpen up for your next certification with free, realistic multiple-choice practice tests.
          Every question runs entirely in your browser — instant scoring, per-question explanations,
          and your best score saved locally. No signup, no paywall.
        </p>
      </div>

      <p class="mt-14 text-center text-[13px] font-medium uppercase tracking-wide text-mute">
        Choose a certification
      </p>
      <ul
        role="list"
        class="mx-auto mt-6 grid max-w-6xl grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
      >
        {
          cards.map(({ category, href, liveCount, bannerStyle, iconStyle }) => (
            <li class="h-full">
              <div
                class="card card-interactive relative flex h-full flex-col overflow-hidden p-6 shadow-soft"
                data-test-category
                data-slug={category.slug}
              >
                <div
                  class="-mx-6 -mt-6 mb-5 flex h-24 items-center justify-center border-b border-hairline"
                  style={bannerStyle}
                  aria-hidden="true"
                >
                  <svg
                    width="60"
                    height="60"
                    viewBox="0 0 48 48"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    style={iconStyle}
                  >
                    <Fragment set:html={category.icon} />
                  </svg>
                </div>
                <h3 class="display-sm text-ink">
                  <a
                    href={href}
                    class="rounded-sm outline-none after:absolute after:inset-0 after:content-['']"
                  >
                    {category.name}
                  </a>
                </h3>
                <p class="badge-mono mt-1.5 tracking-wide text-mute">{category.shortName}</p>
                <p class="body-sm mt-2.5 text-pretty text-body">{category.description}</p>
                <div class="mt-3.5 flex flex-wrap items-center gap-1.5">
                  <span class="badge badge-mono">
                    {liveCount} test{liveCount === 1 ? '' : 's'}
                  </span>
                  {/* Best-score badge — filled by the boot script when a stored
                      best exists for any test in this category; hidden cold. */}
                  <span class="badge tests-best-badge" data-best-badge hidden>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6M18 9h1.5a2.5 2.5 0 0 0 0-5H18M4 22h16M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22M18 2H6v7a6 6 0 0 0 12 0V2Z" /></svg>
                    <span data-best-badge-text></span>
                  </span>
                </div>
                <div class="mt-auto pt-5">
                  <span class="link-inline body-sm inline-flex items-center gap-1 font-medium">
                    View tests
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
                  </span>
                </div>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Shell>

<style>
  .tests-best-badge {
    border: 1px solid color-mix(in srgb, var(--color-brand) 30%, transparent);
    background: var(--color-brand-soft);
    color: var(--color-brand-strong);
    font-weight: 600;
  }
</style>

<script>
  import { parseProgress, bestFor, PROGRESS_KEY } from '../../lib/tests/progress';
  import { liveTestsInCategory, testKey } from '../../data/tests';

  function boot(): void {
    let progress;
    try {
      progress = parseProgress(localStorage.getItem(PROGRESS_KEY));
    } catch {
      return; // storage blocked — leave the cold static markup as-is
    }

    document
      .querySelectorAll<HTMLElement>('[data-test-category]')
      .forEach((card) => {
        const slug = card.dataset.slug ?? '';
        // Highest stored best across every live test in this category.
        let best: number | undefined;
        for (const test of liveTestsInCategory(slug)) {
          const attempt = bestFor(progress, testKey(test.categorySlug, test.slug));
          if (attempt && (best === undefined || attempt.bestPct > best)) {
            best = attempt.bestPct;
          }
        }
        if (best === undefined) return;
        const badge = card.querySelector<HTMLElement>('[data-best-badge]');
        const text = card.querySelector<HTMLElement>('[data-best-badge-text]');
        if (badge && text) {
          text.textContent = `Best ${best}%`;
          badge.hidden = false;
        }
      });
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
