---
/**
 * 404 — branded not-found page, rendered as a terminal request/response slab
 * (the "field manual" treatment). Shows the failing GET for the current path,
 * then routes the visitor back into the catalog / search.
 */
import Shell from '../components/Shell.astro';
import Button from '../components/Button.astro';
import ErrorTerminal from '../components/ErrorTerminal.astro';
---

<Shell
  title="Page not found — OpsCanopy"
  description="That page is not part of the canopy."
  canonical="/404"
  noindex={true}
  noAlternates={true}
>
  <ErrorTerminal
    eyebrow="Error 404"
    command="GET /… HTTP/1.1"
    statusLine="HTTP/1.1 404 Not Found"
    note="that page isn't part of the canopy — the link may be broken, or it may have moved."
    srHeading="404 — page not found"
    injectPath={true}
  >
    <Button href="/" variant="primary">Back to home</Button>
    <Button href="/tools/" variant="secondary">Browse all tools</Button>
    <span class="body-sm text-mute sm:ml-1">
      or press <kbd class="rounded-xs border border-hairline-muted bg-canvas px-1.5 py-0.5 font-mono text-[11px] text-body">⌘K</kbd> to search
    </span>
  </ErrorTerminal>
</Shell>
