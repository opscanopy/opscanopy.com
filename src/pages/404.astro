---
/**
 * 404 — branded not-found page.
 * Calm, centered, on-brand: a large "404", a one-line active-voice message,
 * and two CTAs. A faint hero-scale mesh gradient drifts behind the content.
 */
import Shell from '../components/Shell.astro';
import Button from '../components/Button.astro';
import MeshGradient from '../components/MeshGradient.astro';
---

<Shell
  title="Page not found — OpsCanopy"
  description="That page is not part of the canopy."
  canonical="/404"
  noindex={true}
  noAlternates={true}
>
  <section class="relative isolate overflow-hidden">
    <MeshGradient class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[420px] opacity-60" />

    <div class="container-page flex min-h-[70vh] flex-col items-center justify-center py-24 text-center sm:py-32">
      <p class="eyebrow mb-5">Error 404</p>

      <h1 class="display-xl text-ink">404<span class="sr-only"> — page not found</span></h1>

      <p class="body-lg mt-5 max-w-md text-balance text-body">
        This page is not part of the canopy. The link may be broken, or the page may
        have moved.
      </p>

      <div class="mt-9 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
        <Button href="/" variant="primary">Back to Home</Button>
        <Button href="/tools/" variant="secondary">Browse All Tools</Button>
      </div>

      <p class="body-sm mt-8 text-mute">
        Looking for something specific?{' '}
        <a class="link-inline" href="/tools/">Check the catalog.</a>
      </p>
    </div>
  </section>
</Shell>
