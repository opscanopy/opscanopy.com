---
/**
 * /blog — post index.
 * Lists every non-draft entry from the "blog" collection, newest first,
 * as a responsive grid of post cards linking to /blog/[id].
 */
import { getCollection } from 'astro:content';
import Shell from '../../components/Shell.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Shell
  title="Blog — OpsCanopy"
  description="Notes on DevOps tooling, observability, and the gaps worth filling."
  canonical="/blog"
>
  <section class="border-b border-hairline bg-canvas-soft">
    <div class="container-page py-16 sm:py-24">
      <header class="max-w-[44rem]">
        <p class="eyebrow">Writing</p>
        <h1 class="display-xl mt-4 text-ink">Notes from the canopy.</h1>
        <p class="body-lg mt-6 text-body">
          Observations on DevOps tooling, observability, and the small gaps in the
          ecosystem worth filling — written for the engineers who hit them.
        </p>
        {posts.length > 0 && (
          <p class="caption mt-6 flex items-center gap-2 text-mute">
            <span class="tabular-nums">{posts.length}</span>
            {posts.length === 1 ? 'post' : 'posts'} and counting.
          </p>
        )}
      </header>

      {
        posts.length === 0 ? (
          <div class="card-soft mt-12 flex flex-col items-center justify-center px-6 py-16 text-center">
            <p class="eyebrow">Notes</p>
            <p class="display-sm mt-3 text-ink">Nothing here right now.</p>
            <p class="body-md mt-2 max-w-md text-balance text-body">
              New notes are on the way. In the meantime, explore the tools.
            </p>
            <a href="/tools" class="btn btn-secondary btn-sm mt-6">Browse the Tools</a>
          </div>
        ) : (
          <ul role="list" class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => (
              <li class="h-full">
                <a
                  href={`/blog/${post.id}`}
                  class="card group flex h-full min-w-0 flex-col p-6 transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-soft focus-visible:-translate-y-0.5 focus-visible:shadow-soft motion-reduce:transform-none motion-reduce:hover:translate-y-0"
                >
                  <time
                    datetime={post.data.pubDate.toISOString()}
                    class="eyebrow tabular-nums"
                  >
                    {dateFmt.format(post.data.pubDate)}
                  </time>
                  <h2 class="display-sm mt-3 text-balance text-ink">{post.data.title}</h2>
                  <p class="body-sm mt-3 line-clamp-4 grow text-pretty text-body">
                    {post.data.description}
                  </p>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <ul role="list" class="mt-5 flex flex-wrap gap-2">
                      {post.data.tags.map((tag) => (
                        <li class="badge code-mono lowercase">{tag}</li>
                      ))}
                    </ul>
                  )}
                  <span
                    class="body-sm mt-5 inline-flex items-center gap-1 font-medium text-link"
                    aria-hidden="true"
                  >
                    Read post
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 16 16"
                      fill="none"
                      class="transition-transform duration-150 ease-out group-hover:translate-x-0.5 group-focus-visible:translate-x-0.5 motion-reduce:transform-none"
                    >
                      <path
                        d="M6 3.5 10.5 8 6 12.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</Shell>
