---
/**
 * /blog/tag/[tag] — posts filed under a single tag.
 *
 * SCOPE: default locale (en) only. Per-locale tag routing
 * (/es/blog/tag/…, /de/blog/tag/… …) is a deliberate follow-up — keeping this
 * to en avoids generating localized tag URLs the cards/breadcrumbs would have
 * to special-case, and keeps the i18n routing + build green. When localizing,
 * add src/pages/[lang]/blog/tag/[tag].astro mirroring this file with `lang`
 * threaded through getAllTags/getPostsByTag and localizeKey on every href.
 *
 * Tag slugs are lowercased (see getAllTags); matching is case-insensitive so a
 * "Cron" frontmatter tag and /blog/tag/cron resolve to the same page.
 */
import Shell from '../../../components/Shell.astro';
import { DEFAULT_LOCALE } from '../../../i18n/config';
import { useTranslations } from '../../../i18n/utils';
import { breadcrumbLd } from '../../../lib/jsonld';
import { site } from '../../../data/site';
import {
  getAllPosts,
  getAllTags,
  getPostsByTag,
  formatPostDate,
  estimateReadingTime,
} from '../../../i18n/blog';

const lang = DEFAULT_LOCALE;

export async function getStaticPaths() {
  const all = await getAllPosts();
  const tags = getAllTags(DEFAULT_LOCALE, all);
  return tags.map((tag) => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.props as { tag: string };
const t = useTranslations(lang);

const allPosts = await getAllPosts();
const posts = getPostsByTag(tag, lang, allPosts);

const canonical = `/blog/tag/${tag}`;

const breadcrumbJsonLd = breadcrumbLd([
  { name: t('blog.breadcrumbHome'), item: `${site.url}/` },
  { name: t('blog.breadcrumbBlog'), item: `${site.url}/blog` },
  { name: t('blog.breadcrumbTag'), item: `${site.url}/blog` },
  { name: tag, item: `${site.url}${canonical}` },
]);
---

<Shell
  title={`${t('blog.tagTitle', { tag })} — OpsCanopy`}
  description={t('blog.tagLead', { tag })}
  canonical={canonical}
>
  <section class="border-b border-hairline bg-canvas-soft">
    <div class="container-page py-16 sm:py-24">
      <nav aria-label={t('blog.breadcrumbAriaLabel')} class="mb-6">
        <ol role="list" class="caption flex flex-wrap items-center gap-x-1.5 gap-y-1 text-mute">
          <li>
            <a href="/" class="rounded px-0.5 transition-colors hover:text-ink">
              {t('blog.breadcrumbHome')}
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li>
            <a href="/blog" class="rounded px-0.5 transition-colors hover:text-ink">
              {t('blog.breadcrumbBlog')}
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li class="min-w-0 truncate text-body" aria-current="page">{tag}</li>
        </ol>
      </nav>

      <header class="max-w-[44rem]">
        <p class="eyebrow">{t('blog.tagEyebrow')}</p>
        <h1 class="display-xl mt-4 text-balance text-ink">{t('blog.tagTitle', { tag })}</h1>
        <p class="body-lg mt-6 text-body">{t('blog.tagLead', { tag })}</p>
        {
          posts.length > 0 && (
            <p class="caption mt-6 flex items-center gap-2 text-mute">
              <span class="tabular-nums">{posts.length}</span>
              {posts.length === 1 ? t('blog.tagCountSingular') : t('blog.tagCountPlural')}
            </p>
          )
        }
      </header>

      <ul role="list" class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          posts.map((post) => (
            <li class="h-full">
              <a
                href={`/blog/${post.slug}`}
                class="card group flex h-full min-w-0 flex-col p-6 transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-soft focus-visible:-translate-y-0.5 focus-visible:shadow-soft motion-reduce:transform-none motion-reduce:hover:translate-y-0"
              >
                <p class="caption flex flex-wrap items-center gap-x-1.5 gap-y-1 text-mute">
                  <span>{post.entry.data.author}</span>
                  <span aria-hidden="true">·</span>
                  <time datetime={post.entry.data.pubDate.toISOString()} class="tabular-nums">
                    {formatPostDate(lang, post.entry.data.pubDate)}
                  </time>
                  <span aria-hidden="true">·</span>
                  <span class="tabular-nums">
                    {t('blog.readingTime', { minutes: estimateReadingTime(post.entry.body) })}
                  </span>
                </p>
                <h2 class="display-sm mt-3 text-balance text-ink">{post.entry.data.title}</h2>
                <p class="body-sm mt-3 line-clamp-4 grow text-pretty text-body">
                  {post.entry.data.description}
                </p>
                {post.entry.data.tags && post.entry.data.tags.length > 0 && (
                  <ul role="list" class="mt-5 flex flex-wrap gap-2">
                    {post.entry.data.tags.map((tg) => (
                      <li class="badge code-mono lowercase">{tg}</li>
                    ))}
                  </ul>
                )}
                <span
                  class="body-sm mt-5 inline-flex items-center gap-1 font-medium text-link"
                  aria-hidden="true"
                >
                  {t('blog.readPost')}
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 16 16"
                    fill="none"
                    class="transition-transform duration-150 ease-out group-hover:translate-x-0.5 group-focus-visible:translate-x-0.5 motion-reduce:transform-none"
                  >
                    <path
                      d="M6 3.5 10.5 8 6 12.5"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
</Shell>
