---
/**
 * /blog/[slug] — English single post. Thin wrapper over the shared BlogPost
 * component; per-locale posts live at src/pages/[lang]/blog/[...slug].astro.
 */
import BlogPost from '../../components/page/BlogPost.astro';
import { getPostsForLocale, localesForSlug } from '../../i18n/blog';

export async function getStaticPaths() {
  const posts = await getPostsForLocale('en');
  const paths = [];
  for (const post of posts) {
    const available = await localesForSlug(post.slug);
    paths.push({ params: { slug: post.slug }, props: { post, available } });
  }
  return paths;
}

const { post, available } = Astro.props;
---

<BlogPost post={post} lang="en" available={available} />
