---
/**
 * Slugify — the slugify tool page (SEO surface). Turn any title into a clean,
 * URL-safe slug: strip accents and diacritics, collapse separators and enforce
 * a max length, with a configurable separator — entirely in the browser.
 */
import Shell from '../components/Shell.astro';
import SlugifyPlayground from '../components/SlugifyPlayground.astro';
import Button from '../components/Button.astro';
import CodeBlock from '../components/CodeBlock.astro';
import ToolHero from '../components/ToolHero.astro';
import ToolPipeline from '../components/ToolPipeline.astro';
import FaqList from '../components/FaqList.astro';
import ToolCrossLinks from '../components/ToolCrossLinks.astro';
import { site, navLinks } from '../data/site';
import { getTool } from '../data/tools';
import { softwareAppLd, faqPageLd } from '../lib/jsonld';

const tool = getTool('slugify');
const pagePath = '/slugify/';
const pageUrl = `${site.url}${pagePath}`;

const faqs = [
  {
    q: 'What is a slug?',
    a: 'A slug is the human-readable part of a URL that identifies a page in words rather than an opaque id — the "hello-world" in /blog/hello-world. A good slug uses only lowercase letters, digits and a single separator, so it is safe to type, share and index. Slugify turns any title or heading into one in your browser.',
  },
  {
    q: 'How are accented and non-English characters handled?',
    a: 'The title is Unicode-normalized (NFKD) and every combining mark is stripped, so accents and diacritics are removed rather than dropped: café becomes cafe, Zürich becomes zurich, and typographic ligatures like ﬁ decompose to fi. Characters with no ASCII letter or digit underneath — emoji, symbols, CJK — are removed, and the remaining words are joined with your separator.',
  },
  {
    q: 'Which separators can I use?',
    a: 'A hyphen (-), an underscore (_) or a dot (.). Hyphen is the convention for web URLs and the one search engines treat as a word break, so it is the default. Whichever you pick, any run of disallowed characters collapses to a single separator and leading or trailing separators are trimmed.',
  },
  {
    q: 'What does the max-length option do?',
    a: 'It caps the slug at a number of characters. Slugify prefers to cut at the last separator boundary at or before the limit so the slug ends on a whole word; if a single word is already longer than the limit it hard-cuts at the limit and removes any trailing separator. Leave it empty (or 0) for no limit.',
  },
  {
    q: 'Why should slugs be lowercase?',
    a: 'URLs are case-sensitive on most servers, so /Hello-World and /hello-world can resolve to different pages — a common source of duplicate-content and broken-link problems. Lowercasing keeps every slug canonical and predictable. The Lowercase toggle is on by default; turn it off if you specifically need to preserve case.',
  },
  {
    q: 'Does my text ever leave my browser?',
    a: 'No. Slugify runs 100% client-side in your tab — there is no server, no account and no logging. You can paste draft titles, internal headings or private content; it never travels over the network.',
  },
  {
    q: 'Is the slug SEO-friendly?',
    a: 'Yes. Short, lowercase, hyphen-separated slugs that contain the page keywords are the format search engines and users read best. Slugify strips stop punctuation and accents so the words survive intact, and the max-length option keeps the slug concise instead of a wall of hyphenated text.',
  },
  {
    q: 'Can I turn a slug back into a title?',
    a: 'Not reliably — slugifying is lossy. Case, punctuation, accents and separators are all normalized away, so hello-world could have come from "Hello, World!" or "hello world". Keep the original title as your source of truth and generate the slug from it, not the other way around.',
  },
];

const softwareApp = softwareAppLd({
  name: 'Slugify',
  description:
    'Free slugify tool. Turn any title into a clean, URL-safe slug — strip accents and diacritics, collapse separators and enforce a max length, with a configurable separator. 100% in-browser, no signup, data stays local.',
  url: pageUrl,
  subCategory: 'Utilities',
  featureList: [
    'Transliterate accents and strip diacritics via Unicode NFKD',
    'Configurable separator — hyphen, underscore or dot',
    'Max-length limit with word-boundary truncation',
    '100% client-side, no upload, no signup',
  ],
  keywords: tool?.keywords.join(', '),
});
const faqPage = faqPageLd(faqs);

const pipeline = [
  {
    title: 'Normalize the Unicode.',
    body: 'The title is decomposed to NFKD form so accents, diacritics and ligatures separate from their base letters — café becomes cafe, ﬁ becomes fi.',
  },
  {
    title: 'Strip what URLs reject.',
    body: 'Combining marks and every character outside letters and digits — punctuation, symbols, emoji — are removed, leaving only URL-safe words.',
  },
  {
    title: 'Join and collapse.',
    body: 'Words are joined with your chosen separator; runs of separators collapse to one and any leading or trailing separator is trimmed.',
  },
  {
    title: 'Bound the length.',
    body: 'If a max length is set, the slug is cut at the last word boundary at or before the limit — or hard-cut when a single word overruns it.',
  },
];

const rulesTable = `input   "Blog post: Héllo Wörld! (2026)"

step 1  NFKD      Blog post: He\u0301llo Wo\u0308rld! (2026)
step 2  strip \\p{M}   Blog post: Hello World! (2026)
step 3  lowercase     blog post: hello world! (2026)
step 4  non-alnum → - blog-post-hello-world-2026

separators   -  _  .        (single char, collapsed)
kept chars   a–z 0–9         (A–Z 0–9 if lowercase off)
max length   cut at last "-" boundary ≤ limit`;

const boundaryExample = `slug     hello-world-again          (17 chars)

max 12   hello-world                cut at "-" boundary ≤ 12
max 5    hello                      "hello-…" trimmed
max 60   hello-world-again          within the limit

no boundary before the limit → hard cut:
supercalifragilistic  max 5  →  super`;
---

<Shell
  title="Slugify — Free Online URL Slug Generator, In-Browser"
  description="Free slugify tool. Turn any title into a clean, URL-safe slug — strip accents and diacritics, collapse separators and set a max length. 100% in-browser, no signup, data stays local."
  canonical="/slugify"
  jsonLd={[softwareApp, faqPage]}
>
  <ToolHero
    slug="slugify"
    eyebrow="Slugify · Utilities"
    badges={[
      { label: 'Runs in your browser', variant: 'live' },
      { label: 'Accent-aware', variant: 'neutral' },
      { label: 'No signup', variant: 'neutral' },
    ]}
  >
    <Fragment slot="headline">Turn any title into a clean URL slug.</Fragment>
    <Fragment slot="lead">
      Transliterate accents, strip punctuation and join the words with your chosen
      separator — bounded to a max length — then copy the slug or a ready-made link.
      Free, no signup, and your text never leaves your device.
    </Fragment>
  </ToolHero>

  <section id="playground" class="scroll-mt-24 bg-canvas-soft pt-8 pb-20 sm:pb-24">
    <div class="container-page">
      <h2 class="sr-only">Slugify playground</h2>
      <SlugifyPlayground />
    </div>
  </section>

  <section id="why" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
        <div>
          <p class="eyebrow">The Gap</p>
          <h2 class="display-lg mt-3 text-balance text-ink">
            One stray accent, a broken permalink.
          </h2>
        </div>
        <div class="space-y-4">
          <p class="body-md text-pretty text-body">
            A title looks harmless until it becomes a URL. Leave an accented
            <span class="code-mono text-ink" translate="no">é</span> in place and some
            systems percent-encode it into
            <span class="code-mono text-ink" translate="no">%C3%A9</span>; keep the spaces,
            capitals and punctuation and you get a link nobody can read, share or index
            cleanly.
          </p>
          <p class="body-md text-pretty text-body">
            This slugify tool normalizes the text as Unicode NFKD, strips every combining
            mark so accents disappear instead of exploding into escapes, drops the
            punctuation, and joins the words with the separator you choose — bounded to a
            max length so the slug stays concise. Everything runs in the browser, with
            nothing to install and no text ever leaving your device.
          </p>
          <p class="body-sm text-mute">
            Need a different transform instead of a slug? The
            <a class="link-inline" href="/case-converter/">Case Converter</a> switches text
            between camelCase, snake_case, kebab-case and more.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ToolPipeline
    id="how-it-works"
    eyebrow="The Pipeline"
    heading="How it works."
    lead="Four deterministic steps run on every keystroke — all inside your browser tab, Unicode normalized before a single character is dropped."
    steps={pipeline}
  />

  <section id="reference" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Slug Rules</p>
        <h2 class="display-lg mt-3 text-ink">What makes a clean slug.</h2>
        <p class="body-md mx-auto mt-3 max-w-xl text-pretty text-body">
          Every title runs through the same four rules — normalize, strip, join, bound.
          Here is exactly what each one does and how the max-length limit decides where to
          cut.
        </p>
      </div>
      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-2">
        <div class="min-w-0">
          <h3 class="display-sm text-ink">The four rules</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            Normalize to <span class="code-mono text-ink" translate="no">NFKD</span>, strip
            combining marks with <span class="code-mono text-ink" translate="no">\p&#123;M&#125;</span>,
            optionally lowercase, then map everything outside
            <span class="code-mono text-ink" translate="no">a–z 0–9</span> to the separator.
          </p>
          <CodeBlock lang="text" filename="slug-rules" code={rulesTable} />
        </div>
        <div class="min-w-0">
          <h3 class="display-sm text-ink">Where max length cuts</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            The limit prefers the last separator boundary at or before it; a single
            over-long word is hard-cut at the limit with the trailing separator removed.
          </p>
          <CodeBlock lang="text" filename="max-length" code={boundaryExample} />
        </div>
      </div>
    </div>
  </section>

  <section id="next" class="scroll-mt-24 bg-inverse text-inverse-fg">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
        <div class="min-w-0">
          <p class="eyebrow !text-cyan">Next Step</p>
          <h2 class="display-lg mt-3 text-balance text-inverse-fg">
            Not a slug — a case change? Convert it.
          </h2>
          <p class="body-md mt-4 text-pretty text-white/70">
            Slugify is for URLs. When you need to rename a variable or a file instead, the
            <span translate="no">Case Converter</span> switches text between
            <span translate="no">camelCase</span>, <span translate="no">snake_case</span>,
            <span translate="no">kebab-case</span> and more — and the
            <span translate="no">Base64 Encoder / Decoder</span> handles the encoding side,
            all in your browser.
          </p>
          <div class="mt-7 flex flex-wrap items-center gap-3">
            <Button href="/case-converter/" variant="secondary">Open the Case Converter</Button>
            <Button href="/base64-encoder-decoder/" variant="secondary">Open Base64 Encoder</Button>
          </div>
        </div>
        <CodeBlock
          lang="text"
          filename="slug.txt"
          code={`Héllo Wörld!        ←  title
hello-world         ←  slug (kebab)
hello_world         ←  slug (underscore)
hello.world         ←  slug (dot)`}
        />
      </div>
    </div>
  </section>

  <FaqList faqs={faqs} />

  <ToolCrossLinks slug="slugify">
    <Fragment slot="lead">
      Slugify is one tool in
      <span translate="no">{site.name}</span> — a growing canopy of browser-based validators,
      converters and testers that never touch a server.
    </Fragment>
    <Fragment slot="links">
      Related text tools: the
      <a class="link-inline" href="/case-converter/">Case Converter</a> and the
      <a class="link-inline" href="/base64-encoder-decoder/">Base64 Encoder / Decoder</a>, or
      browse the full
      <a class="link-inline" href={`${navLinks[0].href}/`}>tools directory</a>.
    </Fragment>
    <Fragment slot="disclaimer">
      Provided as-is for convenience; slugifying is lossy — keep the original title as your
      source of truth. <span translate="no">{site.name}</span> is free and open.
    </Fragment>
  </ToolCrossLinks>
</Shell>
