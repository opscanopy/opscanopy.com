<style>
  .m90-journey-num {
    display: inline-grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-brand) 16%, var(--color-canvas));
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .m90-journey-count {
    font-family: var(--font-mono);
    font-size: 12px;
    font-variant-numeric: tabular-nums;
    color: var(--color-brand-strong);
  }
</style>

<script>
  import {
    parseProgress,
    doneCount,
    resumeDay,
    phaseProgress,
    exportProgress,
    importProgress,
    markPhaseDone,
    unmarkDays,
    setPace,
    PROGRESS_KEY,
    type M90Progress,
  } from '../../lib/mission90/progress';
  import { sessionDate, projectedFinish, buildIcs, formatSessionDate } from '../../lib/mission90/pace';
  import { copyTextToClipboard } from '../../lib/clipboard';
  import { safeGtag } from '../../lib/gtag';

  interface LiveDay {
    day: number;
    title: string;
    minutes: number;
    phase: string;
  }

  function readProgress() {
    let raw: string | null = null;
    try {
      raw = localStorage.getItem(PROGRESS_KEY);
    } catch {
      /* storage blocked — cold start */
    }
    return parseProgress(raw);
  }

  /** Today's date as YYYY-MM-DD (UTC) — the anchor every pace projection is
   *  computed forward from, so a projection can never claim to be "behind". */
  function todayDateString(): string {
    return new Date().toISOString().slice(0, 10);
  }

  /** Live days not yet marked complete, sorted ascending — the schedule the
   *  pace planner and the resume banner's ambient line both project from. */
  function incompleteLiveDays(p: M90Progress, liveDays: LiveDay[]): LiveDay[] {
    return liveDays
      .filter((d) => !Object.prototype.hasOwnProperty.call(p.days, String(d.day)))
      .sort((a, b) => a.day - b.day);
  }

  /** Parse a "21-45" data attribute into a [lo, hi] tuple, or null if malformed. */
  function parsePhaseRange(raw: string | undefined): [number, number] | null {
    const parts = (raw ?? '').split('-').map(Number);
    return parts.length === 2 && parts.every(Number.isFinite) ? [parts[0], parts[1]] : null;
  }

  function getData(): { liveDays: LiveDay[]; liveDayNumbers: number[]; programTotal: number } {
    const empty = { liveDays: [], liveDayNumbers: [], programTotal: 0 };
    const el = document.getElementById('m90-data');
    if (!el || !el.textContent) return empty;
    try {
      return JSON.parse(el.textContent);
    } catch {
      return empty;
    }
  }

  // ── Pace planner: state persists across render() calls within a page load,
  // so completing a day elsewhere (skip-ahead, the day table) refreshes the
  // projection without losing the learner's chip selection. ──
  let selectedPace: number | null = null;

  function updatePaceUI(): void {
    const root = document.querySelector<HTMLElement>('[data-m90-pace]');
    if (!root) return;
    const result = root.querySelector<HTMLElement>('[data-pace-result]');
    const icsBtn = root.querySelector<HTMLButtonElement>('[data-pace-ics]');
    const saveBtn = root.querySelector<HTMLButtonElement>('[data-pace-save]');
    if (!result || !icsBtn || !saveBtn) return;

    const { liveDays } = getData();
    const remaining = incompleteLiveDays(readProgress(), liveDays);

    if (remaining.length === 0) {
      result.textContent = "You've completed every available day — nothing left to plan.";
      icsBtn.disabled = true;
      saveBtn.disabled = true;
      return;
    }
    if (selectedPace === null) {
      result.textContent = 'Pick a pace above to see your projected finish date.';
      icsBtn.disabled = true;
      saveBtn.disabled = true;
      return;
    }
    const finish = projectedFinish(todayDateString(), remaining.length, selectedPace);
    const dayWord = remaining.length === 1 ? 'day' : 'days';
    result.textContent = `At ${selectedPace}/week, you'd finish around ${formatSessionDate(finish)} (${remaining.length} ${dayWord} left).`;
    icsBtn.disabled = false;
    saveBtn.disabled = false;
  }

  function initPacePlanner(): void {
    const root = document.querySelector<HTMLElement>('[data-m90-pace]');
    if (!root || root.dataset.bound === 'true') return;
    root.dataset.bound = 'true';

    const chipsWrap = root.querySelector<HTMLElement>('[data-pace-chips]');
    const icsBtn = root.querySelector<HTMLButtonElement>('[data-pace-ics]');
    const saveBtn = root.querySelector<HTMLButtonElement>('[data-pace-save]');
    const status = root.querySelector<HTMLElement>('[data-pace-status]');
    if (!chipsWrap || !icsBtn || !saveBtn) return;

    function selectChip(n: number): void {
      selectedPace = n;
      chipsWrap!.querySelectorAll<HTMLButtonElement>('[data-pace-value]').forEach((chip) => {
        const isActive = Number(chip.dataset.paceValue) === n;
        chip.classList.toggle('is-active', isActive);
        chip.setAttribute('aria-pressed', String(isActive));
      });
      updatePaceUI();
    }

    chipsWrap.addEventListener('click', (e) => {
      const chip = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-pace-value]');
      if (!chip) return;
      const n = Number(chip.dataset.paceValue);
      if (Number.isFinite(n)) selectChip(n);
    });

    icsBtn.addEventListener('click', () => {
      if (selectedPace === null) return;
      const { liveDays } = getData();
      const remaining = incompleteLiveDays(readProgress(), liveDays);
      if (remaining.length === 0) return;
      const today = todayDateString();
      const events = remaining.map((d, i) => ({
        day: d.day,
        date: sessionDate(today, i, selectedPace!),
        title: d.title,
      }));
      const ics = buildIcs(events, new Date().toISOString());
      const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'mission-90-pace.ics';
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
      if (status) status.textContent = 'Calendar file downloaded — import it into your calendar app.';
    });

    saveBtn.addEventListener('click', () => {
      if (selectedPace === null) return;
      const next = setPace(readProgress(), { daysPerWeek: selectedPace, startDate: todayDateString() });
      try {
        localStorage.setItem(PROGRESS_KEY, JSON.stringify(next));
      } catch {
        if (status) status.textContent = "Couldn't save — this browser is blocking site storage.";
        return;
      }
      if (status) status.textContent = 'Pace saved — this hub will remember it next time.';
      document.dispatchEvent(new CustomEvent('m90:progress'));
    });

    // Pre-select a previously saved pace, if any; otherwise render the
    // "nothing selected yet" / "all done" state.
    const savedPace = readProgress().pace;
    if (savedPace) selectChip(savedPace.daysPerWeek);
    else updatePaceUI();
  }

  function render(): void {
    const cta = document.querySelector('[data-m90-cta]');
    if (!cta) return; // not on the hub

    const p = readProgress();

    // 5-phase journey counts (independent of live-day state).
    document
      .querySelectorAll<HTMLElement>('[data-m90-journey] [data-phase-card]')
      .forEach((card) => {
        const range = (card.dataset.phaseRange ?? '').split('-').map(Number);
        const [lo, hi] = range;
        if (!Number.isFinite(lo) || !Number.isFinite(hi)) return;
        const { done: pd, total } = phaseProgress(p, [lo, hi]);
        const c = card.querySelector<HTMLElement>('[data-phase-count]');
        if (c) c.textContent = `${pd}/${total}`;
      });

    // Skip-ahead disclosure: same phaseProgress counts, plus a toggle whose
    // label/state reflects whether the WHOLE phase is done — however that
    // happened, bulk-marked here or completed day-by-day in the table below.
    document.querySelectorAll<HTMLElement>('[data-skip-phase]').forEach((row) => {
      const range = parsePhaseRange(row.dataset.skipPhaseRange);
      if (!range) return;
      const { done: pd, total } = phaseProgress(p, range);
      const count = row.querySelector<HTMLElement>('[data-skip-phase-count]');
      if (count) count.textContent = `${pd}/${total} done`;
      const btn = row.querySelector<HTMLButtonElement>('[data-skip-phase-toggle]');
      if (btn) {
        const isDone = total > 0 && pd === total;
        btn.textContent = isDone ? 'Marked — undo' : 'Mark done';
        btn.dataset.state = isDone ? 'done' : 'pending';
      }
    });

    updatePaceUI();

    const first = document.querySelector<HTMLElement>('[data-m90-cta-first]');
    const returning = document.querySelector<HTMLElement>('[data-m90-cta-returning]');
    const doneBlock = document.querySelector<HTMLElement>('[data-m90-cta-done]');
    const resume = document.querySelector<HTMLElement>('[data-m90-resume]');

    const show = (state: 'first' | 'returning' | 'done') => {
      if (first) first.hidden = state !== 'first';
      if (returning) returning.hidden = state !== 'returning';
      if (doneBlock) doneBlock.hidden = state !== 'done';
    };

    const { liveDays, liveDayNumbers, programTotal } = getData();

    // Without live-day data we cannot resolve the CTA state — keep the
    // static first-visit default and hide the resume card.
    if (liveDayNumbers.length === 0) {
      show('first');
      if (resume) resume.hidden = true;
      return;
    }

    const infoByDay = new Map<number, LiveDay>(liveDays.map((d) => [d.day, d]));
    const done = doneCount(p);
    // resumeDay (not nextDay): respects lastVisitedDay, so a learner who
    // jumped ahead is not routed back to the lowest incomplete day.
    const n = resumeDay(p, liveDayNumbers);
    const hasProgress =
      done > 0 || p.startedAt !== undefined || p.lastVisitedDay !== undefined;

    if (n === null) {
      // Every shipped day complete.
      show('done');
      if (resume) resume.hidden = true;
      return;
    }

    if (!hasProgress) {
      show('first');
      if (resume) resume.hidden = true;
      return;
    }

    // Returning learner with a day still to do.
    show('returning');
    const info = infoByDay.get(n);
    const link = returning?.querySelector<HTMLAnchorElement>('[data-m90-continue]');
    const label = returning?.querySelector<HTMLElement>('[data-m90-continue-label]');
    const caption = returning?.querySelector<HTMLElement>('[data-m90-continue-caption]');
    if (link) link.href = `/mission-90/day/${n}/`;
    if (label) label.textContent = info ? `Continue Day ${n}: ${info.title}` : `Continue Day ${n}`;
    if (caption) {
      caption.textContent = `${done} of ${programTotal} done — picking up where you left off.`;
    }

    if (resume) {
      const rLead = resume.querySelector<HTMLElement>('[data-m90-welcome]');
      const rLink = resume.querySelector<HTMLAnchorElement>('[data-m90-resume-link]');
      const rText = resume.querySelector<HTMLElement>('[data-m90-resume-text]');
      const pcCount = resume.querySelector<HTMLElement>('[data-m90-progress-count]');
      const pcFill = resume.querySelector<HTMLElement>('[data-m90-bar]');
      const pcWrap = resume.querySelector<HTMLElement>('[data-m90-barwrap]');
      // Welcome-back lead (A1) — deliberately metric-free: M90ProgressCard owns
      // the "{done} of {total}" count inside this same banner.
      if (rLead) {
        rLead.textContent = `Welcome back — Day ${n} is ready when you are.`;
        rLead.hidden = false;
      }
      if (rLink) rLink.href = `/mission-90/day/${n}/`;
      if (rText) {
        rText.textContent = info ? `Day ${n} · ${info.phase} · ~${info.minutes} min` : `Day ${n}`;
      }
      if (pcCount) pcCount.textContent = `${done} of ${programTotal} days`;
      if (pcFill) pcFill.style.width = `${Math.round((done / programTotal) * 100)}%`;
      if (pcWrap) pcWrap.setAttribute('aria-valuenow', String(done));

      // Ambient pace line — a forward projection from TODAY, never a
      // comparison against the original plan, so it can never say "behind".
      const paceLine = resume.querySelector<HTMLElement>('[data-m90-pace-line]');
      if (paceLine) {
        const remaining = incompleteLiveDays(p, liveDays);
        if (p.pace && remaining.length > 0) {
          const finish = projectedFinish(todayDateString(), remaining.length, p.pace.daysPerWeek);
          paceLine.textContent = `At your saved pace (${p.pace.daysPerWeek}/week), you'd finish around ${formatSessionDate(finish)}.`;
          paceLine.hidden = false;
        } else {
          paceLine.hidden = true;
        }
      }

      resume.hidden = false;
    }
  }

  // LR3 — lightweight GA4 CTA analytics. No PII — just the CTA name.
  function fireCta(name: string): void {
    safeGtag('event', 'cta_click', { cta: name });
  }

  function onCtaClick(e: MouseEvent): void {
    const el = (e.target as HTMLElement | null)?.closest<HTMLElement>('[data-cta]');
    const name = el?.dataset.cta;
    if (name) fireCta(name);
  }

  // A2 — cross-tab sync: progress written in another tab (e.g. a mission victory)
  // re-renders this hub in place. Silent by design: no announcements, no focus
  // changes, no scroll — render() only updates DOM.
  function onStorage(e: StorageEvent): void {
    try {
      if (e.key === PROGRESS_KEY) render();
    } catch {
      /* cross-tab sync is best-effort — never let it break the page */
    }
  }

  // ── Backup / restore — copy a portable progress code, or paste one back
  // in. A single polite status line per side, no confirm dialog.
  function initBackupRestore(): void {
    const root = document.querySelector<HTMLElement>('[data-m90-backup]');
    if (!root || root.dataset.bound === 'true') return;
    root.dataset.bound = 'true';

    const copyBtn = root.querySelector<HTMLButtonElement>('[data-m90-backup-copy]');
    const copyStatus = root.querySelector<HTMLElement>('[data-m90-backup-status]');
    const restoreInput = root.querySelector<HTMLInputElement>('#m90-restore-input');
    const restoreBtn = root.querySelector<HTMLButtonElement>('[data-m90-restore-btn]');
    const restoreStatus = root.querySelector<HTMLElement>('[data-m90-restore-status]');

    const copyFallback = root.querySelector<HTMLTextAreaElement>('[data-m90-backup-code]');

    copyBtn?.addEventListener('click', () => {
      const code = exportProgress(readProgress());
      void copyTextToClipboard(code).then((ok) => {
        if (copyStatus) {
          copyStatus.textContent = ok
            ? 'Copied — paste it somewhere safe, then paste it back here on the other device.'
            : "Couldn't copy automatically — select the code below and copy it by hand.";
        }
        // Clipboard blocked (hardened browsers): surface the code itself so
        // the backup path is never a dead end.
        if (!ok && copyFallback) {
          copyFallback.value = code;
          copyFallback.hidden = false;
          copyFallback.focus();
          copyFallback.select();
        }
      });
    });

    const restore = () => {
      const raw = restoreInput?.value ?? '';
      const imported = importProgress(raw);
      if (!imported) {
        if (restoreStatus) {
          restoreStatus.textContent =
            "That code doesn't look right — check you copied the whole thing (a valid code always contains progress).";
        }
        return;
      }
      try {
        localStorage.setItem(PROGRESS_KEY, JSON.stringify(imported));
      } catch {
        // Storage blocked (private mode / quota): the restore did NOT stick.
        // Say so honestly instead of claiming success over unchanged data.
        if (restoreStatus) {
          restoreStatus.textContent =
            "Couldn't save — this browser is blocking site storage, so the restore didn't stick.";
        }
        return;
      }
      if (restoreInput) restoreInput.value = '';
      if (restoreStatus) restoreStatus.textContent = 'Progress restored.';
      document.dispatchEvent(new CustomEvent('m90:progress'));
    };
    restoreBtn?.addEventListener('click', restore);
    restoreInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') restore();
    });
  }

  // Skip-ahead: bulk mark/unmark a whole phase. One delegated listener on the
  // disclosure root — render() (above) keeps every row's count/label in sync,
  // so this handler only needs to mutate storage and dispatch m90:progress.
  function initSkipAhead(): void {
    const root = document.querySelector<HTMLElement>('[data-m90-skip-ahead]');
    if (!root || root.dataset.bound === 'true') return;
    root.dataset.bound = 'true';

    const status = root.querySelector<HTMLElement>('[data-skip-ahead-status]');

    root.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-skip-phase-toggle]');
      if (!btn) return;
      const row = btn.closest<HTMLElement>('[data-skip-phase]');
      const range = parsePhaseRange(row?.dataset.skipPhaseRange);
      if (!range) return;

      const wasDone = btn.dataset.state === 'done';
      const now = new Date().toISOString();
      const next = wasDone ? unmarkDays(readProgress(), range) : markPhaseDone(readProgress(), range, now);
      try {
        localStorage.setItem(PROGRESS_KEY, JSON.stringify(next));
      } catch {
        if (status) status.textContent = "Couldn't save — this browser is blocking site storage.";
        return;
      }
      if (status) status.textContent = wasDone ? 'Phase unmarked.' : 'Phase marked done.';
      document.dispatchEvent(new CustomEvent('m90:progress'));
    });
  }

  let bound = false;
  function boot(): void {
    render();
    initBackupRestore();
    initSkipAhead();
    initPacePlanner();
    if (!bound) {
      bound = true;
      // The table re-fires this after a day is ticked so the hub re-syncs.
      document.addEventListener('m90:progress', render);
      window.addEventListener('storage', onStorage);
      document.addEventListener('click', onCtaClick, true);
    }
  }

  // This site ships no ClientRouter, so `astro:page-load` never fires on a fresh
  // page load — run boot() immediately (module scripts are deferred, so the DOM
  // is ready). boot() is idempotent (the `bound` guard binds listeners once), so
  // keeping the listener too is harmless if view transitions are ever added.
  boot();
  document.addEventListener('astro:page-load', boot);
</script>
