---
/**
 * Mission 90 Days DevOps — the program hub at /mission-90/.
 *
 * Conversion order (do NOT reorder): resume card (returning only) → backup/
 * restore disclosure (always rendered) → hero → "is this for you?" →
 * 3-layer time model → 5-phase journey → missions teaser → the 90-day table →
 * FAQ → final CTA + founding note.
 *
 * Everything renders perfectly with JavaScript or storage blocked: the static
 * markup IS the cold-start / first-visit state. A single boot script reads the
 * `oc-m90-v1` progress and (a) flips the hero CTA between its three states,
 * (b) reveals + fills the resume card for returning learners, and (c) fills the
 * per-phase counts in the journey. The 90-day table owns its own progress logic
 * and dispatches `m90:progress` so this script re-syncs after a day is ticked.
 */
import Shell from '../../components/Shell.astro';
import MeshGradient from '../../components/MeshGradient.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import FaqList from '../../components/FaqList.astro';
import Badge from '../../components/Badge.astro';
import M90ProgressCard from '../../components/mission90/M90ProgressCard.astro';
import M90StateCta from '../../components/mission90/M90StateCta.astro';
import M90DayTable from '../../components/mission90/M90DayTable.astro';
import M90SkipAhead from '../../components/mission90/M90SkipAhead.astro';
import M90PacePlanner from '../../components/mission90/M90PacePlanner.astro';
import { site } from '../../data/site';
import {
  program,
  phases,
  days,
  missions,
  liveDays,
  phaseForDay,
  totalCoreMinutes,
  community,
} from '../../data/mission90';
import { courseLd, faqPageLd, breadcrumbLd } from '../../lib/jsonld';

// Trust caption — ALWAYS derived from the registry, never hand-written.
const hours = Math.round(totalCoreMinutes / 60 / 10) * 10;

// The next day that will drop (first still-draft day), or null once every day
// is live — drives the all-done CTA's graduation-vs-"drops soon" branch.
const firstDraftDay = days.find((d) => d.status === 'draft')?.day ?? null;
// Completion signal derived from the registry, so hub copy self-heals: true
// while any day is still draft, false once the whole program is shipped.
const hasDraftDays = days.some((d) => d.status === 'draft');
const liveMissionCount = missions.filter((m) => m.status === 'live').length;

// Minimal live-day metadata handed to the client so the CTA / resume card can
// name the day the learner should continue with.
const liveDayInfo = liveDays.map((d) => ({
  day: d.day,
  title: d.title,
  minutes: d.minutes,
  phase: phaseForDay(d.day)?.name ?? '',
}));
const liveDayNumbers = liveDays.map((d) => d.day);

// 5-phase journey cards.
const phaseCards = phases.map((p) => ({
  id: p.id,
  name: p.name,
  tagline: p.tagline,
  range: p.days,
  total: p.days[1] - p.days[0] + 1,
}));

// Missions teaser — independent, compact markup (NOT a MissionCard component).
// STATUS-DRIVEN (never position-based): the featured hero is the live mission,
// and every other card derives its playable-vs-"in production" state from the
// registry `status`. A future mission flipping to `live` needs zero hub edits.
const heroMission = missions.find((m) => m.status === 'live') ?? missions[0];
// Honest even in the (test-guarded, currently unreachable) no-live-mission case:
// the featured card only claims "Playable" when the hero is actually live.
const heroIsLive = heroMission.status === 'live';
const restMissions = missions.filter((m) => m.id !== heroMission.id);
const nextMissions = restMissions.slice(0, 2);
const roadAheadMissions = restMissions.slice(2);
const heroPlayHref = `/mission-90/missions/${heroMission.id}/`;
// Terminal-style codename for the mini-header chrome — derived from the mission
// id (e.g. week1-server-down → "mission-01 · server-down"), so it tracks the
// live mission automatically instead of being hand-written.
const heroCodename = `mission-${String(heroMission.week).padStart(2, '0')} · ${heroMission.id
  .replace(/^week\d+-/, '')
  .replace(/^final-/, '')}`;
const missionFeatures = ['No setup', 'Runs in your browser', 'No programming required'];

// Honest launch-scope line (LR4) — derived from the registry so it can never
// over-promise as content ships. Rendered under the trust caption near the H1.
const liveDayScope = liveDays.length === 1 ? `Day ${liveDays[0].day}` : `${liveDays.length} days`;
const scopeLine = hasDraftDays
  ? `${liveDayScope} and the Week-${heroMission.week} mission are live now — new days drop as they're written.`
  : `All ${program.totalDays} days and ${liveMissionCount} missions are live now — free, no signup.`;

// Public build feeds — reused by the "get notified" affordance, the author
// block and the founding note. No new links invented; from site.ts.
const xUrl = `https://x.com/${site.twitter.replace('@', '')}`;

// Hero play transcript — sells the game with zero JS.
const heroTranscript = `student@prod-web-01:~$ ps aux --sort=-%cpu | head -3
USER    PID  %CPU  COMMAND
root   4521  94.0  /opt/scripts/nightly-backup.sh
student@prod-web-01:~$ kill 4521
student@prod-web-01:~$ systemctl restart nginx
student@prod-web-01:~$ curl -so /dev/null -w '%{http_code}\\n' localhost
200
# 02:07 — the site is back. You did that.`;

// 3-layer time model.
const timeModel = [
  {
    eyebrow: 'Every day',
    title: 'Core lesson',
    time: '45–60 min',
    body: 'One focused lesson a day — read it, run the commands, understand the why. This is the spine of the whole program.',
    icon: '<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>',
  },
  {
    eyebrow: 'Optional',
    title: 'Go Deeper',
    time: '+30–60 min',
    body: 'Extra rabbit-holes for the days you have the time and the appetite — always optional, never assumed by the next lesson.',
    icon: '<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>',
  },
  {
    eyebrow: 'Weekly',
    title: 'Mission game',
    time: '15–20 min',
    body: 'End the week inside a broken system and fix it live in your browser — a story-driven mission, no setup, no code required.',
    icon: '<line x1="6" y1="11" x2="10" y2="11"/><line x1="8" y1="9" x2="8" y2="13"/><line x1="15" y1="12" x2="15.01" y2="12"/><line x1="18" y1="10" x2="18.01" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.544-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/>',
  },
];

const faqs = [
  {
    q: 'Is it really free?',
    a: 'Yes — completely. All 90 days and every mission, with no account, no email capture, no paywall and no upsell. It runs as static pages in your browser, so there is nothing to bill you for, and your progress is saved locally in your own browser.',
  },
  {
    q: 'How much is available right now?',
    a: hasDraftDays
      ? `Being honest: this is a build-in-public program, so not all 90 days are written yet. Day 1 and the first weekly mission — "${heroMission.title}" — are live and free to use today, and new days publish one at a time as they are finished. There is no fixed drop date and no email wall — new days simply appear on this page. Want a ping when the next one lands? Subscribe to the RSS feed at /mission-90/feed.xml, or follow the build on GitHub or X.`
      : `Everything. All ${program.totalDays} days and every weekly mission are live and free to use today — no account, no email wall, no paywall. Start at Day 1, or jump straight to any phase from the plan above, and go at your own pace; your progress is saved locally in this browser.`,
  },
  {
    q: 'I only have 30 minutes some days — will I fall behind?',
    a: 'No. The core lesson is built to fit in 45–60 minutes, and on a tight day you can do just the essentials and skip the optional "Go Deeper" section entirely. Nothing in the next day assumes you did the optional depth, so a short day never leaves a hole. Go at the pace your life allows.',
  },
  {
    q: 'Do I need a Linux machine?',
    a: 'No. On Windows you will use WSL2 (the Windows Subsystem for Linux), which gives you a real Linux environment in a few minutes; macOS uses Multipass and Linux works directly. The Day 0 setup at /mission-90/setup/ covers all three, plus a browser-only option (Codespaces or Cloud Shell, /mission-90/setup/#no-install) if you cannot install anything at all.',
  },
  {
    q: 'What if I miss days?',
    a: 'Nothing breaks. The program is a sequence, not a calendar — Day 12 always comes after Day 11, whenever you get to it. There is no streak to lose and no shame screen for a gap. Pick up exactly where you left off; the plan remembers your place in this browser.',
  },
  {
    q: 'Will this actually get me a DevOps job?',
    a: 'Honestly: it gives you the skills, the projects and the vocabulary, but no curriculum can guarantee a job. What you get here is a genuine foundation across Linux, containers, CI/CD, cloud, Kubernetes and Terraform, plus a portfolio of real projects and interview practice. The rest depends on you, your applications and the market you are in.',
  },
];

const canonical = '/mission-90/';
const jsonLd = [
  courseLd(
    { name: program.name, description: program.description, url: `${site.url}/mission-90/` },
    phases.map((p) => ({ name: p.name, days: p.days })),
    totalCoreMinutes,
  ),
  faqPageLd(faqs),
  breadcrumbLd([
    { name: 'Home', item: `${site.url}/` },
    { name: '90 Days DevOps', item: `${site.url}/mission-90/` },
  ]),
];

const gamepadPath =
  '<line x1="6" y1="11" x2="10" y2="11"/><line x1="8" y1="9" x2="8" y2="13"/><line x1="15" y1="12" x2="15.01" y2="12"/><line x1="18" y1="10" x2="18.01" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.544-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/>';
const constructionPath =
  '<rect x="2" y="6" width="20" height="8" rx="1"/><path d="M17 14v7"/><path d="M7 14v7"/><path d="M17 3v3"/><path d="M7 3v3"/><path d="m10 14-7.7-7.7"/><path d="m14 6 7.7 7.7"/><path d="m8 6 8 8"/>';
---

<Shell
  title="Free 90-Day DevOps Roadmap & Missions — OpsCanopy"
  description="A free, hands-on 90-day DevOps roadmap — Linux to Kubernetes and cloud, with story-driven missions you play in your browser. No signup; progress saved locally."
  canonical={canonical}
  image="/mission-90/mission-90-og.png"
  jsonLd={jsonLd}
  noAlternates
>
  {/* RSS discovery — the "new days drop" feed (feed.xml built separately). */}
  <link
    slot="head"
    rel="alternate"
    type="application/rss+xml"
    title="Mission 90 Days DevOps"
    href="/mission-90/feed.xml"
  />

  {/* ───── 1 · RESUME CARD (returning learners only; hidden until confirmed) ───── */}
  <section class="bg-canvas-soft" data-m90-resume hidden>
    <div class="container-page py-4 sm:py-5">
      <div
        class="mx-auto flex max-w-4xl flex-col gap-3 rounded-lg border border-hairline bg-canvas p-4 shadow-soft sm:flex-row sm:items-center sm:justify-between"
      >
        <div class="flex min-w-0 flex-col gap-1">
          {/* Metric-free welcome-back lead (A1) — a styled p, NOT a heading (this
              banner precedes the page h1). Empty + hidden until render() fills it
              on the returning path only. */}
          <p class="body-sm text-ink" data-m90-welcome hidden></p>
          <a
            href="/mission-90/day/1/"
            class="link-inline group inline-flex items-center gap-2 font-medium"
            data-m90-resume-link
          >
            <span class="text-mute">Continue</span>
            <span aria-hidden="true" class="transition-transform duration-150 ease-out group-hover:translate-x-0.5">&rarr;</span>
            <span class="text-ink" data-m90-resume-text>Day 1</span>
          </a>
          {/* Ambient forward-computed pace line — only ever a forward
              projection from today, so it can never claim the learner is
              "behind". Filled + revealed only when a pace is saved. */}
          <p class="caption text-mute" data-m90-pace-line hidden></p>
        </div>
        <M90ProgressCard total={program.totalDays} />
      </div>
    </div>
  </section>

  {/* ───── 1b · BACKUP / RESTORE — always rendered (not just for returning
       learners): a new-device visitor with zero local progress needs the
       restore half just as much as a returning learner needs the backup
       half. Progress lives only in this browser's localStorage — this is
       the only way to move it. ───── */}
  <section class="border-t border-hairline bg-canvas-soft" data-m90-backup>
    <div class="container-page py-3">
      <details class="mx-auto max-w-4xl">
        <summary
          class="body-sm inline-flex cursor-pointer items-center gap-1.5 text-mute [touch-action:manipulation] hover:text-ink"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
          Back up or restore your progress
        </summary>
        <div class="mt-3 flex flex-col gap-4 rounded-lg border border-hairline bg-canvas p-4 sm:flex-row sm:items-start">
          <div class="min-w-0 flex-1">
            <p class="body-sm font-medium text-ink">Copy my progress code</p>
            <p class="caption mt-1 text-mute">
              Progress is saved only in this browser. Copy a code before clearing site data or
              switching devices, then paste it back on the other side.
            </p>
            <button type="button" data-m90-backup-copy class="btn btn-secondary btn-sm mt-3" style="touch-action: manipulation;">
              Copy my code
            </button>
            <p class="caption mt-1.5 text-mute" role="status" data-m90-backup-status></p>
            {/* Manual fallback — revealed only when the clipboard is blocked,
                so the backup path is never a dead end. */}
            <textarea
              data-m90-backup-code
              hidden
              readonly
              rows="3"
              aria-label="Your progress backup code"
              class="input-focus mt-2 w-full rounded-lg border border-hairline bg-canvas p-2 font-mono text-xs text-ink"></textarea>
          </div>
          <div class="min-w-0 flex-1">
            <label for="m90-restore-input" class="body-sm font-medium text-ink">Restore from a code</label>
            <div class="mt-3 flex flex-col gap-2 sm:flex-row">
              <input
                id="m90-restore-input"
                type="text"
                inputmode="text"
                autocomplete="off"
                autocapitalize="off"
                spellcheck="false"
                placeholder="Paste your progress code"
                class="input-focus w-full min-w-0 rounded-lg border border-hairline bg-canvas px-3 py-2 text-sm text-ink placeholder:text-mute"
              />
              <button type="button" data-m90-restore-btn class="btn btn-secondary btn-sm shrink-0" style="touch-action: manipulation;">
                Restore
              </button>
            </div>
            <p class="caption mt-1.5 text-mute" role="status" data-m90-restore-status></p>
          </div>
        </div>
      </details>
    </div>
  </section>

  {/* ─────────────────────────────── 2 · HERO ─────────────────────────────── */}
  <section class="section-pad relative isolate overflow-hidden bg-canvas-soft">
    <MeshGradient class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[90%] opacity-90" />
    <div
      class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-32 bg-gradient-to-b from-canvas-soft to-transparent"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-48 bg-gradient-to-b from-transparent to-canvas-soft"
      aria-hidden="true"
    >
    </div>

    <div class="container-page relative z-10 flex flex-col items-center text-center">
      <p class="eyebrow text-mute">MISSION: 90 DAYS · DEVOPS</p>

      <h1 class="display-xl mt-4 max-w-3xl text-balance text-ink">
        From developer to DevOps engineer in 90 days.
      </h1>

      <p class="body-lg mx-auto mt-4 max-w-2xl text-pretty text-body">
        A free, hands-on curriculum that takes you from your first terminal command to job-ready —
        one focused lesson a day, with a story-driven mission to fix a broken system at the end of
        every week.
      </p>

      <p class="caption mt-4 text-mute">
        ~{hours} hrs core · free, no signup · progress saved in your browser
      </p>

      <p class="caption mt-2 inline-flex items-center gap-1.5 text-mute">
        <span class="size-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"></span>
        {scopeLine}
      </p>

      <div class="mt-8">
        <M90StateCta firstDraftDay={firstDraftDay} />
      </div>

      <div class="mt-12 w-full max-w-2xl text-left">
        <CodeBlock code={heroTranscript} filename="mission: server-down" />
      </div>
    </div>
  </section>

  {/* ───────────────────────── 2b · IS THIS FOR YOU? ───────────────────────── */}
  <section class="section-pad bg-canvas" aria-labelledby="fit-heading">
    <div class="container-page">
      <div class="max-w-2xl">
        <p class="eyebrow">Before you dive in</p>
        <h2 id="fit-heading" class="display-lg mt-3 text-balance text-ink">Is this for you?</h2>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-3">
        <Card class="flex h-full flex-col p-6 sm:p-7">
          <p class="eyebrow text-brand-strong">Good fit if you're</p>
          <ul role="list" class="body-sm mt-3 flex-1 space-y-2 text-pretty text-body">
            <li>— a developer who wants to understand the infra your code runs on</li>
            <li>— self-taught and looking for a structured, project-based path into DevOps/SRE</li>
            <li>— comfortable typing commands in a terminal, even if you've never called yourself "technical"</li>
          </ul>
        </Card>

        <Card class="flex h-full flex-col p-6 sm:p-7">
          <p class="eyebrow text-mute">Maybe skip it if</p>
          <ul role="list" class="body-sm mt-3 flex-1 space-y-2 text-pretty text-body">
            <li>— you're already running production Kubernetes and CI/CD day to day — you'll outpace the early days fast</li>
            <li>— you want a certification exam, not a hands-on curriculum</li>
            <li>— you're not near a computer you can install software on <em>and</em> can't use a free browser-only option (see <a href="/mission-90/setup/#no-install" class="link-inline">no-install setup</a>)</li>
          </ul>
        </Card>

        <Card class="flex h-full flex-col p-6 sm:p-7">
          <p class="eyebrow text-brand-strong">Before you start</p>
          <ul role="list" class="body-sm mt-3 flex-1 space-y-2 text-pretty text-body">
            <li>— no prior coding required — missions are played in a browser terminal, no code to write</li>
            <li>— Phase 3 (Cloud) uses a real AWS account; every step is built to stay near the free tier, with an explicit teardown at the end of each lab, but keep an eye on your bill</li>
            <li>— progress is saved only in this browser's local storage — no account, no email. Back up a code before clearing site data (below) or switching devices</li>
          </ul>
        </Card>
      </div>

      <div class="mt-8 max-w-2xl">
        <M90SkipAhead />
      </div>
    </div>
  </section>

  {/* ─────────────────────── 3 · THREE-LAYER TIME MODEL ─────────────────────── */}
  <section id="how" class="section-pad scroll-mt-24 bg-canvas">
    <div class="container-page">
      <div class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">How it works</span>
        <h2 class="display-lg mt-3 text-balance text-ink">Three layers. Forty-five minutes a day.</h2>
        <p class="body-md mt-3 text-pretty text-body">
          Every day has the same shape, so you always know what "done" looks like — and the optional
          depth is there on the days you want more.
        </p>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-3">
        {
          timeModel.map((c) => (
            <Card variant="soft" class="flex h-full flex-col">
              <span class="mb-4 inline-flex size-10 items-center justify-center rounded-lg bg-brand/10 text-brand-strong">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={c.icon}
                />
              </span>
              <span class="eyebrow">{c.eyebrow}</span>
              <div class="mt-2 flex items-baseline justify-between gap-2">
                <h3 class="display-sm text-ink">{c.title}</h3>
                <span class="code-mono text-[13px] text-brand-strong">{c.time}</span>
              </div>
              <p class="body-sm mt-3 flex-1 text-pretty text-body">{c.body}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  {/* ───────────────────────── 4 · FIVE-PHASE JOURNEY ───────────────────────── */}
  <section class="section-pad bg-canvas-soft">
    <div class="container-page">
      <div class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">The Journey</span>
        <h2 class="display-lg mt-3 text-balance text-ink">Five phases, ninety days.</h2>
        <p class="body-md mt-3 text-pretty text-body">
          From your first terminal session to a portfolio and interview answers. Jump straight to
          any phase in the full plan below.
        </p>
      </div>

      <ol data-m90-journey role="list" class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-5">
        {
          phaseCards.map((p) => (
            <li class="h-full">
              <Card variant="soft" href={`#phase-${p.id}`} class="h-full">
                <div
                  class="flex h-full flex-col"
                  data-phase-card
                  data-phase-range={`${p.range[0]}-${p.range[1]}`}
                >
                  <span class="m90-journey-num" aria-hidden="true">
                    {String(p.id).padStart(2, '0')}
                  </span>
                  <h3 class="display-sm mt-3 text-ink">{p.name}</h3>
                  <p class="body-sm mt-1 flex-1 text-pretty text-mute">{p.tagline}</p>
                  <div class="mt-3 flex items-center justify-between gap-2">
                    <span class="caption text-mute">
                      Days {p.range[0]}–{p.range[1]}
                    </span>
                    <span class="m90-journey-count" data-phase-count>
                      0/{p.total}
                    </span>
                  </div>
                </div>
              </Card>
            </li>
          ))
        }
      </ol>
      <p class="mt-6 text-center">
        <a href="/mission-90/job-ready/" class="link-inline body-sm font-medium">
          Preview Phase 5: the job-ready interview hub &rarr;
        </a>
      </p>
    </div>
  </section>

  {/* ─────────────────────────── 5 · MISSIONS TEASER ─────────────────────────── */}
  <section class="section-pad bg-canvas">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">Missions</span>
          <h2 class="display-lg mt-3 text-balance text-ink">Every week ends in a broken system.</h2>
