---
/**
 * Mission 90 — mission play route (MINIMAL; masthead polish is task T13).
 *
 * Static-generates ONE page per LIVE mission (registry `status: 'live'`) — at
 * launch that is just `week1-server-down`. Planned missions never emit a page.
 *
 * A lean, non-broken layout: a compact masthead + the MissionTerminal island.
 * The registry import is metadata-only (never engine code); the engine + mission
 * config are code-split behind the island's dynamic import.
 */
import Shell from '../../../components/Shell.astro';
import MissionTerminal from '../../../components/mission90/MissionTerminal.astro';
import { missions } from '../../../data/mission90';
import { softwareAppLd, breadcrumbLd } from '../../../lib/jsonld';
import { site } from '../../../data/site';

export function getStaticPaths() {
  return missions
    .filter((m) => m.status === 'live')
    .map((m) => ({ params: { id: m.id }, props: { mission: m } }));
}

const { mission } = Astro.props;
const canonical = `/mission-90/missions/${mission.id}/`;
const pageUrl = `${site.url}${canonical}`;

// Skills as a prose list for the static scenario framing (metadata only).
const skillList = mission.skills.join(', ');

const jsonLd = [
  softwareAppLd({
    name: `${mission.title} — Mission 90 Days DevOps`,
    description: mission.blurb,
    url: pageUrl,
    subCategory: 'Interactive DevOps mission',
    keywords: mission.skills.join(', '),
  }),
  breadcrumbLd([
    { name: 'Home', item: `${site.url}/` },
    { name: '90 Days DevOps', item: `${site.url}/mission-90/` },
    { name: 'Missions', item: `${site.url}/mission-90/missions/` },
    { name: mission.title, item: pageUrl },
  ]),
];
---

<Shell
  title={`${mission.title} — Mission 90`}
  description={mission.blurb}
  canonical={canonical}
  image="/mission-90/mission-90-og.png"
  jsonLd={jsonLd}
  noAlternates
>
  <section class="bg-canvas">
    <div class="container-page py-8 sm:py-12">
      <nav aria-label="Breadcrumb" class="body-sm text-mute">
        <ol class="flex flex-wrap items-center gap-1.5">
          <li><a class="hover:text-ink" href="/">Home</a></li>
          <li aria-hidden="true" class="px-1.5 text-hairline-strong">/</li>
          <li><a class="hover:text-ink" href="/mission-90/">90 Days DevOps</a></li>
          <li aria-hidden="true" class="px-1.5 text-hairline-strong">/</li>
          <li><a class="hover:text-ink" href="/mission-90/missions/">Missions</a></li>
          <li aria-hidden="true" class="px-1.5 text-hairline-strong">/</li>
          <li aria-current="page" class="text-body">Week {mission.week} · {mission.title}</li>
        </ol>
      </nav>

      <p class="eyebrow mt-4">Mission · Week {mission.week}</p>
      <h1 class="display-lg mt-2 text-balance text-ink">{mission.title}</h1>
      <p class="body-lg mt-3 max-w-2xl text-pretty text-body">{mission.blurb}</p>

      <ul class="mt-5 flex flex-wrap gap-2" role="list" aria-label="Skills this mission drills">
        {
          mission.skills.map((skill) => (
            <li class="inline-flex items-center rounded-full border border-hairline bg-canvas-soft px-3 py-1 text-[12px] font-medium text-body">
              {skill}
            </li>
          ))
        }
      </ul>

      <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2">
        <p class="caption text-mute">Pairs with Day {mission.unlockAfterDay}</p>
        <a
          href="/mission-90/missions/"
          class="link-inline body-sm inline-flex items-center gap-1.5 font-medium"
        >
          <span aria-hidden="true">&larr;</span>
          All missions
        </a>
      </div>

      {/* ── Static scenario framing (registry metadata only — no engine import) ──
          Server-rendered orientation so the page is meaningful BEFORE the
          terminal island boots (pre-JS it otherwise shows only "Booting
          mission…"). This is how-to-play orientation drawn from mission
          metadata — deliberately NOT the game's briefing (config.story), which
          is client-only and prints on boot. Light-surface tokens; the terminal
          island keeps its own inverse chrome. */}
      <div class="mt-8 rounded-md border border-hairline bg-canvas-soft p-5 sm:p-6">
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5">
          <p class="eyebrow">Your mission</p>
          {
            mission.noCodeFriendly && (
              <span class="inline-flex items-center rounded-full border border-hairline bg-canvas px-2.5 py-0.5 text-[11px] font-medium text-mute">
                No setup · no code required
              </span>
            )
          }
        </div>
        <p class="body-sm mt-2 max-w-2xl text-pretty text-body">
          A hands-on Week {mission.week} scenario — you&rsquo;ll put {skillList} to work, right here in
          your browser.
        </p>
        <p class="caption mt-3 max-w-2xl text-mute">
          This mission runs entirely in your browser, with nothing to install. When the terminal loads,
          type <code class="code-mono rounded-sm bg-canvas-soft-2 px-1 py-0.5 text-[0.9em] text-ink">help</code>
          to see the commands available to you.
        </p>
      </div>

      <div class="mt-6">
        <MissionTerminal missionId={mission.id} />
      </div>
    </div>
  </section>
</Shell>
