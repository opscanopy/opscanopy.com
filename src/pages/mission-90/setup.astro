---
/**
 * Mission 90 — Day 0 (setup, uncounted). A lean static article: turn a Windows
 * machine into a real Linux workstation (WSL2 + Ubuntu 24.04) so every command
 * in the 90-day path runs the same way it does on the author's box.
 *
 * Zero client JS, no new components — reuses the site chrome (Shell) and design
 * tokens. Code blocks are hand-rendered onto the dark inverse surface and are
 * HTML-escaped via `esc()` (same approach as CodeBlock, minus the copy island).
 */
import Shell from '../../components/Shell.astro';
import { breadcrumbLd, howToLd } from '../../lib/jsonld';
import { site } from '../../data/site';

/** Escape a raw command snippet for safe injection into <pre><code>. */
const esc = (s: string) =>
  s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

/* ── Command snippets — authored & run in WSL2 Ubuntu 24.04 ─────────────── */
const installCmd = `# Run in an ADMIN PowerShell or Windows Terminal, then reboot when prompted.
wsl --install -d Ubuntu-24.04

# Expected (abridged):
# Installing: Windows Subsystem for Linux
# Installing: Ubuntu 24.04 LTS
# Ubuntu 24.04 LTS has been installed.
# The requested operation is successful. Changes will not be
# effective until the system is rebooted.`;

const firstBootCmd = `# The first launch creates your Linux user. The password is INVISIBLE as you
# type it — that silence is normal, not a frozen terminal.
Enter new UNIX username: pushkar
New password:
Retype new password:
passwd: password updated successfully
Installation successful!`;

const systemdCmd = `# Ask systemd how the boot went. Ubuntu 24.04 on WSL2 ships with systemd
# enabled, so you should get an answer here — not an error.
systemctl is-system-running

# Output:
# running        <- systemd is up ("degraded" is fine too: an optional
#                   unit failed, systemd itself is healthy)`;

const wslConfCmd = `# ONLY if the command above printed "System has not been booted with systemd
# as init system (PID 1)". Turn systemd on, then restart the WSL VM.
sudo nano /etc/wsl.conf

# Add exactly these two lines, then save (Ctrl+O, Enter) and exit (Ctrl+X):
# [boot]
# systemd=true

# Back in Windows PowerShell, fully restart the VM, then reopen Ubuntu:
# wsl --shutdown`;

const updateCmd = `# Refresh the package index, then install every security & bug-fix update.
# -y answers "yes" so the upgrade runs unattended.
sudo apt update && sudo apt upgrade -y

# Output (abridged — your counts will differ; a fresh image usually has updates):
# Hit:1 http://archive.ubuntu.com/ubuntu noble InRelease
# Reading package lists... Done
# Building dependency tree... Done
# Calculating upgrade... Done
# 12 upgraded, 0 newly installed, 0 to remove and 0 not upgraded.`;

const verifyCmd = `# 1. Which Ubuntu is this? Expect 24.04, codename "noble".
lsb_release -a

# Output (abridged):
# No LSB modules are available.
# Distributor ID: Ubuntu
# Description:    Ubuntu 24.04.1 LTS
# Release:        24.04
# Codename:       noble

# 2. Which kernel? The -microsoft-standard-WSL2 suffix proves this is WSL2.
uname -r

# Output:
# 5.15.167.4-microsoft-standard-WSL2`;

/* ── macOS: Homebrew + Multipass — representative output (author-run on WSL2,
   not personally re-run on macOS hardware for this section). ─────────────── */
const brewInstallCmd = `# Skip this if \`brew --version\` already prints something.
/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

# Follow the printed "Next steps" to add brew to your shell PATH, then confirm:
brew --version

# Representative output:
# Homebrew 4.4.0`;

const multipassCmd = `# Multipass is Canonical's own lightweight Ubuntu VM manager for Mac and
# Windows — it distributes as a Homebrew cask.
brew install --cask multipass

# Launch a real Ubuntu 24.04 VM (sized comfortably for this program's labs):
multipass launch 24.04 --name devops-lab --cpus 2 --memory 4G --disk 20G

# Drop into a shell inside it — this is your terminal for every day from here on:
multipass shell devops-lab

# Representative output:
# Welcome to Ubuntu 24.04.1 LTS (GNU/Linux 6.8.0-1015-aws x86_64)
# ubuntu@devops-lab:~$`;

const multipassStopStartCmd = `# Later, to leave and come back without re-launching the whole VM:
exit                              # back to your Mac's own terminal
multipass stop devops-lab         # pause it (frees your Mac's RAM/CPU)
multipass start devops-lab        # resume it
multipass shell devops-lab        # shell back in`;

/* ── Linux: verify + a Fedora/Arch package-manager aside. ────────────────── */
const linuxVerifyCmd = `# Confirm your version — most labs assume Ubuntu/Debian's apt, so if you're
# already on Ubuntu 24.04 you can go straight to Day 1 after this.
lsb_release -a

# Then apply the same update every WSL2/Multipass learner runs:
sudo apt update && sudo apt upgrade -y`;

/* ── No install: browser-based options — representative output; the exact
   Codespaces default image can change, so this is described, not asserted
   as a fixed version. ───────────────────────────────────────────────────── */
const codespacesSystemdCmd = `# Inside a Codespace or other Docker-based dev container, systemd is NOT
# PID 1 — the container runs a single foreground process, not a full init
# system. This command (which Day 10 relies on) will look different here:
systemctl is-system-running

# Representative output inside a container:
# System has not been booted with systemd as init system (PID 1). Can't operate.`;

const canonical = '/mission-90/setup/';
const pageUrl = `${site.url}/mission-90/setup/`;
const jsonLd = [
  breadcrumbLd([
    { name: 'Home', item: `${site.url}/` },
    { name: '90 Days DevOps', item: `${site.url}/mission-90/` },
    { name: 'Day 0 — Set up your lab', item: pageUrl },
  ]),
  howToLd({
    name: 'Set up your DevOps lab: WSL2 + Ubuntu 24.04',
    description:
      'Turn a Windows machine into a real Linux workstation with WSL2 and Ubuntu 24.04 LTS in about twenty minutes.',
    url: pageUrl,
    totalTime: 'PT20M',
    steps: [
      {
        name: 'Install WSL2 + Ubuntu 24.04',
        text: 'In an admin PowerShell run `wsl --install -d Ubuntu-24.04`, then reboot Windows when prompted. WSL2 runs a genuine Linux kernel in a lightweight VM.',
      },
      {
        name: 'Create your Ubuntu user',
        text: 'On its first launch, Ubuntu asks you to create a Linux username and password. Pick a simple lowercase name; the account is a member of the sudo group.',
      },
      {
        name: 'Confirm systemd is your init system',
        text: 'Run `systemctl is-system-running`. Ubuntu 24.04 on WSL2 enables systemd by default; if it is off, add `[boot]` and `systemd=true` to /etc/wsl.conf and run `wsl --shutdown`.',
      },
      {
        name: 'Update the system',
        text: 'Run `sudo apt update && sudo apt upgrade -y` to refresh the package index and apply every available security and bug-fix update.',
      },
      {
        name: 'Verify your lab',
        text: 'Run `lsb_release -a` and `uname -r`. Expect Ubuntu 24.04 (noble) and a -microsoft-standard-WSL2 kernel, which confirms you are inside WSL2.',
      },
    ],
  }),
];
---

<Shell
  title="Set up your DevOps lab: WSL2 + Ubuntu 24.04 — Mission 90, Day 0"
  description="Set up a real Linux lab on Windows in ~20 min: install WSL2 + Ubuntu 24.04, confirm systemd, verify the WSL2 kernel. Free Day 0 of the 90-day DevOps path."
  canonical={canonical}
  image="/mission-90/mission-90-og.png"
  jsonLd={jsonLd}
  noAlternates
>
  <article>
    <!-- ── Hero band ──────────────────────────────────────────────────── -->
    <section class="border-b border-hairline bg-canvas-soft">
      <div class="container-page py-12 sm:py-16">
        <div class="max-w-3xl">
          <p class="eyebrow">Mission 90 · Day 0 · ~20 min (uncounted)</p>
          <h1 class="display-lg mt-3 text-balance text-ink">
            Set up your DevOps lab: WSL2 + Ubuntu 24.04
          </h1>
          <p class="body-lg mt-4 max-w-2xl text-pretty text-body">
            Day 0 doesn't count against the 90 and takes about twenty minutes. You'll end with a
            real Linux workstation — the exact environment every command in the path was written and
            run against, so nothing later is "well, it works on my machine".
          </p>
          <div class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
            <a href="#windows-wsl2" class="card-soft flex h-full flex-col gap-1 p-4 transition-colors hover:border-brand">
              <span class="caption font-semibold uppercase tracking-wide text-brand-strong">Primary path</span>
              <span class="body-md font-semibold text-ink">Windows — WSL2</span>
              <span class="body-sm text-mute">~20 min · the exact environment every lesson was written and run against</span>
            </a>
            <a href="#macos" class="card-soft flex h-full flex-col gap-1 p-4 transition-colors hover:border-brand">
              <span class="caption font-semibold uppercase tracking-wide text-mute">macOS</span>
              <span class="body-md font-semibold text-ink">Homebrew + Multipass</span>
              <span class="body-sm text-mute">~15 min · a real Ubuntu 24.04 VM, not a bare Mac terminal</span>
            </a>
            <a href="#linux" class="card-soft flex h-full flex-col gap-1 p-4 transition-colors hover:border-brand">
              <span class="caption font-semibold uppercase tracking-wide text-mute">Linux</span>
              <span class="body-md font-semibold text-ink">You already have a terminal</span>
              <span class="body-sm text-mute">~5 min · confirm your version, plus a Fedora/Arch command aside</span>
            </a>
            <a href="#no-install" class="card-soft flex h-full flex-col gap-1 p-4 transition-colors hover:border-brand">
              <span class="caption font-semibold uppercase tracking-wide text-mute">No install</span>
              <span class="body-md font-semibold text-ink">Codespaces or Cloud Shell</span>
              <span class="body-sm text-mute">Browser-only · one honest caveat for Day 10</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Article column ────────────────────────────────────────────── -->
    <section class="bg-canvas">
      <div class="container-page py-14 sm:py-20">
        <div class="mx-auto max-w-3xl">
          <nav aria-label="Breadcrumb" class="body-sm text-mute">
            <ol class="flex flex-wrap items-center gap-1.5">
              <li><a class="hover:text-ink" href="/">Home</a></li>
              <li aria-hidden="true" class="px-1.5 text-hairline-strong">/</li>
              <li><a class="hover:text-ink" href="/mission-90/">90 Days DevOps</a></li>
              <li aria-hidden="true" class="px-1.5 text-hairline-strong">/</li>
              <li aria-current="page" class="text-body">Day 0 · Set up your lab</li>
            </ol>
          </nav>

          <section id="windows-wsl2" class="mt-8 scroll-mt-24">
            <h2 class="display-md text-balance text-ink">Windows — WSL2 + Ubuntu 24.04</h2>
            <p class="body-md mt-2 text-pretty text-body">
              The primary path — the exact environment every command in this program was written and
              run against. Five steps, about twenty minutes.
            </p>
          <div class="mt-8 space-y-12">
            <!-- 1. Install WSL2 -->
            <div>
              <h3 class="display-sm text-balance text-ink">1. Install WSL2 + Ubuntu 24.04</h3>
              <p class="body-md mt-3 text-pretty text-body">
                WSL2 (Windows Subsystem for Linux, version 2) runs a genuine Linux kernel inside a
                lightweight VM on Windows — not an emulator. One command installs both WSL2 and
                Ubuntu 24.04 LTS. Open the Start menu, type "PowerShell", right-click and choose
                <em>Run as administrator</em>, then run:
              </p>
              <figure class="mt-4 overflow-hidden rounded-md bg-inverse text-inverse-fg shadow-float">
                <figcaption class="border-b border-white/10 px-4 py-2.5 code-mono text-white/55">
                  Windows PowerShell (Admin)
                </figcaption>
                <div class="overflow-x-auto">
                  <pre class="cmd code-mono px-5 py-4"><code set:html={esc(installCmd)} /></pre>
                </div>
              </figure>
              <p class="body-md mt-3 text-pretty text-body">
                When it asks, <strong class="text-ink">reboot Windows</strong>. After the restart,
                Ubuntu finishes installing on its own and opens a terminal window.
              </p>
            </div>

            <!-- 2. First-boot user -->
            <div>
              <h3 class="display-sm text-balance text-ink">2. Create your Ubuntu user</h3>
              <p class="body-md mt-3 text-pretty text-body">
                On its very first launch, Ubuntu asks you to create a Linux username and password.
                This account is a member of the <code class="code-mono">sudo</code> group, so it can
                run administrative commands with <code class="code-mono">sudo</code>. Pick a simple
                lowercase username — it is separate from your Windows login.
              </p>
              <figure class="mt-4 overflow-hidden rounded-md bg-inverse text-inverse-fg shadow-float">
                <figcaption class="border-b border-white/10 px-4 py-2.5 code-mono text-white/55">
                  Ubuntu — first launch
                </figcaption>
                <div class="overflow-x-auto">
                  <pre class="cmd code-mono px-5 py-4"><code set:html={esc(firstBootCmd)} /></pre>
                </div>
              </figure>
            </div>

            <!-- 3. systemd -->
            <div>
              <h3 class="display-sm text-balance text-ink">3. Confirm systemd is your init system</h3>
              <p class="body-md mt-3 text-pretty text-body">
                <code class="code-mono">systemd</code> is the init system that starts and supervises
                services on modern Linux — you'll manage services with it all through Phase 1. Ubuntu
                24.04 on WSL2 enables it by default; confirm it's actually running:
              </p>
              <figure class="mt-4 overflow-hidden rounded-md bg-inverse text-inverse-fg shadow-float">
                <figcaption class="border-b border-white/10 px-4 py-2.5 code-mono text-white/55">
                  Ubuntu
                </figcaption>
                <div class="overflow-x-auto">
                  <pre class="cmd code-mono px-5 py-4"><code set:html={esc(systemdCmd)} /></pre>
                </div>
              </figure>
              <p class="body-md mt-3 text-pretty text-body">
                If instead you see "System has not been booted with systemd as init system (PID 1)",
                turn it on and restart the WSL VM:
              </p>
              <figure class="mt-4 overflow-hidden rounded-md bg-inverse text-inverse-fg shadow-float">
                <figcaption class="border-b border-white/10 px-4 py-2.5 code-mono text-white/55">
                  Ubuntu — only if systemd is off
                </figcaption>
                <div class="overflow-x-auto">
                  <pre class="cmd code-mono px-5 py-4"><code set:html={esc(wslConfCmd)} /></pre>
                </div>
              </figure>
            </div>

            <!-- 4. Update -->
            <div>
              <h3 class="display-sm text-balance text-ink">4. Update the system</h3>
              <p class="body-md mt-3 text-pretty text-body">
                A fresh image is already a little behind. Pull the current package index and apply
                every available update so you start from a known-good, patched base:
              </p>
              <figure class="mt-4 overflow-hidden rounded-md bg-inverse text-inverse-fg shadow-float">
                <figcaption class="border-b border-white/10 px-4 py-2.5 code-mono text-white/55">
                  Ubuntu
                </figcaption>
                <div class="overflow-x-auto">
                  <pre class="cmd code-mono px-5 py-4"><code set:html={esc(updateCmd)} /></pre>
                </div>
              </figure>
            </div>

            <!-- 5. Verify -->
            <div>
              <h3 class="display-sm text-balance text-ink">5. Verify your lab</h3>
              <p class="body-md mt-3 text-pretty text-body">
                Two quick checks prove you're on the right OS and the right kernel. The
                <code class="code-mono">-microsoft-standard-WSL2</code> suffix on the kernel version
                is the tell-tale sign you're inside WSL2 and not a bare Ubuntu install:
              </p>
              <figure class="mt-4 overflow-hidden rounded-md bg-inverse text-inverse-fg shadow-float">
                <figcaption class="border-b border-white/10 px-4 py-2.5 code-mono text-white/55">
                  Ubuntu
                </figcaption>
                <div class="overflow-x-auto">
                  <pre class="cmd code-mono px-5 py-4"><code set:html={esc(verifyCmd)} /></pre>
                </div>
              </figure>
              <p class="body-md mt-3 text-pretty text-body">
                See <code class="code-mono">Ubuntu 24.04</code> and a
                <code class="code-mono">-microsoft-standard-WSL2</code> kernel? Your lab is ready.
              </p>
            </div>
          </div>
          </section>

          <!-- ── macOS: Homebrew + Multipass ──────────────────────────── -->
          <section id="macos" class="mt-16 scroll-mt-24">
            <h2 class="display-md text-balance text-ink">macOS — Homebrew + Multipass</h2>
            <p class="body-md mt-2 text-pretty text-body">
              Your Mac's own Terminal uses Homebrew and launchd, not <code class="code-mono">apt</code>
              and <code class="code-mono">systemd</code> — the two package managers and init systems
              this program is built on. <a
                href="https://multipass.run/"
                target="_blank"
                rel="noopener noreferrer"
                class="font-medium text-brand-strong underline underline-offset-2 hover:no-underline">Multipass</a>,
              Canonical's own VM manager, gives you a genuine Ubuntu 24.04 machine instead of trying to
              approximate one with Mac-native tools.
            </p>
            <div class="mt-6 space-y-10">
              <div>
                <h3 class="display-sm text-balance text-ink">1. Install Homebrew (if you don't have it)</h3>
                <figure class="mt-4 overflow-hidden rounded-md bg-inverse text-inverse-fg shadow-float">
                  <figcaption class="border-b border-white/10 px-4 py-2.5 code-mono text-white/55">
                    macOS Terminal
                  </figcaption>
                  <div class="overflow-x-auto">
                    <pre class="cmd code-mono px-5 py-4"><code set:html={esc(brewInstallCmd)} /></pre>
                  </div>
                </figure>
              </div>
              <div>
                <h3 class="display-sm text-balance text-ink">2. Install Multipass and launch Ubuntu 24.04</h3>
                <figure class="mt-4 overflow-hidden rounded-md bg-inverse text-inverse-fg shadow-float">
                  <figcaption class="border-b border-white/10 px-4 py-2.5 code-mono text-white/55">
                    macOS Terminal
                  </figcaption>
                  <div class="overflow-x-auto">
                    <pre class="cmd code-mono px-5 py-4"><code set:html={esc(multipassCmd)} /></pre>
                  </div>
                </figure>
                <p class="body-md mt-3 text-pretty text-body">
                  From here, everything in this program — every <code class="code-mono">apt</code>{' '}
                  command, every <code class="code-mono">systemctl</code> check — works exactly like
                  WSL2's Ubuntu, because this Multipass VM <em>is</em> Ubuntu 24.04. Run those commands
                  inside <code class="code-mono">multipass shell devops-lab</code>, never in your Mac's
                  own Terminal directly.
                </p>
              </div>
              <div>
                <h3 class="display-sm text-balance text-ink">3. Leaving and coming back</h3>
                <figure class="mt-4 overflow-hidden rounded-md bg-inverse text-inverse-fg shadow-float">
                  <figcaption class="border-b border-white/10 px-4 py-2.5 code-mono text-white/55">
                    macOS Terminal
                  </figcaption>
                  <div class="overflow-x-auto">
                    <pre class="cmd code-mono px-5 py-4"><code set:html={esc(multipassStopStartCmd)} /></pre>
                  </div>
                </figure>
              </div>
            </div>
          </section>

          <!-- ── Linux: direct + Fedora/Arch aside ────────────────────── -->
          <section id="linux" class="mt-16 scroll-mt-24">
            <h2 class="display-md text-balance text-ink">Linux — you already have a terminal</h2>
            <p class="body-md mt-2 text-pretty text-body">
              If you're on Ubuntu 24.04, you're already the target environment — confirm your version
              and update, then go straight to Day 1:
            </p>
            <figure class="mt-4 overflow-hidden rounded-md bg-inverse text-inverse-fg shadow-float">
              <figcaption class="border-b border-white/10 px-4 py-2.5 code-mono text-white/55">
                Terminal
              </figcaption>
              <div class="overflow-x-auto">
                <pre class="cmd code-mono px-5 py-4"><code set:html={esc(linuxVerifyCmd)} /></pre>
              </div>
            </figure>
            <aside class="mt-6 rounded-lg border border-hairline bg-canvas-soft p-4">
              <p class="body-sm font-semibold text-ink">On Fedora or Arch instead of Ubuntu/Debian?</p>
              <p class="body-sm mt-1.5 text-pretty text-body">
                Every <code class="code-mono">systemctl</code> and <code class="code-mono">journalctl</code>{' '}
                command in this program is identical — systemd itself doesn't care which distro it's on.
                Only the package-manager commands differ:
              </p>
              <div class="mt-3 overflow-x-auto">
                <table class="w-full text-left body-sm">
                  <thead>
                    <tr class="border-b border-hairline-strong text-mute">
                      <th class="py-1.5 pr-4 font-medium">Ubuntu/Debian</th>
                      <th class="py-1.5 pr-4 font-medium">Fedora</th>
                      <th class="py-1.5 font-medium">Arch</th>
                    </tr>
                  </thead>
                  <tbody class="code-mono text-[13px]">
                    <tr class="border-b border-hairline">
                      <td class="py-1.5 pr-4">apt update &amp;&amp; apt upgrade</td>
                      <td class="py-1.5 pr-4">dnf upgrade</td>
                      <td class="py-1.5">pacman -Syu</td>
                    </tr>
                    <tr class="border-b border-hairline">
                      <td class="py-1.5 pr-4">apt install x</td>
                      <td class="py-1.5 pr-4">dnf install x</td>
                      <td class="py-1.5">pacman -S x</td>
                    </tr>
                    <tr>
                      <td class="py-1.5 pr-4">apt remove x</td>
                      <td class="py-1.5 pr-4">dnf remove x</td>
                      <td class="py-1.5">pacman -R x</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </aside>
          </section>

          <!-- ── No install: Codespaces / Cloud Shell ─────────────────── -->
          <section id="no-install" class="mt-16 scroll-mt-24">
            <h2 class="display-md text-balance text-ink">No install — Codespaces or Cloud Shell</h2>
            <p class="body-md mt-2 text-pretty text-body">
              Not near a computer you can install anything on? Two free, browser-only options give you
              a real Linux terminal with zero setup.
            </p>
            <div class="mt-6 space-y-6">
              <div class="card-soft p-5">
                <p class="body-md font-semibold text-ink">GitHub Codespaces</p>
                <p class="body-sm mt-1.5 text-pretty text-body">
                  On any GitHub repository (or a fresh blank one), click <strong class="text-ink">Code →
                  Codespaces → Create codespace</strong>. You get a browser-based VS Code with an
                  integrated terminal running in an Ubuntu-based container — no local install at all.
                </p>
              </div>
              <div class="card-soft p-5">
                <p class="body-md font-semibold text-ink">Google Cloud Shell</p>
                <p class="body-sm mt-1.5 text-pretty text-body">
                  Free with any Google account at <a
                    href="https://shell.cloud.google.com/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-medium text-brand-strong underline underline-offset-2 hover:no-underline">shell.cloud.google.com</a>.
                  Gives you an ephemeral Debian-based VM with a terminal — still <code class="code-mono">apt</code>-based,
                  close enough for the program's early days.
                </p>
              </div>
            </div>
            <div class="mt-6 rounded-lg border border-hairline bg-canvas-soft p-4">
              <p class="body-sm font-semibold text-ink">Honest caveat for Day 10 (systemd)</p>
              <p class="body-sm mt-1.5 text-pretty text-body">
                Docker-based environments like Codespaces run a single foreground process, not a full
                init system — there is no systemd as PID 1:
              </p>
              <figure class="mt-3 overflow-hidden rounded-md bg-inverse text-inverse-fg shadow-float">
                <figcaption class="border-b border-white/10 px-4 py-2.5 code-mono text-white/55">
                  Inside a Codespace
                </figcaption>
                <div class="overflow-x-auto">
                  <pre class="cmd code-mono px-5 py-4"><code set:html={esc(codespacesSystemdCmd)} /></pre>
                </div>
              </figure>
              <p class="body-sm mt-3 text-pretty text-body">
                The concepts in Day 10 still apply, but you won't be able to run every command exactly
                as written. If you want the full hands-on lab that day, WSL2 or Multipass (above) both
                give you a real init system.
              </p>
            </div>
          </section>

          <!-- ── Next ─────────────────────────────────────────────────── -->
          <div class="mt-12 rounded-xl border border-hairline bg-canvas-soft p-6">
            <p class="eyebrow text-brand-strong">Next</p>
