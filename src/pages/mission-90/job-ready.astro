---
/**
 * /mission-90/job-ready — the job-ready interview hub. Aggregates every LIVE
 * day's interviewQA into one searchable, phase-grouped bank, then points at
 * the two "turn the work into a job" days (86 resume/LinkedIn, 87 GitHub
 * portfolio) and the finale (90). Indexable + in the sitemap (no config
 * change needed — nothing excludes it); English-only like the rest of
 * /mission-90 (ENGLISH_ONLY_SECTIONS), hence noAlternates.
 *
 * There is no `resumeBullet` frontmatter (yet) — that's the deferred Phase-D
 * addition described in the plan. This page works entirely from
 * interviewQA, which already exists on every live day.
 */
import { getCollection } from 'astro:content';
import Shell from '../../components/Shell.astro';
import Button from '../../components/Button.astro';
import { site } from '../../data/site';
import { phases, liveDays, getDay } from '../../data/mission90';
import { breadcrumbLd, collectionPageLd } from '../../lib/jsonld';

const allDayEntries = await getCollection('mission90Days');
const byDay = new Map(allDayEntries.map((e) => [e.data.day, e.data]));

interface FlatQA {
  day: number;
  q: string;
  a: string;
  track: 'service' | 'product' | 'both';
}

// Every live day's interviewQA, flattened and tagged with its source day —
// day order (registry order) is preserved within each phase group.
const allQA: FlatQA[] = [];
for (const ld of liveDays) {
  const entry = byDay.get(ld.day);
  if (!entry) continue;
  for (const qa of entry.interviewQA) {
    allQA.push({ day: ld.day, q: qa.q, a: qa.a, track: qa.track });
  }
}

const totalQuestions = allQA.length;
const totalDays = liveDays.length;

const trackLabel = (t: 'service' | 'product' | 'both') =>
  t === 'service' ? 'Service' : t === 'product' ? 'Product' : 'Both';

// Group by phase; drop phases with nothing live yet rather than render an
// empty section.
const phaseGroups = phases
  .map((p) => ({
    phase: p,
    items: allQA.filter((qa) => qa.day >= p.days[0] && qa.day <= p.days[1]),
  }))
  .filter((g) => g.items.length > 0);

const day86 = getDay(86);
const day87 = getDay(87);
const day90 = getDay(90);

const canonical = '/mission-90/job-ready';
const pageUrl = `${site.url}${canonical}/`;
const description = `${totalQuestions} real interview questions and answers drawn from all ${totalDays} live days of the free 90-day DevOps program, organized by phase and searchable by keyword or track.`;

const jsonLd = [
  breadcrumbLd([
    { name: 'Home', item: `${site.url}/` },
    { name: '90 Days DevOps', item: `${site.url}/mission-90/` },
    { name: 'Job-Ready Hub', item: pageUrl },
  ]),
  collectionPageLd({
    name: 'Mission 90 Days — Job-Ready Interview Hub',
    description,
    url: pageUrl,
  }),
];
---

<Shell
  title="Job-Ready Interview Hub — Mission 90 Days DevOps"
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
  noAlternates
>
  {/* ── Hero ── */}
  <section class="section-pad bg-canvas-soft">
    <div class="container-page">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Mission 90 Days DevOps</p>
        <h1 class="display-xl mt-4 text-balance text-ink">Job-ready interview hub.</h1>
        <p class="body-lg mx-auto mt-4 max-w-2xl text-pretty text-body">
          Every interview question and answer from all {totalDays} live days, in one place —
          {totalQuestions} of them so far. Search by keyword, filter by track, and copy any answer to
          practice saying it out loud.
        </p>
      </div>
    </div>
  </section>

  {/* ── Interview bank: search + track filter + phase-grouped Q&A ── */}
  <section class="section-pad bg-canvas" aria-label="Interview question bank">
    <div class="container-page">
      <div class="mx-auto max-w-3xl" data-jr-bank>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <label class="min-w-0 flex-1">
            <span class="sr-only">Search questions and answers</span>
            <input
              type="search"
              inputmode="search"
              autocomplete="off"
              placeholder="Search questions and answers…"
              class="input-focus w-full rounded-lg border border-hairline bg-canvas px-3 py-2 text-sm text-ink placeholder:text-mute"
              data-jr-search
            />
          </label>
          <div class="jr-chips" role="group" aria-label="Filter by track" data-jr-chips>
            <button type="button" class="jr-chip is-active" data-jr-chip="all" aria-pressed="true">All</button>
            <button type="button" class="jr-chip" data-jr-chip="service" aria-pressed="false">Service</button>
            <button type="button" class="jr-chip" data-jr-chip="product" aria-pressed="false">Product</button>
            <button type="button" class="jr-chip" data-jr-chip="both" aria-pressed="false">Both</button>
          </div>
        </div>
        <p class="caption mt-2 text-mute" role="status" data-jr-count></p>

        <div class="mt-6 flex flex-col gap-10">
          {
            phaseGroups.map((g) => (
              <div data-jr-phase-group>
                <p class="eyebrow text-brand-strong">
                  Phase {g.phase.id} · {g.phase.name}
                </p>
                <div class="mt-3 divide-y divide-hairline border-y border-hairline">
                  {g.items.map((qa) => (
                    <details
                      class="md-faq group"
                      data-jr-item
                      data-track={qa.track}
                      data-search={`${qa.q} ${qa.a}`.toLowerCase()}
                    >
                      <summary class="flex cursor-pointer list-none items-start justify-between gap-3 py-4">
                        <span class="body-md text-balance font-semibold text-ink transition-colors group-hover:text-link">
                          {qa.q}
                        </span>
                        <span class="mt-0.5 flex shrink-0 items-center gap-2">
                          <span class="md-track-tag">{trackLabel(qa.track)}</span>
                          <span
                            aria-hidden="true"
                            class="grid size-6 place-items-center rounded-full text-mute transition-colors group-hover:bg-canvas-soft-2 group-hover:text-ink"
                          >
                            <svg
                              class="md-faq-chevron size-4 transition-transform duration-200 ease-out"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            >
                              <polyline points="6 9 12 15 18 9" />
                            </svg>
                          </span>
                        </span>
                      </summary>
                      <div class="pb-5">
                        <p class="body-sm text-pretty text-body">{qa.a}</p>
                        <div class="mt-3 flex flex-wrap items-center gap-3">
                          <button
                            type="button"
                            class="md-copy-answer inline-flex items-center gap-1.5 rounded-md border border-hairline-strong bg-canvas px-2.5 py-1.5 text-xs font-medium text-brand-strong transition-colors hover:bg-canvas-soft-2 [touch-action:manipulation]"
                            data-copy-answer={qa.a}
                            data-day={qa.day}
                            aria-label={`Copy the answer to “${qa.q}” for sharing`}
                          >
                            <svg
                              class="md-copy-icon size-3.5"
                              viewBox="0 0 16 16"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.4"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              aria-hidden="true"
                            >
                              <rect x="5.5" y="5.5" width="8.5" height="8.5" rx="1.5" />
                              <path d="M10.5 3.5H3.5A1.5 1.5 0 0 0 2 5v7" />
                            </svg>
                            <svg
                              class="md-copy-check hidden size-3.5"
                              viewBox="0 0 16 16"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.7"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              aria-hidden="true"
                            >
                              <path d="M3 8.5l3.5 3.5L13 4.5" />
                            </svg>
                            <span class="md-copy-label">Copy answer</span>
                          </button>
                          <a href={`/mission-90/day/${qa.day}/`} class="link-inline text-xs font-medium">
                            From Day {qa.day} &rarr;
                          </a>
                        </div>
                      </div>
                    </details>
                  ))}
                </div>
              </div>
            ))
          }
        </div>

        <p class="body-md mt-8 text-center text-mute" data-jr-empty hidden>
          No questions match that search — try a different keyword or clear the track filter.
        </p>
        <span class="sr-only" role="status" aria-live="polite" data-jr-copy-status></span>
      </div>
    </div>
  </section>

  {/* ── Turn 90 days into a job: resume/LinkedIn (Day 86) + GitHub (Day 87) ── */}
  <section class="section-pad bg-canvas-soft" aria-labelledby="jr-turn-heading">
    <div class="container-page">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Turn 90 days into a job search</p>
        <h2 id="jr-turn-heading" class="display-lg mt-3 text-balance text-ink">
          The questions are only half of it.
        </h2>
        <p class="body-md mt-3 text-pretty text-body">
          Knowing the answers matters, but a recruiter reads your resume and your GitHub before they
          ever ask you a question. Two days in the program are built specifically for that.
        </p>
      </div>
      <div class="mx-auto mt-8 grid max-w-3xl gap-4 sm:grid-cols-2">
        {day86 && (
          <a href={`/mission-90/day/86/`} class="card-soft flex h-full flex-col gap-1.5 p-5 transition-colors hover:border-brand">
            <span class="eyebrow text-brand-strong">Day 86</span>
            <span class="body-md font-semibold text-ink">{day86.title}</span>
            <span class="body-sm text-mute">
              Turn what you actually did in the last 90 days into resume bullets and a LinkedIn summary
              that survives an ATS scan.
            </span>
          </a>
        )}
        {day87 && (
          <a href={`/mission-90/day/87/`} class="card-soft flex h-full flex-col gap-1.5 p-5 transition-colors hover:border-brand">
            <span class="eyebrow text-brand-strong">Day 87</span>
            <span class="body-md font-semibold text-ink">{day87.title}</span>
            <span class="body-sm text-mute">
              Clean up your GitHub profile and pin the projects that show real work — READMEs, diagrams,
              and a demo a recruiter can actually run.
            </span>
          </a>
        )}
      </div>
    </div>
  </section>

  {/* ── Day 90 cross-link ── */}
  {day90 && (
    <section class="section-pad bg-canvas">
      <div class="container-page">
        <div class="mx-auto max-w-2xl rounded-xl border border-hairline bg-canvas-soft p-6 text-center shadow-soft sm:p-8">
          <p class="eyebrow text-brand-strong">The finale</p>
          <h2 class="display-sm mt-3 text-balance text-ink">{day90.title}</h2>
          <p class="body-sm mt-2 text-pretty text-body">
            Day 90 puts everything from all five phases against one incident, under pressure — the
            closest thing to a real on-call night the program has.
          </p>
          <div class="mt-5">
            <Button href="/mission-90/day/90/" variant="secondary">Read Day 90</Button>
          </div>
        </div>
      </div>
    </section>
  )}

  {/* ── Back to the hub ── */}
  <section class="section-pad bg-canvas-soft">
    <div class="container-page text-center">
      <Button href="/mission-90/" variant="secondary">Back to the hub</Button>
    </div>
  </section>
</Shell>

<style>
  .jr-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .jr-chip {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    border: none;
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    font-size: 12px;
    font-weight: 500;
    line-height: 18px;
    color: var(--color-brand-strong);
    cursor: pointer;
    transition:
      background 0.12s ease,
      box-shadow 0.12s ease;
  }
  .jr-chip:hover,
  .jr-chip.is-active {
    background: var(--color-brand-soft);
    box-shadow: inset 0 0 0 1px var(--color-brand);
  }
  .jr-chip:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 1px;
  }
  @media (pointer: coarse) {
    .jr-chip {
      min-height: 44px;
    }
  }

  /* Interview disclosures — same idiom as MissionDay's interview bank. */
  .md-faq > summary::-webkit-details-marker {
    display: none;
  }
  .md-faq[open] > summary .md-faq-chevron {
    transform: rotate(180deg);
  }
  .md-track-tag {
    font-size: 10px;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
    color: var(--color-mute);
    border: 1px solid var(--color-hairline-strong);
    border-radius: 9999px;
    padding: 3px 7px;
    white-space: nowrap;
  }
  .md-copy-answer:focus-visible {
    outline: 2px solid var(--color-brand);
    outline-offset: 2px;
  }
  .md-copy-answer[data-copied] {
    border-color: color-mix(in srgb, var(--color-success) 55%, transparent);
    color: var(--color-success);
  }
  @media (pointer: coarse) {
    .md-copy-answer {
      min-height: 44px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .md-faq-chevron {
      transition: none;
    }
  }
</style>

<script>
  import { copyTextToClipboard } from '../../lib/clipboard';

  function initFilter(): void {
    const root = document.querySelector<HTMLElement>('[data-jr-bank]');
    if (!root || root.dataset.filterBound === 'true') return;
    root.dataset.filterBound = 'true';

    const searchInput = root.querySelector<HTMLInputElement>('[data-jr-search]');
    const chips = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-jr-chip]'));
    const items = Array.from(root.querySelectorAll<HTMLElement>('[data-jr-item]'));
    const groups = Array.from(root.querySelectorAll<HTMLElement>('[data-jr-phase-group]'));
    const emptyState = root.querySelector<HTMLElement>('[data-jr-empty]');
    const count = root.querySelector<HTMLElement>('[data-jr-count]');
    let activeTrack = 'all';

    function applyFilter(): void {
      const query = (searchInput?.value ?? '').trim().toLowerCase();
      let visible = 0;
      items.forEach((item) => {
        const track = item.dataset.track ?? 'both';
        const matchesTrack = activeTrack === 'all' || track === activeTrack;
        const haystack = item.dataset.search ?? '';
        const matchesQuery = !query || haystack.includes(query);
        const show = matchesTrack && matchesQuery;
        item.hidden = !show;
        if (show) visible++;
      });
      groups.forEach((group) => {
        const anyVisible = Array.from(group.querySelectorAll<HTMLElement>('[data-jr-item]')).some((i) => !i.hidden);
        group.hidden = !anyVisible;
      });
      if (emptyState) emptyState.hidden = visible > 0;
      if (count) count.textContent = `Showing ${visible} of ${items.length} questions.`;
    }

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        activeTrack = chip.dataset.jrChip ?? 'all';
        chips.forEach((c) => {
          const isActive = c === chip;
          c.classList.toggle('is-active', isActive);
          c.setAttribute('aria-pressed', String(isActive));
        });
        applyFilter();
      });
    });

    let debounce = 0;
    searchInput?.addEventListener('input', () => {
      window.clearTimeout(debounce);
      debounce = window.setTimeout(applyFilter, 150);
    });

    applyFilter();
  }

  function initCopyAnswer(): void {
    const status = document.querySelector<HTMLElement>('[data-jr-copy-status]');
    document.querySelectorAll<HTMLButtonElement>('.md-copy-answer').forEach((btn) => {
      if (btn.dataset.copyBound) return;
      btn.dataset.copyBound = 'true';
      const label = btn.querySelector<HTMLElement>('.md-copy-label');
      const idle = label?.textContent ?? 'Copy answer';
      let resetTimer = 0;

      const setCopied = (copied: boolean): void => {
        btn.querySelector('.md-copy-icon')?.classList.toggle('hidden', copied);
        btn.querySelector('.md-copy-check')?.classList.toggle('hidden', !copied);
        if (label) label.textContent = copied ? 'Copied' : idle;
        if (copied) btn.dataset.copied = 'true';
        else delete btn.dataset.copied;
      };

      btn.addEventListener('click', async () => {
        const answer = btn.dataset.copyAnswer ?? '';
        const day = btn.dataset.day ?? '';
        const url = `${location.origin}/mission-90/day/${day}/?utm_source=telegram&utm_medium=post&utm_campaign=m90`;
        const text = `${answer}\n\n— OpsCanopy · 90 Days DevOps${day ? ` · Day ${day}` : ''}\n${url}`;
        const ok = await copyTextToClipboard(text);
        if (ok) {
          setCopied(true);
          if (status) status.textContent = 'Answer copied to clipboard.';
          window.clearTimeout(resetTimer);
          resetTimer = window.setTimeout(() => {
            setCopied(false);
            if (status) status.textContent = '';
          }, 2000);
        } else if (status) {
          status.textContent = 'Copy failed — select the text manually.';
        }
      });
    });
  }

  function boot(): void {
    initFilter();
    initCopyAnswer();
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
