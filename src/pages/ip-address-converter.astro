---
/**
 * IP Address Converter — the ip-address-converter tool page (SEO surface).
 * Paste an IP in any form and see dotted decimal, integer, hex, binary (and the
 * IPv6 compressed/expanded forms) — entirely in the browser.
 */
import Shell from '../components/Shell.astro';
import IpConverterPlayground from '../components/IpConverterPlayground.astro';
import Button from '../components/Button.astro';
import CodeBlock from '../components/CodeBlock.astro';
import ToolHero from '../components/ToolHero.astro';
import ToolPipeline from '../components/ToolPipeline.astro';
import FaqList from '../components/FaqList.astro';
import ToolCrossLinks from '../components/ToolCrossLinks.astro';
import { site, navLinks } from '../data/site';
import { getTool } from '../data/tools';
import { softwareAppLd, faqPageLd } from '../lib/jsonld';

const tool = getTool('ip-address-converter');
const pagePath = '/ip-address-converter';
const pageUrl = `${site.url}${pagePath}`;

const faqs = [
  {
    q: 'What does the IP Address Converter do?',
    a: 'Paste an IP address in any common form — dotted decimal (192.168.1.10), a 32-bit integer (3232235786), hexadecimal (0xC0A8010A), binary, or an IPv6 literal (2001:db8::1) — and it shows every other representation at once, plus the address type. Everything is computed in your browser.',
  },
  {
    q: 'Does my address ever leave my browser?',
    a: 'No. Detection and conversion run 100% client-side in your tab. There is no server, no account and no logging, so internal addresses are safe to paste.',
  },
  {
    q: 'Which input formats are detected automatically?',
    a: 'A value with colons is read as IPv6; a 0x-prefixed value as hexadecimal; a string of only 0s and 1s (32 or 128 long) as binary; a plain run of digits as an integer; and a dotted value as IPv4. You do not pick the format — the converter infers it and tells you what it read.',
  },
  {
    q: 'Why would I convert an IP to an integer?',
    a: 'Storing an address as its integer makes range checks and sorting trivial (a CIDR is just a numeric interval), which is why databases, GeoIP tables and allow/deny lists often keep IPs as integers. Converting back and forth by hand is error-prone — this does it exactly.',
  },
  {
    q: 'Does it handle IPv6?',
    a: 'Yes. IPv6 is converted with full 128-bit precision: you get the RFC 5952 compressed form, the fully expanded form, the decimal integer and the padded hexadecimal. Embedded IPv4 (for example ::ffff:192.168.1.1) is parsed too.',
  },
  {
    q: 'Is the hexadecimal output zero-padded?',
    a: 'Yes — IPv4 is shown as a full 8-digit hex value and IPv6 as a full 32-digit value, so the width is unambiguous. The dotted-binary view groups IPv4 into four labelled octets.',
  },
];

const softwareApp = softwareAppLd({
  name: 'IP Address Converter',
  description:
    'Paste an IPv4 or IPv6 address in any form — dotted decimal, integer, hexadecimal or binary — and see every representation at once. 100% in your browser.',
  url: pageUrl,
  subCategory: 'Networking',
  featureList: [
    'Convert between dotted decimal, integer, hex and binary',
    'Automatic input-format detection',
    'IPv4 and IPv6 (compressed + expanded)',
    '100% client-side, no upload, no signup',
  ],
  keywords: tool?.keywords.join(', '),
});
const faqPage = faqPageLd(faqs);

const pipeline = [
  {
    title: 'Detect the format.',
    body: 'Colons mean IPv6, 0x means hex, only 0s and 1s mean binary, digits mean an integer, dots mean IPv4.',
  },
  {
    title: 'Read to a number.',
    body: 'The input is parsed to a single BigInt — the canonical value behind every representation.',
  },
  {
    title: 'Re-encode.',
    body: 'That value is rendered back out as dotted decimal, integer, hexadecimal and binary (or IPv6 forms).',
  },
  {
    title: 'Classify.',
    body: 'The address is labelled — private, loopback, link-local, documentation, multicast and so on.',
  },
];

const formatsExample = `192.168.1.10            dotted decimal
3232235786              integer (decimal)
0xC0A8010A              hexadecimal
11000000.10101000.      binary (by octet)
  00000001.00001010`;

const ipv6FormsExample = `2001:db8::1             compressed (RFC 5952)
2001:0db8:0000:0000:    expanded
  0000:0000:0000:0001
42540766411282592856…   integer (decimal)
0x20010db8000000000…    hexadecimal (32 digits)`;
---

<Shell
  title="IP Address Converter — Dotted, Integer, Hex & Binary (IPv4/IPv6)"
  description="Paste an IPv4 or IPv6 address in any form — dotted decimal, integer, hexadecimal or binary — and see every representation at once. 100% in your browser."
  canonical="/ip-address-converter"
  jsonLd={[softwareApp, faqPage]}
>
  <ToolHero
    eyebrow="IP Address Converter · Networking"
    badges={[
      { label: 'Runs in your browser', variant: 'live' },
      { label: 'IPv4 & IPv6', variant: 'neutral' },
      { label: 'No signup', variant: 'neutral' },
    ]}
  >
    <Fragment slot="headline">See an IP address in every form at once.</Fragment>
    <Fragment slot="lead">
      Paste an IP in any form —
      <span class="code-mono text-ink" translate="no">192.168.1.10</span>,
      <span class="code-mono text-ink" translate="no">3232235786</span> or
      <span class="code-mono text-ink" translate="no">0xC0A8010A</span> — and get dotted decimal,
      integer, hex and binary together.
    </Fragment>
  </ToolHero>

  <section id="playground" class="scroll-mt-24 bg-canvas-soft pt-8 pb-20 sm:pb-24">
    <div class="container-page">
      <h2 class="sr-only">IP Address Converter playground</h2>
      <IpConverterPlayground />
    </div>
  </section>

  <section id="why" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
        <div>
          <p class="eyebrow">The Gap</p>
          <h2 class="display-lg mt-3 text-balance text-ink">
            The same address, four ways to write it.
          </h2>
        </div>
        <div class="space-y-4">
          <p class="body-md text-pretty text-body">
            A log line stores an IP as an integer, a firewall shows it in hex, your code reads it
            dotted, and a packet capture prints binary. Converting between them by hand means
            multiplying by powers of 256 and is easy to get subtly wrong.
          </p>
          <p class="body-md text-pretty text-body">
            This converter detects whatever form you paste and shows the rest instantly — IPv4 and
            IPv6 — so you can match a value across tools without reaching for a calculator. Entirely
            in the browser, with nothing to install.
          </p>
          <p class="body-sm text-mute">
            Need the network maths instead? Open the
            <a class="link-inline" href="/subnet-calculator">Subnet Calculator</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ToolPipeline
    id="how-it-works"
    eyebrow="The Pipeline"
    heading="How it works."
    lead="Four deterministic steps run on every keystroke — all inside your browser tab, with exact BigInt arithmetic."
    steps={pipeline}
  />

  <section id="formats" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">The Formats</p>
        <h2 class="display-lg mt-3 text-ink">One value, every representation.</h2>
        <p class="body-md mx-auto mt-3 max-w-xl text-pretty text-body">
          Each form is just a different encoding of the same underlying number — 32 bits for IPv4,
          128 for IPv6.
        </p>
      </div>
      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-2">
        <div class="min-w-0">
          <h3 class="display-sm text-ink">IPv4</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            <span class="code-mono text-ink" translate="no">192.168.1.10</span> in each form:
          </p>
          <CodeBlock lang="text" filename="ipv4-forms" code={formatsExample} />
        </div>
        <div class="min-w-0">
          <h3 class="display-sm text-ink">IPv6</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            <span class="code-mono text-ink" translate="no">2001:db8::1</span> compressed, expanded,
            and as a number:
          </p>
          <CodeBlock lang="text" filename="ipv6-forms" code={ipv6FormsExample} />
        </div>
      </div>
    </div>
  </section>

  <section id="next" class="scroll-mt-24 bg-inverse text-inverse-fg">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
        <div class="min-w-0">
          <p class="eyebrow !text-cyan">Next Step</p>
          <h2 class="display-lg mt-3 text-balance text-inverse-fg">
            Need the network, not just the address?
          </h2>
          <p class="body-md mt-4 text-pretty text-white/70">
            The <span translate="no">Subnet Calculator</span> takes an address plus a prefix and
            returns the network, broadcast, mask, wildcard and host range for IPv4 and IPv6 — the
            companion to converting a single address.
          </p>
          <div class="mt-7 flex flex-wrap items-center gap-3">
            <Button href="/subnet-calculator" variant="secondary">Open the Subnet Calculator</Button>
          </div>
        </div>
        <CodeBlock
          lang="text"
          filename="convert.txt"
          code={`0xC0A8010A
  →  192.168.1.10
  →  3232235786
  →  11000000.10101000.00000001.00001010`}
        />
      </div>
    </div>
  </section>

  <FaqList faqs={faqs} />

  <ToolCrossLinks>
    <Fragment slot="lead">
      The IP Address Converter is one tool in
      <span translate="no">{site.name}</span> — a growing canopy of browser-based validators,
      converters and testers that never touch a server.
    </Fragment>
    <Fragment slot="links">
      More networking: the
      <a class="link-inline" href="/subnet-calculator">Subnet Calculator</a> and the
      <a class="link-inline" href="/cidr-checker">CIDR / Subnet Checker</a>, or browse the full
      <a class="link-inline" href={navLinks[0].href}>tools directory</a>.
    </Fragment>
    <Fragment slot="disclaimer">
      Provided as-is for convenience. <span translate="no">{site.name}</span> is free and open.
    </Fragment>
  </ToolCrossLinks>
</Shell>
