---
/**
 * OpsCanopy hub homepage — the flagship marketing surface.
 * Composes the Vercel-inspired design system defined in global.css / DESIGN.md.
 *
 * Component prop contracts (provided by sibling agents in src/components/*):
 *  - <MeshGradient class="…" />                          atmospheric hero backdrop
 *  - <Button href variant="primary|secondary" size? />   marketing pill CTA (label via slot)
 *  - <Card class? as?>…</Card>                            canvas card chrome (slot body)
 *  - <Badge variant?>…</Badge>                            inline status pill (label via slot)
 *  - <CodeBlock code lang? filename? />                   dark mono code surface
 */
import Shell from '../components/Shell.astro';
import MeshGradient from '../components/MeshGradient.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Badge from '../components/Badge.astro';
import CodeBlock from '../components/CodeBlock.astro';
import FaqList from '../components/FaqList.astro';
import { site } from '../data/site';
import { tools, liveTools, getTool, categoryAccent } from '../data/tools';
import { faqPageLd } from '../lib/jsonld';

const alertLint = liveTools[0] ?? tools[0];

// Representative tools for the no-JS hero product preview — chosen so several
// category accent hues are visible at a glance (Observability, Networking,
// Security, CI/CD). Falls back to the live catalog if a slug is ever renamed.
const previewSlugs = [
  'loki-alert-rule-tester',
  'subnet-calculator',
  'jwt-decoder',
  'github-actions-validator',
];
const previewTools = previewSlugs
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t) && t!.status === 'live')
  .slice(0, 4);

const faqs = [
  {
    q: 'Are OpsCanopy tools really free?',
    a: 'Yes. Every tool is completely free with no paywalls, usage limits, or premium tiers. There is no account requirement of any kind — open a tool in your browser and start using it immediately.',
  },
  {
    q: 'Do I need to sign up to use these online DevOps tools?',
    a: 'No. There is no signup, login, or email capture. Open any tool in your browser tab and use it immediately — no account, no cookie consent wall, no friction.',
  },
  {
    q: 'Is my data uploaded to a server when I use the tools?',
    a: 'No. Every tool runs 100% client-side in your browser tab; nothing you paste is logged, stored, or uploaded. Your data never leaves the browser.',
  },
  {
    q: 'Is it safe to paste a JWT or config into a browser-based tool?',
    a: 'On OpsCanopy, yes. Decoding and parsing happen entirely in local JavaScript with zero server calls, which you can verify yourself in the browser network tab. As general hygiene, never share signing secrets with any third party, but OpsCanopy transmits nothing.',
  },
  {
    q: 'Do the tools work offline?',
    a: 'Once a tool page has loaded, it keeps working even if you disconnect from the internet, because all processing is local and there is no backend to call. Going offline is also an easy way to verify the client-side privacy claim yourself.',
  },
  {
    q: 'Who are these browser-based DevOps tools for?',
    a: 'DevOps engineers, SREs, sysadmins, platform and backend engineers — anyone who needs quick subnet and CIDR math, cron schedules, PromQL or LogQL queries, JWT, Base64 and hash utilities, timestamp conversion, GitHub Actions validation, or Kubernetes resource sizing without installing anything.',
  },
  {
    q: 'How is OpsCanopy different from other online developer tool collections?',
    a: 'Most tool collections focus on generic formatters. OpsCanopy specialises in DevOps and SRE workflows — CIDR planning, cron, PromQL and LogQL, Kubernetes capacity, CI validators — with the same guarantees throughout: free, no signup, 100% client-side, nothing uploaded or logged.',
  },
];

// Quietly-stated trust principles for the value strip.
const principles = [
  { label: 'PRICE', title: 'Free forever', body: 'Every tool, no paywall, no trial.' },
  { label: 'RUNTIME', title: 'Runs in your browser', body: 'Pure client-side. Nothing to install.' },
  { label: 'PRIVACY', title: 'Your data stays local', body: 'Inputs never leave the device.' },
  { label: 'ACCESS', title: 'No signup', body: 'Open the page and start working.' },
];

// "Why a hub" value props, drawn from the strategy.
const whyCards = [
  {
    eyebrow: 'COMPOUNDING',
    title: 'A hub compounds.',
    body: 'Each focused, search-shaped tool earns its own keywords and links back to the rest. The catalog grows more discoverable with every release.',
  },
  {
    eyebrow: 'STATIC + CHEAP',
    title: 'Cheap to run, fast to load.',
    body: 'Everything is static and client-side, so there are no servers to scale and no bills to chase. Pages stay instant under any traffic.',
  },
  {
    eyebrow: 'PRIVACY',
    title: 'Privacy is a feature.',
    body: 'Your rules, configs and logs are yours. Nothing is uploaded, logged or phoned home — the whole point of running it in your tab.',
  },
];

// Loki rule + test snippet for the featured AlertLint band.
const alertLintSnippet = `# rules.yml — the Loki alert under test
groups:
  - name: ingest
    rules:
      - alert: HighErrorRate
        expr: |
          sum(rate({app="api"} |= "level=error" [5m])) > 10
        for: 2m

# tests.yml — assert it fires (and doesn't, when quiet)
tests:
  - name: fires when errors spike
    input:
      - logs: 'level=error'
        rate: 25/min
    expect: { alert: HighErrorRate, fires: true }
  - name: stays quiet under threshold
    input:
      - logs: 'level=error'
        rate: 3/min
    expect: { alert: HighErrorRate, fires: false }`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: site.name,
    url: site.url,
    description: site.description,
    sameAs: [site.github, `https://x.com/${site.twitter.replace('@', '')}`],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: site.name,
    url: site.url,
    description: site.description,
    publisher: { '@type': 'Organization', name: site.name, url: site.url },
  },
  faqPageLd(faqs),
];
---

<Shell
  title="OpsCanopy — Free Online DevOps & SRE Tools, No Signup"
  description="Free online DevOps tools that run 100% in your browser — subnet/CIDR calculators, cron testers, JWT decoder & more. No signup, nothing uploaded."
  canonical="/"
  jsonLd={jsonLd}
>
  {/* ─────────────────────────── 1 · HERO ─────────────────────────── */}
  <section class="section-pad relative isolate overflow-hidden bg-canvas-soft">
    <MeshGradient class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[90%] opacity-90" />
    {/* Soft top sheen + bottom fade frame the mesh so it reads as ambient light,
        keeping crisp ink contrast under the headline. */}
    <div
      class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-32 bg-gradient-to-b from-canvas-soft to-transparent"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-48 bg-gradient-to-b from-transparent to-canvas-soft"
      aria-hidden="true"
    >
    </div>

    <div class="container-page relative z-10 flex flex-col items-center text-center">
      {/* Trust strip — sits above the H1, quiet and scannable. */}
      <p class="eyebrow flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-mute">
        <span>Free forever</span>
        <span aria-hidden="true" class="text-hairline">&bull;</span>
        <span>No signup</span>
        <span aria-hidden="true" class="text-hairline">&bull;</span>
        <span>Your data stays local</span>
      </p>

      <h1 class="display-xl mt-4 max-w-3xl text-balance text-ink">
        A canopy of tools for the ops you actually do.
      </h1>

      <p class="body-md mx-auto mt-4 max-w-2xl text-pretty text-body">
        Free online developer tools that run entirely in the browser — validators, converters, testers
        and linters for DevOps and SRE engineers. No signup, no servers, no tracking: your data never
        leaves the device.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
        <Button href="/tools" variant="primary">Explore tools — no signup</Button>
        <a
          href="/blog"
          class="link-inline group body-md inline-flex items-center gap-1 font-medium"
        >
          Read the blog
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>

      {/* Product preview — a static, no-JS faux app window showing real tool
          cards so the category accent hues are visible. Height is reserved via
          the card grid's min-heights so it never shifts layout on load. */}
      <div
        class="mt-14 w-full max-w-4xl overflow-hidden rounded-2xl bg-canvas text-left shadow-float"
        aria-hidden="true"
      >
        <div class="flex items-center gap-2 border-b border-hairline bg-canvas-soft px-4 py-3">
          <span class="size-3 rounded-full bg-[#ff5f57]"></span>
          <span class="size-3 rounded-full bg-[#febc2e]"></span>
          <span class="size-3 rounded-full bg-[#28c840]"></span>
          <span class="caption ml-3 truncate text-mute">opscanopy.com/tools</span>
        </div>
        <div class="grid grid-cols-1 gap-4 p-5 sm:grid-cols-2 sm:p-6">
          {
            previewTools.map((tool) => (
              <div class="flex min-h-[8.5rem] min-w-0 flex-col overflow-hidden rounded-lg bg-canvas shadow-soft">
                <span
                  class="h-1 w-full"
                  style={`background:${categoryAccent[tool.category]}`}
                />
                <div class="flex min-w-0 flex-1 flex-col p-4 sm:p-5">
                  <span class="display-sm min-w-0 break-words text-ink" translate="no">
                    {tool.name}
                  </span>
                  <span class="caption mt-2 inline-flex items-center gap-1.5 font-medium uppercase tracking-wide text-body">
                    <span
                      class="size-1.5 rounded-full"
                      style={`background:${categoryAccent[tool.category]}`}
                    />
                    {tool.category}
                  </span>
                  <span class="body-sm mt-2 text-pretty text-mute">{tool.tagline}</span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  {/* ─── 2 · TOOLS PREVIEW (the catalog leads — MVP first) ─── */}
  <section class="section-pad-lg bg-canvas" aria-labelledby="tools-preview">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">The Catalog</span>
          <h2 id="tools-preview" class="display-lg mt-3 text-balance text-ink">Tools in the canopy.</h2>
          <p class="body-md mt-3 text-pretty text-body">
            Focused, single-purpose utilities for platform and DevOps engineers — every one live,
            free and running entirely in your browser.
          </p>
        </div>
        <a
          href="/tools"
          class="link-inline group body-md inline-flex shrink-0 items-center gap-1 whitespace-nowrap font-medium"
        >
          See all tools
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>

      <ul class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          liveTools.map((tool) => (
            <li class="h-full">
              <a
                href={`/${tool.slug}`}
                class="card-interactive group relative flex h-full min-w-0 flex-col overflow-hidden rounded-lg bg-canvas shadow-soft"
              >
                <span
                  aria-hidden="true"
                  class="h-1 w-full"
                  style={`background:${categoryAccent[tool.category]}`}
                />
                <div class="flex h-full min-w-0 flex-col p-6 sm:p-7">
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="display-sm min-w-0 break-words text-ink" translate="no">
                      {tool.name}
                    </h3>
                    <Badge variant="live" class="shrink-0">Live</Badge>
                  </div>
                  <p class="caption mt-2 inline-flex items-center gap-1.5 font-medium uppercase tracking-wide text-body">
                    <span
                      aria-hidden="true"
                      class="size-1.5 rounded-full"
                      style={`background:${categoryAccent[tool.category]}`}
                    />
                    {tool.category}
                  </p>
                  <p class="body-md mt-4 flex-1 text-pretty text-body">{tool.tagline}</p>
                  <span class="body-sm mt-6 inline-flex items-center gap-1 font-medium text-link">
                    Open tool
                    <span
                      aria-hidden="true"
                      class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
                    >
                      &rarr;
                    </span>
                  </span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ─────────────────── 3 · FEATURED TOOL BAND (AlertLint) ─────────────────── */}
  <section class="section-pad bg-canvas-soft" aria-labelledby="featured-tool">
    <div class="container-page">
      <div
        class="overflow-hidden rounded-xl bg-inverse text-inverse-fg shadow-float"
      >
        <div class="grid grid-cols-1 gap-10 p-8 sm:p-12 lg:grid-cols-2 lg:items-center lg:gap-12 lg:p-16">
          <div class="flex min-w-0 flex-col">
            <span class="eyebrow text-cyan">Tool&nbsp;01 · Observability</span>
            <h2 id="featured-tool" class="display-lg mt-4 text-balance text-inverse-fg">
              Test your Loki alerting rules before they fire in production.
            </h2>
            <p class="body-lg mt-5 max-w-xl text-pretty text-white/80">
              Paste your alerting and recording rules alongside synthetic log streams, then assert
              exactly what should — and shouldn&rsquo;t — fire. The <span translate="no">promtool</span>
              equivalent Loki never shipped, running entirely in your browser.
            </p>
            <div class="mt-8">
              <Button href={`/${alertLint.slug}`} variant="secondary">Open <span translate="no">AlertLint</span></Button>
            </div>
          </div>

          <div class="min-w-0 lg:pl-2">
            <CodeBlock
              code={alertLintSnippet}
              lang="yaml"
              filename="alertlint test ./tests"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ───────────────────── 4 · VALUE / TRUST STRIP ───────────────────── */}
  <section class="section-pad-sm bg-canvas" aria-label="Why OpsCanopy is different">
    <div class="container-page border-t border-hairline pt-12 sm:pt-14">
      <ul class="grid grid-cols-1 gap-x-8 gap-y-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          principles.map((p) => (
            <li class="flex min-w-0 flex-col gap-2 sm:[&:not(:first-child)]:border-l sm:[&:not(:first-child)]:border-hairline sm:[&:not(:first-child)]:pl-8">
              <span class="eyebrow">{p.label}</span>
              <span class="body-md font-medium text-ink">{p.title}</span>
              <span class="body-sm text-pretty text-mute">{p.body}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ─── 5 · WHY A HUB (the thesis sits below the catalog) ─── */}
  <section id="why" class="section-pad bg-canvas-soft">
    <div class="container-page">
      <div class="max-w-2xl">
        <span class="eyebrow">The Thesis</span>
        <h2 class="display-lg mt-4 text-balance text-ink">Why build a hub, not a single tool.</h2>
        <p class="body-lg mt-5 text-pretty text-body">
          One great utility is a side project. A canopy of them is a platform — each tool feeding
          the next with traffic, trust and reuse.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          whyCards.map((c) => (
            <Card class="flex h-full min-w-0 flex-col p-6 sm:p-8">
              <span class="eyebrow">{c.eyebrow}</span>
              <h3 class="display-sm mt-3 text-balance text-ink">{c.title}</h3>
              <p class="body-md mt-3 text-pretty text-body">{c.body}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  {/* ─────────────────────────── 6 · PRIVACY ─────────────────────────── */}
  <section id="privacy" class="section-pad bg-canvas" aria-labelledby="privacy-heading">
    <div class="container-page">
      <Card class="flex flex-col gap-6 p-8 sm:p-12 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">Privacy</span>
          <h2 id="privacy-heading" class="display-md mt-3 text-balance text-ink">
            Nothing you paste leaves your tab.
          </h2>
          <p class="body-md mt-4 text-pretty text-body">
            Every <span translate="no">OpsCanopy</span> tool runs as static JavaScript in your
            browser. There is no backend to receive your rules, configs or logs — no uploads, no
            telemetry on your inputs, no account to create. Close the tab and it&rsquo;s gone.
          </p>
        </div>
        <div class="shrink-0">
          <span class="badge">
            <span aria-hidden="true" class="size-1.5 rounded-full bg-cyan"></span>
            100%&nbsp;client-side
          </span>
        </div>
      </Card>
    </div>
  </section>

  {/* ─────────────────────────── 7 · FAQ ─────────────────────────── */}
  <FaqList faqs={faqs} />

  {/* ───────────────────────── 8 · FOOTER CTA ───────────────────────── */}
  <section class="section-pad bg-canvas-soft" aria-labelledby="closing-cta">
    <div class="container-page">
      <div class="flex flex-col items-center gap-6 text-center">
        <h2 id="closing-cta" class="display-xl max-w-3xl text-balance text-ink">
          Find your tool. Skip the install.
        </h2>
        <p class="body-lg max-w-xl text-pretty text-body">
          Free, private and instant. Open the catalog and put the right utility to work in your next deploy.
        </p>
        <div class="mt-2">
          <Button href="/tools" variant="primary">Find your tool — open the catalog</Button>
        </div>
      </div>
    </div>
  </section>
</Shell>
