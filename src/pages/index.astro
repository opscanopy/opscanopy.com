---
/**
 * OpsCanopy hub homepage — the flagship marketing surface.
 * Composes the Vercel-inspired design system defined in global.css / DESIGN.md.
 *
 * Component prop contracts (provided by sibling agents in src/components/*):
 *  - <MeshGradient class="…" />                          atmospheric hero backdrop
 *  - <Button href variant="primary|secondary" size? />   marketing pill CTA (label via slot)
 *  - <Card class? as?>…</Card>                            canvas card chrome (slot body)
 *  - <Badge variant?>…</Badge>                            inline status pill (label via slot)
 *  - <CodeBlock code lang? filename? />                   dark mono code surface
 */
import Shell from '../components/Shell.astro';
import MeshGradient from '../components/MeshGradient.astro';
import HeroDemo from '../components/home/HeroDemo.astro';
import TerminalPlay from '../components/TerminalPlay.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Badge from '../components/Badge.astro';
import CodeBlock from '../components/CodeBlock.astro';
import FaqList from '../components/FaqList.astro';
import JumpBackIn from '../components/JumpBackIn.astro';
import ToolArt from '../components/ToolArt.astro';
import TrackCard from '../components/learn/TrackCard.astro';
import { site } from '../data/site';
import { tools, liveTools, getTool, categoryAccent } from '../data/tools';
import { tracks } from '../data/learn';
import { program, phases as m90Phases, missions as m90Missions, totalCoreMinutes } from '../data/mission90';
import { trackIcon } from '../data/track-icons';
import { getGuidesForLocale, estimateReadingTime } from '../lib/learn/guides';
import { faqPageLd } from '../lib/jsonld';

const alertLint = liveTools[0] ?? tools[0];
// Featured lead-band tool — the most universally-recognized DevOps utility
// (every ops person subnets), not the niche flagship, so a first-time
// generalist visitor immediately sees something they'd actually use today.
const leadTool = getTool('subnet-calculator') ?? alertLint;

// Featured catalog grid — a CURATED set of 9 representative tools (one per major
// category, led by the AlertLint flagship) rather than a full mirror of /tools.
// Slugs are resolved from the registry so a rename surfaces as a dropped card,
// never a dead link; the "Browse all" link below uses liveTools.length so the
// count is always accurate. Accent hues are spread across categories for variety.
const featuredSlugs = [
  'loki-alert-rule-tester', // Observability (flagship)
  'github-actions-validator', // CI/CD
  'subnet-calculator', // Networking
  'jwt-decoder', // Security
  'docker-run-to-compose', // Docker
  'kubernetes-resource-calculator', // Kubernetes
  'cron-expression-tester', // Scheduling
  'base64-encoder-decoder', // Encoding
  'uuid-ulid-generator', // Utilities
];
const featuredTools = featuredSlugs
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t) && t!.status === 'live');

// Learn band — route the homepage's authority into /learn (it previously linked
// nowhere into the section). Feature the foundational tracks + the master roadmap.
const learnGuides = await getGuidesForLocale('en');
const learnByTrack = (slug: string) =>
  learnGuides.filter((g) => g.entry.data.track === slug).sort((x, y) => x.entry.data.order - y.entry.data.order);
const trackMeta = (slug: string) => {
  const gs = learnByTrack(slug);
  return {
    count: gs.length,
    minutes: gs.reduce((s, g) => s + (g.entry.data.estMinutes ?? estimateReadingTime(g.entry.body)), 0),
    difficulty: gs[0]?.entry.data.difficulty ?? 'beginner',
  };
};
const featuredTracks = tracks.filter((t) => ['linux', 'docker', 'kubernetes'].includes(t.slug));
const mission90Icon = trackIcon('mission-90');

// Mission-90 homepage feature band — every figure derived from the registry so
// the pitch can never drift out of sync as the program's content ships.
const m90LiveMissions = m90Missions.filter((m) => m.status === 'live').length;
const m90Hours = Math.round(totalCoreMinutes / 60 / 10) * 10;
const m90Stats = [
  { n: String(program.totalDays), l: 'days' },
  { n: String(m90Phases.length), l: 'phases' },
  { n: String(m90LiveMissions), l: 'browser missions' },
  { n: `~${m90Hours}`, l: 'hours core' },
];
// The week-1 "Server Down!" mission moment — the payoff, shown as a transcript.
const m90Transcript = `student@prod-web-01:~$ ps aux --sort=-%cpu | head -3
USER   PID   %CPU  COMMAND
root   4521  94.0  /opt/scripts/nightly-backup.sh
student@prod-web-01:~$ kill 4521
student@prod-web-01:~$ systemctl restart nginx
student@prod-web-01:~$ curl -sI localhost | head -1
HTTP/1.1 200 OK
# 02:07 — the site is back. You did that.`;

const faqs = [
  {
    q: 'Are OpsCanopy tools really free?',
    a: 'Yes. Every tool is completely free with no paywalls, usage limits, or premium tiers. There is no account requirement of any kind — open a tool in your browser and start using it immediately.',
  },
  {
    q: 'Do I need to sign up to use these online DevOps tools?',
    a: 'No. There is no signup, login, or email capture. Open any tool in your browser tab and use it immediately — no account, no cookie banner, no friction. Analytics runs cookieless unless you opt in on the privacy page.',
  },
  {
    q: 'Is my data uploaded to a server when I use the tools?',
    a: 'No. Every tool runs 100% client-side in your browser tab; nothing you paste is logged, stored, or uploaded. Your data never leaves the browser.',
  },
  {
    q: 'Is it safe to paste a JWT or config into a browser-based tool?',
    a: 'On OpsCanopy, yes. Decoding and parsing happen entirely in local JavaScript — nothing you paste is ever transmitted, which you can verify in the browser network tab (the only outbound traffic is anonymous, cookieless page analytics, disclosed in our privacy policy). As general hygiene, never share signing secrets with any third party, but OpsCanopy uploads none of your input.',
  },
  {
    q: 'Do the tools work offline?',
    a: 'Once a tool page has loaded, it keeps working even if you disconnect from the internet, because all processing is local and there is no backend to call. Going offline is also an easy way to verify the client-side privacy claim yourself.',
  },
  {
    q: 'Who are these browser-based DevOps tools for?',
    a: 'DevOps engineers, SREs, sysadmins, platform and backend engineers — anyone who needs quick subnet and CIDR math, cron schedules, PromQL or LogQL queries, JWT, Base64 and hash utilities, timestamp conversion, GitHub Actions validation, or Kubernetes resource sizing without installing anything.',
  },
  {
    q: 'Why use these instead of asking ChatGPT or Claude?',
    a: 'Use both — for different jobs. An AI assistant is excellent at explaining concepts and drafting configs, but it generates plausible text rather than computing answers, and exact arithmetic is a documented weak spot: subnet boundaries, cron schedules, epoch conversions and regex behaviour routinely come back looking right and being wrong. OpsCanopy tools compute answers deterministically — real parsers, exact math — and recompute instantly as you tweak the input, with no re-prompting, no token cost and no rate limits; once a tool page has loaded, it keeps working offline. Nothing you paste is ever transmitted, so logs, tokens and configs stay on your machine. Several tools even make handy AI checkers: run the same subnet, cron expression or timestamp through them and you get the ground truth to compare against.',
  },
  {
    q: 'How is OpsCanopy different from other online developer tool collections?',
    a: 'Most tool collections focus on generic formatters. OpsCanopy specialises in DevOps and SRE workflows — CIDR planning, cron, PromQL and LogQL, Kubernetes capacity, CI validators — with the same guarantees throughout: free, no signup, 100% client-side, nothing uploaded or logged.',
  },
  {
    q: 'I want to become a DevOps engineer — where do I start?',
    a: 'Start with OpsCanopy Learn at /learn. It pairs a staged DevOps career roadmap (/learn/roadmaps/devops) with free, hands-on guides covering Linux, Docker, Kubernetes, AWS and networking — going from the fundamentals to job-ready. As you read, you can practise immediately with the matching tools in the catalog, no signup required.',
  },
];

// Quietly-stated trust principles for the value strip.
const principles = [
  { label: 'PRICE', title: 'Free forever', body: 'Every tool, no paywall, no trial.', icon: '<path d="M3 11.4 11.4 3H19a2 2 0 0 1 2 2v7.6l-8.4 8.4a1.5 1.5 0 0 1-2.1 0L3 13.5a1.5 1.5 0 0 1 0-2.1Z"/><circle cx="15.8" cy="8.2" r="1.4"/>' },
  { label: 'RUNTIME', title: 'Runs in your browser', body: 'Pure client-side. Nothing to install.', icon: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 9h18"/><circle cx="6" cy="7" r="0.6" fill="currentColor"/>' },
  { label: 'PRIVACY', title: 'Your data stays local', body: 'Inputs never leave the device. Open code — audit it.', icon: '<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>' },
  { label: 'ACCESS', title: 'No signup', body: 'Open the page and start working.', icon: '<path d="M14 4h5a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1h-5"/><path d="M3 12h11m0 0-4-4m4 4-4 4"/>' },
];

// "Why a hub" value props — framed as what a returning user gets, not the
// business thesis behind building a catalog.
const whyCards = [
  {
    eyebrow: 'ONE PLACE',
    title: 'Everything in one tab.',
    body: "Bookmark one site instead of a dozen. When you need a converter, validator, or calculator, it's already here — same look, same shortcuts, no re-learning.",
    icon: '<path d="M3 20h18"/><path d="M6 20v-4M12 20V8M18 20v-9"/>',
  },
  {
    eyebrow: 'ALWAYS FAST',
    title: 'Instant, every time.',
    body: 'Every tool is static and client-side, so there are no server queues or cold starts to wait on — pages load instantly, whether you or ten thousand people hit them at once.',
    icon: '<path d="M13 3 5 13h6l-1 8 9-11h-6l1-7Z"/>',
  },
  {
    eyebrow: 'PRIVACY',
    title: 'Privacy is a feature.',
    body: 'Your rules, configs and logs are yours. Nothing is uploaded, logged or phoned home — the whole point of running it in your tab.',
    icon: '<path d="M12 3 5 6v5c0 4.6 3.1 8.2 7 10 3.9-1.8 7-5.4 7-10V6l-7-3Z"/>',
  },
];


const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: site.name,
    url: site.url,
    description: site.description,
    sameAs: [site.github, `https://x.com/${site.twitter.replace('@', '')}`],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: site.name,
    url: site.url,
    description: site.description,
    publisher: { '@type': 'Organization', name: site.name, url: site.url },
  },
  faqPageLd(faqs),
];
---

<Shell
  title="OpsCanopy — Free Online DevOps & SRE Tools, No Signup"
  description="Free online DevOps tools that run 100% in your browser — subnet/CIDR calculators, cron testers, JWT decoder & more. No signup, nothing uploaded."
  canonical="/"
  jsonLd={jsonLd}
>
  {/* ─────────────────────────── 1 · HERO ─────────────────────────── */}
  <section class="section-pad relative isolate overflow-hidden bg-canvas-soft">
    <MeshGradient class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[90%] opacity-90" />
    {/* Soft top sheen + bottom fade frame the mesh so it reads as ambient light,
        keeping crisp ink contrast under the headline. */}
    <div
      class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-32 bg-gradient-to-b from-canvas-soft to-transparent"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-48 bg-gradient-to-b from-transparent to-canvas-soft"
      aria-hidden="true"
    >
    </div>

    <div class="container-page relative z-10">
      <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[5fr_7fr] lg:gap-14">
        {/* Left — copy */}
        <div class="flex flex-col">
          {/* Differentiator strip — quiet, scannable, high-signal scale facts. */}
          <p class="eyebrow flex flex-wrap items-center gap-x-2 gap-y-1 text-mute">
            <span>{liveTools.length} tools</span>
            <span aria-hidden="true" class="text-hairline">&bull;</span>
            <span>100% client-side</span>
            <span aria-hidden="true" class="text-hairline">&bull;</span>
            <a
              href="https://github.com/opscanopy/opscanopy.com"
              target="_blank"
              rel="noopener noreferrer"
              class="underline decoration-hairline underline-offset-4 transition-colors hover:text-ink"
              >Open source</a
            >
          </p>

          <h1 class="display-hero mt-4 max-w-xl text-balance text-ink">
            A canopy of tools for the ops you actually do.
          </h1>

          <p class="body-md mt-4 max-w-xl text-pretty text-body">
            Validators, converters, testers and linters for DevOps and SRE engineers — subnet and
            CIDR math, cron, PromQL and LogQL, JWT and Kubernetes sizing. No sign-up, and nothing you
            paste leaves your device.
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3">
            <Button href="/tools/" variant="primary">Explore tools — no signup</Button>
            <a
              href="/learn/"
              class="link-inline group body-md inline-flex items-center gap-1 font-medium"
            >
              Learn DevOps
              <span
                aria-hidden="true"
                class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
              >
                &rarr;
              </span>
            </a>
          </div>
        </div>

        {/* Right — live instrument slab: a real subnet calculator, computed in
            the browser (build-time-seeded, so it also works with no JS). */}
        <div class="flex justify-center lg:justify-end">
          <HeroDemo />
        </div>
      </div>
    </div>
  </section>

  {/* ─────────────────── 1b · JUMP BACK IN (pinned/recent tools) ─────────────────── */}
  <JumpBackIn heading="Jump back in" />

  {/* ─── 3 · TOOLS PREVIEW (the catalog leads — MVP first) ─── */}
  <section class="section-pad-lg bg-canvas" aria-labelledby="tools-preview">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">The Catalog</span>
          <h2 id="tools-preview" class="display-lg mt-3 text-balance text-ink">Tools in the canopy.</h2>
          <p class="body-md mt-3 text-pretty text-body">
            Focused, single-purpose utilities for platform and DevOps engineers — every one live,
            free and running entirely in your browser.
          </p>
        </div>
        <a
          href="/tools/"
          class="link-inline group body-md inline-flex shrink-0 items-center gap-1 whitespace-nowrap font-medium"
        >
          See all tools
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>

      <ul class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          featuredTools.map((tool) => (
            <li class="h-full">
              <a
                href={`/${tool.slug}/`}
                class="card-interactive group relative flex h-full min-w-0 flex-col overflow-hidden rounded-lg bg-canvas shadow-soft"
              >
                <ToolArt
                  slug={tool.slug}
                  accent={categoryAccent[tool.category]}
                  class="border-b border-hairline"
                />
                <div class="flex h-full min-w-0 flex-col p-6 sm:p-7">
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="display-sm min-w-0 break-words text-ink" translate="no">
                      {tool.name}
                    </h3>
                    <Badge variant="live" class="shrink-0">Live</Badge>
                  </div>
                  <p class="caption mt-2 inline-flex items-center gap-1.5 font-medium uppercase tracking-wide text-body">
                    <span
                      aria-hidden="true"
                      class="size-1.5 rounded-full"
                      style={`background:${categoryAccent[tool.category]}`}
                    />
                    {tool.category}
                  </p>
                  <p class="body-md mt-4 flex-1 text-pretty text-body">{tool.tagline}</p>
                  <span class="body-sm mt-6 inline-flex items-center gap-1 font-medium text-link">
                    Open tool
                    <span
                      aria-hidden="true"
                      class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
                    >
                      &rarr;
                    </span>
                  </span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>

      <div class="mt-10 flex justify-center">
        <a
          href="/tools/"
          class="group inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-6 py-3 text-link shadow-soft transition-colors duration-150 ease-out hover:border-brand-strong"
        >
          <span class="body-md font-medium">Browse all {liveTools.length} tools</span>
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>
    </div>
  </section>

  {/* ─── 3b · MISSION 90 — the flagship guided program, its own moment ─── */}
  <section class="section-pad bg-canvas-soft" aria-labelledby="mission90-home">
    <div class="container-page">
      <div class="overflow-hidden rounded-xl bg-inverse text-inverse-fg shadow-float">
        <div class="grid grid-cols-1 gap-10 p-8 sm:p-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-14 lg:p-16">
          {/* Left — the pitch */}
          <div class="flex min-w-0 flex-col">
            <span
              class="grid size-12 place-items-center rounded-xl border border-brand/30 bg-brand/10 text-brand"
              aria-hidden="true"
            >
              <svg width="26" height="26" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={mission90Icon} />
            </span>
            <span class="eyebrow mt-5 text-brand">Mission · 90 Days · DevOps</span>
            <h2 id="mission90-home" class="display-lg mt-3 text-balance text-inverse-fg">
              From developer to DevOps engineer in 90 days.
            </h2>
            <p class="body-lg mt-5 max-w-xl text-pretty text-white/80">
              A free, guided path — one focused lesson a day, and a story-driven mission you
              play right in your browser terminal to fix a broken system at the end of every
              week. All 90 days and 10 missions are live now — no signup.
            </p>

            <dl class="mt-8 grid grid-cols-2 gap-x-6 gap-y-5 sm:grid-cols-4">
              {
                m90Stats.map((s) => (
                  <div class="flex flex-col gap-1 border-l border-white/15 pl-4">
                    <dt class="display-sm text-inverse-fg">{s.n}</dt>
                    <dd class="caption text-white/60">{s.l}</dd>
                  </div>
                ))
              }
            </dl>

            <div class="mt-9 flex flex-wrap items-center gap-x-6 gap-y-3">
              <Button href="/mission-90/" variant="secondary">Start Day 1 — free, no signup</Button>
              <a
                href="/mission-90/missions/"
                class="link-inline group body-md inline-flex items-center gap-1 font-medium text-white/85 hover:text-white"
              >
                Browse the missions
                <span
                  aria-hidden="true"
                  class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
                >
                  &rarr;
                </span>
              </a>
            </div>
          </div>

          {/* Right — a real mission transcript that types itself out on scroll:
              the week-1 "Server Down!" payoff. */}
          <div class="min-w-0">
            <TerminalPlay transcript={m90Transcript} title="mission: server-down" class="shadow-float" />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ─── 4 · LEARN DEVOPS (route homepage authority into /learn) ─── */}
  <section class="section-pad-lg bg-canvas-soft" aria-labelledby="learn-devops">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">Learn DevOps</span>
          <h2 id="learn-devops" class="display-lg mt-3 text-balance text-ink">
            Free roadmaps &amp; hands-on guides.
          </h2>
          <p class="body-md mt-3 text-pretty text-body">
            Go from the fundamentals to job-ready with staged career roadmaps and deep, practical
            guides — Linux, Docker, Kubernetes, AWS and networking. Free, no signup, and you can
            practise with the tools as you go.
          </p>
        </div>
        <a
          href="/learn/"
          class="link-inline group body-md inline-flex shrink-0 items-center gap-1 whitespace-nowrap font-medium"
        >
          Browse all guides
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>

      <div class="mt-8">
        <Button href="/learn/roadmaps/devops/" variant="primary">Start with the DevOps roadmap</Button>
      </div>

      <ul role="list" class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredTracks.map((track) => {
          const m = trackMeta(track.slug);
          return <TrackCard track={track} guideCount={m.count} difficulty={m.difficulty} minutes={m.minutes} />;
        })}
      </ul>
    </div>
  </section>

  {/* ───────────────────── 5 · VALUE / TRUST STRIP ───────────────────── */}
  <section class="section-pad-sm bg-canvas" aria-label="Why OpsCanopy is different">
    <div class="container-page border-t border-hairline pt-12 sm:pt-14">
      <ul class="grid grid-cols-1 gap-x-8 gap-y-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          principles.map((p) => (
            <li class="flex min-w-0 flex-col gap-2 sm:[&:not(:first-child)]:border-l sm:[&:not(:first-child)]:border-hairline sm:[&:not(:first-child)]:pl-8">
              <span class="mb-1 inline-flex size-9 items-center justify-center rounded-lg bg-brand/10 text-brand-strong">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={p.icon} />
              </span>
              <span class="eyebrow">{p.label}</span>
              <span class="body-md font-medium text-ink">{p.title}</span>
              <span class="body-sm text-pretty text-mute">{p.body}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ─── 6 · WHY A HUB (what you get, not our business thesis) ─── */}
  <section id="why" class="section-pad bg-canvas-soft">
    <div class="container-page">
      <div class="max-w-2xl">
        <span class="eyebrow">Why OpsCanopy</span>
        <h2 class="display-lg mt-4 text-balance text-ink">One toolbox, not twenty tabs.</h2>
        <p class="body-lg mt-5 text-pretty text-body">
          Every tool shares the same privacy guarantees, the same fast static pages, and one search
          box across all of it — so switching tasks doesn&rsquo;t mean switching trust levels.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          whyCards.map((c) => (
            <Card class="flex h-full min-w-0 flex-col p-6 sm:p-8">
              <span class="mb-4 inline-flex size-10 items-center justify-center rounded-lg bg-brand/10 text-brand-strong">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={c.icon} />
              </span>
              <span class="eyebrow">{c.eyebrow}</span>
              <h3 class="display-sm mt-3 text-balance text-ink">{c.title}</h3>
              <p class="body-md mt-3 text-pretty text-body">{c.body}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  {/* ─────────────────────────── 7 · PRIVACY ─────────────────────────── */}
  <section id="privacy" class="section-pad bg-canvas" aria-labelledby="privacy-heading">
    <div class="container-page">
      <Card class="flex flex-col gap-6 p-8 sm:p-12 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">Privacy</span>
          <h2 id="privacy-heading" class="display-md mt-3 text-balance text-ink">
            Nothing you paste leaves your tab.
          </h2>
          <p class="body-md mt-4 text-pretty text-body">
