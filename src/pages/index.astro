---
/**
 * OpsCanopy hub homepage — the flagship marketing surface.
 * Composes the Vercel-inspired design system defined in global.css / DESIGN.md.
 *
 * Component prop contracts (provided by sibling agents in src/components/*):
 *  - <MeshGradient class="…" />                          atmospheric hero backdrop
 *  - <Button href variant="primary|secondary" size? />   marketing pill CTA (label via slot)
 *  - <Card class? as?>…</Card>                            canvas card chrome (slot body)
 *  - <Badge variant?>…</Badge>                            inline status pill (label via slot)
 *  - <CodeBlock code lang? filename? />                   dark mono code surface
 *  - <Banner href>…</Banner>                              "Introducing X" announcement pill
 */
import Shell from '../components/Shell.astro';
import MeshGradient from '../components/MeshGradient.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Badge from '../components/Badge.astro';
import CodeBlock from '../components/CodeBlock.astro';
import Banner from '../components/Banner.astro';
import { site } from '../data/site';
import { tools, liveTools, plannedTools, accentEdgeClass } from '../data/tools';

const alertLint = liveTools[0] ?? tools[0];

// Quietly-stated trust principles for the value strip.
const principles = [
  { label: 'PRICE', title: 'Free forever', body: 'Every tool, no paywall, no trial.' },
  { label: 'RUNTIME', title: 'Runs in your browser', body: 'Pure client-side. Nothing to install.' },
  { label: 'PRIVACY', title: 'Your data stays local', body: 'Inputs never leave the device.' },
  { label: 'ACCESS', title: 'No signup', body: 'Open the page and start working.' },
];

// "Why a hub" value props, drawn from the strategy.
const whyCards = [
  {
    eyebrow: 'COMPOUNDING',
    title: 'A hub compounds.',
    body: 'Each focused, search-shaped tool earns its own keywords and links back to the rest. The catalog grows more discoverable with every release.',
  },
  {
    eyebrow: 'STATIC + CHEAP',
    title: 'Cheap to run, fast to load.',
    body: 'Everything is static and client-side, so there are no servers to scale and no bills to chase. Pages stay instant under any traffic.',
  },
  {
    eyebrow: 'PRIVACY',
    title: 'Privacy is a feature.',
    body: 'Your rules, configs and logs are yours. Nothing is uploaded, logged or phoned home — the whole point of running it in your tab.',
  },
];

// Loki rule + test snippet for the featured AlertLint band.
const alertLintSnippet = `# rules.yml — the Loki alert under test
groups:
  - name: ingest
    rules:
      - alert: HighErrorRate
        expr: |
          sum(rate({app="api"} |= "level=error" [5m])) > 10
        for: 2m

# tests.yml — assert it fires (and doesn't, when quiet)
tests:
  - name: fires when errors spike
    input:
      - logs: 'level=error'
        rate: 25/min
    expect: { alert: HighErrorRate, fires: true }
  - name: stays quiet under threshold
    input:
      - logs: 'level=error'
        rate: 3/min
    expect: { alert: HighErrorRate, fires: false }`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: site.name,
    url: site.url,
    description: site.description,
    sameAs: [site.github],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: site.name,
    url: site.url,
    description: site.description,
  },
];
---

<Shell
  title="OpsCanopy — Free, private DevOps tools for platform engineers"
  description={site.description}
  canonical="/"
  jsonLd={jsonLd}
>
  {/* ─────────────────────────── 1 · HERO ─────────────────────────── */}
  <section class="relative isolate overflow-hidden bg-canvas-soft">
    <MeshGradient class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[90%] opacity-90" />
    {/* Soft top sheen + bottom fade frame the mesh so it reads as ambient light,
        keeping crisp ink contrast under the headline. */}
    <div
      class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-32 bg-gradient-to-b from-canvas-soft to-transparent"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-48 bg-gradient-to-b from-transparent to-canvas-soft"
      aria-hidden="true"
    >
    </div>

    <div class="container-page relative z-10 flex flex-col items-center py-24 text-center sm:py-32 lg:py-40">
      <Banner href={`/${alertLint.slug}`}>
        <span class="eyebrow text-ink">New</span>
        <span class="text-body">
          Introducing <span translate="no">AlertLint</span> — unit testing for Loki alert rules.
        </span>
      </Banner>

      <h1 class="display-hero mt-8 max-w-4xl text-balance text-ink">
        A canopy of tools for the ops you actually do.
      </h1>

      <p class="body-lg mt-6 max-w-2xl text-pretty text-body">
        <span translate="no">OpsCanopy</span> is a growing hub of free, browser-based DevOps
        utilities — validators, converters, testers and linters that run entirely client-side. No
        signup, no servers, your data never leaves the device.
      </p>

      <div class="mt-10 flex flex-col items-center gap-3 sm:flex-row">
        <Button href="/tools" variant="primary">Browse Tools</Button>
        <Button href={`/${alertLint.slug}`} variant="secondary">Try <span translate="no">AlertLint</span></Button>
      </div>
    </div>
  </section>

  {/* ───────────────────── 2 · VALUE / TRUST STRIP ───────────────────── */}
  <section class="bg-canvas-soft" aria-label="Why OpsCanopy is different">
    <div class="container-page border-t border-hairline py-12 sm:py-14">
      <ul class="grid grid-cols-1 gap-x-8 gap-y-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          principles.map((p) => (
            <li class="flex min-w-0 flex-col gap-2 sm:[&:not(:first-child)]:border-l sm:[&:not(:first-child)]:border-hairline sm:[&:not(:first-child)]:pl-8">
              <span class="eyebrow">{p.label}</span>
              <span class="body-md font-medium text-ink">{p.title}</span>
              <span class="body-sm text-pretty text-mute">{p.body}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ─────────────────── 3 · FEATURED TOOL BAND (AlertLint) ─────────────────── */}
  <section class="bg-canvas-soft py-16 sm:py-24" aria-labelledby="featured-tool">
    <div class="container-page">
      <div
        class="overflow-hidden rounded-xl bg-primary text-on-primary shadow-float"
      >
        <div class="grid grid-cols-1 gap-10 p-8 sm:p-12 lg:grid-cols-2 lg:items-center lg:gap-12 lg:p-16">
          <div class="flex min-w-0 flex-col">
            <span class="eyebrow text-cyan">Tool&nbsp;01 · Observability</span>
            <h2 id="featured-tool" class="display-lg mt-4 text-balance text-on-primary">
              Test your Loki alerting rules before they fire in production.
            </h2>
            <p class="body-lg mt-5 max-w-xl text-pretty text-white/80">
              Paste your alerting and recording rules alongside synthetic log streams, then assert
              exactly what should — and shouldn&rsquo;t — fire. The <span translate="no">promtool</span>
              equivalent Loki never shipped, running entirely in your browser.
            </p>
            <div class="mt-8">
              <Button href={`/${alertLint.slug}`} variant="secondary">Open <span translate="no">AlertLint</span></Button>
            </div>
          </div>

          <div class="min-w-0 lg:pl-2">
            <CodeBlock
              code={alertLintSnippet}
              lang="yaml"
              filename="alertlint test ./tests"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ───────────────────────── 4 · WHY A HUB ───────────────────────── */}
  <section id="why" class="section-pad bg-canvas">
    <div class="container-page">
      <div class="max-w-2xl">
        <span class="eyebrow">The Thesis</span>
        <h2 class="display-lg mt-4 text-balance text-ink">Why build a hub, not a single tool.</h2>
        <p class="body-lg mt-5 text-pretty text-body">
          One great utility is a side project. A canopy of them is a platform — each tool feeding
          the next with traffic, trust and reuse.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 lg:grid-cols-3">
        {
          whyCards.map((c) => (
            <Card class="flex h-full min-w-0 flex-col p-6 sm:p-8">
              <span class="eyebrow">{c.eyebrow}</span>
              <h3 class="display-sm mt-3 text-balance text-ink">{c.title}</h3>
              <p class="body-md mt-3 text-pretty text-body">{c.body}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  {/* ─────────────────────── 5 · TOOLS PREVIEW ─────────────────────── */}
  <section class="section-pad bg-canvas-soft" aria-labelledby="tools-preview">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">The Catalog</span>
          <h2 id="tools-preview" class="display-lg mt-4 text-balance text-ink">Tools in the canopy.</h2>
          <p class="body-lg mt-5 text-pretty text-body">
            Focused, single-purpose utilities for platform and DevOps engineers. Live now, with
            more landing soon.
          </p>
        </div>
        <a
          href="/tools"
          class="link-inline group body-md inline-flex shrink-0 items-center gap-1 whitespace-nowrap font-medium"
        >
          See all tools
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>

      <ul class="mt-12 grid grid-cols-1 gap-6 lg:grid-cols-3">
        {
          tools.map((tool) => {
            const isLive = tool.status === 'live';
            const Wrapper = isLive ? 'a' : 'div';
            return (
              <li class="h-full">
                <Wrapper
                  href={isLive ? `/${tool.slug}` : undefined}
                  class:list={[
                    'group relative flex h-full min-w-0 flex-col overflow-hidden rounded-lg bg-canvas shadow-soft',
                    isLive ? 'card-interactive' : 'opacity-70',
                  ]}
                >
                  <span
                    aria-hidden="true"
                    class:list={[
                      'h-1 w-full bg-gradient-to-r',
                      accentEdgeClass[tool.accent],
                    ]}
                  />
                  <div class="flex h-full min-w-0 flex-col p-6 sm:p-7">
                    {!isLive && <span class="sr-only">Coming soon. </span>}
                    <div class="flex items-start justify-between gap-3">
                      <h3 class="display-sm min-w-0 break-words text-ink" translate="no">
                        {tool.name}
                      </h3>
                      {isLive ? (
                        <Badge variant="live" class="shrink-0">Live</Badge>
                      ) : (
                        <Badge variant="planned" class="shrink-0">Coming soon</Badge>
                      )}
                    </div>
                    <p class="caption mt-1 text-mute">{tool.category}</p>
                    <p class="body-md mt-4 flex-1 text-pretty text-body">{tool.tagline}</p>
                    {isLive ? (
                      <span class="body-sm mt-6 inline-flex items-center gap-1 font-medium text-link">
                        Open tool
                        <span
                          aria-hidden="true"
                          class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
                        >
                          &rarr;
                        </span>
                      </span>
                    ) : (
                      <span class="body-sm mt-6 inline-flex items-center gap-1.5 font-medium text-mute">
                        <span aria-hidden="true" class="size-1.5 rounded-full bg-hairline-strong"></span>
                        In&nbsp;the&nbsp;roadmap
                      </span>
                    )}
                  </div>
                </Wrapper>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>

  {/* ─────────────────────────── 6 · PRIVACY ─────────────────────────── */}
  <section id="privacy" class="section-pad bg-canvas" aria-labelledby="privacy-heading">
    <div class="container-page">
      <Card class="flex flex-col gap-6 p-8 sm:p-12 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">Privacy</span>
          <h2 id="privacy-heading" class="display-md mt-3 text-balance text-ink">
            Nothing you paste leaves your tab.
          </h2>
          <p class="body-md mt-4 text-pretty text-body">
            Every <span translate="no">OpsCanopy</span> tool runs as static JavaScript in your
            browser. There is no backend to receive your rules, configs or logs — no uploads, no
            telemetry on your inputs, no account to create. Close the tab and it&rsquo;s gone.
          </p>
        </div>
        <div class="shrink-0">
          <span class="badge">
            <span aria-hidden="true" class="size-1.5 rounded-full bg-cyan"></span>
            100%&nbsp;client-side
          </span>
        </div>
      </Card>
    </div>
  </section>

  {/* ───────────────────────── 7 · FOOTER CTA ───────────────────────── */}
  <section class="section-pad bg-canvas-soft" aria-labelledby="closing-cta">
    <div class="container-page">
      <div class="flex flex-col items-center gap-6 text-center">
        <h2 id="closing-cta" class="display-xl max-w-3xl text-balance text-ink">
          Find the tool. Skip the install.
        </h2>
        <p class="body-lg max-w-xl text-pretty text-body">
          Free, private and instant. Browse the canopy and put it to work in your next deploy.
        </p>
        <div class="mt-2">
          <Button href="/tools" variant="primary">Browse All Tools</Button>
        </div>
      </div>
    </div>
  </section>
</Shell>
