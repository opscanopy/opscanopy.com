---
/**
 * OpsCanopy hub homepage — the flagship marketing surface.
 * Composes the Vercel-inspired design system defined in global.css / DESIGN.md.
 * Structural mirror of src/pages/index.astro (English) — see that file for the
 * canonical section order; keep both in sync when the layout changes.
 *
 * Component prop contracts (provided by sibling agents in src/components/*):
 *  - <MeshGradient class="…" />                          atmospheric hero backdrop
 *  - <Button href variant="primary|secondary" size? />   marketing pill CTA (label via slot)
 *  - <Card class? as?>…</Card>                            canvas card chrome (slot body)
 *  - <Badge variant?>…</Badge>                            inline status pill (label via slot)
 *  - <CodeBlock code lang? filename? />                   dark mono code surface
 */
import Shell from '../../components/Shell.astro';
import MeshGradient from '../../components/MeshGradient.astro';
import HeroDemo from '../../components/home/HeroDemo.astro';
import TerminalPlay from '../../components/TerminalPlay.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import Badge from '../../components/Badge.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import FaqList from '../../components/FaqList.astro';
import JumpBackIn from '../../components/JumpBackIn.astro';
import ToolArt from '../../components/ToolArt.astro';
import TrackCard from '../../components/learn/TrackCard.astro';
import { site } from '../../data/site';
import { tools, liveTools, getTool, categoryAccent } from '../../data/tools';
import { tracks } from '../../data/learn';
import { program, phases as m90Phases, missions as m90Missions, totalCoreMinutes } from '../../data/mission90';
import { trackIcon } from '../../data/track-icons';
import { getGuidesForLocale, estimateReadingTime } from '../../lib/learn/guides';
import { faqPageLd } from '../../lib/jsonld';
import type { Locale as __Locale } from '../../i18n/config';
import { localizeKey as __l, localizeNavHref as __nav } from '../../i18n/utils';

const __lang = (Astro.currentLocale ?? 'en') as __Locale;

const alertLint = liveTools[0] ?? tools[0];
// Featured lead-band tool — mirrors the English homepage (see src/pages/index.astro):
// the universally-recognized subnet calculator, not the niche flagship.
const leadTool = getTool('subnet-calculator') ?? alertLint;

// Featured catalog grid — a CURATED set of 8 representative tools, mirrors English.
const featuredSlugs = [
  'loki-alert-rule-tester',
  'github-actions-validator',
  'subnet-calculator',
  'jwt-decoder',
  'docker-run-to-compose',
  'kubernetes-resource-calculator',
  'cron-expression-tester',
  'base64-encoder-decoder',
];
const featuredTools = featuredSlugs
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t) && t!.status === 'live');

// Learn band — /learn is English-only content (ENGLISH_ONLY_SECTIONS), so the
// guides themselves are fetched in English regardless of page locale.
const learnGuides = await getGuidesForLocale('en');
const learnByTrack = (slug: string) =>
  learnGuides.filter((g) => g.entry.data.track === slug).sort((x, y) => x.entry.data.order - y.entry.data.order);
const trackMeta = (slug: string) => {
  const gs = learnByTrack(slug);
  return {
    count: gs.length,
    minutes: gs.reduce((s, g) => s + (g.entry.data.estMinutes ?? estimateReadingTime(g.entry.body)), 0),
    difficulty: gs[0]?.entry.data.difficulty ?? 'beginner',
  };
};
const featuredTracks = tracks.filter((t) => ['linux', 'docker', 'kubernetes'].includes(t.slug));
const mission90Icon = trackIcon('mission-90');

// Mission-90 homepage feature band — figures derived from the registry, mirrors
// English. Mission-90 is also English-only content, so the transcript stays English.
const m90LiveMissions = m90Missions.filter((m) => m.status === 'live').length;
const m90Hours = Math.round(totalCoreMinutes / 60 / 10) * 10;
const m90Stats = [
  { n: String(program.totalDays), l: 'días' },
  { n: String(m90Phases.length), l: 'fases' },
  { n: String(m90LiveMissions), l: 'misiones en el navegador' },
  { n: `~${m90Hours}`, l: 'horas de contenido' },
];
const m90Transcript = `student@prod-web-01:~$ ps aux --sort=-%cpu | head -3
USER   PID   %CPU  COMMAND
root   4521  94.0  /opt/scripts/nightly-backup.sh
student@prod-web-01:~$ kill 4521
student@prod-web-01:~$ systemctl restart nginx
student@prod-web-01:~$ curl -sI localhost | head -1
HTTP/1.1 200 OK
# 02:07 — the site is back. You did that.`;

const faqs = [
  {
    q: '¿Las herramientas de OpsCanopy son realmente gratuitas?',
    a: 'Sí. Cada herramienta es completamente gratuita, sin muros de pago, límites de uso ni planes premium. No hay ningún requisito de cuenta de ningún tipo: abre una herramienta en tu navegador y empieza a usarla de inmediato.',
  },
  {
    q: '¿Necesito registrarme para usar estas herramientas DevOps en línea?',
    a: 'No. No hay registro, inicio de sesión ni captura de correo. Abre cualquier herramienta en una pestaña de tu navegador y úsala de inmediato: sin cuenta, sin banner de cookies, sin fricción. La analítica funciona sin cookies salvo que actives la opción en la página de privacidad.',
  },
  {
    q: '¿Mis datos se suben a un servidor cuando uso las herramientas?',
    a: 'No. Cada herramienta se ejecuta 100% del lado del cliente en la pestaña de tu navegador; nada de lo que pegas se registra, almacena ni sube. Tus datos nunca salen del navegador.',
  },
  {
    q: '¿Es seguro pegar un JWT o una configuración en una herramienta basada en navegador?',
    a: 'En OpsCanopy, sí. La decodificación y el análisis ocurren por completo en JavaScript local: nada de lo que pegas se transmite jamás, algo que puedes verificar tú mismo en la pestaña de red del navegador (el único tráfico saliente es una analítica de páginas anónima y sin cookies, descrita en nuestra política de privacidad). Como higiene general, nunca compartas secretos de firma con terceros, pero OpsCanopy no sube nada de lo que introduces.',
  },
  {
    q: '¿Las herramientas funcionan sin conexión?',
    a: 'Una vez que la página de una herramienta se ha cargado, sigue funcionando aunque te desconectes de internet, porque todo el procesamiento es local y no hay backend al que llamar. Desconectarte también es una forma fácil de verificar tú mismo la afirmación de privacidad del lado del cliente.',
  },
  {
    q: '¿Para quién son estas herramientas DevOps basadas en navegador?',
    a: 'Ingenieros DevOps, SRE, administradores de sistemas, ingenieros de plataforma y backend: cualquiera que necesite cálculos rápidos de subredes y CIDR, programaciones de cron, consultas PromQL o LogQL, utilidades de JWT, Base64 y hash, conversión de marcas de tiempo, validación de GitHub Actions o dimensionamiento de recursos de Kubernetes sin instalar nada.',
  },
  {
    q: '¿Por qué usar estas herramientas en lugar de preguntar a ChatGPT o Claude?',
    a: 'Usa ambos — para tareas distintas. Un asistente de IA es excelente explicando conceptos y redactando configuraciones, pero genera texto plausible en lugar de calcular respuestas, y la aritmética exacta es un punto débil documentado: los límites de subred, las programaciones de cron, las conversiones de época Unix y el comportamiento de las regex vuelven de forma habitual pareciendo correctos cuando en realidad están mal. Las herramientas de OpsCanopy calculan las respuestas de forma determinista — analizadores reales, matemática exacta — y recalculan al instante mientras ajustas la entrada, sin nuevos prompts, sin coste en tokens y sin límites de uso; una vez cargada la página de una herramienta, sigue funcionando sin conexión. Nada de lo que pegas se transmite jamás, así que los logs, tokens y configuraciones se quedan en tu máquina. Varias herramientas sirven incluso como prácticos verificadores de la IA: pasa por ellas la misma subred, expresión de cron o marca de tiempo y obtienes la verdad de referencia con la que comparar.',
  },
  {
    q: '¿En qué se diferencia OpsCanopy de otras colecciones de herramientas para desarrolladores en línea?',
    a: 'La mayoría de las colecciones de herramientas se centran en formateadores genéricos. OpsCanopy se especializa en flujos de trabajo DevOps y SRE: planificación de CIDR, cron, PromQL y LogQL, capacidad de Kubernetes, validadores de CI, con las mismas garantías en todo momento: gratis, sin registro, 100% del lado del cliente, sin subir ni registrar nada.',
  },
  {
    q: 'Quiero convertirme en ingeniero DevOps — ¿por dónde empiezo?',
    a: 'Empieza con OpsCanopy Learn en /learn. Combina una hoja de ruta profesional de DevOps por etapas (/learn/roadmaps/devops) con guías gratuitas y prácticas sobre Linux, Docker, Kubernetes, AWS y redes — yendo de los fundamentos a estar listo para el trabajo. Mientras lees, puedes practicar de inmediato con las herramientas correspondientes del catálogo, sin necesidad de registro.',
  },
];

// Quietly-stated trust principles for the value strip.
const principles = [
  { label: 'PRECIO', title: 'Gratis para siempre', body: 'Cada herramienta, sin muro de pago, sin prueba.', icon: '<path d="M3 11.4 11.4 3H19a2 2 0 0 1 2 2v7.6l-8.4 8.4a1.5 1.5 0 0 1-2.1 0L3 13.5a1.5 1.5 0 0 1 0-2.1Z"/><circle cx="15.8" cy="8.2" r="1.4"/>' },
  { label: 'EJECUCIÓN', title: 'Se ejecuta en tu navegador', body: 'Puro lado del cliente. Nada que instalar.', icon: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 9h18"/><circle cx="6" cy="7" r="0.6" fill="currentColor"/>' },
  { label: 'PRIVACIDAD', title: 'Tus datos se quedan en local', body: 'Las entradas nunca salen del dispositivo. Código abierto — audítalo.', icon: '<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>' },
  { label: 'ACCESO', title: 'Sin registro', body: 'Abre la página y empieza a trabajar.', icon: '<path d="M14 4h5a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1h-5"/><path d="M3 12h11m0 0-4-4m4 4-4 4"/>' },
];

// "Why a hub" value props, mirrors English.
const whyCards = [
  {
    eyebrow: 'UN SOLO LUGAR',
    title: 'Todo en una pestaña.',
    body: 'Guarda un solo marcador en lugar de una docena. Cuando necesites un conversor, un validador o una calculadora, ya está aquí: misma apariencia, mismos atajos, nada nuevo que aprender.',
    icon: '<path d="M3 20h18"/><path d="M6 20v-4M12 20V8M18 20v-9"/>',
  },
  {
    eyebrow: 'SIEMPRE RÁPIDO',
    title: 'Instantáneo, siempre.',
    body: 'Cada herramienta es estática y se ejecuta en el cliente, así que no hay colas de servidor ni arranques en frío que esperar: las páginas cargan al instante, tanto si entras tú como diez mil personas a la vez.',
    icon: '<path d="M13 3 5 13h6l-1 8 9-11h-6l1-7Z"/>',
  },
  {
    eyebrow: 'PRIVACIDAD',
    title: 'La privacidad es una característica.',
    body: 'Tus reglas, configuraciones y registros son tuyos. Nada se sube, se registra ni se envía a casa: ese es justamente el sentido de ejecutarlo en tu pestaña.',
    icon: '<path d="M12 3 5 6v5c0 4.6 3.1 8.2 7 10 3.9-1.8 7-5.4 7-10V6l-7-3Z"/>',
  },
];

// CIDR breakdown snippet for the featured lead band (Subnet Calculator).
const leadToolSnippet = `> 10.20.0.0/22

Network address     10.20.0.0
Broadcast address    10.20.3.255
Netmask               255.255.252.0
Wildcard mask         0.0.3.255
Usable host range     10.20.0.1 – 10.20.3.254
Usable hosts          1,022
Total addresses       1,024`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: site.name,
    url: site.url,
    description: site.description,
    sameAs: [site.github, `https://x.com/${site.twitter.replace('@', '')}`],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: site.name,
    url: site.url,
    description: site.description,
    publisher: { '@type': 'Organization', name: site.name, url: site.url },
  },
  faqPageLd(faqs),
];
---

<Shell
  title="OpsCanopy — Herramientas DevOps y SRE en línea, gratis y sin registro"
  description="Herramientas DevOps en línea gratuitas que se ejecutan 100% en tu navegador: calculadoras de subred/CIDR, probadores de cron, decodificador de JWT y más. Sin registro, sin subir nada."
  canonical="/"
  jsonLd={jsonLd}
>
  {/* ─────────────────────────── 1 · HERO ─────────────────────────── */}
  <section class="section-pad relative isolate overflow-hidden bg-canvas-soft">
    <MeshGradient class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[90%] opacity-90" />
    <div
      class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-32 bg-gradient-to-b from-canvas-soft to-transparent"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-48 bg-gradient-to-b from-transparent to-canvas-soft"
      aria-hidden="true"
    >
    </div>

    <div class="container-page relative z-10">
      <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[5fr_7fr] lg:gap-14">
        <div class="flex flex-col">
      <p class="eyebrow flex flex-wrap items-center gap-x-2 gap-y-1 text-mute">
        <span>{liveTools.length} herramientas</span>
        <span aria-hidden="true" class="text-hairline">&bull;</span>
        <span>100% del lado del cliente</span>
        <span aria-hidden="true" class="text-hairline">&bull;</span>
        <a
          href="https://github.com/opscanopy/opscanopy.com"
          target="_blank"
          rel="noopener noreferrer"
          class="underline decoration-hairline underline-offset-4 transition-colors hover:text-ink"
          >Código abierto</a
        >
      </p>

      <h1 class="display-hero mt-4 max-w-xl text-balance text-ink">
        Un dosel de herramientas para las operaciones que de verdad haces.
      </h1>

      <p class="body-md mt-4 max-w-xl text-pretty text-body">
        Validadores, conversores, probadores y linters para ingenieros DevOps y SRE — cálculos de
        subred y CIDR, cron, PromQL y LogQL, JWT y dimensionamiento de Kubernetes. Sin registro, y
        nada de lo que pegues sale de tu dispositivo.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3">
        <Button href={__l('/tools', __lang)} variant="primary">Explorar herramientas — sin registro</Button>
        <a
          href={__nav('/learn', __lang)}
          class="link-inline group body-md inline-flex items-center gap-1 font-medium"
        >
          Aprender DevOps
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>
        </div>

        <div class="flex justify-center lg:justify-end">
          <HeroDemo />
        </div>
      </div>
    </div>
  </section>

  {/* ─────────────────── 1b · JUMP BACK IN (pinned/recent tools) ─────────────────── */}
  <JumpBackIn heading="Continúa donde lo dejaste" lang="es" />

  {/* ─────────────────── 2 · FEATURED TOOL BAND (Subnet Calculator) ─────────────────── */}
  <section class="section-pad bg-canvas-soft" aria-labelledby="featured-tool">
    <div class="container-page">
      <div class="overflow-hidden rounded-xl bg-inverse text-inverse-fg shadow-float">
        <div class="grid grid-cols-1 gap-10 p-8 sm:p-12 lg:grid-cols-2 lg:items-center lg:gap-12 lg:p-16">
          <div class="flex min-w-0 flex-col">
            <span class="eyebrow text-cyan">Herramienta&nbsp;01 · Redes</span>
            <h2 id="featured-tool" class="display-lg mt-4 text-balance text-inverse-fg">
              Cálculo de subredes en un solo pegado: se acabó contar bits a mano.
            </h2>
            <p class="body-lg mt-5 max-w-xl text-pretty text-white/80">
              Introduce cualquier dirección IPv4 o IPv6 con su prefijo y obtén la dirección de red y de
              difusión, la máscara, la wildcard, el rango de hosts utilizables y el recuento de
              direcciones: al instante y por completo en tu navegador.
            </p>
            <div class="mt-8">
              <Button href={__l(`/${leadTool.slug}`, __lang)} variant="secondary">Abrir <span translate="no">Subnet Calculator</span></Button>
            </div>
          </div>

          <div class="min-w-0 lg:pl-2">
            <CodeBlock
              code={leadToolSnippet}
              lang="text"
              filename="subnet-calculator"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ─── 3 · TOOLS PREVIEW (the catalog leads — MVP first) ─── */}
  <section class="section-pad-lg bg-canvas" aria-labelledby="tools-preview">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">El catálogo</span>
          <h2 id="tools-preview" class="display-lg mt-3 text-balance text-ink">Herramientas en el dosel.</h2>
          <p class="body-md mt-3 text-pretty text-body">
            Utilidades enfocadas y de propósito único para ingenieros de plataforma y DevOps: cada una
            en vivo, gratuita y ejecutándose por completo en tu navegador.
          </p>
        </div>
        <a
          href={__l('/tools', __lang)}
          class="link-inline group body-md inline-flex shrink-0 items-center gap-1 whitespace-nowrap font-medium"
        >
          Ver todas las herramientas
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>

      <ul class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          featuredTools.map((tool) => (
            <li class="h-full">
              <a
                href={__l(`/${tool.slug}`, __lang)}
                class="card-interactive group relative flex h-full min-w-0 flex-col overflow-hidden rounded-lg bg-canvas shadow-soft"
              >
                <ToolArt
                  slug={tool.slug}
                  accent={categoryAccent[tool.category]}
                  class="border-b border-hairline"
                />
                <div class="flex h-full min-w-0 flex-col p-6 sm:p-7">
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="display-sm min-w-0 break-words text-ink" translate="no">
                      {tool.name}
                    </h3>
                    <Badge variant="live" class="shrink-0">En vivo</Badge>
                  </div>
                  <p class="caption mt-2 inline-flex items-center gap-1.5 font-medium uppercase tracking-wide text-body">
                    <span
                      aria-hidden="true"
                      class="size-1.5 rounded-full"
                      style={`background:${categoryAccent[tool.category]}`}
                    />
                    {tool.category}
                  </p>
                  <p class="body-md mt-4 flex-1 text-pretty text-body">{tool.tagline}</p>
                  <span class="body-sm mt-6 inline-flex items-center gap-1 font-medium text-link">
                    Abrir herramienta
                    <span
                      aria-hidden="true"
                      class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
                    >
                      &rarr;
                    </span>
                  </span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>

      <div class="mt-10 flex justify-center">
        <a
          href={__l('/tools', __lang)}
          class="group inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-6 py-3 text-link shadow-soft transition-colors duration-150 ease-out hover:border-brand-strong"
        >
          <span class="body-md font-medium">Explorar las {liveTools.length} herramientas</span>
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>
    </div>
  </section>

  {/* ─── 3b · MISSION 90 — the flagship guided program, its own moment ─── */}
  <section class="section-pad bg-canvas-soft" aria-labelledby="mission90-home">
    <div class="container-page">
      <div class="overflow-hidden rounded-xl bg-inverse text-inverse-fg shadow-float">
        <div class="grid grid-cols-1 gap-10 p-8 sm:p-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-14 lg:p-16">
          <div class="flex min-w-0 flex-col">
            <span
              class="grid size-12 place-items-center rounded-xl border border-brand/30 bg-brand/10 text-brand"
              aria-hidden="true"
            >
              <svg width="26" height="26" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={mission90Icon} />
            </span>
            <span class="eyebrow mt-5 text-brand">Mission · 90 Days · DevOps</span>
            <h2 id="mission90-home" class="display-lg mt-3 text-balance text-inverse-fg">
              De desarrollador a ingeniero DevOps en 90 días.
            </h2>
            <p class="body-lg mt-5 max-w-xl text-pretty text-white/80">
              Un camino gratuito y guiado: una lección enfocada al día, y al final de cada semana una
              misión narrativa que juegas directamente en la terminal de tu navegador para arreglar un
              sistema roto. Los 90 días y las 10 misiones ya están disponibles — sin registro.
            </p>

            <dl class="mt-8 grid grid-cols-2 gap-x-6 gap-y-5 sm:grid-cols-4">
              {
                m90Stats.map((s) => (
                  <div class="flex flex-col gap-1 border-l border-white/15 pl-4">
                    <dt class="display-sm text-inverse-fg">{s.n}</dt>
                    <dd class="caption text-white/60">{s.l}</dd>
                  </div>
                ))
              }
            </dl>

            <div class="mt-9 flex flex-wrap items-center gap-x-6 gap-y-3">
              <Button href={__nav('/mission-90', __lang)} variant="secondary">Empezar el día 1 — gratis, sin registro</Button>
              <a
                href={__nav('/mission-90/missions', __lang)}
                class="link-inline group body-md inline-flex items-center gap-1 font-medium text-white/85 hover:text-white"
              >
                Explorar las misiones
                <span
                  aria-hidden="true"
                  class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
                >
                  &rarr;
                </span>
              </a>
            </div>
          </div>

          <div class="min-w-0">
            <TerminalPlay transcript={m90Transcript} title="mission: server-down" class="shadow-float" />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ─── 4 · LEARN DEVOPS (route homepage authority into /learn) ─── */}
  <section class="section-pad-lg bg-canvas-soft" aria-labelledby="learn-devops">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">Learn DevOps</span>
          <h2 id="learn-devops" class="display-lg mt-3 text-balance text-ink">
            Hojas de ruta y guías prácticas gratuitas.
          </h2>
          <p class="body-md mt-3 text-pretty text-body">
            Ve de los fundamentos a estar listo para el trabajo con hojas de ruta profesionales por
            etapas y guías extensas y prácticas — Linux, Docker, Kubernetes, AWS y redes. Gratis, sin
            registro, y puedes practicar con las herramientas mientras avanzas.
          </p>
        </div>
        <a
          href={__nav('/learn', __lang)}
          class="link-inline group body-md inline-flex shrink-0 items-center gap-1 whitespace-nowrap font-medium"
        >
          Ver todas las guías
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>

      <div class="mt-8">
        <Button href={__nav('/learn/roadmaps/devops', __lang)} variant="primary">Empezar con la hoja de ruta de DevOps</Button>
      </div>

      <ul role="list" class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredTracks.map((track) => {
          const m = trackMeta(track.slug);
          return <TrackCard track={track} guideCount={m.count} difficulty={m.difficulty} minutes={m.minutes} />;
        })}
      </ul>
    </div>
  </section>

  {/* ───────────────────── 5 · VALUE / TRUST STRIP ───────────────────── */}
  <section class="section-pad-sm bg-canvas" aria-label="Por qué OpsCanopy es diferente">
    <div class="container-page border-t border-hairline pt-12 sm:pt-14">
      <ul class="grid grid-cols-1 gap-x-8 gap-y-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          principles.map((p) => (
            <li class="flex min-w-0 flex-col gap-2 sm:[&:not(:first-child)]:border-l sm:[&:not(:first-child)]:border-hairline sm:[&:not(:first-child)]:pl-8">
              <span class="mb-1 inline-flex size-9 items-center justify-center rounded-lg bg-brand/10 text-brand-strong">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={p.icon} />
              </span>
              <span class="eyebrow">{p.label}</span>
              <span class="body-md font-medium text-ink">{p.title}</span>
              <span class="body-sm text-pretty text-mute">{p.body}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ─── 6 · WHY A HUB (what you get, not our business thesis) ─── */}
  <section id="why" class="section-pad bg-canvas-soft">
    <div class="container-page">
      <div class="max-w-2xl">
        <span class="eyebrow">Por qué OpsCanopy</span>
        <h2 class="display-lg mt-4 text-balance text-ink">Una caja de herramientas, no veinte pestañas.</h2>
        <p class="body-lg mt-5 text-pretty text-body">
          Todas las herramientas comparten las mismas garantías de privacidad, las mismas páginas
          estáticas veloces y un único buscador para todo: cambiar de tarea no significa cambiar de
          nivel de confianza.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          whyCards.map((c) => (
            <Card class="flex h-full min-w-0 flex-col p-6 sm:p-8">
              <span class="mb-4 inline-flex size-10 items-center justify-center rounded-lg bg-brand/10 text-brand-strong">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={c.icon} />
              </span>
              <span class="eyebrow">{c.eyebrow}</span>
              <h3 class="display-sm mt-3 text-balance text-ink">{c.title}</h3>
              <p class="body-md mt-3 text-pretty text-body">{c.body}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  {/* ─────────────────────────── 7 · PRIVACY ─────────────────────────── */}
  <section id="privacy" class="section-pad bg-canvas" aria-labelledby="privacy-heading">
    <div class="container-page">
      <Card class="flex flex-col gap-6 p-8 sm:p-12 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">Privacidad</span>
          <h2 id="privacy-heading" class="display-md mt-3 text-balance text-ink">
            Nada de lo que pegas sale de tu pestaña.
          </h2>
          <p class="body-md mt-4 text-pretty text-body">
            Cada herramienta de <span translate="no">OpsCanopy</span> se ejecuta como JavaScript estático en tu
            navegador. No hay backend que reciba tus reglas, configuraciones o registros: sin subidas, sin
            telemetría sobre tus entradas, sin cuenta que crear. Cierra la pestaña y desaparece.
          </p>
        </div>
        <div class="shrink-0">
          <span class="badge">
            <span aria-hidden="true" class="size-1.5 rounded-full bg-cyan"></span>
            100%&nbsp;client-side
          </span>
        </div>
      </Card>
    </div>
  </section>

  {/* ─────────────────────────── 8 · FAQ ─────────────────────────── */}
  <FaqList faqs={faqs} />

  {/* ───────────────────────── 9 · FOOTER CTA ───────────────────────── */}
  <section class="section-pad bg-canvas-soft" aria-labelledby="closing-cta">
    <div class="container-page">
      <div class="flex flex-col items-center gap-6 text-center">
        <h2 id="closing-cta" class="display-xl max-w-3xl text-balance text-ink">
          Encuentra tu herramienta. Sáltate la instalación.
        </h2>
        <p class="body-lg max-w-xl text-pretty text-body">
          Gratis, privada e instantánea. Abre el catálogo y pon la herramienta adecuada a trabajar en
          tu próximo despliegue.
        </p>
        <div class="mt-2">
          <Button href={__l('/tools', __lang)} variant="primary">Encontrar herramienta — abrir el catálogo</Button>
        </div>
      </div>
    </div>
  </section>
</Shell>
