---
/**
 * chmod Calculator — the chmod-calculator tool page (SEO surface).
 * Convert Unix file permissions between octal (755), symbolic (rwxr-xr-x) and a
 * read/write/execute checkbox matrix — including setuid, setgid and the sticky
 * bit — and copy the exact chmod command. Pure client-side bit math.
 */
import Shell from '../components/Shell.astro';
import ChmodCalculatorPlayground from '../components/ChmodCalculatorPlayground.astro';
import Button from '../components/Button.astro';
import CodeBlock from '../components/CodeBlock.astro';
import ToolHero from '../components/ToolHero.astro';
import ToolPipeline from '../components/ToolPipeline.astro';
import FaqList from '../components/FaqList.astro';
import ToolCrossLinks from '../components/ToolCrossLinks.astro';
import { site, navLinks } from '../data/site';
import { getTool } from '../data/tools';
import { softwareAppLd, faqPageLd } from '../lib/jsonld';

const tool = getTool('chmod-calculator');
const pagePath = '/chmod-calculator/';
const pageUrl = `${site.url}${pagePath}`;

const faqs = [
  {
    q: 'What does chmod 755 mean?',
    a: 'chmod 755 sets read, write and execute for the owner (7 = 4+2+1) and read plus execute — but not write — for the group and everyone else (5 = 4+0+1). Symbolically it is rwxr-xr-x. It is the usual mode for directories and executables: the owner can change the contents while everyone else can only read and run them.',
  },
  {
    q: 'What is the difference between octal and symbolic permissions?',
    a: 'They describe the same nine permission bits two ways. Octal packs each read/write/execute triad into one digit 0–7 (rwx = 7, r-x = 5, rw- = 6), so 644 means rw-r--r--. Symbolic spells the bits out as three groups of rwx for owner, group and other. This calculator keeps both — plus the checkbox matrix — in sync, so editing any one updates the rest instantly.',
  },
  {
    q: 'When do I use a 4-digit chmod value like 4755?',
    a: 'The optional leading digit carries the special bits: 4 = setuid, 2 = setgid, 1 = sticky (they add, so 6 = setuid+setgid). You only need the fourth digit when one of those is set — 4755 is setuid + rwxr-xr-x. When the special digit is zero the conventional form drops it, so 0755 is written simply as 755.',
  },
  {
    q: 'What do setuid, setgid and the sticky bit do?',
    a: 'setuid (4000) makes an executable run as its owner rather than the caller; setgid (2000) runs it as its group, or on a directory makes new files inherit that directory\u2019s group. The sticky bit (1000) on a shared directory like /tmp lets users delete only their own files. In symbolic mode they appear in the execute slots as s/S (setuid/setgid) and t/T (sticky) — uppercase when the underlying execute bit is off.',
  },
  {
    q: 'What does the s or t in rwsr-xr-x mean?',
    a: 'A lowercase s in the owner or group execute slot means that special bit is set and execute is also on (setuid or setgid). An uppercase S means the special bit is set but execute is off — often a mistake. Likewise t in the other-execute slot is the sticky bit with execute on, and T is sticky with execute off. This tool renders all of them exactly as ls -l would.',
  },
  {
    q: 'How do I read an ls -l permission string?',
    a: 'The first character is the file type (- for a regular file, d for a directory, l for a symlink); the next nine are the owner, group and other rwx triads. Paste a full 10-character string like -rwxr-xr-x into the symbolic field and the calculator strips the type character and shows the octal and chmod command.',
  },
  {
    q: 'Does anything I type get uploaded?',
    a: 'No. The conversion is pure bit math running 100% in your browser — there is no server, no account and no logging. The permission values you enter never leave your device.',
  },
  {
    q: 'Can I share a specific permission value?',
    a: 'Yes. Every valid value updates the URL with an #m= fragment (for example #m=755), and the Copy link button copies that full URL. Open it later or send it to a teammate and the calculator restores that exact mode.',
  },
];

const softwareApp = softwareAppLd({
  name: 'chmod Calculator',
  description:
    'Free chmod calculator. Convert Unix file permissions between octal (755), symbolic (rwxr-xr-x) and a read/write/execute matrix — including setuid, setgid and the sticky bit — and copy the exact chmod command. 100% in-browser, no signup.',
  url: pageUrl,
  subCategory: 'Utilities',
  featureList: [
    'Two-way conversion between octal, symbolic and the permission matrix',
    'setuid, setgid and sticky-bit support (s/S and t/T)',
    'Copyable ls -l string and exact chmod command',
    '100% client-side, no upload, no signup',
  ],
  keywords: tool?.keywords.join(', '),
});
const faqPage = faqPageLd(faqs);

const pipeline = [
  {
    title: 'Read the nine permission bits.',
    body: 'Owner, group and other each get a read / write / execute triad — nine bits in all, plus three special bits (setuid, setgid, sticky).',
  },
  {
    title: 'Pack each triad into a digit.',
    body: 'rwx = 4+2+1 = 7, r-x = 5, rw- = 6. Three triads become three octal digits; a set special bit adds a leading fourth digit.',
  },
  {
    title: 'Spell it out symbolically.',
    body: 'The same bits render as rwxr-xr-x, with s/S in the execute slots for setuid/setgid and t/T for the sticky bit — exactly as ls -l shows them.',
  },
  {
    title: 'Emit the command.',
    body: 'Drop the octal into chmod <mode> <file> and copy it. Every field stays in sync, so edit any one and the rest follow.',
  },
];

const octalTable = `octal  bits  symbolic   meaning
0      ---   ---        no access
1      --x   --x        execute only
2      -w-   -w-        write only
4      r--   r--        read only
5      r-x   r-x        read + execute
6      rw-   rw-        read + write
7      rwx   rwx        read + write + execute`;

const specialTable = `high digit   bit      symbolic slot     example
4            setuid   owner exec (s/S)  4755  rwsr-xr-x
2            setgid   group exec (s/S)  2755  rwxr-sr-x
1            sticky   other exec (t/T)  1777  rwxrwxrwt

exec OFF -> uppercase:  4644 rwSr--r--  ·  1666 rw-rw-rwT`;
---

<Shell
  title="chmod Calculator — Octal, Symbolic & Permission Matrix"
  description="Free chmod calculator. Convert Unix file permissions between octal (755), symbolic (rwxr-xr-x) and a read/write/execute matrix — including setuid, setgid and the sticky bit — and copy the exact chmod command. 100% in-browser, no signup."
  canonical="/chmod-calculator"
  jsonLd={[softwareApp, faqPage]}
>
  <ToolHero
    slug="chmod-calculator"
    eyebrow="chmod Calculator · Utilities"
    badges={[
      { label: 'Runs in your browser', variant: 'live' },
      { label: 'Octal & symbolic', variant: 'neutral' },
      { label: 'No signup', variant: 'neutral' },
    ]}
  >
    <Fragment slot="headline">Toggle bits, read the chmod command instantly.</Fragment>
    <Fragment slot="lead">
      Check the read / write / execute matrix or type an octal
      (<span class="code-mono text-ink" translate="no">755</span>) or symbolic
      (<span class="code-mono text-ink" translate="no">rwxr-xr-x</span>) value — including setuid,
      setgid and the sticky bit. Every field stays in sync and the
      <span class="code-mono text-ink" translate="no">chmod</span> command is ready to copy, all in
      your browser.
    </Fragment>
  </ToolHero>

  <section id="playground" class="scroll-mt-24 bg-canvas-soft pt-8 pb-20 sm:pb-24">
    <div class="container-page">
      <h2 class="sr-only">chmod calculator playground</h2>
      <ChmodCalculatorPlayground />
    </div>
  </section>

  <section id="why" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
        <div>
          <p class="eyebrow">The Gap</p>
          <h2 class="display-lg mt-3 text-balance text-ink">
            One wrong digit, a world-writable file.
          </h2>
        </div>
        <div class="space-y-4">
          <p class="body-md text-pretty text-body">
            chmod looks simple until the numbers bite. Is
            <span class="code-mono text-ink" translate="no">644</span> or
            <span class="code-mono text-ink" translate="no">664</span> the safe one? Does
            <span class="code-mono text-ink" translate="no">777</span> really mean what you think?
            Fat-finger a digit and you either lock yourself out or leave a file writable by everyone
            on the box.
          </p>
          <p class="body-md text-pretty text-body">
            This free chmod calculator shows the octal value, the
            <span class="code-mono text-ink" translate="no">rwxr-xr-x</span> string, the
            <span class="code-mono text-ink" translate="no">ls -l</span> form and the exact
            <span class="code-mono text-ink" translate="no">chmod</span> command side by side —
            including setuid, setgid and the sticky bit. Toggle a checkbox, type a value or paste an
            <span class="code-mono text-ink" translate="no">ls -l</span> line; every field updates
            together so you confirm the mode before you run it.
          </p>
          <p class="body-md text-pretty text-body">
            It is pure bit math in your browser — no server, no account, nothing uploaded. Share a
            specific mode with a
            <span class="code-mono text-ink" translate="no">#m=755</span> deep link and it reopens
            exactly as you left it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ToolPipeline
    id="how-it-works"
    eyebrow="The Pipeline"
    heading="How it works."
    lead="Four deterministic steps turn the permission matrix into an octal value, a symbolic string and a ready-to-run command — all inside your browser tab."
    steps={pipeline}
  />

  <section id="reference" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Permission Reference</p>
        <h2 class="display-lg mt-3 text-ink">Octal &harr; symbolic.</h2>
        <p class="body-md mx-auto mt-3 max-w-xl text-pretty text-body">
          Each octal digit encodes one read / write / execute triad; the optional leading digit
          carries the special bits. These two tables are the whole mapping.
        </p>
      </div>
      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-2">
        <div class="min-w-0">
          <h3 class="display-sm text-ink">The per-digit triad</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            One digit <span class="code-mono text-ink" translate="no">0</span>&ndash;<span
              class="code-mono text-ink"
              translate="no">7</span
            > per owner / group / other group.
          </p>
          <CodeBlock lang="text" filename="octal-to-symbolic" code={octalTable} />
        </div>
        <div class="min-w-0">
          <h3 class="display-sm text-ink">The special bits</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            setuid / setgid / sticky ride the leading digit and show as
            <span class="code-mono text-ink" translate="no">s</span>/<span
              class="code-mono text-ink"
              translate="no">S</span
            > and <span class="code-mono text-ink" translate="no">t</span>/<span
              class="code-mono text-ink"
              translate="no">T</span
            >.
          </p>
          <CodeBlock lang="text" filename="special-bits" code={specialTable} />
        </div>
      </div>
    </div>
  </section>

  <section id="next" class="scroll-mt-24 bg-inverse text-inverse-fg">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
        <div class="min-w-0">
          <p class="eyebrow !text-cyan">Next Step</p>
          <h2 class="display-lg mt-3 text-balance text-inverse-fg">
            Reshape identifiers and text the same way.
          </h2>
          <p class="body-md mt-4 text-pretty text-white/70">
            The chmod calculator is one of a set of pure, in-browser utilities. Generate
            <span translate="no">UUIDs</span> and <span translate="no">ULIDs</span>, convert a
            string between <span translate="no">camelCase</span> and
            <span translate="no">snake_case</span>, or turn a title into a clean URL slug — no
            server, no signup.
          </p>
          <div class="mt-7 flex flex-wrap items-center gap-3">
            <Button href="/uuid-ulid-generator/" variant="secondary">Open the UUID / ULID Generator</Button>
            <Button href="/case-converter/" variant="secondary">Open the Case Converter</Button>
          </div>
        </div>
        <CodeBlock
          lang="text"
          filename="chmod.sh"
          code={`chmod 755 deploy.sh   #  rwxr-xr-x
chmod 644 config.yml   #  rw-r--r--
chmod 4755 /usr/bin/x  #  setuid, rwsr-xr-x
chmod 1777 /tmp        #  sticky, rwxrwxrwt`}
        />
      </div>
    </div>
  </section>

  <FaqList faqs={faqs} />

  <ToolCrossLinks slug="chmod-calculator">
    <Fragment slot="lead">
      The chmod Calculator is one tool in
      <span translate="no">{site.name}</span> — a growing canopy of browser-based validators,
      converters and testers that never touch a server.
    </Fragment>
    <Fragment slot="links">
      Related utilities: the
      <a class="link-inline" href="/uuid-ulid-generator/">UUID / ULID Generator</a>, the
      <a class="link-inline" href="/case-converter/">Case Converter</a> and the
      <a class="link-inline" href="/slugify/">Slugify</a> tool, or the
      <a class="link-inline" href="/cve-ignore-converter/">CVE Ignore Converter</a> — or browse the
      full <a class="link-inline" href={`${navLinks[0].href}/`}>tools directory</a>.
    </Fragment>
    <Fragment slot="disclaimer">
      Provided as-is for convenience; always double-check permission changes on production systems.
      <span translate="no">{site.name}</span> is free and open.
    </Fragment>
  </ToolCrossLinks>
</Shell>
