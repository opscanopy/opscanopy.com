---
/**
 * Timestamp Converter — the timestamp-converter tool page (SEO surface).
 * Paste a Unix epoch (seconds / ms / µs) or a date string and get every
 * representation back — UTC, local, ISO 8601 and relative time — entirely
 * in the browser.
 */
import Shell from '../components/Shell.astro';
import TimestampConverterPlayground from '../components/TimestampConverterPlayground.astro';
import TimestampVerifyPanel from '../components/TimestampVerifyPanel.astro';
import Button from '../components/Button.astro';
import CodeBlock from '../components/CodeBlock.astro';
import ToolHero from '../components/ToolHero.astro';
import ToolGapVisual from '../components/ToolGapVisual.astro';
import ToolPipeline from '../components/ToolPipeline.astro';
import FaqList from '../components/FaqList.astro';
import ToolCrossLinks from '../components/ToolCrossLinks.astro';
import { site, navLinks } from '../data/site';
import { getTool } from '../data/tools';
import { softwareAppLd, faqPageLd } from '../lib/jsonld';

const tool = getTool('timestamp-converter');
const pagePath = '/timestamp-converter/';
const pageUrl = `${site.url}${pagePath}`;

const faqs = [
  {
    q: 'What is Unix time?',
    a: 'Unix time — also called epoch time or POSIX time — is the number of seconds that have elapsed since the Unix epoch, 1970-01-01 00:00:00 UTC, not counting leap seconds. It is the most common way computers store an instant: a single integer, timezone-free, that every system can agree on. This converter turns that integer into a human-readable date and back again.',
  },
  {
    q: 'Seconds, milliseconds or microseconds — how do I tell them apart?',
    a: 'By length. A present-day epoch in seconds is 10 digits, in milliseconds 13 digits, and in microseconds 16 digits (nanoseconds reach 19). The converter detects the unit from the magnitude of the number — so 1700000000 is read as seconds and 1700000000000 as milliseconds — and you can override the guess if your data uses a different unit.',
  },
  {
    q: 'Does my timestamp ever leave my browser?',
    a: 'No. Parsing, the epoch maths and all the formatting run 100% client-side in your tab — there is no server, no account and no logging. You can safely paste timestamps from internal logs and private systems.',
  },
  {
    q: 'How does it handle time zones and daylight saving?',
    a: 'An epoch is an absolute instant, so the underlying moment never changes — only how it is rendered. The converter always shows the canonical UTC value alongside your browser local time, and the local rendering reflects your machine\'s time zone and its daylight-saving rules at that instant via the built-in Intl APIs. Switch machines or zones and the UTC line stays put while the local line shifts.',
  },
  {
    q: 'What is ISO 8601 and why does it matter?',
    a: 'ISO 8601 is the international standard for writing dates and times as text — for example 2024-01-15T09:30:00Z, where the trailing Z means UTC. It sorts lexicographically, is unambiguous about order (year-month-day), and is what JSON APIs, logs and databases overwhelmingly expect. The converter emits a strict ISO 8601 string so you can paste it straight into a payload or query.',
  },
  {
    q: 'How do I convert an ISO 8601 date to a Unix timestamp?',
    a: 'Paste an ISO 8601 string such as 2026-06-11T00:00:00Z into the input and the converter returns the matching epoch value in both seconds and milliseconds. The format follows YYYY-MM-DDTHH:mm:ssZ where Z denotes UTC; offsets such as +05:30 are also accepted. Conversion is bidirectional, so you can go from epoch to ISO 8601 or from ISO 8601 back to epoch.',
  },
  {
    q: 'How do I convert a 13-digit millisecond timestamp to a date?',
    a: 'Paste the 13-digit value directly and the converter recognises it as a milliseconds epoch automatically. Internally it divides by 1000 to get the underlying second and then formats the result as UTC, local time, ISO 8601 and a relative phrase. This matches the value produced by JavaScript Date.now() and Java System.currentTimeMillis().',
  },
  {
    q: 'What is the current unix timestamp right now?',
    a: 'The current Unix timestamp is the number of seconds that have elapsed since 1 January 1970 UTC at this exact moment. The converter displays the live value in both seconds and milliseconds, updated in real time in your browser. Most server-side APIs and SQL databases work in seconds, while JavaScript and browser analytics code typically use milliseconds.',
  },
  {
    q: 'How do I convert a date back to an epoch timestamp?',
    a: 'Enter any human-readable or ISO 8601 date string and the converter returns the corresponding Unix epoch value in seconds and milliseconds. Inputs such as 2024-01-15T09:30:00Z and similar formats are all accepted. The result is ready to paste into an API call, a database query, or a JWT claim.',
  },
];

const softwareApp = softwareAppLd({
  name: 'Timestamp Converter',
  description:
    'Free Unix timestamp converter. Convert epoch to date, ISO 8601 and milliseconds across UTC and local time. 100% in-browser, no signup, data stays on your device.',
  url: pageUrl,
  subCategory: 'Encoding',
  featureList: [
    'Convert a Unix epoch to human, ISO 8601 and local time',
    'Auto-detect seconds, milliseconds and microseconds',
    'Parse a date string back into an epoch',
    '100% client-side, no upload, no signup',
  ],
  keywords: tool?.keywords.join(', '),
});
const faqPage = faqPageLd(faqs);

const pipeline = [
  {
    title: 'Detect the input.',
    body: 'The value is read as an epoch in seconds, milliseconds or microseconds — guessed from its length — or as a date string.',
  },
  {
    title: 'Build the instant.',
    body: 'Whatever you typed is normalised to one absolute moment: milliseconds since the Unix epoch, timezone-free.',
  },
  {
    title: 'Render every form.',
    body: 'That instant becomes UTC, ISO 8601, the raw epoch in each unit, and the readable date and time.',
  },
  {
    title: 'Show relative & local.',
    body: 'Finally it adds your browser-local time and a human relative phrase like “3 hours ago”.',
  },
];

const cheatSheet = `unit            length   example              note
seconds         10       1700000000           classic Unix epoch
milliseconds    13       1700000000000        JS Date.now(), Java
microseconds    16       1700000000000000     Postgres, some traces
nanoseconds     19       1700000000000000000  Go time, perf counters`;

const dateExamples = `1700000000            →  2023-11-14T22:13:20Z
2023-11-14T22:13:20Z  →  1700000000  (seconds)
2023-11-14 22:13:20   →  parsed as local time
Nov 14 2023 22:13 UTC →  1700000000
now                   →  current instant`;
---

<Shell
  title="Timestamp Converter — Unix Timestamp & Epoch to Date"
  description="Free Unix timestamp converter. Convert epoch to date, ISO 8601 and milliseconds across UTC and local time. 100% in-browser, no signup, data stays local."
  canonical="/timestamp-converter"
  jsonLd={[softwareApp, faqPage]}
>
  <ToolHero
    slug="timestamp-converter"
    eyebrow="Timestamp Converter · Encoding"
    badges={[
      { label: 'Runs in your browser', variant: 'live' },
      { label: 'UTC & local', variant: 'neutral' },
      { label: 'No signup', variant: 'neutral' },
    ]}
  >
    <Fragment slot="headline">Turn a Unix epoch into time you can read — and back.</Fragment>
    <Fragment slot="lead">
      Paste a Unix timestamp like
      <span class="code-mono text-ink" translate="no">1700000000</span> or a date string to convert
      epoch time to a human-readable date — UTC, ISO 8601, local and relative time at once, all in
      your browser, across seconds, milliseconds and microseconds.
    </Fragment>
  </ToolHero>

  <section id="playground" class="scroll-mt-24 bg-canvas-soft pt-8 pb-20 sm:pb-24">
    <div class="container-page">
      <h2 class="sr-only">Timestamp Converter playground</h2>
      <TimestampConverterPlayground />
      <TimestampVerifyPanel />
    </div>
  </section>

  <section id="why" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
        <div>
          <p class="eyebrow">The Gap</p>
          <h2 class="display-lg mt-3 text-balance text-ink">
            A bare integer in a log is nobody’s idea of a time.
          </h2>
          <ToolGapVisual />
        </div>
        <div class="space-y-4">
          <p class="body-md text-pretty text-body">
            Epoch timestamps are everywhere — log lines, API payloads, database rows, JWT
            <span class="code-mono text-ink" translate="no">exp</span> claims — and every one of
            them is just a number until you decode it. Worse, the unit is rarely labelled: is
            <span class="code-mono text-ink" translate="no">1700000000</span> seconds or has someone
            already multiplied by a thousand? Guess wrong and you are reading a date in 1970 or the
            year 56000.
          </p>
          <p class="body-md text-pretty text-body">
            This converter takes the integer or date string and gives you the concrete facts: the
            Unix timestamp to UTC mapping, a strict ISO 8601 string, your own local time, and how
            long ago it was — with the seconds vs milliseconds unit auto-detected so you never have
            to guess. Entirely in the browser, with nothing to install.
          </p>
          <p class="body-md text-pretty text-body">
            It’s also a safer path than asking an AI: language models tokenize long numbers and
            quietly lose place value, so epoch conversions come back off by an hour, a day, or a
            factor of a thousand — and still look right. This converter does the arithmetic exactly,
            every time.
          </p>
          <p class="body-sm text-mute">
            Pulling timestamps out of a token? The
            <a class="link-inline" href="/jwt-decoder/">JWT Decoder</a> reads
            <span class="code-mono text-ink" translate="no">iat</span> and
            <span class="code-mono text-ink" translate="no">exp</span> for you.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ToolPipeline
    id="how-it-works"
    eyebrow="The Pipeline"
    heading="How it works."
    lead="Four deterministic steps run on every keystroke — all inside your browser tab, with no clock sent to a server."
    steps={pipeline}
  />

  <section id="reference" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Epoch Reference</p>
        <h2 class="display-lg mt-3 text-ink">Which unit is that number?</h2>
        <p class="body-md mx-auto mt-3 max-w-xl text-pretty text-body">
          For present-day timestamps the digit count gives the unit away. A quick cheat-sheet of
          epoch lengths, and the date forms the converter accepts.
        </p>
      </div>
      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-2">
        <div class="min-w-0">
          <h3 class="display-sm text-ink">Epoch lengths</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            Each step up multiplies by a thousand — so
            <span class="code-mono text-ink" translate="no">10</span> digits is seconds,
            <span class="code-mono text-ink" translate="no">13</span> is milliseconds,
            <span class="code-mono text-ink" translate="no">16</span> is microseconds.
          </p>
          <CodeBlock lang="text" filename="epoch-lengths" code={cheatSheet} />
        </div>
        <div class="min-w-0">
          <h3 class="display-sm text-ink">Date examples</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            Feed it an epoch or a date string — ISO 8601, a plain date-time, or even
            <span class="code-mono text-ink" translate="no">now</span> — and it resolves the same
            instant either way.
          </p>
          <CodeBlock lang="text" filename="date-examples" code={dateExamples} />
        </div>
      </div>
    </div>
  </section>

  <section id="next" class="scroll-mt-24 bg-inverse text-inverse-fg">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
        <div class="min-w-0">
          <p class="eyebrow !text-cyan">Next Step</p>
          <h2 class="display-lg mt-3 text-balance text-inverse-fg">
            Found that timestamp inside a token or a blob?
          </h2>
          <p class="body-md mt-4 text-pretty text-white/70">
            Epoch values rarely travel alone. If yours came out of a JSON Web Token, the
            <span translate="no">JWT Decoder</span> reads the
            <span class="code-mono" translate="no">iat</span> and
            <span class="code-mono" translate="no">exp</span> claims for you; if it was buried in an
            encoded payload, the <span translate="no">Base64 Encoder / Decoder</span> turns the blob
            back into readable text first.
          </p>
          <div class="mt-7 flex flex-wrap items-center gap-3">
            <Button href="/jwt-decoder/" variant="secondary">Open the JWT Decoder</Button>
            <Button href="/base64-encoder-decoder/" variant="secondary">
              Open the Base64 tool
            </Button>
          </div>
        </div>
        <CodeBlock
          lang="text"
          filename="jwt-claims.txt"
          code={`"iat": 1700000000   →  2023-11-14T22:13:20Z
"exp": 1700003600   →  2023-11-14T23:13:20Z
                       expires in 1 hour`}
        />
      </div>
    </div>
  </section>

  <FaqList faqs={faqs} />

  <ToolCrossLinks slug="timestamp-converter">
    <Fragment slot="lead">
      The Timestamp Converter is one tool in
      <span translate="no">{site.name}</span> — a growing canopy of browser-based validators,
      converters and testers that never touch a server.
    </Fragment>
    <Fragment slot="links">
      More encoding: the
      <a class="link-inline" href="/jwt-decoder/">JWT Decoder</a> and the
      <a class="link-inline" href="/base64-encoder-decoder/">Base64 Encoder / Decoder</a>, or browse
      the full <a class="link-inline" href={`${navLinks[0].href}/`}>tools directory</a>.
    </Fragment>
    <Fragment slot="disclaimer">
      Provided as-is for convenience; always confirm critical time-sensitive values against an
      authoritative clock. <span translate="no">{site.name}</span> is free and open.
    </Fragment>
  </ToolCrossLinks>
</Shell>
