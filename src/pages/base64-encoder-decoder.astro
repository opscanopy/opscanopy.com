---
/**
 * Base64 Encoder / Decoder — the base64-encoder-decoder tool page (SEO surface).
 * Encode text to Base64 and decode it back, with the URL-safe (base64url)
 * variant and padding controls — entirely in the browser.
 */
import Shell from '../components/Shell.astro';
import Base64Playground from '../components/Base64Playground.astro';
import Button from '../components/Button.astro';
import CodeBlock from '../components/CodeBlock.astro';
import ToolHero from '../components/ToolHero.astro';
import ToolGapVisual from '../components/ToolGapVisual.astro';
import ToolPipeline from '../components/ToolPipeline.astro';
import FaqList from '../components/FaqList.astro';
import ToolCrossLinks from '../components/ToolCrossLinks.astro';
import { site, navLinks } from '../data/site';
import { getTool } from '../data/tools';
import { softwareAppLd, faqPageLd } from '../lib/jsonld';

const tool = getTool('base64-encoder-decoder');
const pagePath = '/base64-encoder-decoder/';
const pageUrl = `${site.url}${pagePath}`;

const faqs = [
  {
    q: 'What is Base64?',
    a: 'Base64 is a binary-to-text encoding that represents arbitrary bytes using just 64 printable ASCII characters (A–Z, a–z, 0–9 and two symbols). It takes three bytes (24 bits) at a time and splits them into four 6-bit groups, each mapped to one character. The result is roughly a third larger than the input but safe to drop into JSON, URLs, email or HTML where raw bytes would be mangled.',
  },
  {
    q: 'What is the difference between standard Base64 and URL-safe Base64?',
    a: 'They share the first 62 characters (A–Z, a–z, 0–9). Standard Base64 uses + and / for the last two and pads the output with = to a multiple of four. URL-safe Base64 (base64url, RFC 4648 §5) swaps those to - and _ so the value survives inside a URL or filename without percent-encoding, and the = padding is usually dropped. Toggle the variant here and the output updates live.',
  },
  {
    q: 'Is Base64 encryption? Does it secure my data?',
    a: 'No. Base64 is an encoding, not encryption — there is no key and anyone can decode it instantly. It only changes how bytes are represented so they travel safely through text-only channels. Never use Base64 to hide secrets; reach for real encryption or hashing if you need confidentiality or integrity.',
  },
  {
    q: 'Does my text ever leave my browser?',
    a: 'No. Encoding and decoding run 100% client-side in your tab — there is no server, no account and no logging. You can safely paste tokens, config snippets or private data; it never travels over the network.',
  },
  {
    q: 'How is non-ASCII text handled?',
    a: 'Text is first read as UTF-8 bytes before encoding, so emoji, accents and any Unicode character round-trip correctly — unlike the raw btoa() function, which only handles Latin-1. Decoding reverses the steps: Base64 back to bytes, then those bytes back to text as UTF-8.',
  },
  {
    q: 'What is Base64 encoding used for?',
    a: 'Base64 converts binary data into ASCII text so it can travel safely over text-only channels. Common uses include email attachments (MIME), embedding images in HTML or CSS as data URIs, encoding the three segments of a JWT, SSL certificates in PEM format, and SAML assertions. Anywhere a protocol or format only allows printable ASCII, Base64 is how binary gets through.',
  },
  {
    q: 'Why is my Base64-encoded output larger than the original data?',
    a: 'Base64 maps every 3 bytes of input to 4 ASCII characters, so the encoded output is about 33% larger than the source. If the input length is not a multiple of three, one or two = padding characters are appended to align the output to a 4-character boundary. For example, 3 bytes encode to 4 characters; 4 bytes encode to 8 characters including one = pad.',
  },
  {
    q: 'How do I decode a Base64 string back to a file or image?',
    a: 'Decode the Base64 to recover the raw bytes, then save them with the correct file extension. For images embedded in HTML data URIs, strip the data:image/...;base64, prefix first, then paste the remaining string into the decoder to get the binary content. This tool decodes any valid Base64 or base64url string to text — for downloading binary files directly, you would need a dedicated file-handling tool.',
  },
];

const softwareApp = softwareAppLd({
  name: 'Base64 Encoder / Decoder',
  description:
    'Free Base64 encoder and decoder. Encode and decode Base64 and URL-safe Base64 online with full UTF-8 support. 100% in-browser, no signup, data never leaves your device.',
  url: pageUrl,
  subCategory: 'Encoding',
  featureList: [
    'Encode text to Base64 and decode Base64 back to text',
    'Standard and URL-safe (base64url) alphabets',
    'Optional padding, with full UTF-8 support',
    '100% client-side, no upload, no signup',
  ],
  keywords: tool?.keywords.join(', '),
});
const faqPage = faqPageLd(faqs);

const pipeline = [
  {
    title: 'Read the text as bytes.',
    body: 'Your input is encoded to UTF-8 first, so emoji and accents become the exact bytes Base64 will carry.',
  },
  {
    title: 'Map to the alphabet.',
    body: 'Bytes are grouped 24 bits at a time and split into four 6-bit values, each mapped to a Base64 character.',
  },
  {
    title: 'Choose the variant.',
    body: 'Standard uses + and / with = padding; URL-safe swaps to - and _ and can drop the padding entirely.',
  },
  {
    title: 'Decode back to text.',
    body: 'Reverse the steps — Base64 to bytes, then bytes back to UTF-8 — to recover the original string exactly.',
  },
];

const alphabetTable = `index  std  url      index  std  url
0–25   A–Z  A–Z      62     +    -
26–51  a–z  a–z      63     /    _
52–61  0–9  0–9      pad    =    (omitted)`;

const variantExample = `text     ">>>"   (UTF-8 bytes)

standard Pj4+            ·  uses + / and = padding
url-safe Pj4-            ·  + -> - , / -> _ , no =

text     ">>>?"

standard Pj4+Pw==        ·  '+\' and trailing \'=='
url-safe Pj4-Pw          ·  '-' , padding dropped`;
---

<Shell
  title="Base64 Encoder / Decoder — Free Online, In-Browser"
  description="Free Base64 encoder and decoder. Encode and decode Base64 and URL-safe Base64 online with full UTF-8 support. 100% in-browser, no signup, data stays local."
  canonical="/base64-encoder-decoder"
  jsonLd={[softwareApp, faqPage]}
>
  <ToolHero
    slug="base64-encoder-decoder"
    eyebrow="Base64 Encoder / Decoder · Encoding"
    badges={[
      { label: 'Runs in your browser', variant: 'live' },
      { label: 'Standard & URL-safe', variant: 'neutral' },
      { label: 'No signup', variant: 'neutral' },
    ]}
  >
    <Fragment slot="headline">Encode and decode Base64, the right way.</Fragment>
    <Fragment slot="lead">
      Turn any text into Base64 or read it back — with the
      <span class="code-mono text-ink" translate="no">base64url</span> variant and padding controls,
      full UTF-8 support, and everything running client-side in your browser. Free, no signup, and
      your data never leaves your device.
    </Fragment>
  </ToolHero>

  <section id="playground" class="scroll-mt-24 bg-canvas-soft pt-8 pb-20 sm:pb-24">
    <div class="container-page">
      <h2 class="sr-only">Base64 encoder and decoder playground</h2>
      <Base64Playground />
    </div>
  </section>

  <section id="why" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
        <div>
          <p class="eyebrow">The Gap</p>
          <h2 class="display-lg mt-3 text-balance text-ink">
            The wrong alphabet, a quietly broken token.
          </h2>
          <ToolGapVisual />
        </div>
        <div class="space-y-4">
          <p class="body-md text-pretty text-body">
            Base64 looks trivial until a value travels somewhere text rules. Use the standard
            alphabet inside a URL and the
            <span class="code-mono text-ink" translate="no">+</span> and
            <span class="code-mono text-ink" translate="no">/</span> get percent-mangled; forget that
            JWTs are <span class="code-mono text-ink" translate="no">base64url</span> with no padding
            and your decoder chokes on the very token you need to read.
          </p>
          <p class="body-md text-pretty text-body">
            This free Base64 encoder and decoder shows both alphabets side by side, lets you toggle
            padding, and reads your text as UTF-8 so Unicode round-trips cleanly — so you can
            confirm exactly what a value decodes to before it lands in a request, a config or a
            header. Entirely in the browser, with nothing to install and no data ever leaving your
            device.
          </p>
          <p class="body-sm text-mute">
            Decoding a JWT? The
            <a class="link-inline" href="/jwt-decoder/">JWT Decoder</a> splits and base64url-decodes the
            three parts for you.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ToolPipeline
    id="how-it-works"
    eyebrow="The Pipeline"
    heading="How it works."
    lead="Four deterministic steps run on every keystroke — all inside your browser tab, with UTF-8 read before the bytes are mapped."
    steps={pipeline}
  />

  <section id="reference" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Alphabet Reference</p>
        <h2 class="display-lg mt-3 text-ink">Standard vs URL-safe.</h2>
        <p class="body-md mx-auto mt-3 max-w-xl text-pretty text-body">
          Both variants share 62 characters and differ only on the last two and on padding. That one
          difference is what keeps a value intact inside a URL or filename.
        </p>
      </div>
      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-2">
        <div class="min-w-0">
          <h3 class="display-sm text-ink">The two alphabets</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            Index <span class="code-mono text-ink" translate="no">62</span> and
            <span class="code-mono text-ink" translate="no">63</span> change, and URL-safe usually
            omits the <span class="code-mono text-ink" translate="no">=</span> padding.
          </p>
          <CodeBlock lang="text" filename="base64-alphabets" code={alphabetTable} />
        </div>
        <div class="min-w-0">
          <h3 class="display-sm text-ink">Where it matters</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            The same bytes encode identically until a
            <span class="code-mono text-ink" translate="no">+</span>,
            <span class="code-mono text-ink" translate="no">/</span> or
            <span class="code-mono text-ink" translate="no">=</span> appears — then the variants
            diverge.
          </p>
          <CodeBlock lang="text" filename="standard-vs-url-safe" code={variantExample} />
        </div>
      </div>
    </div>
  </section>

  <section id="next" class="scroll-mt-24 bg-inverse text-inverse-fg">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
        <div class="min-w-0">
          <p class="eyebrow !text-cyan">Next Step</p>
          <h2 class="display-lg mt-3 text-balance text-inverse-fg">
            That token is base64url — decode the whole JWT.
          </h2>
          <p class="body-md mt-4 text-pretty text-white/70">
            A JWT is three <span translate="no">base64url</span> segments joined by dots. The
            <span translate="no">JWT Decoder</span> splits them, decodes the header and payload, and
            shows the claims — or, if you just need a digest, the
            <span translate="no">Hash Generator</span> computes SHA-256 and friends, all in your
            browser.
          </p>
          <div class="mt-7 flex flex-wrap items-center gap-3">
            <Button href="/jwt-decoder/" variant="secondary">Open the JWT Decoder</Button>
            <Button href="/hash-generator/" variant="secondary">Open the Hash Generator</Button>
          </div>
        </div>
        <CodeBlock
          lang="text"
          filename="jwt.txt"
          code={`eyJhbGciOiJIUzI1NiJ9   ←  header  (base64url)
.eyJzdWIiOiIxMjM0In0   ←  payload (base64url)
.dBjftJeZ4CVP-mB92K   ←  signature`}
        />
      </div>
    </div>
  </section>

  <FaqList faqs={faqs} />

  <ToolCrossLinks slug="base64-encoder-decoder">
    <Fragment slot="lead">
      The Base64 Encoder / Decoder is one tool in
      <span translate="no">{site.name}</span> — a growing canopy of browser-based validators,
      converters and testers that never touch a server.
    </Fragment>
    <Fragment slot="links">
      Related encoding tools: the
      <a class="link-inline" href="/jwt-decoder/">JWT Decoder</a>, the
      <a class="link-inline" href="/hash-generator/">Hash Generator</a> and the
      <a class="link-inline" href="/timestamp-converter/">Timestamp Converter</a>, or browse the full
      <a class="link-inline" href={navLinks[0].href}>tools directory</a>.
    </Fragment>
    <Fragment slot="disclaimer">
      Provided as-is for convenience; Base64 is an encoding, not encryption — never use it to protect
      secrets. <span translate="no">{site.name}</span> is free and open.
    </Fragment>
  </ToolCrossLinks>
</Shell>
