---
/**
 * AlertLint — the AlertLint tool page (primary SEO surface).
 * "promtool for Loki" — paste Loki ruler YAML + a promtool-modeled test file,
 * assert pass/fail, entirely in the browser. No server, no signup.
 *
 * Imports the interactive island (AlertLintPlayground, self-mounting) plus the
 * brand primitives. JSON-LD (SoftwareApplication + FAQPage) is assembled in
 * frontmatter and handed to Shell via the `jsonLd` prop.
 */
import Shell from '../../components/Shell.astro';
import AlertLintPlayground from '../../components/AlertLintPlayground.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ToolHero from '../../components/ToolHero.astro';
import ToolGapVisual from '../../components/ToolGapVisual.astro';
import ToolPipeline from '../../components/ToolPipeline.astro';
import FaqList from '../../components/FaqList.astro';
import ToolCrossLinks from '../../components/ToolCrossLinks.astro';
import { site, navLinks } from '../../data/site';
import { getTool } from '../../data/tools';
import { softwareAppLd, faqPageLd } from '../../lib/jsonld';

const tool = getTool('loki-alert-rule-tester');

const pagePath = '/loki-alert-rule-tester/';
const pageUrl = `${site.url}${pagePath}`;

// ── Loki issue references (the "why it exists" gap) ──────────────────────────
const lokiIssue7655 = 'https://github.com/grafana/loki/issues/7655';
const lokiIssue16659 = 'https://github.com/grafana/loki/issues/16659';

// ── FAQ content — single source for both the rendered section and FAQPage LD ─
const faqs = [
  {
    q: 'Was ist AlertLint?',
    a: 'AlertLint ist ein kostenloser, browserbasierter Unit-Tester für Alerting- und Recording-Regeln von Grafana Loki. Sie fügen Ihr Loki-Ruler-YAML sowie eine promtool-modellierte Testdatei mit synthetischen Log-Streams ein, klicken auf Run, und AlertLint wertet die LogQL aus und meldet, ob die von Ihnen erwarteten Alerts tatsächlich ausgelöst haben. Es ist das Äquivalent zu promtool „test rules“, das Loki nie ausgeliefert hat.',
  },
  {
    q: 'Verlassen meine Daten jemals meinen Browser?',
    a: 'Nein. AlertLint läuft zu 100 % clientseitig. Ihre Regeln und synthetischen Logs werden in Ihrem Browser-Tab ausgewertet — nichts wird auf einen Server hochgeladen, und es gibt kein Konto und keine Registrierung. Sie können es bedenkenlos für interne oder sensible Regeldefinitionen verwenden.',
  },
  {
    q: 'Wie unterscheidet sich das von promtool?',
    a: 'Prometheus liefert promtool test rules aus, um Alerting-Regeln gegen synthetische Samples zu testen. Loki hat kein eingebautes Äquivalent — es gibt keinen loki test-Befehl. AlertLint schließt diese Lücke für LogQL: Sie legen fest, welche Alerts aus einer bestimmten Menge von Log-Zeilen ausgelöst werden sollen, bevor die Regeln jemals die Produktion erreichen.',
  },
  {
    q: 'Welche LogQL-Funktionen unterstützt die In-Browser-Engine?',
    a: 'Der Preview-Evaluator deckt die gängigen Alerting- und Recording-Muster ab — Log- und Metrik-Abfragen, Stream-Selektoren, Label-Matcher, Line-Filter, rate- und count_over_time-Aggregationen, sum-Aggregationen sowie Schwellenwertvergleiche gegen erwartete Alerts. Vollständige Parität mit der vorgelagerten Loki-Query-Engine (kompiliertes Go zu WebAssembly) ist für ein zukünftiges Release geplant.',
  },
  {
    q: 'Kann ich feststellen, dass kein Alert auslöst?',
    a: 'Ja. Eine leere exp_alerts-Liste bei einem Testfall stellt fest, dass die Regel zum Auswertungszeitpunkt keine Alerts erzeugt — dieselbe Negativfall-Semantik, die promtool verwendet. Es ist die kanonische Methode, um zu belegen, dass eine Regel bei gutartigem Log-Volumen nicht auslöst.',
  },
  {
    q: 'Ist AlertLint mit Grafana Labs verbunden?',
    a: 'Nein. AlertLint ist ein unabhängiges Community-Tool und ist nicht mit Grafana Labs verbunden oder von Grafana Labs unterstützt. Loki und Grafana sind Marken von Raintank, Inc. AlertLint bildet das promtool-Testdateiformat zur Vertrautheit nach und verwendet die Herstellernamen nur, um zu beschreiben, was es testet.',
  },
  {
    q: 'Wie teste ich Loki-Alerting-Regeln, bevor sie die Produktion erreichen?',
    a: 'Linten Sie vor dem Deployment Ihr Regel-YAML mit lokitool rules lint oder cortextool rules lint --backend=loki und führen Sie Ihre Abfragen probeweise in Grafana Explore oder logcli aus. Für Assertion-basiertes Pre-Flight-Testing — den Schritt, den diese Tools nicht abdecken — fügen Sie Ihre Regeln plus synthetische Log-Streams in AlertLint ein und stellen Sie fest, welche Alerts auslösen sollen, einschließlich Negativfällen. Ein grüner Durchlauf gibt starke Pre-Flight-Sicherheit, auch wenn der In-Browser-Evaluator eher eine Preview-Engine als ein vollständiges Produktions-Replay ist.',
  },
  {
    q: 'Wie unterscheidet sich AlertLint von lokitool und cortextool?',
    a: 'lokitool und cortextool bieten rules lint- und sync-Befehle, die die Regelstruktur validieren und Regeln an einen Loki-Ruler pushen — aber keines von beiden führt Alert-Assertions mit synthetischen Logs aus oder sagt Ihnen, ob eine Regel auslöst. AlertLint bringt den promtool-artigen, Assertion-basierten Workflow zu LogQL: Sie liefern synthetische Log-Streams, deklarieren, welche Alerts Sie erwarten, und erhalten ein Bestanden- oder Fehlgeschlagen-Urteil, vollständig im Browser und ohne Installation.',
  },
  {
    q: 'Wie validiere ich Loki-Ruler-YAML online?',
    a: 'AlertLint parst standardmäßiges Loki-Ruler-YAML — Gruppen von Alerting- und Recording-Regeln, jeweils mit einer LogQL-expr, einer optionalen for-Dauer und labels/annotations — und meldet strukturelle Probleme inline. Für tiefergehende Expression-Policy-Prüfungen gegen Regel-Metadaten ist promruval mit --support-loki eine CLI-Option. AlertLint läuft vollständig im Browser, ohne dass eine Registrierung erforderlich ist.',
  },
];

// ── JSON-LD: SoftwareApplication + FAQPage (shared builders) ─────────────────
const softwareApp = softwareAppLd({
  name: 'AlertLint',
  description:
    'Kostenloser Online-Tester für Loki-Alert-Regeln. Fügen Sie Ruler-YAML + synthetische Logs ein und stellen Sie fest, welche Alerts auslösen — das promtool-Äquivalent, das Loki fehlt. Im Browser, ohne Registrierung.',
  url: pageUrl,
  subCategory: 'Observability',
  featureList: [
    'Loki-Alerting-Regeln (LogQL) gegen synthetische Logs unit-testen',
    'promtool-modelliertes Testdateiformat',
    'Feststellen, welche Alerts auslösen — inklusive Negativfälle',
    '100 % clientseitig, kein Upload, keine Registrierung',
  ],
  keywords: tool?.keywords.join(', '),
});

const faqPage = faqPageLd(faqs);

// ── HOW IT WORKS pipeline ────────────────────────────────────────────────────
const pipeline = [
  {
    title: 'Die Regeln parsen.',
    body: 'Ihr Loki-Ruler-YAML wird in Alerting- und Recording-Regelgruppen geparst — dieselbe Form, die der Loki-Ruler lädt.',
  },
  {
    title: 'Die Testdatei parsen.',
    body: 'Die promtool-modellierte Testdatei wird für ihre Input-Log-Series, das Auswertungsintervall und die von Ihnen erwarteten Alerts eingelesen.',
  },
  {
    title: 'Einen In-Memory-Store aufbauen.',
    body: 'Synthetische Log-Zeilen werden in einen flüchtigen In-Browser-Log-Store geladen, damit Abfragen etwas zum Lesen haben.',
  },
  {
    title: 'Die LogQL auswerten.',
    body: 'Jeder Regelausdruck läuft zum Auswertungszeitpunkt des Tests gegen den Store und erzeugt die Alerts, die auslösen würden.',
  },
  {
    title: 'Gegen die Erwartung abgleichen.',
    body: 'Tatsächliche Alerts werden gegen Ihre exp_alerts abgeglichen. Jede Abweichung ist ein fehlgeschlagener Fall und wird inline gemeldet.',
  },
];

// ── Example: Loki ruler rule file ────────────────────────────────────────────
const ruleFileExample = `groups:
  - name: app-errors
    rules:
      - alert: HighErrorRate
        expr: |
          sum(rate({app="checkout"} |= "error" [5m])) > 0.2
        for: 2m
        labels:
          severity: page
        annotations:
          summary: "Checkout error rate is high"`;

// ── Example: promtool-modeled test file ──────────────────────────────────────
const testFileExample = `tests:
  - interval: 1m
    input_series:
      - stream: '{app="checkout"}'
        # 5 error lines/min for 6 minutes
        values: '{level="error"}x6'
    alert_rule_test:
      - eval_time: 6m
        alertname: HighErrorRate
        exp_alerts:
          - exp_labels:
              severity: page
              app: checkout
            exp_annotations:
              summary: "Checkout error rate is high"

  # Negative case — empty exp_alerts asserts NO alert fires.
  - interval: 1m
    input_series:
      - stream: '{app="checkout"}'
        values: '{level="info"}x6'
    alert_rule_test:
      - eval_time: 6m
        alertname: HighErrorRate
        exp_alerts: []`;

// ── CLI teaser ───────────────────────────────────────────────────────────────
const cliExample = `# Coming soon — the same engine as a CLI
$ alertlint test ./tests/**.yaml

  ✓ app-errors › HighErrorRate (fires)
  ✓ app-errors › HighErrorRate (no-fire on info logs)

  2 passed, 0 failed`;
import type { Locale as __Locale } from '../../i18n/config';
import { localizeKey as __l } from '../../i18n/utils';
const __lang = (Astro.currentLocale ?? 'en') as __Locale;

---

<Shell
  title="AlertLint — Loki-Alert-Regel-Tester, kostenlos & im Browser"
  description="Kostenloser Online-Tester für Loki-Alert-Regeln. Fügen Sie Ruler-YAML + synthetische Logs ein und stellen Sie fest, welche Alerts auslösen — das promtool-Äquivalent, das Loki fehlt. Im Browser, ohne Registrierung."
  canonical="/loki-alert-rule-tester"
  jsonLd={[softwareApp, faqPage]}
>
  <!-- ════════════════════════════════════════════════════════════════════
       1) HERO — compact, mesh gradient behind
       ════════════════════════════════════════════════════════════════════ -->
  <ToolHero
    eyebrow="AlertLint · Observability"
    badges={[
      { label: 'Läuft in Ihrem Browser', variant: 'live' },
      { label: 'Keine Registrierung', variant: 'neutral' },
      { label: 'Kostenlos & offen', variant: 'neutral' },
    ]}
  >
    <Fragment slot="headline">
      Testen Sie Ihre <span translate="no">Loki</span>-Alerting-Regeln, bevor sie in der Produktion auslösen.
    </Fragment>
    <Fragment slot="lead">
      Mit <span translate="no">AlertLint</span> können Sie <span translate="no">Loki</span>-Alerting-Regeln
      vor der Produktion testen — fügen Sie Ihre Regeln und synthetischen Logs ein, stellen Sie fest, welche Alerts auslösen sollen,
      und erhalten Sie ein Bestanden oder Fehlgeschlagen, alles online ohne Installation oder Registrierung.
    </Fragment>
  </ToolHero>

  <!-- ════════════════════════════════════════════════════════════════════
       2) THE PLAYGROUND
       ════════════════════════════════════════════════════════════════════ -->
  <section id="playground" class="scroll-mt-24 bg-canvas-soft pt-8 pb-20 sm:pb-24">
    <div class="container-page">
      <h2 class="sr-only">AlertLint-Playground</h2>
      <AlertLintPlayground />
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       3) WHY IT EXISTS — the gap
       ════════════════════════════════════════════════════════════════════ -->
  <section id="why" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
        <div>
          <p class="eyebrow">Die Lücke</p>
          <h2 class="display-lg mt-3 text-balance text-ink">
            <span translate="no">Loki</span> hat kein <span translate="no">promtool</span>.
          </h2>
          <ToolGapVisual />
        </div>
        <div class="space-y-4">
          <p class="body-md text-pretty text-body">
            <span translate="no">Prometheus</span>-Ingenieure liefern seit Jahren getestete Alerting-Regeln aus
            mit <span class="code-mono text-ink" translate="no">promtool test rules</span> —
            synthetische Samples rein, ein Bestanden oder Fehlgeschlagen raus. <span translate="no">Loki</span> übernahm das
            gleiche Regelformat, lieferte aber nie den Test-Runner aus, sodass <span translate="no">LogQL</span>-Alerts
            ungetestet ausgeliefert wurden: Die einzige Möglichkeit zu wissen, ob eine Regel auslöste, bestand darin, auf
            Produktions-Traffic zu warten.
          </p>
          <p class="body-md text-pretty text-body">
            Die Community fordert dies seit Jahren — siehe <span translate="no">Loki</span>
            <a
              class="link-inline"
              href={lokiIssue7655}
              target="_blank"
              rel="noopener noreferrer">Issue #7655</a
            > und
            <a
              class="link-inline"
              href={lokiIssue16659}
              target="_blank"
              rel="noopener noreferrer">Issue #16659</a
            >. <span translate="no">AlertLint</span> schließt diese Lücke schon heute: ein kostenloser browserbasierter
            <span translate="no">Loki</span>-Alerting-Regel-Unit-Tester, der die vertraute
            <span translate="no">promtool</span>-artige Testdatei verwendet und vollständig clientseitig läuft.
          </p>
          <p class="body-sm text-mute">
            Neu beim Format? Springen Sie zu <a class="link-inline" href="#formats">den zwei Dateien</a> oder
            probieren Sie das <a class="link-inline" href="#playground">Live-Playground</a> oben aus.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       4) HOW IT WORKS — numbered pipeline
       ════════════════════════════════════════════════════════════════════ -->
  <ToolPipeline
    id="how-it-works"
    eyebrow="Die Pipeline"
    heading="So funktioniert es."
    lead="Fünf deterministische Schritte laufen bei jedem Druck auf Run end-to-end durch — jedes Mal vollständig in Ihrem Browser-Tab."
    steps={pipeline}
  />

  <!-- ════════════════════════════════════════════════════════════════════
       5) FORMATS — rule file + test file docs
       ════════════════════════════════════════════════════════════════════ -->
  <section id="formats" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Dateiformate</p>
        <h2 class="display-lg mt-3 text-ink">Zwei Dateien, beide vertraut.</h2>
        <p class="body-md mx-auto mt-3 max-w-xl text-pretty text-body">
          <span translate="no">AlertLint</span> liest genau zwei Eingaben: Ihr
          <span translate="no">Loki</span>-Ruler-YAML und eine <span translate="no">promtool</span>-modellierte
          Testdatei. Wenn Sie zuvor schon eine davon für <span translate="no">Prometheus</span> oder
          <span translate="no">Loki</span> geschrieben haben, werden sich diese wie Zuhause anfühlen.
        </p>
      </div>

      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-2">
        <div class="min-w-0">
          <h3 class="display-sm text-ink">Die Regeldatei</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            Standardmäßiges <span translate="no">Loki</span>-Ruler-YAML —
            <span class="code-mono text-ink" translate="no">groups</span> von Alerting- und Recording-Regeln,
            jeweils mit einer <span translate="no">LogQL</span>-<span class="code-mono text-ink" translate="no">expr</span>, einer optionalen
            <span class="code-mono text-ink" translate="no">for</span>-Dauer und
            <span class="code-mono text-ink" translate="no">labels</span> /
            <span class="code-mono text-ink" translate="no">annotations</span>. Dies ist dieselbe
            Datei, die Ihr Ruler bereits lädt.
          </p>
          <CodeBlock lang="yaml" filename="rules.yaml" code={ruleFileExample} />
        </div>

        <div class="min-w-0">
          <h3 class="display-sm text-ink">Die Testdatei</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            Nach dem Vorbild von <span translate="no">promtool</span>:
            <span class="code-mono text-ink" translate="no">input_series</span> von synthetischen Log-Streams,
            ein Auswertungs-<span class="code-mono text-ink" translate="no">interval</span>
            und ein <span class="code-mono text-ink" translate="no">alert_rule_test</span>, das
            die von Ihnen erwarteten Alerts auflistet. Ein leeres
            <span class="code-mono text-ink" translate="no">exp_alerts: []</span> stellt fest, dass
            <em>kein</em> Alert auslöst.
          </p>
          <CodeBlock lang="yaml" filename="tests.yaml" code={testFileExample} />
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       6) CLI TEASER — polarity-flipped dark band
       ════════════════════════════════════════════════════════════════════ -->
  <section id="cli" class="scroll-mt-24 bg-inverse text-inverse-fg">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl items-center gap-10 lg:grid-cols-2 lg:gap-16">
        <div class="min-w-0">
          <p class="eyebrow !text-cyan">Demnächst verfügbar</p>
          <h2 class="display-lg mt-3 text-balance text-inverse-fg">Führen Sie dieselben Prüfungen in CI aus.</h2>
          <p class="body-md mt-4 text-pretty text-white/70">
            Die Browser-Engine ist Schritt eins. Eine Drop-in-CLI wird die identischen Assertions über einen
            Glob von Testdateien in Ihrer Pipeline ausführen, sodass ein kaputter Alert den Build zum Fehlschlagen bringt, statt Sie
            um 3 Uhr morgens zu paging.
          </p>
          <p class="body-sm mt-4 text-pretty text-white/55">
            Eine First-Party-<span translate="no">GitHub</span>-Action, die die CLI umschließt, ist parallel dazu geplant.
            Beides ist demnächst verfügbar — der In-Browser-Tester oben funktioniert schon heute.
          </p>
        </div>
        <CodeBlock lang="bash" filename="ci.sh" code={cliExample} />
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       7) NOTE — honest preview-engine callout
       ════════════════════════════════════════════════════════════════════ -->
  <section class="bg-canvas-soft">
    <div class="container-page py-12 sm:py-16">
      <div class="card-soft mx-auto max-w-3xl p-6">
        <p class="eyebrow">Preview-Engine</p>
        <p class="body-md mt-3 text-pretty text-body">
          Ein Hinweis zur Genauigkeit: Der In-Browser-Evaluator ist eine <strong class="font-medium text-ink"
            >Preview-Engine</strong
          >, die die gängigen <span translate="no">LogQL</span>-Alerting-Muster abdeckt — Label-Matcher,
          Line- und Label-Filter,
          <span class="code-mono text-ink" translate="no">rate</span> /
          <span class="code-mono text-ink" translate="no">count_over_time</span>-Aggregationen und
          Schwellenwertvergleiche. Ein Build mit voller Parität, der die vorgelagerte
          <span translate="no">Loki</span>-Query-Engine zu WebAssembly kompiliert, ist demnächst verfügbar. Behandeln Sie bis dahin
          einen grünen Durchlauf als starke Pre-Flight-Sicherheit und nicht als Byte-für-Byte-Produktions-Replay.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       8) FAQ
       ════════════════════════════════════════════════════════════════════ -->
  <FaqList faqs={faqs} />

  <!-- ════════════════════════════════════════════════════════════════════
       Cross-links + footer disclaimer
       ════════════════════════════════════════════════════════════════════ -->
  <ToolCrossLinks lang={__lang}>
    <Fragment slot="lead">
      <span translate="no">AlertLint</span> ist eines von vielen Tools in
      <span translate="no">{site.name}</span> — ein wachsendes Dach aus browserbasierten Validatoren,
      Konvertern und Testern, die niemals einen Server berühren.
    </Fragment>
    <Fragment slot="links">
      Kombinieren Sie es mit dem nun verfügbaren
      <a class="link-inline" href={__l("/cve-ignore-converter", __lang)}><span translate="no">CVE</span>-Ignore-Konverter</a> und dem
      <a class="link-inline" href={__l("/github-actions-validator", __lang)}><span translate="no">GitHub</span>-Actions-Validator</a>,
      oder durchstöbern Sie das vollständige
      <a class="link-inline" href={__l(navLinks[0].href, __lang)}>Tools-Verzeichnis</a>.
    </Fragment>
    <Fragment slot="disclaimer">
      Nicht verbunden mit oder unterstützt von <span translate="no">Grafana Labs</span>.
      <span translate="no">Loki</span> und <span translate="no">Grafana</span> sind Marken von
      <span translate="no">Raintank, Inc.</span>
    </Fragment>
  </ToolCrossLinks>
</Shell>
