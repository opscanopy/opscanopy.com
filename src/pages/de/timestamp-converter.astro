---
/**
 * Timestamp Converter — the timestamp-converter tool page (SEO surface).
 * Paste a Unix epoch (seconds / ms / µs) or a date string and get every
 * representation back — UTC, local, ISO 8601 and relative time — entirely
 * in the browser.
 */
import Shell from '../../components/Shell.astro';
import TimestampConverterPlayground from '../../components/TimestampConverterPlayground.astro';
import Button from '../../components/Button.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ToolHero from '../../components/ToolHero.astro';
import ToolPipeline from '../../components/ToolPipeline.astro';
import FaqList from '../../components/FaqList.astro';
import ToolCrossLinks from '../../components/ToolCrossLinks.astro';
import { site, navLinks } from '../../data/site';
import { getTool } from '../../data/tools';
import { softwareAppLd, faqPageLd } from '../../lib/jsonld';

const tool = getTool('timestamp-converter');
const pagePath = '/timestamp-converter';
const pageUrl = `${site.url}${pagePath}`;

const faqs = [
  {
    q: 'Was ist die Unix-Zeit?',
    a: 'Die Unix-Zeit — auch Epochenzeit oder POSIX-Zeit genannt — ist die Anzahl der Sekunden, die seit der Unix-Epoche, dem 1970-01-01 00:00:00 UTC, vergangen sind, ohne Berücksichtigung von Schaltsekunden. Sie ist die gängigste Art, wie Computer einen Zeitpunkt speichern: als einzelne, zeitzonenfreie Ganzzahl, auf die sich jedes System einigen kann. Dieser Konverter verwandelt diese Ganzzahl in ein menschenlesbares Datum und wieder zurück.',
  },
  {
    q: 'Sekunden, Millisekunden oder Mikrosekunden — wie unterscheide ich sie?',
    a: 'An der Länge. Eine heutige Epoche in Sekunden hat 10 Ziffern, in Millisekunden 13 Ziffern und in Mikrosekunden 16 Ziffern (Nanosekunden erreichen 19). Der Konverter erkennt die Einheit an der Größenordnung der Zahl — so wird 1700000000 als Sekunden und 1700000000000 als Millisekunden gelesen — und Sie können die Vermutung überschreiben, falls Ihre Daten eine andere Einheit verwenden.',
  },
  {
    q: 'Verlässt mein Zeitstempel jemals meinen Browser?',
    a: 'Nein. Das Parsen, die Epochen-Berechnung und die gesamte Formatierung laufen zu 100 % clientseitig in Ihrem Tab — es gibt keinen Server, kein Konto und keine Protokollierung. Sie können Zeitstempel aus internen Logs und privaten Systemen bedenkenlos einfügen.',
  },
  {
    q: 'Wie geht das Tool mit Zeitzonen und Sommerzeit um?',
    a: 'Eine Epoche ist ein absoluter Zeitpunkt, daher ändert sich der zugrunde liegende Moment nie — nur seine Darstellung. Der Konverter zeigt immer den kanonischen UTC-Wert neben Ihrer lokalen Browserzeit an, und die lokale Darstellung spiegelt über die integrierten Intl-APIs die Zeitzone Ihres Rechners und ihre Sommerzeitregeln zu diesem Zeitpunkt wider. Wechseln Sie den Rechner oder die Zone, bleibt die UTC-Zeile unverändert, während sich die lokale Zeile verschiebt.',
  },
  {
    q: 'Was ist ISO 8601 und warum ist es wichtig?',
    a: 'ISO 8601 ist der internationale Standard, um Datums- und Zeitangaben als Text zu schreiben — zum Beispiel 2024-01-15T09:30:00Z, wobei das abschließende Z für UTC steht. Er lässt sich lexikografisch sortieren, ist eindeutig in der Reihenfolge (Jahr-Monat-Tag) und ist das, was JSON-APIs, Logs und Datenbanken überwiegend erwarten. Der Konverter gibt einen strengen ISO-8601-String aus, den Sie direkt in eine Payload oder eine Query einfügen können.',
  },
  {
    q: 'Wie konvertiere ich ein ISO-8601-Datum in einen Unix-Zeitstempel?',
    a: 'Fügen Sie einen ISO-8601-String wie 2026-06-11T00:00:00Z in die Eingabe ein, und der Konverter liefert den passenden Epochenwert in Sekunden und Millisekunden zurück. Das Format folgt YYYY-MM-DDTHH:mm:ssZ, wobei Z für UTC steht; Offsets wie +05:30 werden ebenfalls akzeptiert. Die Konvertierung ist bidirektional, sodass Sie von der Epoche zu ISO 8601 oder von ISO 8601 zurück zur Epoche gelangen können.',
  },
  {
    q: 'Wie konvertiere ich einen 13-stelligen Millisekunden-Zeitstempel in ein Datum?',
    a: 'Fügen Sie den 13-stelligen Wert direkt ein, und der Konverter erkennt ihn automatisch als Millisekunden-Epoche. Intern teilt er durch 1000, um die zugrunde liegende Sekunde zu erhalten, und formatiert das Ergebnis dann als UTC, lokale Zeit, ISO 8601 und als relative Angabe. Dies entspricht dem von JavaScript Date.now() und Java System.currentTimeMillis() erzeugten Wert.',
  },
  {
    q: 'Was ist der aktuelle Unix-Zeitstempel gerade jetzt?',
    a: 'Der aktuelle Unix-Zeitstempel ist die Anzahl der Sekunden, die seit dem 1. Januar 1970 UTC bis zu genau diesem Moment vergangen sind. Der Konverter zeigt den Live-Wert sowohl in Sekunden als auch in Millisekunden an, in Echtzeit in Ihrem Browser aktualisiert. Die meisten serverseitigen APIs und SQL-Datenbanken arbeiten in Sekunden, während JavaScript- und Browser-Analytics-Code typischerweise Millisekunden verwenden.',
  },
  {
    q: 'Wie konvertiere ich ein Datum zurück in einen Epochen-Zeitstempel?',
    a: 'Geben Sie einen beliebigen menschenlesbaren oder ISO-8601-Datumsstring ein, und der Konverter liefert den entsprechenden Unix-Epochenwert in Sekunden und Millisekunden zurück. Eingaben wie 2024-01-15T09:30:00Z und ähnliche Formate werden alle akzeptiert. Das Ergebnis lässt sich direkt in einen API-Aufruf, eine Datenbankabfrage oder einen JWT-Claim einfügen.',
  },
];

const softwareApp = softwareAppLd({
  name: 'Timestamp Converter',
  description:
    'Kostenloser Unix-Timestamp-Konverter. Konvertieren Sie Epoche in Datum, ISO 8601 und Millisekunden über UTC und lokale Zeit hinweg. 100 % im Browser, ohne Anmeldung, Ihre Daten bleiben auf Ihrem Gerät.',
  url: pageUrl,
  subCategory: 'Encoding',
  featureList: [
    'Eine Unix-Epoche in menschenlesbare, ISO-8601- und lokale Zeit konvertieren',
    'Sekunden, Millisekunden und Mikrosekunden automatisch erkennen',
    'Einen Datumsstring zurück in eine Epoche parsen',
    '100 % clientseitig, kein Upload, keine Anmeldung',
  ],
  keywords: tool?.keywords.join(', '),
});
const faqPage = faqPageLd(faqs);

const pipeline = [
  {
    title: 'Die Eingabe erkennen.',
    body: 'Der Wert wird als Epoche in Sekunden, Millisekunden oder Mikrosekunden — anhand seiner Länge geschätzt — oder als Datumsstring gelesen.',
  },
  {
    title: 'Den Zeitpunkt bilden.',
    body: 'Was auch immer Sie eingegeben haben, wird auf einen absoluten Moment normalisiert: Millisekunden seit der Unix-Epoche, zeitzonenfrei.',
  },
  {
    title: 'Jede Form darstellen.',
    body: 'Dieser Zeitpunkt wird zu UTC, ISO 8601, der rohen Epoche in jeder Einheit sowie zum lesbaren Datum und der Uhrzeit.',
  },
  {
    title: 'Relativ & lokal anzeigen.',
    body: 'Schließlich werden Ihre lokale Browserzeit und eine menschliche relative Angabe wie „vor 3 Stunden“ ergänzt.',
  },
];

const cheatSheet = `unit            length   example              note
seconds         10       1700000000           classic Unix epoch
milliseconds    13       1700000000000        JS Date.now(), Java
microseconds    16       1700000000000000     Postgres, some traces
nanoseconds     19       1700000000000000000  Go time, perf counters`;

const dateExamples = `1700000000            →  2023-11-14T22:13:20Z
2023-11-14T22:13:20Z  →  1700000000  (seconds)
2023-11-14 22:13:20   →  parsed as local time
Nov 14 2023 22:13 UTC →  1700000000
now                   →  current instant`;
import type { Locale as __Locale } from '../../i18n/config';
import { localizeKey as __l } from '../../i18n/utils';
const __lang = (Astro.currentLocale ?? 'en') as __Locale;

---

<Shell
  title="Timestamp Converter — Unix-Zeitstempel & Epoche zu Datum"
  description="Kostenloser Unix-Timestamp-Konverter. Konvertieren Sie Epoche in Datum, ISO 8601 und Millisekunden über UTC und lokale Zeit hinweg. 100 % im Browser, ohne Anmeldung, Ihre Daten bleiben auf Ihrem Gerät."
  canonical="/timestamp-converter"
  jsonLd={[softwareApp, faqPage]}
>
  <ToolHero
    eyebrow="Timestamp Converter · Encoding"
    badges={[
      { label: 'Läuft in Ihrem Browser', variant: 'live' },
      { label: 'UTC & lokal', variant: 'neutral' },
      { label: 'Keine Anmeldung', variant: 'neutral' },
    ]}
  >
    <Fragment slot="headline">Verwandeln Sie eine Unix-Epoche in lesbare Zeit — und zurück.</Fragment>
    <Fragment slot="lead">
      Fügen Sie einen Unix-Zeitstempel wie
      <span class="code-mono text-ink" translate="no">1700000000</span> oder einen Datumsstring ein, um
      Epochenzeit in ein menschenlesbares Datum zu konvertieren — UTC, ISO 8601, lokale und relative Zeit auf einmal, alles in
      Ihrem Browser, über Sekunden, Millisekunden und Mikrosekunden hinweg.
    </Fragment>
  </ToolHero>

  <section id="playground" class="scroll-mt-24 bg-canvas-soft pt-8 pb-20 sm:pb-24">
    <div class="container-page">
      <h2 class="sr-only">Timestamp-Converter-Playground</h2>
      <TimestampConverterPlayground />
    </div>
  </section>

  <section id="why" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
        <div>
          <p class="eyebrow">Die Lücke</p>
          <h2 class="display-lg mt-3 text-balance text-ink">
            Eine nackte Ganzzahl in einem Log ist für niemanden eine Zeitangabe.
          </h2>
        </div>
        <div class="space-y-4">
          <p class="body-md text-pretty text-body">
            Epochen-Zeitstempel sind überall — Logzeilen, API-Payloads, Datenbankzeilen, JWT-
            <span class="code-mono text-ink" translate="no">exp</span>-Claims — und jeder einzelne davon
            ist nur eine Zahl, bis Sie ihn dekodieren. Schlimmer noch, die Einheit ist selten beschriftet: Sind
            <span class="code-mono text-ink" translate="no">1700000000</span> Sekunden, oder hat jemand
            bereits mit tausend multipliziert? Raten Sie falsch, lesen Sie ein Datum im Jahr 1970 oder im
            Jahr 56000.
          </p>
          <p class="body-md text-pretty text-body">
            Dieser Konverter nimmt die Ganzzahl oder den Datumsstring und liefert Ihnen die konkreten Fakten: die
            Zuordnung des Unix-Zeitstempels zu UTC, einen strengen ISO-8601-String, Ihre eigene lokale Zeit und wie
            lange es her ist — wobei die Einheit Sekunden gegenüber Millisekunden automatisch erkannt wird, sodass Sie nie
            raten müssen. Vollständig im Browser, ohne Installation.
          </p>
          <p class="body-sm text-mute">
            Sie ziehen Zeitstempel aus einem Token? Der
            <a class="link-inline" href={__l("/jwt-decoder", __lang)}>JWT Decoder</a> liest
            <span class="code-mono text-ink" translate="no">iat</span> und
            <span class="code-mono text-ink" translate="no">exp</span> für Sie aus.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ToolPipeline
    id="how-it-works"
    eyebrow="Die Pipeline"
    heading="So funktioniert es."
    lead="Vier deterministische Schritte laufen bei jedem Tastendruck — alle innerhalb Ihres Browser-Tabs, ohne dass eine Uhr an einen Server gesendet wird."
    steps={pipeline}
  />

  <section id="reference" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Epochen-Referenz</p>
        <h2 class="display-lg mt-3 text-ink">Welche Einheit ist diese Zahl?</h2>
        <p class="body-md mx-auto mt-3 max-w-xl text-pretty text-body">
          Bei heutigen Zeitstempeln verrät die Anzahl der Ziffern die Einheit. Ein kurzer Spickzettel der
          Epochenlängen und der Datumsformen, die der Konverter akzeptiert.
        </p>
      </div>
      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-2">
        <div class="min-w-0">
          <h3 class="display-sm text-ink">Epochenlängen</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            Jede Stufe nach oben multipliziert mit tausend — also sind
            <span class="code-mono text-ink" translate="no">10</span> Ziffern Sekunden,
            <span class="code-mono text-ink" translate="no">13</span> Millisekunden,
            <span class="code-mono text-ink" translate="no">16</span> Mikrosekunden.
          </p>
          <CodeBlock lang="text" filename="epoch-lengths" code={cheatSheet} />
        </div>
        <div class="min-w-0">
          <h3 class="display-sm text-ink">Datumsbeispiele</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            Geben Sie ihm eine Epoche oder einen Datumsstring — ISO 8601, ein einfaches Datum mit Uhrzeit oder sogar
            <span class="code-mono text-ink" translate="no">now</span> — und er löst denselben
            Zeitpunkt auf jede Weise auf.
          </p>
          <CodeBlock lang="text" filename="date-examples" code={dateExamples} />
        </div>
      </div>
    </div>
  </section>

  <section id="next" class="scroll-mt-24 bg-inverse text-inverse-fg">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
        <div class="min-w-0">
          <p class="eyebrow !text-cyan">Nächster Schritt</p>
          <h2 class="display-lg mt-3 text-balance text-inverse-fg">
            Diesen Zeitstempel in einem Token oder einem Blob gefunden?
          </h2>
          <p class="body-md mt-4 text-pretty text-white/70">
            Epochenwerte reisen selten allein. Wenn Ihrer aus einem JSON Web Token stammt, liest der
            <span translate="no">JWT Decoder</span> die
            <span class="code-mono" translate="no">iat</span>- und
            <span class="code-mono" translate="no">exp</span>-Claims für Sie aus; war er in einer
            kodierten Payload vergraben, verwandelt der <span translate="no">Base64 Encoder / Decoder</span> den Blob
            zuerst zurück in lesbaren Text.
          </p>
          <div class="mt-7 flex flex-wrap items-center gap-3">
            <Button href={__l("/jwt-decoder", __lang)} variant="secondary">JWT Decoder öffnen</Button>
            <Button href={__l("/base64-encoder-decoder", __lang)} variant="secondary">
              Base64-Tool öffnen
            </Button>
          </div>
        </div>
        <CodeBlock
          lang="text"
          filename="jwt-claims.txt"
          code={`"iat": 1700000000   →  2023-11-14T22:13:20Z
"exp": 1700003600   →  2023-11-14T23:13:20Z
                       expires in 1 hour`}
        />
      </div>
    </div>
  </section>

  <FaqList faqs={faqs} />

  <ToolCrossLinks>
    <Fragment slot="lead">
      Der Timestamp Converter ist eines von vielen Tools in
      <span translate="no">{site.name}</span> — einem wachsenden Schirm browserbasierter Validatoren,
      Konverter und Tester, die niemals einen Server berühren.
    </Fragment>
    <Fragment slot="links">
      Mehr zum Thema Encoding: der
      <a class="link-inline" href={__l("/jwt-decoder", __lang)}>JWT Decoder</a> und der
      <a class="link-inline" href={__l("/base64-encoder-decoder", __lang)}>Base64 Encoder / Decoder</a>, oder durchsuchen Sie
      das vollständige <a class="link-inline" href={__l(navLinks[0].href, __lang)}>Tool-Verzeichnis</a>.
    </Fragment>
    <Fragment slot="disclaimer">
      Ohne Gewähr zur Vereinfachung bereitgestellt; überprüfen Sie kritische zeitkritische Werte stets gegen eine
      maßgebliche Uhr. <span translate="no">{site.name}</span> ist kostenlos und quelloffen.
    </Fragment>
  </ToolCrossLinks>
</Shell>
