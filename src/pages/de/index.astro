---
/**
 * OpsCanopy hub homepage — the flagship marketing surface.
 * Composes the Vercel-inspired design system defined in global.css / DESIGN.md.
 *
 * Component prop contracts (provided by sibling agents in src/components/*):
 *  - <MeshGradient class="…" />                          atmospheric hero backdrop
 *  - <Button href variant="primary|secondary" size? />   marketing pill CTA (label via slot)
 *  - <Card class? as?>…</Card>                            canvas card chrome (slot body)
 *  - <Badge variant?>…</Badge>                            inline status pill (label via slot)
 *  - <CodeBlock code lang? filename? />                   dark mono code surface
 *  - <Banner href>…</Banner>                              "Introducing X" announcement pill
 */
import Shell from '../../components/Shell.astro';
import MeshGradient from '../../components/MeshGradient.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import Badge from '../../components/Badge.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import Banner from '../../components/Banner.astro';
import FaqList from '../../components/FaqList.astro';
import { site } from '../../data/site';
import { tools, liveTools, accentEdgeClass } from '../../data/tools';
import { faqPageLd } from '../../lib/jsonld';

const alertLint = liveTools[0] ?? tools[0];

const faqs = [
  {
    q: 'Sind die OpsCanopy-Tools wirklich kostenlos?',
    a: 'Ja. Jedes Tool ist vollständig kostenlos, ohne Bezahlschranken, Nutzungslimits oder Premium-Stufen. Es gibt keinerlei Konto-Pflicht — öffnen Sie ein Tool in Ihrem Browser und nutzen Sie es sofort.',
  },
  {
    q: 'Muss ich mich registrieren, um diese Online-DevOps-Tools zu nutzen?',
    a: 'Nein. Es gibt keine Registrierung, kein Login und keine E-Mail-Erfassung. Öffnen Sie ein beliebiges Tool in Ihrem Browser-Tab und nutzen Sie es sofort — kein Konto, keine Cookie-Einwilligungswand, keine Reibung.',
  },
  {
    q: 'Werden meine Daten auf einen Server hochgeladen, wenn ich die Tools nutze?',
    a: 'Nein. Jedes Tool läuft zu 100 % clientseitig in Ihrem Browser-Tab; nichts, was Sie einfügen, wird protokolliert, gespeichert oder hochgeladen. Ihre Daten verlassen den Browser nie.',
  },
  {
    q: 'Ist es sicher, ein JWT oder eine Konfiguration in ein browserbasiertes Tool einzufügen?',
    a: 'Bei OpsCanopy: ja. Das Decodieren und Parsen geschieht vollständig in lokalem JavaScript ohne jegliche Server-Aufrufe, was Sie im Netzwerk-Tab des Browsers selbst überprüfen können. Als allgemeine Hygiene gilt: Geben Sie Signatur-Geheimnisse niemals an Dritte weiter — OpsCanopy überträgt jedoch nichts.',
  },
  {
    q: 'Funktionieren die Tools offline?',
    a: 'Sobald eine Tool-Seite geladen ist, funktioniert sie weiter, selbst wenn Sie die Internetverbindung trennen, denn die gesamte Verarbeitung erfolgt lokal und es gibt kein Backend, das aufgerufen werden müsste. Offline zu gehen ist außerdem eine einfache Möglichkeit, die Behauptung der clientseitigen Privatsphäre selbst zu überprüfen.',
  },
  {
    q: 'Für wen sind diese browserbasierten DevOps-Tools gedacht?',
    a: 'DevOps-Engineers, SREs, Sysadmins, Plattform- und Backend-Engineers — alle, die schnell Subnetz- und CIDR-Berechnungen, Cron-Zeitpläne, PromQL- oder LogQL-Abfragen, JWT-, Base64- und Hash-Werkzeuge, Timestamp-Umrechnung, GitHub-Actions-Validierung oder Kubernetes-Ressourcendimensionierung benötigen, ohne etwas zu installieren.',
  },
  {
    q: 'Wie unterscheidet sich OpsCanopy von anderen Online-Sammlungen für Entwickler-Tools?',
    a: 'Die meisten Tool-Sammlungen konzentrieren sich auf generische Formatierer. OpsCanopy spezialisiert sich auf DevOps- und SRE-Workflows — CIDR-Planung, Cron, PromQL und LogQL, Kubernetes-Kapazität, CI-Validatoren — durchgängig mit denselben Garantien: kostenlos, ohne Registrierung, zu 100 % clientseitig, nichts hochgeladen oder protokolliert.',
  },
];

// Quietly-stated trust principles for the value strip.
const principles = [
  { label: 'PREIS', title: 'Für immer kostenlos', body: 'Jedes Tool, ohne Bezahlschranke, ohne Testphase.' },
  { label: 'LAUFZEITUMGEBUNG', title: 'Läuft in Ihrem Browser', body: 'Rein clientseitig. Nichts zu installieren.' },
  { label: 'DATENSCHUTZ', title: 'Ihre Daten bleiben lokal', body: 'Eingaben verlassen das Gerät nie.' },
  { label: 'ZUGANG', title: 'Keine Registrierung', body: 'Öffnen Sie die Seite und legen Sie los.' },
];

// "Why a hub" value props, drawn from the strategy.
const whyCards = [
  {
    eyebrow: 'KUMULATIV',
    title: 'Ein Hub verstärkt sich selbst.',
    body: 'Jedes fokussierte, suchorientierte Tool verdient sich eigene Keywords und verlinkt zurück auf die übrigen. Der Katalog wird mit jeder Veröffentlichung besser auffindbar.',
  },
  {
    eyebrow: 'STATISCH + GÜNSTIG',
    title: 'Günstig im Betrieb, schnell beim Laden.',
    body: 'Alles ist statisch und clientseitig, daher gibt es keine Server zu skalieren und keine Rechnungen zu begleichen. Die Seiten bleiben bei jedem Traffic-Aufkommen blitzschnell.',
  },
  {
    eyebrow: 'DATENSCHUTZ',
    title: 'Datenschutz ist ein Feature.',
    body: 'Ihre Regeln, Konfigurationen und Logs gehören Ihnen. Nichts wird hochgeladen, protokolliert oder nach Hause telefoniert — genau das ist der Sinn, es in Ihrem Tab laufen zu lassen.',
  },
];

// Loki rule + test snippet for the featured AlertLint band.
const alertLintSnippet = `# rules.yml — the Loki alert under test
groups:
  - name: ingest
    rules:
      - alert: HighErrorRate
        expr: |
          sum(rate({app="api"} |= "level=error" [5m])) > 10
        for: 2m

# tests.yml — assert it fires (and doesn't, when quiet)
tests:
  - name: fires when errors spike
    input:
      - logs: 'level=error'
        rate: 25/min
    expect: { alert: HighErrorRate, fires: true }
  - name: stays quiet under threshold
    input:
      - logs: 'level=error'
        rate: 3/min
    expect: { alert: HighErrorRate, fires: false }`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: site.name,
    url: site.url,
    description: site.description,
    sameAs: [site.github],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: site.name,
    url: site.url,
    description: site.description,
  },
  faqPageLd(faqs),
];
import type { Locale as __Locale } from '../../i18n/config';
import { localizeKey as __l } from '../../i18n/utils';
const __lang = (Astro.currentLocale ?? 'en') as __Locale;

---

<Shell
  title="OpsCanopy — Kostenlose Online-DevOps- & SRE-Tools, ohne Registrierung"
  description="Kostenlose Online-DevOps-Tools, die zu 100 % in Ihrem Browser laufen — Subnetz-/CIDR-Rechner, Cron-Tester, JWT-Decoder & mehr. Ohne Registrierung, nichts wird hochgeladen."
  canonical="/"
  jsonLd={jsonLd}
>
  {/* ─────────────────────────── 1 · HERO ─────────────────────────── */}
  <section class="relative isolate overflow-hidden bg-canvas-soft">
    <MeshGradient class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[90%] opacity-90" />
    {/* Soft top sheen + bottom fade frame the mesh so it reads as ambient light,
        keeping crisp ink contrast under the headline. */}
    <div
      class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-32 bg-gradient-to-b from-canvas-soft to-transparent"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-48 bg-gradient-to-b from-transparent to-canvas-soft"
      aria-hidden="true"
    >
    </div>

    <div class="container-page relative z-10 flex flex-col items-center py-10 text-center sm:py-12 lg:py-14">
      <Banner href={__l(`/${alertLint.slug}`, __lang)}>
        <span class="eyebrow text-ink">Neu</span>
        <span class="text-body">
          Wir stellen vor: <span translate="no">AlertLint</span> — Unit-Tests für Loki-Alert-Regeln.
        </span>
      </Banner>

      <h1 class="display-xl mt-6 max-w-3xl text-balance text-ink">
        Ein Blätterdach an Tools für die Ops, die Sie tatsächlich machen.
      </h1>

      <p class="body-md mx-auto mt-4 max-w-2xl text-pretty text-body">
        Kostenlose Online-Entwickler-Tools, die vollständig im Browser laufen — Validatoren, Konverter, Tester
        und Linter für DevOps- und SRE-Engineers. Ohne Registrierung, ohne Server, ohne Tracking: Ihre Daten verlassen
        das Gerät nie.
      </p>
    </div>
  </section>

  {/* ─── 2 · TOOLS PREVIEW (the catalog leads — MVP first) ─── */}
  <section class="bg-canvas pt-10 pb-20 sm:pt-12 sm:pb-24" aria-labelledby="tools-preview">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">Der Katalog</span>
          <h2 id="tools-preview" class="display-lg mt-3 text-balance text-ink">Tools im Blätterdach.</h2>
          <p class="body-md mt-3 text-pretty text-body">
            Fokussierte Werkzeuge mit einem einzigen Zweck für Plattform- und DevOps-Engineers — jedes davon live,
            kostenlos und vollständig in Ihrem Browser laufend.
          </p>
        </div>
        <a
          href={__l("/tools", __lang)}
          class="link-inline group body-md inline-flex shrink-0 items-center gap-1 whitespace-nowrap font-medium"
        >
          Alle Tools ansehen
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>

      <ul class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-3">
        {
          liveTools.map((tool) => (
            <li class="h-full">
              <a
                href={__l(`/${tool.slug}`, __lang)}
                class="card-interactive group relative flex h-full min-w-0 flex-col overflow-hidden rounded-lg bg-canvas shadow-soft"
              >
                <span
                  aria-hidden="true"
                  class:list={['h-1 w-full bg-gradient-to-r', accentEdgeClass[tool.accent]]}
                />
                <div class="flex h-full min-w-0 flex-col p-6 sm:p-7">
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="display-sm min-w-0 break-words text-ink" translate="no">
                      {tool.name}
                    </h3>
                    <Badge variant="live" class="shrink-0">Live</Badge>
                  </div>
                  <p class="caption mt-1 text-mute">{tool.category}</p>
                  <p class="body-md mt-4 flex-1 text-pretty text-body">{tool.tagline}</p>
                  <span class="body-sm mt-6 inline-flex items-center gap-1 font-medium text-link">
                    Tool öffnen
                    <span
                      aria-hidden="true"
                      class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
                    >
                      &rarr;
                    </span>
                  </span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ─────────────────── 3 · FEATURED TOOL BAND (AlertLint) ─────────────────── */}
  <section class="bg-canvas-soft py-16 sm:py-24" aria-labelledby="featured-tool">
    <div class="container-page">
      <div
        class="overflow-hidden rounded-xl bg-inverse text-inverse-fg shadow-float"
      >
        <div class="grid grid-cols-1 gap-10 p-8 sm:p-12 lg:grid-cols-2 lg:items-center lg:gap-12 lg:p-16">
          <div class="flex min-w-0 flex-col">
            <span class="eyebrow text-cyan">Tool&nbsp;01 · Observability</span>
            <h2 id="featured-tool" class="display-lg mt-4 text-balance text-inverse-fg">
              Testen Sie Ihre Loki-Alert-Regeln, bevor sie in der Produktion auslösen.
            </h2>
            <p class="body-lg mt-5 max-w-xl text-pretty text-white/80">
              Fügen Sie Ihre Alert- und Recording-Regeln zusammen mit synthetischen Log-Streams ein und sichern Sie
              anschließend genau zu, was auslösen soll — und was nicht. Das <span translate="no">promtool</span>-
              Äquivalent, das Loki nie ausgeliefert hat, vollständig in Ihrem Browser laufend.
            </p>
            <div class="mt-8">
              <Button href={__l(`/${alertLint.slug}`, __lang)} variant="secondary"><span translate="no">AlertLint</span> öffnen</Button>
            </div>
          </div>

          <div class="min-w-0 lg:pl-2">
            <CodeBlock
              code={alertLintSnippet}
              lang="yaml"
              filename="alertlint test ./tests"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ───────────────────── 4 · VALUE / TRUST STRIP ───────────────────── */}
  <section class="bg-canvas" aria-label="Why OpsCanopy is different">
    <div class="container-page border-t border-hairline py-12 sm:py-14">
      <ul class="grid grid-cols-1 gap-x-8 gap-y-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          principles.map((p) => (
            <li class="flex min-w-0 flex-col gap-2 sm:[&:not(:first-child)]:border-l sm:[&:not(:first-child)]:border-hairline sm:[&:not(:first-child)]:pl-8">
              <span class="eyebrow">{p.label}</span>
              <span class="body-md font-medium text-ink">{p.title}</span>
              <span class="body-sm text-pretty text-mute">{p.body}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ─── 5 · WHY A HUB (the thesis sits below the catalog) ─── */}
  <section id="why" class="section-pad bg-canvas-soft">
    <div class="container-page">
      <div class="max-w-2xl">
        <span class="eyebrow">Die These</span>
        <h2 class="display-lg mt-4 text-balance text-ink">Warum einen Hub bauen, nicht ein einzelnes Tool.</h2>
        <p class="body-lg mt-5 text-pretty text-body">
          Ein großartiges Werkzeug ist ein Nebenprojekt. Ein Blätterdach davon ist eine Plattform — jedes Tool versorgt
          das nächste mit Traffic, Vertrauen und Wiederverwendung.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 lg:grid-cols-3">
        {
          whyCards.map((c) => (
            <Card class="flex h-full min-w-0 flex-col p-6 sm:p-8">
              <span class="eyebrow">{c.eyebrow}</span>
              <h3 class="display-sm mt-3 text-balance text-ink">{c.title}</h3>
              <p class="body-md mt-3 text-pretty text-body">{c.body}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  {/* ─────────────────────────── 6 · PRIVACY ─────────────────────────── */}
  <section id="privacy" class="section-pad bg-canvas" aria-labelledby="privacy-heading">
    <div class="container-page">
      <Card class="flex flex-col gap-6 p-8 sm:p-12 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">Datenschutz</span>
          <h2 id="privacy-heading" class="display-md mt-3 text-balance text-ink">
            Nichts, was Sie einfügen, verlässt Ihren Tab.
          </h2>
          <p class="body-md mt-4 text-pretty text-body">
            Jedes <span translate="no">OpsCanopy</span>-Tool läuft als statisches JavaScript in Ihrem
            Browser. Es gibt kein Backend, das Ihre Regeln, Konfigurationen oder Logs empfängt — keine Uploads, keine
            Telemetrie auf Ihren Eingaben, kein Konto zum Anlegen. Schließen Sie den Tab und es ist verschwunden.
          </p>
        </div>
        <div class="shrink-0">
          <span class="badge">
            <span aria-hidden="true" class="size-1.5 rounded-full bg-cyan"></span>
            100%&nbsp;client-side
          </span>
        </div>
      </Card>
    </div>
  </section>

  {/* ─────────────────────────── 7 · FAQ ─────────────────────────── */}
  <FaqList faqs={faqs} />

  {/* ───────────────────────── 8 · FOOTER CTA ───────────────────────── */}
  <section class="section-pad bg-canvas-soft" aria-labelledby="closing-cta">
    <div class="container-page">
      <div class="flex flex-col items-center gap-6 text-center">
        <h2 id="closing-cta" class="display-xl max-w-3xl text-balance text-ink">
          Finden Sie das Tool. Sparen Sie sich die Installation.
        </h2>
        <p class="body-lg max-w-xl text-pretty text-body">
          Kostenlos, privat und sofort einsatzbereit. Durchstöbern Sie das Blätterdach und setzen Sie es bei Ihrem nächsten Deploy ein.
        </p>
        <div class="mt-2">
          <Button href={__l("/tools", __lang)} variant="primary">Alle Tools durchstöbern</Button>
        </div>
      </div>
    </div>
  </section>
</Shell>
