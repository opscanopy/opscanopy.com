---
/**
 * OpsCanopy hub homepage — the flagship marketing surface.
 * Composes the Vercel-inspired design system defined in global.css / DESIGN.md.
 * Structural mirror of src/pages/index.astro (English) — see that file for the
 * canonical section order; keep both in sync when the layout changes.
 *
 * Component prop contracts (provided by sibling agents in src/components/*):
 *  - <MeshGradient class="…" />                          atmospheric hero backdrop
 *  - <Button href variant="primary|secondary" size? />   marketing pill CTA (label via slot)
 *  - <Card class? as?>…</Card>                            canvas card chrome (slot body)
 *  - <Badge variant?>…</Badge>                            inline status pill (label via slot)
 *  - <CodeBlock code lang? filename? />                   dark mono code surface
 */
import Shell from '../../components/Shell.astro';
import MeshGradient from '../../components/MeshGradient.astro';
import HeroDemo from '../../components/home/HeroDemo.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import Badge from '../../components/Badge.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import FaqList from '../../components/FaqList.astro';
import JumpBackIn from '../../components/JumpBackIn.astro';
import ToolArt from '../../components/ToolArt.astro';
import TrackCard from '../../components/learn/TrackCard.astro';
import { site } from '../../data/site';
import { tools, liveTools, getTool, categoryAccent } from '../../data/tools';
import { tracks } from '../../data/learn';
import { program, phases as m90Phases, missions as m90Missions, totalCoreMinutes } from '../../data/mission90';
import { trackIcon } from '../../data/track-icons';
import { getGuidesForLocale, estimateReadingTime } from '../../lib/learn/guides';
import { faqPageLd } from '../../lib/jsonld';
import type { Locale as __Locale } from '../../i18n/config';
import { localizeKey as __l, localizeNavHref as __nav } from '../../i18n/utils';

const __lang = (Astro.currentLocale ?? 'en') as __Locale;

const alertLint = liveTools[0] ?? tools[0];
// Featured lead-band tool — mirrors the English homepage (see src/pages/index.astro):
// the universally-recognized subnet calculator, not the niche flagship.
const leadTool = getTool('subnet-calculator') ?? alertLint;

// Featured catalog grid — a CURATED set of 8 representative tools, mirrors English.
const featuredSlugs = [
  'loki-alert-rule-tester',
  'github-actions-validator',
  'subnet-calculator',
  'jwt-decoder',
  'docker-run-to-compose',
  'kubernetes-resource-calculator',
  'cron-expression-tester',
  'base64-encoder-decoder',
];
const featuredTools = featuredSlugs
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t) && t!.status === 'live');

// Learn band — /learn is English-only content (ENGLISH_ONLY_SECTIONS), so the
// guides themselves are fetched in English regardless of page locale.
const learnGuides = await getGuidesForLocale('en');
const learnByTrack = (slug: string) =>
  learnGuides.filter((g) => g.entry.data.track === slug).sort((x, y) => x.entry.data.order - y.entry.data.order);
const trackMeta = (slug: string) => {
  const gs = learnByTrack(slug);
  return {
    count: gs.length,
    minutes: gs.reduce((s, g) => s + (g.entry.data.estMinutes ?? estimateReadingTime(g.entry.body)), 0),
    difficulty: gs[0]?.entry.data.difficulty ?? 'beginner',
  };
};
const featuredTracks = tracks.filter((t) => ['linux', 'docker', 'kubernetes'].includes(t.slug));
const mission90Icon = trackIcon('mission-90');

// Mission-90 homepage feature band — figures derived from the registry, mirrors
// English. Mission-90 is also English-only content, so the transcript stays English.
const m90LiveMissions = m90Missions.filter((m) => m.status === 'live').length;
const m90Hours = Math.round(totalCoreMinutes / 60 / 10) * 10;
const m90Stats = [
  { n: String(program.totalDays), l: 'Tage' },
  { n: String(m90Phases.length), l: 'Phasen' },
  { n: String(m90LiveMissions), l: 'Browser-Missionen' },
  { n: `~${m90Hours}`, l: 'Std. Kerninhalt' },
];
const m90Transcript = `student@prod-web-01:~$ ps aux --sort=-%cpu | head -3
USER   PID   %CPU  COMMAND
root   4521  94.0  /opt/scripts/nightly-backup.sh
student@prod-web-01:~$ kill 4521
student@prod-web-01:~$ systemctl restart nginx
student@prod-web-01:~$ curl -sI localhost | head -1
HTTP/1.1 200 OK
# 02:07 — the site is back. You did that.`;

const faqs = [
  {
    q: 'Sind die OpsCanopy-Tools wirklich kostenlos?',
    a: 'Ja. Jedes Tool ist vollständig kostenlos, ohne Bezahlschranken, Nutzungslimits oder Premium-Stufen. Es gibt keinerlei Konto-Pflicht — öffnen Sie ein Tool in Ihrem Browser und nutzen Sie es sofort.',
  },
  {
    q: 'Muss ich mich registrieren, um diese Online-DevOps-Tools zu nutzen?',
    a: 'Nein. Es gibt keine Registrierung, kein Login und keine E-Mail-Erfassung. Öffnen Sie ein beliebiges Tool in Ihrem Browser-Tab und nutzen Sie es sofort — kein Konto, kein Cookie-Banner, keine Reibung. Die Web-Analyse läuft cookielos, sofern Sie nicht auf der Datenschutzseite ausdrücklich zustimmen.',
  },
  {
    q: 'Werden meine Daten auf einen Server hochgeladen, wenn ich die Tools nutze?',
    a: 'Nein. Jedes Tool läuft zu 100 % clientseitig in Ihrem Browser-Tab; nichts, was Sie einfügen, wird protokolliert, gespeichert oder hochgeladen. Ihre Daten verlassen den Browser nie.',
  },
  {
    q: 'Ist es sicher, ein JWT oder eine Konfiguration in ein browserbasiertes Tool einzufügen?',
    a: 'Bei OpsCanopy: ja. Das Decodieren und Parsen geschieht vollständig in lokalem JavaScript — nichts, was Sie einfügen, wird jemals übertragen, was Sie im Netzwerk-Tab des Browsers selbst überprüfen können (der einzige ausgehende Datenverkehr ist eine anonyme, cookielose Seiten-Analyse, die in unserer Datenschutzerklärung offengelegt ist). Als allgemeine Hygiene gilt: Geben Sie Signatur-Geheimnisse niemals an Dritte weiter — OpsCanopy lädt nichts von Ihren Eingaben hoch.',
  },
  {
    q: 'Funktionieren die Tools offline?',
    a: 'Sobald eine Tool-Seite geladen ist, funktioniert sie weiter, selbst wenn Sie die Internetverbindung trennen, denn die gesamte Verarbeitung erfolgt lokal und es gibt kein Backend, das aufgerufen werden müsste. Offline zu gehen ist außerdem eine einfache Möglichkeit, die Behauptung der clientseitigen Privatsphäre selbst zu überprüfen.',
  },
  {
    q: 'Für wen sind diese browserbasierten DevOps-Tools gedacht?',
    a: 'DevOps-Engineers, SREs, Sysadmins, Plattform- und Backend-Engineers — alle, die schnell Subnetz- und CIDR-Berechnungen, Cron-Zeitpläne, PromQL- oder LogQL-Abfragen, JWT-, Base64- und Hash-Werkzeuge, Timestamp-Umrechnung, GitHub-Actions-Validierung oder Kubernetes-Ressourcendimensionierung benötigen, ohne etwas zu installieren.',
  },
  {
    q: 'Warum diese Tools nutzen, statt ChatGPT oder Claude zu fragen?',
    a: 'Nutzen Sie beides — für unterschiedliche Aufgaben. Ein KI-Assistent ist hervorragend darin, Konzepte zu erklären und Konfigurationen zu entwerfen, aber er erzeugt plausiblen Text, statt Antworten zu berechnen, und exakte Arithmetik ist eine dokumentierte Schwachstelle: Subnetzgrenzen, Cron-Zeitpläne, Epoch-Umrechnungen und Regex-Verhalten sehen im Ergebnis regelmäßig richtig aus und sind trotzdem falsch. OpsCanopy-Tools berechnen Antworten deterministisch — echte Parser, exakte Mathematik — und rechnen sofort neu, während Sie die Eingabe anpassen, ohne erneutes Prompten, ohne Token-Kosten und ohne Rate-Limits; sobald die Seite eines Tools geladen ist, funktioniert sie auch offline weiter. Nichts, was Sie einfügen, wird jemals übertragen, sodass Logs, Tokens und Konfigurationen auf Ihrem Rechner bleiben. Mehrere Tools eignen sich sogar als praktische Kontrolle für KI-Antworten: Lassen Sie dasselbe Subnetz, denselben Cron-Ausdruck oder Timestamp durch sie laufen, und Sie erhalten die verlässliche Referenz für den Vergleich.',
  },
  {
    q: 'Wie unterscheidet sich OpsCanopy von anderen Online-Sammlungen für Entwickler-Tools?',
    a: 'Die meisten Tool-Sammlungen konzentrieren sich auf generische Formatierer. OpsCanopy spezialisiert sich auf DevOps- und SRE-Workflows — CIDR-Planung, Cron, PromQL und LogQL, Kubernetes-Kapazität, CI-Validatoren — durchgängig mit denselben Garantien: kostenlos, ohne Registrierung, zu 100 % clientseitig, nichts hochgeladen oder protokolliert.',
  },
  {
    q: 'Ich möchte DevOps-Engineer werden — wo fange ich an?',
    a: 'Beginnen Sie mit OpsCanopy Learn unter /learn. Es kombiniert eine gestaffelte DevOps-Karriere-Roadmap (/learn/roadmaps/devops) mit kostenlosen, praxisnahen Guides zu Linux, Docker, Kubernetes, AWS und Netzwerken — von den Grundlagen bis zur Jobreife. Während des Lesens können Sie sofort mit den passenden Tools im Katalog üben, keine Registrierung nötig.',
  },
];

// Quietly-stated trust principles for the value strip.
const principles = [
  { label: 'PREIS', title: 'Für immer kostenlos', body: 'Jedes Tool, ohne Bezahlschranke, ohne Testphase.', icon: '<path d="M3 11.4 11.4 3H19a2 2 0 0 1 2 2v7.6l-8.4 8.4a1.5 1.5 0 0 1-2.1 0L3 13.5a1.5 1.5 0 0 1 0-2.1Z"/><circle cx="15.8" cy="8.2" r="1.4"/>' },
  { label: 'LAUFZEITUMGEBUNG', title: 'Läuft in Ihrem Browser', body: 'Rein clientseitig. Nichts zu installieren.', icon: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 9h18"/><circle cx="6" cy="7" r="0.6" fill="currentColor"/>' },
  { label: 'DATENSCHUTZ', title: 'Ihre Daten bleiben lokal', body: 'Eingaben verlassen das Gerät nie. Offener Code — prüfen Sie ihn.', icon: '<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>' },
  { label: 'ZUGANG', title: 'Keine Registrierung', body: 'Öffnen Sie die Seite und legen Sie los.', icon: '<path d="M14 4h5a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1h-5"/><path d="M3 12h11m0 0-4-4m4 4-4 4"/>' },
];

// "Why a hub" value props — framed as what a returning user gets (mirrors English).
const whyCards = [
  {
    eyebrow: 'EIN ORT',
    title: 'Alles in einem Tab.',
    body: 'Setzen Sie ein Lesezeichen auf eine Website statt auf ein Dutzend. Wenn Sie einen Konverter, Validator oder Rechner brauchen, ist er schon da — gleiches Design, gleiche Abläufe, nichts neu zu lernen.',
    icon: '<path d="M3 20h18"/><path d="M6 20v-4M12 20V8M18 20v-9"/>',
  },
  {
    eyebrow: 'IMMER SCHNELL',
    title: 'Sofort, jedes Mal.',
    body: 'Jedes Tool ist statisch und clientseitig — keine Server-Warteschlangen, keine Kaltstarts. Die Seiten laden sofort, ob Sie allein zugreifen oder zehntausend andere gleichzeitig.',
    icon: '<path d="M13 3 5 13h6l-1 8 9-11h-6l1-7Z"/>',
  },
  {
    eyebrow: 'DATENSCHUTZ',
    title: 'Datenschutz ist ein Feature.',
    body: 'Ihre Regeln, Konfigurationen und Logs gehören Ihnen. Nichts wird hochgeladen, protokolliert oder nach Hause telefoniert — genau das ist der Sinn, es in Ihrem Tab laufen zu lassen.',
    icon: '<path d="M12 3 5 6v5c0 4.6 3.1 8.2 7 10 3.9-1.8 7-5.4 7-10V6l-7-3Z"/>',
  },
];

// CIDR breakdown snippet for the featured lead band (Subnet Calculator).
const leadToolSnippet = `> 10.20.0.0/22

Network address     10.20.0.0
Broadcast address    10.20.3.255
Netmask               255.255.252.0
Wildcard mask         0.0.3.255
Usable host range     10.20.0.1 – 10.20.3.254
Usable hosts          1,022
Total addresses       1,024`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: site.name,
    url: site.url,
    description: site.description,
    sameAs: [site.github, `https://x.com/${site.twitter.replace('@', '')}`],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: site.name,
    url: site.url,
    description: site.description,
    publisher: { '@type': 'Organization', name: site.name, url: site.url },
  },
  faqPageLd(faqs),
];
---

<Shell
  title="OpsCanopy — Kostenlose Online-DevOps- & SRE-Tools, ohne Registrierung"
  description="Kostenlose Online-DevOps-Tools, die zu 100 % in Ihrem Browser laufen — Subnetz-/CIDR-Rechner, Cron-Tester, JWT-Decoder & mehr. Ohne Registrierung, nichts wird hochgeladen."
  canonical="/"
  jsonLd={jsonLd}
>
  {/* ─────────────────────────── 1 · HERO ─────────────────────────── */}
  <section class="section-pad relative isolate overflow-hidden bg-canvas-soft">
    <MeshGradient class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[90%] opacity-90" />
    <div
      class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-32 bg-gradient-to-b from-canvas-soft to-transparent"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-48 bg-gradient-to-b from-transparent to-canvas-soft"
      aria-hidden="true"
    >
    </div>

    <div class="container-page relative z-10">
      <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[5fr_7fr] lg:gap-14">
        <div class="flex flex-col">
      <p class="eyebrow flex flex-wrap items-center gap-x-2 gap-y-1 text-mute">
        <span>{liveTools.length} Tools</span>
        <span aria-hidden="true" class="text-hairline">&bull;</span>
        <span>100 % clientseitig</span>
        <span aria-hidden="true" class="text-hairline">&bull;</span>
        <a
          href="https://github.com/opscanopy/opscanopy.com"
          target="_blank"
          rel="noopener noreferrer"
          class="underline decoration-hairline underline-offset-4 transition-colors hover:text-ink"
          >Open Source</a
        >
      </p>

      <h1 class="display-hero mt-4 max-w-xl text-balance text-ink">
        Ein Blätterdach an Tools für die Ops, die Sie tatsächlich machen.
      </h1>

      <p class="body-md mt-4 max-w-xl text-pretty text-body">
        Validatoren, Konverter, Tester und Linter für DevOps- und SRE-Engineers — Subnetz- und
        CIDR-Berechnungen, Cron, PromQL und LogQL, JWT und Kubernetes-Dimensionierung. Ohne
        Registrierung, und nichts, was Sie einfügen, verlässt Ihr Gerät.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3">
        <Button href={__l('/tools', __lang)} variant="primary">Tools entdecken — ohne Registrierung</Button>
        <a
          href={__nav('/learn', __lang)}
          class="link-inline group body-md inline-flex items-center gap-1 font-medium"
        >
          DevOps lernen
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>
        </div>

        <div class="flex justify-center lg:justify-end">
          <HeroDemo />
        </div>
      </div>
    </div>
  </section>

  {/* ─────────────────── 1b · JUMP BACK IN (pinned/recent tools) ─────────────────── */}
  <JumpBackIn heading="Schnellzugriff" lang="de" />

  {/* ─────────────────── 2 · FEATURED TOOL BAND (Subnet Calculator) ─────────────────── */}
  <section class="section-pad bg-canvas-soft" aria-labelledby="featured-tool">
    <div class="container-page">
      <div class="overflow-hidden rounded-xl bg-inverse text-inverse-fg shadow-float">
        <div class="grid grid-cols-1 gap-10 p-8 sm:p-12 lg:grid-cols-2 lg:items-center lg:gap-12 lg:p-16">
          <div class="flex min-w-0 flex-col">
            <span class="eyebrow text-cyan">Tool&nbsp;01 · Netzwerk</span>
            <h2 id="featured-tool" class="display-lg mt-4 text-balance text-inverse-fg">
              Subnetz-Mathematik mit einem einzigen Einfügen — Schluss mit dem Bit-Zählen von Hand.
            </h2>
            <p class="body-lg mt-5 max-w-xl text-pretty text-white/80">
              Geben Sie eine beliebige IPv4- oder IPv6-Adresse mit Präfix ein und erhalten Sie Netzwerk-
              und Broadcast-Adresse, Netzmaske, Wildcard, nutzbaren Host-Bereich und Adresszahlen —
              sofort, vollständig in Ihrem Browser.
            </p>
            <div class="mt-8">
              <Button href={__l(`/${leadTool.slug}`, __lang)} variant="secondary"><span translate="no">Subnet Calculator</span> öffnen</Button>
            </div>
          </div>

          <div class="min-w-0 lg:pl-2">
            <CodeBlock
              code={leadToolSnippet}
              lang="text"
              filename="subnet-calculator"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ─── 3 · TOOLS PREVIEW (the catalog leads — MVP first) ─── */}
  <section class="section-pad-lg bg-canvas" aria-labelledby="tools-preview">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">Der Katalog</span>
          <h2 id="tools-preview" class="display-lg mt-3 text-balance text-ink">Tools im Blätterdach.</h2>
          <p class="body-md mt-3 text-pretty text-body">
            Fokussierte Werkzeuge mit einem einzigen Zweck für Plattform- und DevOps-Engineers — jedes
            davon live, kostenlos und vollständig in Ihrem Browser laufend.
          </p>
        </div>
        <a
          href={__l('/tools', __lang)}
          class="link-inline group body-md inline-flex shrink-0 items-center gap-1 whitespace-nowrap font-medium"
        >
          Alle Tools ansehen
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>

      <ul class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          featuredTools.map((tool) => (
            <li class="h-full">
              <a
                href={__l(`/${tool.slug}`, __lang)}
                class="card-interactive group relative flex h-full min-w-0 flex-col overflow-hidden rounded-lg bg-canvas shadow-soft"
              >
                <ToolArt
                  slug={tool.slug}
                  accent={categoryAccent[tool.category]}
                  class="border-b border-hairline"
                />
                <div class="flex h-full min-w-0 flex-col p-6 sm:p-7">
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="display-sm min-w-0 break-words text-ink" translate="no">
                      {tool.name}
                    </h3>
                    <Badge variant="live" class="shrink-0">Live</Badge>
                  </div>
                  <p class="caption mt-2 inline-flex items-center gap-1.5 font-medium uppercase tracking-wide text-body">
                    <span
                      aria-hidden="true"
                      class="size-1.5 rounded-full"
                      style={`background:${categoryAccent[tool.category]}`}
                    />
                    {tool.category}
                  </p>
                  <p class="body-md mt-4 flex-1 text-pretty text-body">{tool.tagline}</p>
                  <span class="body-sm mt-6 inline-flex items-center gap-1 font-medium text-link">
                    Tool öffnen
                    <span
                      aria-hidden="true"
                      class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
                    >
                      &rarr;
                    </span>
                  </span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>

      <div class="mt-10 flex justify-center">
        <a
          href={__l('/tools', __lang)}
          class="group inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-6 py-3 text-link shadow-soft transition-colors duration-150 ease-out hover:border-brand-strong"
        >
          <span class="body-md font-medium">Alle {liveTools.length} Tools durchstöbern</span>
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>
    </div>
  </section>

  {/* ─── 3b · MISSION 90 — the flagship guided program, its own moment ─── */}
  <section class="section-pad bg-canvas-soft" aria-labelledby="mission90-home">
    <div class="container-page">
      <div class="overflow-hidden rounded-xl bg-inverse text-inverse-fg shadow-float">
        <div class="grid grid-cols-1 gap-10 p-8 sm:p-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-14 lg:p-16">
          <div class="flex min-w-0 flex-col">
            <span
              class="grid size-12 place-items-center rounded-xl border border-brand/30 bg-brand/10 text-brand"
              aria-hidden="true"
            >
              <svg width="26" height="26" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={mission90Icon} />
            </span>
            <span class="eyebrow mt-5 text-brand">Mission · 90 Days · DevOps</span>
            <h2 id="mission90-home" class="display-lg mt-3 text-balance text-inverse-fg">
              Vom Entwickler zum DevOps-Engineer in 90 Tagen.
            </h2>
            <p class="body-lg mt-5 max-w-xl text-pretty text-white/80">
              Ein kostenloser, geführter Weg — eine fokussierte Lektion pro Tag und am Ende jeder Woche
              eine story-getriebene Mission, die Sie direkt in Ihrem Browser-Terminal spielen, um ein
              kaputtes System zu reparieren. Alle 90 Tage und 10 Missionen sind jetzt live — ohne
              Registrierung.
            </p>

            <dl class="mt-8 grid grid-cols-2 gap-x-6 gap-y-5 sm:grid-cols-4">
              {
                m90Stats.map((s) => (
                  <div class="flex flex-col gap-1 border-l border-white/15 pl-4">
                    <dt class="display-sm text-inverse-fg">{s.n}</dt>
                    <dd class="caption text-white/60">{s.l}</dd>
                  </div>
                ))
              }
            </dl>

            <div class="mt-9 flex flex-wrap items-center gap-x-6 gap-y-3">
              <Button href={__nav('/mission-90', __lang)} variant="secondary">Tag 1 starten — kostenlos, ohne Registrierung</Button>
              <a
                href={__nav('/mission-90/missions', __lang)}
                class="link-inline group body-md inline-flex items-center gap-1 font-medium text-white/85 hover:text-white"
              >
                Missionen durchstöbern
                <span
                  aria-hidden="true"
                  class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
                >
                  &rarr;
                </span>
              </a>
            </div>
          </div>

          <div class="min-w-0">
            <div class="overflow-hidden rounded-xl border border-white/10 bg-black/30 shadow-float">
              <div class="flex items-center gap-2 border-b border-white/10 px-4 py-3">
                <span aria-hidden="true" class="size-3 rounded-full bg-white/20"></span>
                <span aria-hidden="true" class="size-3 rounded-full bg-white/20"></span>
                <span aria-hidden="true" class="size-3 rounded-full bg-white/20"></span>
                <span class="caption ml-3 truncate text-white/50">mission: server-down</span>
              </div>
              <pre class="overflow-x-auto p-5 font-mono text-[13px] leading-relaxed text-white/85"><code>{m90Transcript}</code></pre>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

