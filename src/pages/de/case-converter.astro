---
/**
 * Case Converter — the case-converter tool page (SEO surface).
 * Convert any identifier or phrase between camelCase, PascalCase, snake_case,
 * SCREAMING_SNAKE_CASE, kebab-case, Title Case and more — all in the browser.
 */
import Shell from '../../components/Shell.astro';
import CaseConverterPlayground from '../../components/CaseConverterPlayground.astro';
import Button from '../../components/Button.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ToolHero from '../../components/ToolHero.astro';
import ToolPipeline from '../../components/ToolPipeline.astro';
import FaqList from '../../components/FaqList.astro';
import ToolCrossLinks from '../../components/ToolCrossLinks.astro';
import { site, navLinks } from '../../data/site';
import { getTool } from '../../data/tools';
import { softwareAppLd, faqPageLd } from '../../lib/jsonld';

const tool = getTool('case-converter');
const pagePath = '/case-converter/';
const pageUrl = `${site.url}${pagePath}`;

const faqs = [
  {
    q: 'Welche Schreibweisen unterstützt der Konverter?',
    a: 'Elf auf einmal: camelCase, PascalCase, snake_case, SCREAMING_SNAKE_CASE, CONSTANT_CASE, kebab-case, Train-Case, Title Case, sentence case, dot.case und path/case. Einmal tippen und jede Schreibweise erscheint als kopierbare Zeile — nehmen Sie diejenige, die Ihre Sprache, Konfigurationsdatei oder URL benötigt.',
  },
  {
    q: 'Wie werden Wortgrenzen erkannt?',
    a: 'Der Tokenizer ist Unicode-fähig. Er trennt an Leerzeichen, Bindestrichen, Unterstrichen, Punkten, Schrägstrichen und anderen Symbolen sowie innerhalb von camelCase- und PascalCase-Höckern — sodass userProfileID, user_profile-id und „user profile ID“ alle zu denselben drei Wörtern führen. Auch Übergänge zwischen Buchstabe und Zahl werden getrennt, sodass v2Release zu v / 2 / release wird.',
  },
  {
    q: 'Wie werden Akronyme wie HTTP oder URL behandelt?',
    a: 'Akronyme werden normalisiert, nicht als Großbuchstaben erhalten. getURLFromString wird zu get / url / from / string, daher lautet die camelCase-Form getUrlFromString und die snake_case-Form get_url_from_string. Das ist einfacher und hin- und rückführbar stabil: Gibt man die camelCase-Ausgabe erneut ein, ergeben sich dieselben Wörter — was die Großbuchstaben-Alternative nicht garantieren kann.',
  },
  {
    q: 'Was ist der Unterschied zwischen SCREAMING_SNAKE_CASE und CONSTANT_CASE?',
    a: 'In der Praxis nichts — beide sind großgeschriebene, durch Unterstriche verbundene Wörter (USER_PROFILE_ID). Sie werden als zwei Zeilen geführt, weil verschiedene Communities unterschiedliche Namen verwenden: viele Stilrichtlinien sagen „SCREAMING_SNAKE_CASE“, andere (und einige Linter) nennen dieselbe Konvention „CONSTANT_CASE“ für Konstanten und Umgebungsvariablen.',
  },
  {
    q: 'Verlässt mein Text jemals meinen Browser?',
    a: 'Nein. Die Umwandlung läuft zu 100 % clientseitig in Ihrem Tab — es gibt keinen Server, kein Konto und keine Protokollierung. Sie können bedenkenlos Bezeichner, Spaltennamen oder private Zeichenketten einfügen; nichts wird über das Netzwerk übertragen.',
  },
  {
    q: 'Werden Nicht-ASCII-Text und Unicode verarbeitet?',
    a: 'Ja. Die Grenzerkennung nutzt Unicode-Buchstaben- und -Zahleneigenschaften, sodass akzentuierte und nicht-lateinische Buchstaben innerhalb ihres Wortes bleiben — straßeName teilt sich in straße / name, und die akzentuierten Zeichen bleiben in der Ausgabe erhalten, wo die Schreibweise Buchstaben unverändert lässt.',
  },
  {
    q: 'Warum nicht einfach eine KI die Schreibweise umwandeln lassen?',
    a: 'Ein Sprachmodell sagt Zeichen vorher; es führt keinen deterministischen Tokenizer aus. Bei allem, was länger als ein paar Wörter ist, kann es Tokens auf schwer erkennbare Weise weglassen, zusammenführen oder falsch schreiben. Dieses Tool wendet jedes Mal dieselben expliziten Grenzregeln an, sodass die Ausgabe reproduzierbar ist — dieselbe Eingabe ergibt stets dieselben elf Zeilen.',
  },
  {
    q: 'Kann ich eine bestimmte Umwandlung teilen?',
    a: 'Ja. Sobald Sie eine Eingabe haben, kopiert „Copy link“ eine URL mit Ihrem Text, kodiert in einem #q=-Fragment. Das Öffnen dieses Links stellt die Eingabe wieder her und führt die Umwandlung erneut aus — praktisch, um ein Beispiel in ein Code-Review oder Issue einzufügen.',
  },
];

const softwareApp = softwareAppLd({
  name: 'Case Converter',
  description:
    'Kostenloser Online-Case-Converter. Wandeln Sie beliebige Zeichenketten auf einmal zwischen camelCase, PascalCase, snake_case, SCREAMING_SNAKE_CASE, kebab-case, Title Case und mehr um. Unicode-fähig, 100 % im Browser, ohne Anmeldung.',
  url: pageUrl,
  subCategory: 'Utilities',
  featureList: [
    'Umwandlung in camelCase, PascalCase, snake_case und acht weitere Stile auf einmal',
    'Unicode-fähige Wortgrenzenerkennung mit camelCase-Höcker-Trennung',
    'Kopieren pro Zeile, alles kopieren und teilbare Deep-Links',
    '100 % clientseitig, kein Upload, keine Anmeldung',
  ],
  keywords: tool?.keywords.join(', '),
});
const faqPage = faqPageLd(faqs);

const pipeline = [
  {
    title: 'In Wörter zerlegen.',
    body: 'Ihr Text wird an Leerzeichen, Symbolen und camelCase-Höckern tokenisiert — getHTTPResponse wird zu get / http / response.',
  },
  {
    title: 'Die Tokens normalisieren.',
    body: 'Jedes Wort wird kleingeschrieben und Akronyme werden eingegliedert, sodass dieselbe Phrase stets dieselbe Wortliste ergibt.',
  },
  {
    title: 'Pro Stil neu zusammensetzen.',
    body: 'Wörter werden je Konvention verbunden und geschrieben — ein anfänglich kleines camelCase, Unterstrich-snake_case, Bindestrich-kebab-case und so weiter.',
  },
  {
    title: 'Die benötigte Form kopieren.',
    body: 'Jeder Stil erscheint als beschriftete Zeile mit eigenem Copy-Button — oder „Copy all“, um den gesamten Satz auf einmal zu übernehmen.',
  },
];

const caseGrid = `input    userProfileID   ("user profile ID")

camelCase             userProfileId
PascalCase            UserProfileId
snake_case            user_profile_id
SCREAMING_SNAKE_CASE  USER_PROFILE_ID
CONSTANT_CASE         USER_PROFILE_ID
kebab-case            user-profile-id
Train-Case            User-Profile-Id
Title Case            User Profile Id
sentence case         User profile id
dot.case              user.profile.id
path/case             user/profile/id`;

const tokenExample = `getHTTPResponse   ->  get / http / response
user_profile-id   ->  user / profile / id
XMLHttpRequest    ->  xml / http / request
v2Release         ->  v / 2 / release
Release2          ->  release / 2`;

import type { Locale as __Locale } from '../../i18n/config';
import { localizeKey as __l } from '../../i18n/utils';
const __lang = (Astro.currentLocale ?? 'en') as __Locale;
---

<Shell
  title="Case Converter — camelCase, snake_case & mehr, im Browser"
  description="Kostenloser Case-Converter. Wandeln Sie beliebige Zeichenketten auf einmal zwischen camelCase, PascalCase, snake_case, SCREAMING_SNAKE_CASE, kebab-case, Title Case und mehr um. Unicode-fähig, 100 % im Browser, ohne Anmeldung."
  canonical="/case-converter"
  jsonLd={[softwareApp, faqPage]}
>
  <ToolHero
    slug="case-converter"
    eyebrow="Case Converter · Utilities"
    badges={[
      { label: 'Läuft in Ihrem Browser', variant: 'live' },
      { label: '11 Schreibweisen', variant: 'neutral' },
      { label: 'Keine Anmeldung', variant: 'neutral' },
    ]}
  >
    <Fragment slot="headline">Eine Phrase, jede Schreibweise.</Fragment>
    <Fragment slot="lead">
      Tippen oder fügen Sie einen beliebigen Bezeichner ein und lesen Sie ihn zurück als
      <span class="code-mono text-ink" translate="no">camelCase</span>,
      <span class="code-mono text-ink" translate="no">snake_case</span>,
      <span class="code-mono text-ink" translate="no">kebab-case</span> und acht weitere — jede Zeile
      kopierbar, Unicode-fähig und vollständig in Ihrem Browser berechnet. Kostenlos, ohne Anmeldung,
      und Ihr Text verlässt niemals Ihr Gerät.
    </Fragment>
  </ToolHero>

  <section id="playground" class="scroll-mt-24 bg-canvas-soft pt-8 pb-20 sm:pb-24">
    <div class="container-page">
      <h2 class="sr-only">Case-Converter-Playground</h2>
      <CaseConverterPlayground />
    </div>
  </section>

  <section id="why" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
        <div>
          <p class="eyebrow">Die Lücke</p>
          <h2 class="display-lg mt-3 text-balance text-ink">
            Die richtigen Wörter, die falsche Form.
          </h2>
        </div>
        <div class="space-y-4">
          <p class="body-md text-pretty text-body">
            Einen Bezeichner umzubenennen ist selten einmalig. Die Datenbank will
            <span class="code-mono text-ink" translate="no">snake_case</span>, die JSON-API will
            <span class="code-mono text-ink" translate="no">camelCase</span>, die Umgebungsvariable
            will <span class="code-mono text-ink" translate="no">SCREAMING_SNAKE_CASE</span>
            und der URL-Slug will <span class="code-mono text-ink" translate="no">kebab-case</span>
            — dieselben drei Wörter in fünf Formen neu zu tippen ist genau die Stelle, an der sich ein
            Tippfehler einschleicht.
          </p>
          <p class="body-md text-pretty text-body">
            Dieser kostenlose Case-Converter liest Ihren Text einmal, erkennt Wortgrenzen sogar
            innerhalb von camelCase-Höckern und Akronymen und gibt jeden Stil auf einmal aus, sodass
            Sie die benötigte Form kopieren können. Er ist Unicode-fähig, sodass akzentuierte und
            nicht-lateinische Bezeichner korrekt getrennt werden — und er läuft vollständig im
            Browser, ohne Installation und ohne dass Daten Ihr Gerät verlassen.
          </p>
          <p class="body-md text-pretty text-body">
            Bitten Sie auch keine KI darum: Ein Sprachmodell sagt Zeichen vorher, statt einen
            Tokenizer auszuführen, und es lässt in einem langen Bezeichner still ein Wort weg oder
            schreibt es falsch. Dieses Tool wendet jedes Mal explizite Grenzregeln an, sodass
            dieselbe Eingabe stets dieselben Zeilen erzeugt.
          </p>
          <p class="body-sm text-mute">
            Brauchen Sie stattdessen einen URL-Slug? Das
            <a class="link-inline" href={__l("/slugify", __lang)}>Slugify-Tool</a> behandelt
            Diakritika, Trennzeichen und Längenbegrenzungen.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ToolPipeline
    id="how-it-works"
    eyebrow="Die Pipeline"
    heading="So funktioniert es."
    lead="Vier deterministische Schritte laufen bei jedem Tastendruck — alle innerhalb Ihres Browser-Tabs, mit demselben Tokenizer für jede Schreibweise."
    steps={pipeline}
  />

  <section id="reference" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Schreibweisen-Referenz</p>
        <h2 class="display-lg mt-3 text-ink">Jeder Stil, nebeneinander.</h2>
        <p class="body-md mx-auto mt-3 max-w-xl text-pretty text-body">
          Eine Eingabe, elf Konventionen. Die Wortgrenzen werden einmal erkannt; zwischen den Zeilen
          ändern sich nur der Verbinder und die Groß-/Kleinschreibung.
        </p>
      </div>
      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-2">
        <div class="min-w-0">
          <h3 class="display-sm text-ink">Die elf Schreibweisen</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            Aus einer Phrase — <span class="code-mono text-ink" translate="no">userProfileID</span> —
            jede Schreibweise, die der Konverter ausgibt.
          </p>
          <CodeBlock lang="text" filename="case-styles" code={caseGrid} />
        </div>
        <div class="min-w-0">
          <h3 class="display-sm text-ink">Wie Grenzen getrennt werden</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            Trennzeichen, camelCase-Höcker, Akronym-Läufe und Buchstabe/Zahl-Übergänge werden alle zu
            Wortgrenzen.
          </p>
          <CodeBlock lang="text" filename="tokenizer" code={tokenExample} />
        </div>
      </div>
    </div>
  </section>

  <section id="next" class="scroll-mt-24 bg-inverse text-inverse-fg">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
        <div class="min-w-0">
          <p class="eyebrow !text-cyan">Nächster Schritt</p>
          <h2 class="display-lg mt-3 text-balance text-inverse-fg">
            Aus einem Titel eine URL machen? Slugify es.
          </h2>
          <p class="body-md mt-4 text-pretty text-white/70">
            kebab-case kommt nah heran, aber ein URL-Slug muss auch Diakritika falten, Symbole
            entfernen und eine Länge begrenzen. Das <span translate="no">Slugify</span>-Tool tut genau
            das — oder durchstöbern Sie das übrige <span translate="no">Utilities</span>-Regal für
            weitere Bezeichner- und Texthelfer, alles in Ihrem Browser.
          </p>
          <div class="mt-7 flex flex-wrap items-center gap-3">
            <Button href={__l("/slugify", __lang)} variant="secondary">Slugify öffnen</Button>
            <Button href="/tools/utilities/" variant="secondary">Utilities durchsuchen</Button>
          </div>
        </div>
        <CodeBlock
          lang="text"
          filename="slug.txt"
          code={`Case Converter Guide   (title)
->  kebab-case            case-converter-guide
->  Slugify               case-converter-guide  (url-safe)`}
        />
      </div>
    </div>
  </section>

  <FaqList faqs={faqs} />

  <ToolCrossLinks slug="case-converter" lang={__lang}>
    <Fragment slot="lead">
      Der Case Converter ist eines der Werkzeuge in
      <span translate="no">{site.name}</span> — einem wachsenden Schirm browserbasierter Validatoren,
      Konverter und Tester, die niemals einen Server berühren.
    </Fragment>
    <Fragment slot="links">
      Verwandte Werkzeuge: das
      <a class="link-inline" href={__l("/slugify", __lang)}>Slugify-Tool</a> für URL-sichere Slugs,
      oder durchstöbern Sie das vollständige
      <a class="link-inline" href={__l(navLinks[0].href, __lang)}>Werkzeugverzeichnis</a>.
    </Fragment>
    <Fragment slot="disclaimer">
      Bereitgestellt wie besehen zur bequemen Nutzung. <span translate="no">{site.name}</span> ist
      kostenlos und offen.
    </Fragment>
  </ToolCrossLinks>
</Shell>
