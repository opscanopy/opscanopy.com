// в”Җв”Җ FAQ content вҖ” single source for both the rendered section and FAQPage LD в”Җ
const faqs = [
  {
    q: 'Was ist der Cron Expression Tester?',
    a: 'Es ist ein kostenloses, browserbasiertes Tool, das jeden Cron-Ausdruck im crontab-Stil liest, ihn in eine verstГӨndliche Beschreibung in Klartext Гјbersetzt und die nГӨchsten AusfГјhrungszeitpunkte berechnet. FГјgen Sie eine Zeile wie вҖһ*/15 9-17 * * 1-5вҖң ein, und Sie sehen sofort вҖһAlle 15 Minuten, zwischen 09:00 und 17:00 Uhr, Montag bis FreitagвҖң sowie die anstehenden AusfГјhrungszeitpunkte вҖ” ohne Registrierung, ohne Server-Roundtrip.',
  },
  {
    q: 'VerlГӨsst mein Cron-Ausdruck jemals meinen Browser?',
    a: 'Nein. Das Parsen, die ErklГӨrung in Klartext und die Berechnung der nГӨchsten AusfГјhrung erfolgen allesamt clientseitig in Ihrem Tab. Es wird nichts an einen Server hochgeladen, es gibt kein Konto und kein Logging. Sie kГ¶nnen ZeitplГӨne aus internen oder sensiblen Systemen bedenkenlos einfГјgen.',
  },
  {
