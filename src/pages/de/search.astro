---
/**
 * /de/search — German mirror of /search. See src/pages/search.astro and
 * src/components/SearchPage.astro for the shared implementation notes.
 */
import Shell from '../../components/Shell.astro';
import SearchPage from '../../components/SearchPage.astro';
import { DEFAULT_LOCALE, type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';

const lang: Locale = (Astro.currentLocale as Locale) ?? DEFAULT_LOCALE;
const t = useTranslations(lang);
---

<Shell
  title={t('search.title')}
  description={t('search.metaDescription')}
  canonical="/search"
  noindex={true}
  noAlternates={true}
  searchIndex={false}
>
  <SearchPage />
</Shell>
