---
/**
 * /tools — the OpsCanopy catalog.
 * Users come here to use a tool, so the live-tools grid sits at the top with
 * minimal scroll. Live tools render as accented cards. Catalog content is
 * sourced from ../../data/tools — never hardcoded here.
 */
import Shell from '../../../components/Shell.astro';
import Card from '../../../components/Card.astro';
import Badge from '../../../components/Badge.astro';
import { liveTools, accentEdgeClass } from '../../../data/tools';
import { site } from '../../../data/site';

// ItemList JSON-LD over the live catalog (ordered, with positions).
const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'OpsCanopy tools',
  description:
    'Des outils gratuits, exécutés dans le navigateur, pour les ingénieurs plateforme et DevOps. Sans inscription, sans serveur ; vos données restent sur votre appareil.',
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  numberOfItems: liveTools.length,
  itemListElement: liveTools.map((tool, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: tool.name,
    description: tool.tagline,
    url: `${site.url}/${tool.slug}`,
  })),
};
import type { Locale as __Locale } from '../../../i18n/config';
import { localizeKey as __l } from '../../../i18n/utils';
const __lang = (Astro.currentLocale ?? 'en') as __Locale;

---

<Shell
  title="Outils — OpsCanopy"
  description="Des outils gratuits, exécutés dans le navigateur, pour les ingénieurs plateforme et DevOps. Sans inscription, sans serveur ; vos données restent sur votre appareil."
  canonical="/tools"
  jsonLd={itemList}
>
  <!-- ── Header block ─────────────────────────────────────────────────── -->
  <section class="border-b border-hairline bg-canvas-soft">
    <div class="container-page py-8 sm:py-10">
      <div class="max-w-3xl">
        <h1 class="display-lg text-balance text-ink">Toute la boîte à outils, à un onglet près.</h1>
        <p class="body-md mt-3 max-w-2xl text-pretty text-body">
          Des outils DevOps ciblés qui s'exécutent entièrement dans votre navigateur : gratuits, sans inscription, et rien de ce que vous y collez ne quitte jamais votre appareil.
        </p>
        <div class="mt-5 flex flex-wrap items-center gap-3">
          <span class="badge">
            <span class="size-1.5 rounded-full bg-success" aria-hidden="true"></span>
            <span class="tabular-nums">{liveTools.length}</span> en service
          </span>
          <span class="badge">100%&nbsp;côté client</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Live tools ───────────────────────────────────────────────────── -->
  <section aria-labelledby="live-heading" class="bg-canvas">
    <div class="container-page py-16 sm:py-24">
      <div class="flex items-end justify-between gap-6">
        <div class="min-w-0">
          <p class="eyebrow">Disponibles maintenant</p>
          <h2 id="live-heading" class="display-lg mt-3 text-balance text-ink">Outils en service.</h2>
        </div>
      </div>

      {
        liveTools.length === 0 ? (
          <div class="card-soft mt-10 flex flex-col items-center rounded-lg px-6 py-16 text-center">
            <p class="display-sm text-ink">Rien en service pour l'instant.</p>
            <p class="body-md mt-3 max-w-md text-pretty text-body">
              Le premier outil est en cours de finition avant sa mise en ligne : revenez bientôt pour découvrir ce qui arrive.
            </p>
          </div>
        ) : (
          <div class="mb-8 space-y-4">
  <input
    id="tool-search"
    type="search"
    placeholder="Rechercher des outils…"
    autocomplete="off"
    class="w-full rounded-lg border border-hairline bg-canvas px-4 py-2.5 text-sm text-ink placeholder:text-mute focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
    aria-label="Rechercher des outils"
  />
  <div id="cat-filters" role="group" aria-label="Filtrer par catégorie" class="flex flex-wrap gap-2">
    <button data-cat="all" class="cat-chip badge cursor-pointer select-none transition-colors hover:bg-brand/10 aria-pressed:bg-brand aria-pressed:text-white" aria-pressed="true">Tous</button>
    <button data-cat="networking" class="cat-chip badge cursor-pointer select-none transition-colors hover:bg-brand/10 aria-pressed:bg-brand aria-pressed:text-white" aria-pressed="false">Réseau</button>
    <button data-cat="security" class="cat-chip badge cursor-pointer select-none transition-colors hover:bg-brand/10 aria-pressed:bg-brand aria-pressed:text-white" aria-pressed="false">Sécurité</button>
    <button data-cat="encoding" class="cat-chip badge cursor-pointer select-none transition-colors hover:bg-brand/10 aria-pressed:bg-brand aria-pressed:text-white" aria-pressed="false">Encodage</button>
    <button data-cat="kubernetes" class="cat-chip badge cursor-pointer select-none transition-colors hover:bg-brand/10 aria-pressed:bg-brand aria-pressed:text-white" aria-pressed="false">Kubernetes</button>
    <button data-cat="observability" class="cat-chip badge cursor-pointer select-none transition-colors hover:bg-brand/10 aria-pressed:bg-brand aria-pressed:text-white" aria-pressed="false">Observabilité</button>
    <button data-cat="ci/cd" class="cat-chip badge cursor-pointer select-none transition-colors hover:bg-brand/10 aria-pressed:bg-brand aria-pressed:text-white" aria-pressed="false">CI/CD</button>
    <button data-cat="scheduling" class="cat-chip badge cursor-pointer select-none transition-colors hover:bg-brand/10 aria-pressed:bg-brand aria-pressed:text-white" aria-pressed="false">Planification</button>
    <button data-cat="logs" class="cat-chip badge cursor-pointer select-none transition-colors hover:bg-brand/10 aria-pressed:bg-brand aria-pressed:text-white" aria-pressed="false">Logs</button>
    <button data-cat="config" class="cat-chip badge cursor-pointer select-none transition-colors hover:bg-brand/10 aria-pressed:bg-brand aria-pressed:text-white" aria-pressed="false">Config</button>
  </div>
  <p id="tool-empty" class="hidden body-md text-mute py-4">Aucun outil ne correspond à votre recherche.</p>
</div>
          <ul role="list" class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
            {liveTools.map((tool) => (
              <li class="h-full tool-card" data-name={tool.name.toLowerCase()} data-category={tool.category.toLowerCase()}>
                <Card class="card-interactive group relative flex h-full flex-col overflow-hidden rounded-lg p-0 shadow-soft focus-within:shadow-float focus-within:ring-2 focus-within:ring-link focus-within:ring-offset-2">
                  <span
                    class:list={[
                      'block h-1 w-full bg-gradient-to-r',
                      accentEdgeClass[tool.accent],
                    ]}
                    aria-hidden="true"
                  />
                  <div class="flex h-full flex-col p-6">
                    <div class="flex items-center justify-between gap-3">
                      <p class="eyebrow min-w-0 truncate">{tool.category}</p>
                      <Badge variant="live">En service</Badge>
                    </div>

                    <h3 class="display-sm mt-4 text-balance text-ink">
                      <a
                        href={__l(`/${tool.slug}`, __lang)}
                        class="rounded-sm outline-none after:absolute after:inset-0 after:content-['']"
                      >
                        {tool.name}
                      </a>
                    </h3>
                    <p class="body-md mt-1.5 font-medium text-pretty text-ink">{tool.tagline}</p>
                    <p class="body-sm mt-3 text-pretty text-body">{tool.description}</p>

                    <ul role="list" class="mt-5 flex flex-wrap gap-2">
                      {tool.keywords.slice(0, 3).map((keyword) => (
                        <li class="min-w-0">
                          <span class="badge code-mono max-w-full break-words lowercase text-body">{keyword}</span>
                        </li>
                      ))}
                    </ul>

                    <div class="mt-auto pt-6">
                      <span class="link-inline body-sm inline-flex items-center gap-1 font-medium">
                        Ouvrir l'outil
                        <span
                          class="transition-transform duration-150 group-hover:translate-x-0.5"
                          aria-hidden="true"
                        >
                          &rarr;
                        </span>
                      </span>
                    </div>
                  </div>
                </Card>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</Shell>

<script>
  (function () {
    var search = document.getElementById("tool-search");
    var empty = document.getElementById("tool-empty");
    var activeCat = "all";
    function filter() {
      var q = search ? search.value.toLowerCase().trim() : "";
      var cards = document.querySelectorAll(".tool-card");
      var visible = 0;
      cards.forEach(function(card) {
        var name = (card.dataset.name || "");
        var cat = (card.dataset.category || "");
        var matchSearch = !q || name.indexOf(q) !== -1;
        var matchCat = activeCat === "all" || cat === activeCat;
        var show = matchSearch && matchCat;
        card.style.display = show ? "" : "none";
        if (show) visible++;
      });
      if (empty) empty.classList.toggle("hidden", visible > 0);
    }
    if (search) search.addEventListener("input", filter);
    document.querySelectorAll(".cat-chip").forEach(function(btn) {
      btn.addEventListener("click", function() {
        activeCat = btn.dataset.cat || "all";
        document.querySelectorAll(".cat-chip").forEach(function(b) {
          b.setAttribute("aria-pressed", b === btn ? "true" : "false");
        });
        filter();
      });
    });
  })();
</script>