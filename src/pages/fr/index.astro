---
/**
 * OpsCanopy hub homepage — the flagship marketing surface.
 * Composes the Vercel-inspired design system defined in global.css / DESIGN.md.
 * Structural mirror of src/pages/index.astro (English) — see that file for the
 * canonical section order; keep both in sync when the layout changes.
 *
 * Component prop contracts (provided by sibling agents in src/components/*):
 *  - <MeshGradient class="…" />                          atmospheric hero backdrop
 *  - <Button href variant="primary|secondary" size? />   marketing pill CTA (label via slot)
 *  - <Card class? as?>…</Card>                            canvas card chrome (slot body)
 *  - <Badge variant?>…</Badge>                            inline status pill (label via slot)
 *  - <CodeBlock code lang? filename? />                   dark mono code surface
 */
import Shell from '../../components/Shell.astro';
import MeshGradient from '../../components/MeshGradient.astro';
import HeroDemo from '../../components/home/HeroDemo.astro';
import TerminalPlay from '../../components/TerminalPlay.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import Badge from '../../components/Badge.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import FaqList from '../../components/FaqList.astro';
import JumpBackIn from '../../components/JumpBackIn.astro';
import ToolArt from '../../components/ToolArt.astro';
import TrackCard from '../../components/learn/TrackCard.astro';
import { site } from '../../data/site';
import { tools, liveTools, getTool, categoryAccent } from '../../data/tools';
import { tracks } from '../../data/learn';
import { program, phases as m90Phases, missions as m90Missions, totalCoreMinutes } from '../../data/mission90';
import { trackIcon } from '../../data/track-icons';
import { getGuidesForLocale, estimateReadingTime } from '../../lib/learn/guides';
import { faqPageLd } from '../../lib/jsonld';
import type { Locale as __Locale } from '../../i18n/config';
import { localizeKey as __l, localizeNavHref as __nav } from '../../i18n/utils';

const __lang = (Astro.currentLocale ?? 'en') as __Locale;

const alertLint = liveTools[0] ?? tools[0];
// Featured lead-band tool — mirrors the English homepage (see src/pages/index.astro):
// the universally-recognized subnet calculator, not the niche flagship.
const leadTool = getTool('subnet-calculator') ?? alertLint;

// Featured catalog grid — a CURATED set of 9 representative tools, mirrors English.
const featuredSlugs = [
  'loki-alert-rule-tester',
  'github-actions-validator',
  'subnet-calculator',
  'jwt-decoder',
  'docker-run-to-compose',
  'kubernetes-resource-calculator',
  'cron-expression-tester',
  'base64-encoder-decoder',
  'uuid-ulid-generator',
];
const featuredTools = featuredSlugs
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t) && t!.status === 'live');

// Learn band — /learn is English-only content (ENGLISH_ONLY_SECTIONS), so the
// guides themselves are fetched in English regardless of page locale.
const learnGuides = await getGuidesForLocale('en');
const learnByTrack = (slug: string) =>
  learnGuides.filter((g) => g.entry.data.track === slug).sort((x, y) => x.entry.data.order - y.entry.data.order);
const trackMeta = (slug: string) => {
  const gs = learnByTrack(slug);
  return {
    count: gs.length,
    minutes: gs.reduce((s, g) => s + (g.entry.data.estMinutes ?? estimateReadingTime(g.entry.body)), 0),
    difficulty: gs[0]?.entry.data.difficulty ?? 'beginner',
  };
};
const featuredTracks = tracks.filter((t) => ['linux', 'docker', 'kubernetes'].includes(t.slug));
const mission90Icon = trackIcon('mission-90');

// Mission-90 homepage feature band — figures derived from the registry, mirrors
// English. Mission-90 is also English-only content, so the transcript stays English.
const m90LiveMissions = m90Missions.filter((m) => m.status === 'live').length;
const m90Hours = Math.round(totalCoreMinutes / 60 / 10) * 10;
const m90Stats = [
  { n: String(program.totalDays), l: 'jours' },
  { n: String(m90Phases.length), l: 'phases' },
  { n: String(m90LiveMissions), l: 'missions navigateur' },
  { n: `~${m90Hours}`, l: 'heures de contenu' },
];
const m90Transcript = `student@prod-web-01:~$ ps aux --sort=-%cpu | head -3
USER   PID   %CPU  COMMAND
root   4521  94.0  /opt/scripts/nightly-backup.sh
student@prod-web-01:~$ kill 4521
student@prod-web-01:~$ systemctl restart nginx
student@prod-web-01:~$ curl -sI localhost | head -1
HTTP/1.1 200 OK
# 02:07 — the site is back. You did that.`;

const faqs = [
  {
    q: 'Les outils OpsCanopy sont-ils vraiment gratuits ?',
    a: 'Oui. Chaque outil est entièrement gratuit, sans péage, sans limite d’utilisation ni offre premium. Aucun compte n’est requis, d’aucune sorte : ouvrez un outil dans votre navigateur et commencez à l’utiliser immédiatement.',
  },
  {
    q: 'Dois-je m’inscrire pour utiliser ces outils DevOps en ligne ?',
    a: 'Non. Il n’y a ni inscription, ni connexion, ni collecte d’adresse e-mail. Ouvrez n’importe quel outil dans un onglet de votre navigateur et utilisez-le immédiatement : sans compte, sans bannière de cookies, sans friction. La mesure d’audience fonctionne sans cookies, sauf si vous l’acceptez sur la page de confidentialité.',
  },
  {
    q: 'Mes données sont-elles envoyées à un serveur lorsque j’utilise les outils ?',
    a: 'Non. Chaque outil s’exécute à 100 % côté client dans l’onglet de votre navigateur ; rien de ce que vous collez n’est journalisé, stocké ni envoyé. Vos données ne quittent jamais le navigateur.',
  },
  {
    q: 'Est-il sûr de coller un JWT ou une configuration dans un outil basé sur le navigateur ?',
    a: 'Sur OpsCanopy, oui. Le décodage et l’analyse se déroulent entièrement en JavaScript local — rien de ce que vous collez n’est jamais transmis, ce que vous pouvez vérifier vous-même dans l’onglet réseau du navigateur (le seul trafic sortant est une mesure d’audience anonyme et sans cookies, décrite dans notre politique de confidentialité). Par hygiène générale, ne partagez jamais de secrets de signature avec un tiers, mais OpsCanopy n’envoie rien de ce que vous saisissez.',
  },
  {
    q: 'Les outils fonctionnent-ils hors ligne ?',
    a: 'Une fois la page d’un outil chargée, elle continue de fonctionner même si vous vous déconnectez d’Internet, car tout le traitement est local et il n’y a aucun backend à appeler. Se mettre hors ligne est aussi un moyen simple de vérifier vous-même l’affirmation de confidentialité côté client.',
  },
  {
    q: 'À qui s’adressent ces outils DevOps basés sur le navigateur ?',
    a: 'Aux ingénieurs DevOps, SRE, administrateurs système, ingénieurs plateforme et backend : à toute personne qui a besoin de calculs rapides de sous-réseaux et de CIDR, de planifications cron, de requêtes PromQL ou LogQL, d’utilitaires JWT, Base64 et de hachage, de conversion d’horodatages, de validation GitHub Actions ou de dimensionnement de ressources Kubernetes, sans rien installer.',
  },
  {
    q: 'Pourquoi utiliser ces outils plutôt que de demander à ChatGPT ou Claude ?',
    a: 'Utilisez les deux — pour des tâches différentes. Un assistant IA excelle à expliquer des concepts et à ébaucher des configurations, mais il génère du texte plausible plutôt que de calculer des réponses, et l’arithmétique exacte est une faiblesse documentée : limites de sous-réseaux, planifications cron, conversions d’epoch et comportement des regex reviennent régulièrement en ayant l’air corrects tout en étant faux. Les outils OpsCanopy calculent les réponses de manière déterministe — vrais parseurs, calculs exacts — et recalculent instantanément à mesure que vous ajustez l’entrée, sans nouveau prompt, sans coût en tokens et sans limite de débit ; une fois la page d’un outil chargée, elle continue de fonctionner hors ligne. Rien de ce que vous collez n’est jamais transmis : vos journaux, jetons et configurations restent donc sur votre machine. Plusieurs outils font même office de vérificateurs d’IA bien pratiques : passez-y le même sous-réseau, la même expression cron ou le même horodatage, et vous obtenez la référence exacte à laquelle comparer.',
  },
  {
    q: 'En quoi OpsCanopy se distingue-t-il des autres collections d’outils pour développeurs en ligne ?',
    a: 'La plupart des collections d’outils se concentrent sur des formateurs génériques. OpsCanopy se spécialise dans les flux de travail DevOps et SRE : planification de CIDR, cron, PromQL et LogQL, capacité Kubernetes, validateurs CI, avec les mêmes garanties partout : gratuit, sans inscription, 100 % côté client, rien d’envoyé ni de journalisé.',
  },
  {
    q: 'Je veux devenir ingénieur DevOps — par où commencer ?',
    a: 'Commencez avec OpsCanopy Learn sur /learn. Il associe une feuille de route de carrière DevOps par étapes (/learn/roadmaps/devops) à des guides gratuits et pratiques couvrant Linux, Docker, Kubernetes, AWS et les réseaux — des fondamentaux jusqu’à un profil prêt pour l’emploi. Au fil de votre lecture, vous pouvez vous entraîner immédiatement avec les outils correspondants du catalogue, sans inscription requise.',
  },
];

// Quietly-stated trust principles for the value strip.
const principles = [
  { label: 'PRIX', title: 'Gratuit pour toujours', body: 'Chaque outil, sans péage, sans essai.', icon: '<path d="M3 11.4 11.4 3H19a2 2 0 0 1 2 2v7.6l-8.4 8.4a1.5 1.5 0 0 1-2.1 0L3 13.5a1.5 1.5 0 0 1 0-2.1Z"/><circle cx="15.8" cy="8.2" r="1.4"/>' },
  { label: 'EXÉCUTION', title: 'S’exécute dans votre navigateur', body: 'Pur côté client. Rien à installer.', icon: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 9h18"/><circle cx="6" cy="7" r="0.6" fill="currentColor"/>' },
  { label: 'CONFIDENTIALITÉ', title: 'Vos données restent en local', body: 'Les entrées ne quittent jamais l’appareil. Code ouvert — auditez-le.', icon: '<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>' },
  { label: 'ACCÈS', title: 'Sans inscription', body: 'Ouvrez la page et mettez-vous au travail.', icon: '<path d="M14 4h5a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1h-5"/><path d="M3 12h11m0 0-4-4m4 4-4 4"/>' },
];

// "Why a hub" value props, mirrors English.
const whyCards = [
  {
    eyebrow: 'UN SEUL ENDROIT',
    title: 'Tout dans un seul onglet.',
    body: 'Un seul favori au lieu d’une douzaine. Quand il vous faut un convertisseur, un validateur ou une calculatrice, il est déjà là — même apparence, mêmes raccourcis, rien à réapprendre.',
    icon: '<path d="M3 20h18"/><path d="M6 20v-4M12 20V8M18 20v-9"/>',
  },
  {
    eyebrow: 'TOUJOURS RAPIDE',
    title: 'Instantané, à chaque fois.',
    body: 'Chaque outil est statique et s’exécute côté client : aucune file d’attente serveur, aucun démarrage à froid. Les pages se chargent instantanément, que vous soyez seul ou dix mille à la fois.',
    icon: '<path d="M13 3 5 13h6l-1 8 9-11h-6l1-7Z"/>',
  },
  {
    eyebrow: 'CONFIDENTIALITÉ',
    title: 'La confidentialité est une fonctionnalité.',
    body: 'Vos règles, configurations et journaux sont les vôtres. Rien n’est envoyé, journalisé ni rapatrié : c’est justement tout l’intérêt de l’exécuter dans votre onglet.',
    icon: '<path d="M12 3 5 6v5c0 4.6 3.1 8.2 7 10 3.9-1.8 7-5.4 7-10V6l-7-3Z"/>',
  },
];


const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: site.name,
    url: site.url,
    description: site.description,
    sameAs: [site.github, `https://x.com/${site.twitter.replace('@', '')}`],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: site.name,
    url: site.url,
    description: site.description,
    publisher: { '@type': 'Organization', name: site.name, url: site.url },
  },
  faqPageLd(faqs),
];
---

<Shell
  title="OpsCanopy — Outils DevOps et SRE en ligne, gratuits et sans inscription"
  description="Des outils DevOps en ligne gratuits qui s’exécutent à 100 % dans votre navigateur : calculatrices de sous-réseau/CIDR, testeurs de cron, décodeur de JWT et plus. Sans inscription, rien d’envoyé."
  canonical="/"
  jsonLd={jsonLd}
>
  {/* ─────────────────────────── 1 · HERO ─────────────────────────── */}
  <section class="section-pad relative isolate overflow-hidden bg-canvas-soft">
    <MeshGradient class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[90%] opacity-90" />
    <div
      class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-32 bg-gradient-to-b from-canvas-soft to-transparent"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-48 bg-gradient-to-b from-transparent to-canvas-soft"
      aria-hidden="true"
    >
    </div>

    <div class="container-page relative z-10">
      <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[5fr_7fr] lg:gap-14">
        <div class="flex flex-col">
      <p class="eyebrow flex flex-wrap items-center gap-x-2 gap-y-1 text-mute">
        <span>{liveTools.length} outils</span>
        <span aria-hidden="true" class="text-hairline">&bull;</span>
        <span>100 % côté client</span>
        <span aria-hidden="true" class="text-hairline">&bull;</span>
        <a
          href="https://github.com/opscanopy/opscanopy.com"
          target="_blank"
          rel="noopener noreferrer"
          class="underline decoration-hairline underline-offset-4 transition-colors hover:text-ink"
          >Open source</a
        >
      </p>

      <h1 class="display-hero mt-4 max-w-xl text-balance text-ink">
        Une canopée d’outils pour les opérations que vous menez vraiment.
      </h1>

      <p class="body-md mt-4 max-w-xl text-pretty text-body">
        Validateurs, convertisseurs, testeurs et linters pour ingénieurs DevOps et SRE — calculs de
        sous-réseaux et de CIDR, cron, PromQL et LogQL, JWT et dimensionnement Kubernetes. Sans
        inscription, et rien de ce que vous collez ne quitte votre appareil.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3">
        <Button href={__l('/tools', __lang)} variant="primary">Explorer les outils — sans inscription</Button>
        <a
          href={__nav('/learn', __lang)}
          class="link-inline group body-md inline-flex items-center gap-1 font-medium"
        >
          Apprendre DevOps
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>
        </div>

        <div class="flex justify-center lg:justify-end">
          <HeroDemo />
        </div>
      </div>
    </div>
  </section>

  {/* ─────────────────── 1b · JUMP BACK IN (pinned/recent tools) ─────────────────── */}
  <JumpBackIn heading="Reprenez où vous en étiez" lang="fr" />

  {/* ─── 3 · TOOLS PREVIEW (the catalog leads — MVP first) ─── */}
  <section class="section-pad-lg bg-canvas" aria-labelledby="tools-preview">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">Le catalogue</span>
          <h2 id="tools-preview" class="display-lg mt-3 text-balance text-ink">Des outils dans la canopée.</h2>
          <p class="body-md mt-3 text-pretty text-body">
            Des utilitaires ciblés, à usage unique, pour ingénieurs plateforme et DevOps : chacun en
            ligne, gratuit et s’exécutant entièrement dans votre navigateur.
          </p>
        </div>
        <a
          href={__l('/tools', __lang)}
          class="link-inline group body-md inline-flex shrink-0 items-center gap-1 whitespace-nowrap font-medium"
        >
          Voir tous les outils
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>

      <ul class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          featuredTools.map((tool) => (
            <li class="h-full">
              <a
                href={__l(`/${tool.slug}`, __lang)}
                class="card-interactive group relative flex h-full min-w-0 flex-col overflow-hidden rounded-lg bg-canvas shadow-soft"
              >
                <ToolArt
                  slug={tool.slug}
                  accent={categoryAccent[tool.category]}
                  class="border-b border-hairline"
                />
                <div class="flex h-full min-w-0 flex-col p-6 sm:p-7">
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="display-sm min-w-0 break-words text-ink" translate="no">
                      {tool.name}
                    </h3>
                    <Badge variant="live" class="shrink-0">En ligne</Badge>
                  </div>
                  <p class="caption mt-2 inline-flex items-center gap-1.5 font-medium uppercase tracking-wide text-body">
                    <span
                      aria-hidden="true"
                      class="size-1.5 rounded-full"
                      style={`background:${categoryAccent[tool.category]}`}
                    />
                    {tool.category}
                  </p>
                  <p class="body-md mt-4 flex-1 text-pretty text-body">{tool.tagline}</p>
                  <span class="body-sm mt-6 inline-flex items-center gap-1 font-medium text-link">
                    Ouvrir l’outil
                    <span
                      aria-hidden="true"
                      class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
                    >
                      &rarr;
                    </span>
                  </span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>

      <div class="mt-10 flex justify-center">
        <a
          href={__l('/tools', __lang)}
          class="group inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-6 py-3 text-link shadow-soft transition-colors duration-150 ease-out hover:border-brand-strong"
        >
          <span class="body-md font-medium">Parcourir les {liveTools.length} outils</span>
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>
    </div>
  </section>

  {/* ─── 3b · MISSION 90 — the flagship guided program, its own moment ─── */}
  <section class="section-pad bg-canvas-soft" aria-labelledby="mission90-home">
    <div class="container-page">
      <div class="overflow-hidden rounded-xl bg-inverse text-inverse-fg shadow-float">
        <div class="grid grid-cols-1 gap-10 p-8 sm:p-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-14 lg:p-16">
          <div class="flex min-w-0 flex-col">
            <span
              class="grid size-12 place-items-center rounded-xl border border-brand/30 bg-brand/10 text-brand"
              aria-hidden="true"
            >
              <svg width="26" height="26" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={mission90Icon} />
            </span>
            <span class="eyebrow mt-5 text-brand">Mission · 90 Days · DevOps</span>
            <h2 id="mission90-home" class="display-lg mt-3 text-balance text-inverse-fg">
              De développeur à ingénieur DevOps en 90 jours.
            </h2>
            <p class="body-lg mt-5 max-w-xl text-pretty text-white/80">
              Un parcours gratuit et guidé — une leçon ciblée par jour, et à la fin de chaque semaine
              une mission narrative que vous jouez directement dans le terminal de votre navigateur
              pour réparer un système en panne. Les 90 jours et les 10 missions sont disponibles dès
              maintenant — sans inscription.
            </p>

            <dl class="mt-8 grid grid-cols-2 gap-x-6 gap-y-5 sm:grid-cols-4">
              {
                m90Stats.map((s) => (
                  <div class="flex flex-col gap-1 border-l border-white/15 pl-4">
                    <dt class="display-sm text-inverse-fg">{s.n}</dt>
                    <dd class="caption text-white/60">{s.l}</dd>
                  </div>
                ))
              }
            </dl>

            <div class="mt-9 flex flex-wrap items-center gap-x-6 gap-y-3">
              <Button href={__nav('/mission-90', __lang)} variant="secondary">Commencer le jour 1 — gratuit, sans inscription</Button>
              <a
                href={__nav('/mission-90/missions', __lang)}
                class="link-inline group body-md inline-flex items-center gap-1 font-medium text-white/85 hover:text-white"
              >
                Parcourir les missions
                <span
                  aria-hidden="true"
                  class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
                >
                  &rarr;
                </span>
              </a>
            </div>
          </div>

          <div class="min-w-0">
            <TerminalPlay transcript={m90Transcript} title="mission: server-down" class="shadow-float" />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ─── 4 · LEARN DEVOPS (route homepage authority into /learn) ─── */}
  <section class="section-pad-lg bg-canvas-soft" aria-labelledby="learn-devops">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">Learn DevOps</span>
          <h2 id="learn-devops" class="display-lg mt-3 text-balance text-ink">
            Feuilles de route et guides pratiques gratuits.
          </h2>
          <p class="body-md mt-3 text-pretty text-body">
            Passez des fondamentaux à un profil prêt pour l’emploi grâce à des feuilles de route de
            carrière par étapes et des guides pratiques approfondis — Linux, Docker, Kubernetes, AWS et
            réseaux. Gratuit, sans inscription, et vous pouvez vous entraîner avec les outils au fur et
            à mesure.
          </p>
        </div>
        <a
          href={__nav('/learn', __lang)}
          class="link-inline group body-md inline-flex shrink-0 items-center gap-1 whitespace-nowrap font-medium"
        >
          Parcourir tous les guides
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>

      <div class="mt-8">
        <Button href={__nav('/learn/roadmaps/devops', __lang)} variant="primary">Commencer avec la feuille de route DevOps</Button>
      </div>

      <ul role="list" class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredTracks.map((track) => {
          const m = trackMeta(track.slug);
          return <TrackCard track={track} guideCount={m.count} difficulty={m.difficulty} minutes={m.minutes} />;
        })}
      </ul>
    </div>
  </section>

  {/* ───────────────────── 5 · VALUE / TRUST STRIP ───────────────────── */}
  <section class="section-pad-sm bg-canvas" aria-label="Pourquoi OpsCanopy est différent">
    <div class="container-page border-t border-hairline pt-12 sm:pt-14">
      <ul class="grid grid-cols-1 gap-x-8 gap-y-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          principles.map((p) => (
            <li class="flex min-w-0 flex-col gap-2 sm:[&:not(:first-child)]:border-l sm:[&:not(:first-child)]:border-hairline sm:[&:not(:first-child)]:pl-8">
              <span class="mb-1 inline-flex size-9 items-center justify-center rounded-lg bg-brand/10 text-brand-strong">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={p.icon} />
              </span>
              <span class="eyebrow">{p.label}</span>
              <span class="body-md font-medium text-ink">{p.title}</span>
              <span class="body-sm text-pretty text-mute">{p.body}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ─── 6 · WHY A HUB (what you get, not our business thesis) ─── */}
  <section id="why" class="section-pad bg-canvas-soft">
    <div class="container-page">
      <div class="max-w-2xl">
        <span class="eyebrow">Pourquoi OpsCanopy</span>
        <h2 class="display-lg mt-4 text-balance text-ink">Une boîte à outils, pas vingt onglets.</h2>
        <p class="body-lg mt-5 text-pretty text-body">
          Chaque outil partage les mêmes garanties de confidentialité, les mêmes pages statiques
          rapides et une seule recherche pour l’ensemble — changer de tâche ne veut pas dire changer
          de niveau de confiance.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          whyCards.map((c) => (
            <Card class="flex h-full min-w-0 flex-col p-6 sm:p-8">
              <span class="mb-4 inline-flex size-10 items-center justify-center rounded-lg bg-brand/10 text-brand-strong">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={c.icon} />
              </span>
              <span class="eyebrow">{c.eyebrow}</span>
              <h3 class="display-sm mt-3 text-balance text-ink">{c.title}</h3>
              <p class="body-md mt-3 text-pretty text-body">{c.body}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  {/* ─────────────────────────── 7 · PRIVACY ─────────────────────────── */}
  <section id="privacy" class="section-pad bg-canvas" aria-labelledby="privacy-heading">
    <div class="container-page">
      <Card class="flex flex-col gap-6 p-8 sm:p-12 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">Confidentialité</span>
          <h2 id="privacy-heading" class="display-md mt-3 text-balance text-ink">
            Rien de ce que vous collez ne quitte votre onglet.
          </h2>
          <p class="body-md mt-4 text-pretty text-body">
            Chaque outil <span translate="no">OpsCanopy</span> s’exécute comme du JavaScript statique dans votre
            navigateur. Il n’y a aucun backend pour recevoir vos règles, configurations ou journaux : aucun envoi, aucune
            télémétrie sur vos entrées, aucun compte à créer. Fermez l’onglet et tout disparaît.
          </p>
        </div>
        <div class="shrink-0">
          <span class="badge">
            <span aria-hidden="true" class="size-1.5 rounded-full bg-cyan"></span>
            100%&nbsp;client-side
          </span>
        </div>
      </Card>
    </div>
  </section>

  {/* ─────────────────────────── 8 · FAQ ─────────────────────────── */}
  <FaqList faqs={faqs} />

  {/* ───────────────────────── 9 · FOOTER CTA ───────────────────────── */}
  <section class="section-pad bg-canvas-soft" aria-labelledby="closing-cta">
    <div class="container-page">
      <div class="flex flex-col items-center gap-6 text-center">
        <h2 id="closing-cta" class="display-xl max-w-3xl text-balance text-ink">
          Trouvez votre outil. Évitez l’installation.
        </h2>
        <p class="body-lg max-w-xl text-pretty text-body">
          Gratuit, privé et instantané. Ouvrez le catalogue et mettez l’outil adéquat au travail dans
          votre prochain déploiement.
        </p>
        <div class="mt-2">
          <Button href={__l('/tools', __lang)} variant="primary">Trouver un outil — ouvrir le catalogue</Button>
        </div>
      </div>
    </div>
  </section>
</Shell>
