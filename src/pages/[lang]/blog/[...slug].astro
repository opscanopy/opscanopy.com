---
/**
 * /<locale>/blog/[slug] — per-locale single post (one route handles all
 * prefixed locales). Only emits pages for posts that exist in that locale, so
 * we never serve English text under a localized URL.
 */
import BlogPost from '../../../components/page/BlogPost.astro';
import { getAllPosts } from '../../../i18n/blog';
import { LOCALES, DEFAULT_LOCALE, type Locale } from '../../../i18n/config';

export async function getStaticPaths() {
  // Fetch the collection once, then index slug → locales it exists in, instead
  // of re-scanning per post (was O(posts² × locales) getCollection calls).
  const all = await getAllPosts();
  const localesBySlug = new Map<string, Set<Locale>>();
  for (const p of all) {
    if (!localesBySlug.has(p.slug)) localesBySlug.set(p.slug, new Set());
    localesBySlug.get(p.slug)!.add(p.lang);
  }
  return all
    .filter((post) => post.lang !== DEFAULT_LOCALE) // English served at /blog
    .map((post) => {
      const langs = localesBySlug.get(post.slug)!;
      const available = LOCALES.filter((l) => langs.has(l));
      return { params: { lang: post.lang, slug: post.slug }, props: { post, lang: post.lang, available } };
    });
}

const { post, lang, available } = Astro.props as {
  post: Awaited<ReturnType<typeof getPostsForLocale>>[number];
  lang: Locale;
  available: Locale[];
};
---

<BlogPost post={post} lang={lang} available={available} />
