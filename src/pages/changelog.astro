---
/**
 * /changelog — English-only (see ENGLISH_ONLY_SECTIONS in i18n/paths.ts).
 * Every live tool, newest-updated first, using the same git-derived dates
 * (scripts/gen-tool-meta.mjs) as ToolHero's "Updated" badge and the catalog's
 * "Newest" sort — one honest recency signal, not three different ones.
 */
import Shell from '../components/Shell.astro';
import { liveTools, categoryAccent } from '../data/tools';
import { getToolUpdatedAt } from '../data/tool-meta';
import { site } from '../data/site';
import { useTranslations } from '../i18n/utils';
import { DEFAULT_LOCALE, BCP47 } from '../i18n/config';

const lang = DEFAULT_LOCALE;
const t = useTranslations(lang);

const rows = liveTools
  .map((tool) => ({ tool, updatedAt: getToolUpdatedAt(tool.slug) }))
  .filter((r): r is { tool: (typeof liveTools)[number]; updatedAt: string } => !!r.updatedAt)
  .sort((a, b) => (a.updatedAt < b.updatedAt ? 1 : a.updatedAt > b.updatedAt ? -1 : 0));

const dateFmt = new Intl.DateTimeFormat(BCP47[lang], { dateStyle: 'medium' });
function formatDate(iso: string): string {
  return dateFmt.format(new Date(`${iso}T00:00:00Z`));
}

const description =
  'Every OpsCanopy tool, newest-updated first — a git-derived, honest recency signal for the whole catalog.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: t('changelog.metaTitle'),
  description,
  url: `${site.url}/changelog/`,
  isPartOf: { '@type': 'WebSite', name: site.name, url: site.url },
};
---

<Shell
  title={`${t('changelog.metaTitle')} — ${site.name}`}
  description={description}
  canonical="/changelog"
  jsonLd={jsonLd}
  noAlternates
  searchIndex={false}
>
  <section class="container-page py-16 sm:py-20">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow">{t('changelog.metaTitle')}</p>
      <h1 class="display-lg mt-3 text-balance text-ink">Changelog</h1>
      <p class="body-md mx-auto mt-3 max-w-xl text-pretty text-body">{description}</p>
    </div>

    <ul role="list" class="mx-auto mt-12 flex max-w-2xl flex-col gap-2">
      {
        rows.map(({ tool, updatedAt }) => (
          <li>
            <a
              href={`/${tool.slug}/`}
              class="card-soft group flex items-center justify-between gap-4 p-4 transition-colors hover:border-brand"
            >
              <span class="flex min-w-0 items-center gap-2.5">
                <span
                  class="inline-block size-2 shrink-0 rounded-full"
                  style={`background-color: ${categoryAccent[tool.category] ?? 'var(--color-mute)'}`}
                  aria-hidden="true"
                />
                <span class="min-w-0">
                  <span class="body-md block truncate font-medium text-ink">{tool.name}</span>
                  <span class="caption block truncate text-mute">{tool.tagline}</span>
                </span>
              </span>
              <time datetime={updatedAt} class="caption shrink-0 text-mute code-mono">
                {formatDate(updatedAt)}
              </time>
            </a>
          </li>
        ))
      }
    </ul>

    {
      rows.length < liveTools.length && (
        <p class="body-sm mx-auto mt-8 max-w-2xl text-center text-mute">
          {liveTools.length - rows.length} tool(s) have no recorded commit history yet and are
          omitted above.
        </p>
      )
    }
  </section>
</Shell>
