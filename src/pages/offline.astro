---
/**
 * /offline — the service worker's navigation fallback (see
 * scripts/sw.template.js: an uncached page, fetched with no network, falls
 * back here). English-only utility page, same tier as 404/500 — no locale
 * copies. Precached by scripts/gen-sw.mjs on every build (by URL, along with
 * whatever content-hashed assets this exact page references), so it renders
 * even on a first-ever offline visit.
 */
import Shell from '../components/Shell.astro';
import Button from '../components/Button.astro';
import MeshGradient from '../components/MeshGradient.astro';
---

<Shell
  title="You're offline — OpsCanopy"
  description="No connection right now — tools you've already visited still work."
  canonical="/offline"
  noindex={true}
  noAlternates={true}
>
  <section class="relative isolate overflow-hidden">
    <MeshGradient class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[420px] opacity-60" />

    <div class="container-page flex min-h-[70vh] flex-col items-center justify-center py-24 text-center sm:py-32">
      <p class="eyebrow mb-5">Offline</p>

      <h1 class="display-xl text-ink">No connection<span class="sr-only"> — you're offline</span></h1>

      <p class="body-lg mt-5 max-w-md text-balance text-body">
        This page hasn't been visited before, so it isn't saved for offline use yet.
        Any tool you've already opened in this browser still works — every OpsCanopy
        tool runs entirely on your device once its page has loaded.
      </p>

      <div class="mt-9 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
        <button type="button" id="offline-retry" class="btn btn-primary">Try again</button>
        <Button href="/" variant="secondary">Back to Home</Button>
      </div>
    </div>
  </section>
</Shell>

<script>
  document.getElementById('offline-retry')?.addEventListener('click', () => {
    location.reload();
  });
</script>
