---
/**
 * MAC Address Formatter — the mac-address-formatter tool page (SEO surface).
 * Paste a MAC / EUI-48 in any notation; get every canonical form plus the
 * decoded U/L and I/G bits and the derived EUI-64 — entirely in the browser.
 */
import Shell from '../components/Shell.astro';
import MacFormatterPlayground from '../components/MacFormatterPlayground.astro';
import Button from '../components/Button.astro';
import CodeBlock from '../components/CodeBlock.astro';
import ToolHero from '../components/ToolHero.astro';
import ToolPipeline from '../components/ToolPipeline.astro';
import FaqList from '../components/FaqList.astro';
import ToolCrossLinks from '../components/ToolCrossLinks.astro';
import { site, navLinks } from '../data/site';
import { getTool } from '../data/tools';
import { softwareAppLd, faqPageLd } from '../lib/jsonld';

const tool = getTool('mac-address-formatter');
const pagePath = '/mac-address-formatter';
const pageUrl = `${site.url}${pagePath}`;

const faqs = [
  {
    q: 'What does the MAC Address Formatter do?',
    a: 'Paste a 48-bit MAC / EUI-48 address in any notation — colon-separated (00:1B:44:11:3A:B7), hyphenated (00-1B-44-11-3A-B7), Cisco dotted (001b.4411.3ab7) or bare hex (001B44113AB7) — and it re-emits every other notation at once, decodes the U/L and I/G bits, and derives the matching EUI-64 identifier. Everything is computed in your browser; nothing is uploaded.',
  },
  {
    q: 'Does my address ever leave my browser?',
    a: 'No. Detection, parsing and formatting all run 100% client-side in your tab — there is no server, no account and no logging. You can safely paste hardware addresses from internal inventory.',
  },
  {
    q: 'Which MAC notations does it read and emit?',
    a: 'It reads colon, hyphen, Cisco dot (xxxx.xxxx.xxxx) and bare-hex notations, in upper or lower case, and tolerates surrounding whitespace. It emits the colon, hyphen, Cisco dot and bare forms in both cases, so you can copy whichever your switch, hypervisor or config file expects.',
  },
  {
    q: 'What do the U/L and I/G bits mean?',
    a: 'They are the two least-significant bits of the first octet. The I/G bit (bit 0) is the individual/group flag: 0 is a unicast address, 1 is a multicast (group) address. The U/L bit (bit 1) is the universal/local flag: 0 means a globally unique, OUI-assigned address from the manufacturer, 1 means the address is locally administered — for example a randomised or virtual-machine MAC.',
  },
  {
    q: 'What is EUI-64, and how does a link-local address relate?',
    a: 'EUI-64 is the 64-bit interface identifier derived from a 48-bit MAC by inserting FF:FE in the middle and flipping the U/L bit. It is the historical way an IPv6 host built the host half of its address: prepend the fe80::/64 link-local prefix to that EUI-64 and you get the interface’s link-local IPv6 address. The formatter shows both the modified EUI-64 and the resulting fe80:: address.',
  },
];

const softwareApp = softwareAppLd({
  name: 'MAC Address Formatter',
  description:
    'Paste a 48-bit MAC address in any notation and get every canonical form, the decoded U/L and I/G bits and the derived EUI-64 — 100% in your browser.',
  url: pageUrl,
  subCategory: 'Networking',
  featureList: [
    'Re-emit a MAC in colon, hyphen, Cisco dot and bare-hex notations',
    'Decode the U/L (universal/local) and I/G (individual/group) bits',
    'Derive the modified EUI-64 and fe80:: link-local address',
    '100% client-side, no upload, no signup',
  ],
  keywords: tool?.keywords.join(', '),
});
const faqPage = faqPageLd(faqs);

const pipeline = [
  {
    title: 'Detect the form.',
    body: 'Colons, hyphens, Cisco dots or bare hex are all recognised, in either case, with whitespace trimmed.',
  },
  {
    title: 'Strip to 48 bits.',
    body: 'Separators are removed and the twelve hex digits are read as a single canonical 48-bit value.',
  },
  {
    title: 'Re-emit every notation.',
    body: 'That value is rendered back out in the colon, hyphen, Cisco dot and bare forms, upper and lower case.',
  },
  {
    title: 'Flag the bits.',
    body: 'The first octet yields the U/L and I/G flags, and inserting FF:FE derives the modified EUI-64.',
  },
];

const bitsTable = `first octet  00  →  0000 0000
              bit 0  I/G = 0  unicast (individual)
              bit 1  U/L = 0  universal (OUI-assigned)

first octet  02  →  0000 0010
              bit 0  I/G = 0  unicast
              bit 1  U/L = 1  locally administered

first octet  01  →  0000 0001
              bit 0  I/G = 1  multicast (group)`;

const eui64Example = `MAC          00:1B:44:11:3A:B7
notations    00-1B-44-11-3A-B7   (hyphen)
             001b.4411.3ab7      (Cisco dot)
             001B44113AB7        (bare hex)
EUI-64       02:1B:44:FF:FE:11:3A:B7   (U/L flipped)
link-local   fe80::21b:44ff:fe11:3ab7`;
---

<Shell
  title="MAC Address Formatter — Convert Notations, Decode U/L & I/G, EUI-64"
  description="Paste a 48-bit MAC address in any notation and get every canonical form, the decoded U/L and I/G bits and the derived EUI-64 — 100% in your browser."
  canonical="/mac-address-formatter"
  jsonLd={[softwareApp, faqPage]}
>
  <ToolHero
    eyebrow="MAC Address Formatter · Networking"
    badges={[
      { label: 'Runs in your browser', variant: 'live' },
      { label: 'EUI-48 & EUI-64', variant: 'neutral' },
      { label: 'No signup', variant: 'neutral' },
    ]}
  >
    <Fragment slot="headline">Reformat any MAC address and decode its bits.</Fragment>
    <Fragment slot="lead">
      Paste a MAC in any notation —
      <span class="code-mono text-ink" translate="no">00:1B:44:11:3A:B7</span> — to get every
      canonical form, the U/L and I/G flags, and the derived EUI-64 — all in your browser.
    </Fragment>
  </ToolHero>

  <section id="playground" class="scroll-mt-24 bg-canvas-soft pt-8 pb-20 sm:pb-24">
    <div class="container-page">
      <h2 class="sr-only">MAC Address Formatter playground</h2>
      <MacFormatterPlayground />
    </div>
  </section>

  <section id="why" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
        <div>
          <p class="eyebrow">The Gap</p>
          <h2 class="display-lg mt-3 text-balance text-ink">
            Same address, a different notation in every tool.
          </h2>
        </div>
        <div class="space-y-4">
          <p class="body-md text-pretty text-body">
            A switch prints a MAC with colons, Cisco IOS wants it dotted, a DHCP reservation takes
            hyphens, and your script reads bare hex. Re-typing twelve hex digits between forms is
            tedious and a single transposed nibble points at the wrong device.
          </p>
          <p class="body-md text-pretty text-body">
            This formatter reads whatever notation you paste and shows the rest instantly — plus it
            decodes the U/L and I/G bits so you can tell an OUI-assigned address from a locally
            administered one, and derives the EUI-64 used to build IPv6 interface identifiers.
            Entirely in the browser, with nothing to install.
          </p>
          <p class="body-sm text-mute">
            Working with the IP side instead? Open the
            <a class="link-inline" href="/ip-address-converter">IP Address Converter</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ToolPipeline
    id="how-it-works"
    eyebrow="The Pipeline"
    heading="How it works."
    lead="Four deterministic steps run on every keystroke — all inside your browser tab, with no network calls."
    steps={pipeline}
  />

  <section id="reference" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Bits & Notations</p>
        <h2 class="display-lg mt-3 text-ink">What the formatter decodes.</h2>
        <p class="body-md mx-auto mt-3 max-w-xl text-pretty text-body">
          A MAC is 48 bits — six octets. The two low bits of the first octet carry meaning, and the
          whole address can be written four equivalent ways.
        </p>
      </div>
      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-2">
        <div class="min-w-0">
          <h3 class="display-sm text-ink">The U/L &amp; I/G bits</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            Bit 0 of the first octet is the <span class="code-mono text-ink" translate="no">I/G</span>
            (individual/group) flag; bit 1 is the
            <span class="code-mono text-ink" translate="no">U/L</span> (universal/local) flag.
          </p>
          <CodeBlock lang="text" filename="mac-bits" code={bitsTable} />
        </div>
        <div class="min-w-0">
          <h3 class="display-sm text-ink">Notations &amp; EUI-64</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            The same MAC in each form, plus the modified
            <span class="code-mono text-ink" translate="no">EUI-64</span> and its
            <span class="code-mono text-ink" translate="no">fe80::</span> link-local address.
          </p>
          <CodeBlock lang="text" filename="mac-eui64" code={eui64Example} />
        </div>
      </div>
    </div>
  </section>

  <section id="next" class="scroll-mt-24 bg-inverse text-inverse-fg">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
        <div class="min-w-0">
          <p class="eyebrow !text-cyan">Next Step</p>
          <h2 class="display-lg mt-3 text-balance text-inverse-fg">
            Got the link-local address? See it in every form.
          </h2>
          <p class="body-md mt-4 text-pretty text-white/70">
            The EUI-64 gives you an IPv6 interface identifier. Drop the resulting
            <span translate="no">fe80::</span> address into the
            <span translate="no">IP Address Converter</span> to expand it, compress it and read it as
            an integer — or open the <span translate="no">Subnet Calculator</span> for the prefix
            maths.
          </p>
          <div class="mt-7 flex flex-wrap items-center gap-3">
            <Button href="/ip-address-converter" variant="secondary">Open the IP Converter</Button>
          </div>
        </div>
        <CodeBlock
          lang="text"
          filename="derive.txt"
          code={`00:1B:44:11:3A:B7
  →  02:1B:44:FF:FE:11:3A:B7   (EUI-64)
  →  fe80::21b:44ff:fe11:3ab7  (link-local)`}
        />
      </div>
    </div>
  </section>

  <FaqList faqs={faqs} />

  <ToolCrossLinks>
    <Fragment slot="lead">
      The MAC Address Formatter is one tool in
      <span translate="no">{site.name}</span> — a growing canopy of browser-based validators,
      converters and testers that never touch a server.
    </Fragment>
    <Fragment slot="links">
      More networking: the
      <a class="link-inline" href="/subnet-calculator">Subnet Calculator</a> and the
      <a class="link-inline" href="/ip-address-converter">IP Address Converter</a>, or browse the
      full <a class="link-inline" href={navLinks[0].href}>tools directory</a>.
    </Fragment>
    <Fragment slot="disclaimer">
      Provided as-is for convenience. <span translate="no">{site.name}</span> is free and open.
    </Fragment>
  </ToolCrossLinks>
</Shell>
