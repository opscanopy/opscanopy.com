---
/**
 * /verify-ai — the "Verify the AI" hub. English-only V1 (not in header nav;
 * no ENGLISH_ONLY_SECTIONS entry needed since nothing links a locale-prefixed
 * copy). Explains the flagship differentiator (deterministic tools checking
 * an AI's claimed answer) and deep-links each of the 4 V1 tools' collapsed
 * verify panel via /<slug>/#verify-ai.
 *
 * The "Where models go wrong" transcripts are [PLACEHOLDER]-gated exactly
 * like the /about bios: this page must not deploy with a fabricated AI
 * transcript. The worked "correct answer" lines ARE real, computed facts —
 * only the "here's what an AI actually said" quotes are placeholdered.
 */
import Shell from '../components/Shell.astro';
import Button from '../components/Button.astro';
import FaqList from '../components/FaqList.astro';
import { site } from '../data/site';
import { getTool } from '../data/tools';
import { faqPageLd, itemListLd } from '../lib/jsonld';

const pagePath = '/verify-ai/';
const pageUrl = `${site.url}${pagePath}`;

const verifyTools = ['subnet-calculator', 'timestamp-converter', 'cron-expression-tester', 'base64-encoder-decoder']
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const editorial = [
  {
    tool: 'Subnet Calculator',
    slug: 'subnet-calculator',
    claim: 'Subnetting is exact bit arithmetic — a language model predicts a likely-looking answer instead of computing one, and an off-by-one broadcast address reads exactly like the right one.',
    prompt: 'Ask an AI: "What is the broadcast address of 192.168.1.0/24, and how many usable hosts does it have?"',
    correct: 'The real answer: network 192.168.1.0, broadcast 192.168.1.255, 254 usable hosts (192.168.1.1–192.168.1.254) — reserving the network and broadcast addresses.',
    transcript:
      '[PLACEHOLDER: paste a real, personally-reproduced transcript of an AI assistant getting this wrong — do not fabricate a quote or invent a specific mistake before this is filled in]',
  },
  {
    tool: 'Cron Expression Tester',
    slug: 'cron-expression-tester',
    claim: "Cron's day-of-month/day-of-week OR rule trips models constantly: when both fields are restricted, a date matches if EITHER matches — not both, as most people (and most models) assume.",
    prompt: 'Ask an AI: "Does the cron expression 0 0 1 * 1 run on Monday, January 8th?"',
    correct: "The real answer: yes. 0 0 1 * 1 fires at midnight on the 1st of the month OR every Monday — January 8th is a Monday, so it fires, even though it isn't the 1st.",
    transcript:
      '[PLACEHOLDER: paste a real, personally-reproduced transcript of an AI assistant getting this wrong — do not fabricate a quote or invent a specific mistake before this is filled in]',
  },
  {
    tool: 'Timestamp Converter',
    slug: 'timestamp-converter',
    claim: 'Language models tokenize long numbers and can quietly lose place value, so an epoch conversion comes back off by an hour, a day, or a factor of a thousand — and still looks plausible.',
    prompt: 'Ask an AI: "Convert the Unix timestamp 1705312800 to an ISO 8601 UTC date and tell me the day of the week."',
    correct: 'The real answer: 2024-01-15T10:00:00.000Z — a Monday.',
    transcript:
      '[PLACEHOLDER: paste a real, personally-reproduced transcript of an AI assistant getting this wrong — do not fabricate a quote or invent a specific mistake before this is filled in]',
  },
  {
    tool: 'Base64 Encoder / Decoder',
    slug: 'base64-encoder-decoder',
    claim: 'An AI "decoding" Base64 is predicting bytes character by character, not running the algorithm — long payloads routinely come back subtly corrupted, one character at a time.',
    prompt: 'Ask an AI: "Decode this Base64 string exactly: aGVsbG8gd29ybGQ="',
    correct: 'The real answer: "hello world" — exact, byte for byte, every time (the real algorithm, not a prediction).',
    transcript:
      '[PLACEHOLDER: paste a real, personally-reproduced transcript of an AI assistant getting this wrong — do not fabricate a quote or invent a specific mistake before this is filled in]',
  },
];

const faqs = [
  {
    q: 'How do I check ChatGPT’s or Claude’s subnet math?',
    a: 'Open the Subnet Calculator, enter the same CIDR you gave the AI, expand "Verify an AI’s answer" below the tool, and paste in whatever it claimed for the network address, broadcast address, netmask, usable hosts, or any other field. Each claim is recomputed with exact BigInt arithmetic and compared side by side.',
  },
  {
    q: 'How do I verify an AI-suggested cron expression?',
    a: 'Open the Cron Expression Tester, enter the expression, expand "Verify an AI’s answer", and describe what the AI claimed — that it fires (or doesn’t) at a specific date and time, or that a specific date is the next run. The real cron semantics, including the day-of-month/day-of-week OR rule, decide the verdict.',
  },
  {
    q: 'Can I check a timestamp conversion an AI gave me?',
    a: 'Yes. Open the Timestamp Converter, enter the same epoch or date string, expand the verify panel, and paste the instant or day-of-week the AI claimed. A mismatch is diagnosed where possible — a seconds/milliseconds mix-up, an off-by-one-day error, or a timezone offset.',
  },
  {
    q: 'Does this only check ChatGPT, or Claude too?',
    a: 'Neither, specifically — and every model. The verify panels recompute the real answer from structured claim fields; they never call out to or compare against any particular AI vendor. Paste in whatever any assistant told you.',
  },
  {
    q: 'Is anything I paste into the verify panel uploaded anywhere?',
    a: 'No. The comparison runs the same way every OpsCanopy tool does — entirely in your browser tab, with nothing transmitted. That includes the claim you paste in, even if it’s a secret you shouldn’t have pasted into the AI chat in the first place.',
  },
  {
    q: 'When should I just ask the AI instead of checking it here?',
    a: 'For explaining a concept, drafting a first-pass config, or talking through an approach — an AI assistant is excellent at that, and faster than looking it up. Reach for a verify panel for the exact number, boundary, or byte the decision actually rests on, where "plausible" isn’t good enough.',
  },
];

const jsonLdWebPage = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Verify the AI — check a ChatGPT or Claude answer for free',
  description:
    'Deterministic, local tools that recompute an AI assistant’s claimed answer — subnet math, cron schedules, timestamp conversions, and Base64 — and show you exactly where it went wrong.',
  url: pageUrl,
  isPartOf: { '@type': 'WebSite', name: site.name, url: site.url },
};
const jsonLdFaq = faqPageLd(faqs);
const jsonLdItemList = itemListLd(
  verifyTools.map((t) => ({ name: t.name, url: `${site.url}/${t.slug}/#verify-ai` })),
);
---

<Shell
  title="Verify the AI — Check a ChatGPT or Claude Answer for Free"
  description="Deterministic, local tools that recompute an AI assistant's claimed answer — subnet math, cron schedules, timestamps, and Base64 — and show exactly where it went wrong. 100% client-side."
  canonical="/verify-ai"
  image="/verify-ai/verify-ai-og.png"
  imageAlt="Verify the AI — deterministic checks for ChatGPT and Claude math mistakes"
  jsonLd={[jsonLdWebPage, jsonLdFaq, jsonLdItemList]}
  noAlternates
>
  {/* ── Hero ─────────────────────────────────────────────────────────── */}
  <section class="border-b border-hairline bg-canvas-soft">
    <div class="container-page py-16 sm:py-24">
      <div class="mx-auto max-w-3xl text-center">
        <p class="eyebrow">Verify the AI</p>
        <h1 class="display-xl mt-4 text-balance text-ink">
          AI is a brilliant guesser. This checks the math.
        </h1>
        <p class="body-lg mt-5 text-pretty text-body">
          Models orchestrate; deterministic tools compute. Paste whatever ChatGPT or Claude told
          you into any of the four tools below, and it gets recomputed exactly, locally — no
          upload, no signup, no vendor lock-in on which AI you check.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <Button href="#tools" variant="primary">Jump to the tools</Button>
          <Button href="#faq" variant="secondary">Read the FAQ</Button>
        </div>
      </div>
    </div>
  </section>

  {/* ── Where models go wrong ───────────────────────────────────────── */}
  <section class="border-b border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Where models go wrong</p>
        <h2 class="display-lg mt-3 text-balance text-ink">
          Four documented failure modes — reproduce them yourself.
        </h2>
        <p class="body-md mt-4 text-pretty text-body">
          None of this is a knock on any one assistant. Every large language model generates the
          statistically likely next token, not a computed result — these are the specific shapes
          that habit takes for each kind of exact math.
        </p>
      </div>

      <div class="mx-auto mt-12 grid max-w-5xl gap-6 lg:grid-cols-2">
        {
          editorial.map((e) => (
            <div class="card-soft rounded-lg p-5">
              <p class="eyebrow">{e.tool}</p>
              <p class="body-md mt-2 text-pretty text-body">{e.claim}</p>
              <p class="caption mt-4 text-mute">Try it yourself</p>
              <p class="body-sm mt-1 text-pretty text-ink">{e.prompt}</p>
              <p class="caption mt-3 text-mute">The real answer</p>
              <p class="body-sm mt-1 text-pretty text-ink">{e.correct}</p>
              <p class="caption mt-3 text-mute">What an AI actually said</p>
              <p class="body-sm mt-1 text-pretty text-mute italic">{e.transcript}</p>
              <a href={`/${e.slug}/#verify-ai`} class="link-inline body-sm mt-4 inline-block font-medium">
                Check this in {e.tool} &rarr;
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* ── Tool cards ───────────────────────────────────────────────────── */}
  <section id="tools" class="scroll-mt-24 border-b border-hairline bg-canvas-soft">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">The four V1 tools</p>
        <h2 class="display-lg mt-3 text-balance text-ink">Pick the one you need checked.</h2>
      </div>
      <ul role="list" class="mx-auto mt-10 grid max-w-4xl gap-4 sm:grid-cols-2">
        {
          verifyTools.map((t) => (
            <li>
              <a
                href={`/${t.slug}/#verify-ai`}
                class="card-soft flex h-full flex-col gap-2 rounded-lg p-5 transition-colors hover:border-brand"
              >
                <span class="body-md font-medium text-ink">{t.name}</span>
                <span class="caption text-pretty text-mute">{t.tagline}</span>
                <span class="link-inline body-sm mt-auto pt-2 font-medium">Verify an AI's answer &rarr;</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ── Secrets band ─────────────────────────────────────────────────── */}
  <section class="border-b border-hairline bg-inverse text-inverse-fg">
    <div class="container-page py-14 sm:py-16">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow text-inverse-fg/70">One more reason to keep this local</p>
        <h2 class="display-md mt-3 text-balance">Never paste a secret into a chat box.</h2>
        <p class="body-md mt-4 text-pretty text-inverse-fg/80">
          In 2023, engineers at Samsung reportedly pasted confidential source code into ChatGPT
          while troubleshooting — a widely reported incident that pushed the company to restrict
          external AI tools internally. It's now mainstream guidance: treat an AI chat window the
          same way you'd treat a public web form. Every OpsCanopy tool, including these verify
          panels, keeps what you paste on your machine.
        </p>
      </div>
    </div>
  </section>

  {/* ── FAQ ──────────────────────────────────────────────────────────── */}
  <FaqList id="faq" faqs={faqs} />

  {/* ── Cross-links ──────────────────────────────────────────────────── */}
  <section class="bg-canvas-soft py-14 sm:py-16">
    <div class="container-page">
      <div class="mx-auto flex max-w-2xl flex-col items-center gap-4 text-center">
        <p class="body-md text-body">
          Curious how the tools themselves are built and tested?
          <a href="/about/" class="link-inline font-medium">Read how OpsCanopy works &rarr;</a>
        </p>
        <Button href="/tools/" variant="secondary">Browse all tools</Button>
      </div>
    </div>
  </section>
</Shell>
