---
/**
 * Subnet Splitter — the subnet-splitter tool page (SEO surface).
 * Enter a parent block and any existing allocations; get the free space around
 * them decomposed into minimal CIDRs, and split a block into /N subnets —
 * entirely in the browser.
 */
import Shell from '../components/Shell.astro';
import SubnetSplitterPlayground from '../components/SubnetSplitterPlayground.astro';
import Button from '../components/Button.astro';
import CodeBlock from '../components/CodeBlock.astro';
import ToolHero from '../components/ToolHero.astro';
import ToolPipeline from '../components/ToolPipeline.astro';
import FaqList from '../components/FaqList.astro';
import ToolCrossLinks from '../components/ToolCrossLinks.astro';
import { site, navLinks } from '../data/site';
import { getTool } from '../data/tools';
import { softwareAppLd, faqPageLd } from '../lib/jsonld';

const tool = getTool('subnet-splitter');
const pagePath = '/subnet-splitter';
const pageUrl = `${site.url}${pagePath}`;

const faqs = [
  {
    q: 'What does the Subnet Splitter do?',
    a: 'Give it a parent block — for example 10.0.0.0/24 — plus any subnets already allocated inside it, and it subtracts the used space and reports the gaps as a minimal set of CIDRs. It can also split the parent (or any free gap) evenly into /N subnets and tell you the next free block of a size you ask for. Everything runs in your browser; nothing is uploaded.',
  },
  {
    q: 'Does my data ever leave my browser?',
    a: 'No. Parsing and all the maths run 100% client-side in your tab — there is no server, no account and no logging. You can safely paste internal parent blocks and allocations.',
  },
  {
    q: 'What do "free space" and VLSM mean here?',
    a: 'Free space is the part of the parent block that none of your existing allocations cover. Because that leftover region rarely lines up with a single power-of-two boundary, the splitter expresses it as a Variable-Length Subnet Mask (VLSM) set — the smallest list of differently-sized CIDRs that exactly tiles the gap, rather than forcing one fixed prefix.',
  },
  {
    q: 'What does "next free /N" return?',
    a: 'It scans the free space in order and returns the first block of prefix /N that is fully unallocated and correctly aligned to its own boundary — the block you would hand out next if you were carving the parent into /N subnets. If no aligned /N fits in the remaining free space, it tells you so instead of guessing.',
  },
  {
    q: 'Does it support IPv6 as well as IPv4?',
    a: 'Yes. IPv6 is handled with full 128-bit precision using BigInt, so you can split a site /48 into /64s or find the free space inside a /56 just as accurately as you subtract /26s from an IPv4 /24. IPv4 and IPv6 parents are both first-class.',
  },
];

const softwareApp = softwareAppLd({
  name: 'Subnet Splitter',
  description:
    'Enter a parent block and existing allocations to find the free space as minimal CIDRs, split a block into /N subnets, and pick the next free /N — 100% in your browser.',
  url: pageUrl,
  subCategory: 'Networking',
  featureList: [
    'Find the free space inside a parent block around existing allocations',
    'Decompose gaps into a minimal VLSM CIDR set',
    'Split a block into evenly sized /N subnets and pick the next free one',
    '100% client-side, no upload, no signup',
  ],
  keywords: tool?.keywords.join(', '),
});
const faqPage = faqPageLd(faqs);

const pipeline = [
  {
    title: 'Read the inputs.',
    body: 'The parent block and each existing allocation are parsed to exact 32- or 128-bit ranges.',
  },
  {
    title: 'Subtract the used.',
    body: 'The allocations are removed from the parent, leaving the unallocated address regions.',
  },
  {
    title: 'Decompose the gaps.',
    body: 'Each leftover region is expressed as the minimal set of aligned CIDRs that tiles it exactly.',
  },
  {
    title: 'Split and pick.',
    body: 'Split into /N subnets and the next correctly aligned free /N is surfaced for handing out.',
  },
];

const splitExample = `parent      10.0.0.0/24
allocated   10.0.0.0/26     (used)
            10.0.0.128/26   (used)

free space
  10.0.0.64/26              next free /26
  10.0.0.192/26`;

const vlsmExample = `parent      10.0.0.0/24
allocated   10.0.0.0/25     (used)
            10.0.0.128/27   (used)

free space (minimal VLSM set)
  10.0.0.160/27
  10.0.0.192/26`;
---

<Shell
  title="Subnet Splitter — Find Free CIDRs & Split a Block into /N (IPv4/IPv6)"
  description="Enter a parent block and existing allocations to find the free space as minimal CIDRs, split a block into /N subnets, and pick the next free /N — 100% in your browser."
  canonical="/subnet-splitter"
  jsonLd={[softwareApp, faqPage]}
>
  <ToolHero
    eyebrow="Subnet Splitter · Networking"
    badges={[
      { label: 'Runs in your browser', variant: 'live' },
      { label: 'IPv4 & IPv6', variant: 'neutral' },
      { label: 'No signup', variant: 'neutral' },
    ]}
  >
    <Fragment slot="headline">Split a block and find the free space around it.</Fragment>
    <Fragment slot="lead">
      Give a parent like
      <span class="code-mono text-ink" translate="no">10.0.0.0/24</span> plus the subnets already
      allocated, and get the free space as minimal CIDRs — then split it into /N and pick the next
      free block, all in your browser.
    </Fragment>
  </ToolHero>

  <section id="playground" class="scroll-mt-24 bg-canvas-soft pt-8 pb-20 sm:pb-24">
    <div class="container-page">
      <h2 class="sr-only">Subnet Splitter playground</h2>
      <SubnetSplitterPlayground />
    </div>
  </section>

  <section id="why" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
        <div>
          <p class="eyebrow">The Gap</p>
          <h2 class="display-lg mt-3 text-balance text-ink">
            The leftover space is where mistakes hide.
          </h2>
        </div>
        <div class="space-y-4">
          <p class="body-md text-pretty text-body">
            Carving a block into subnets is easy until something is already allocated. Now the free
            space is a ragged set of differently-sized gaps, and eyeballing the next aligned /26 or
            /27 between two existing assignments is exactly the kind of binary arithmetic that
            produces an overlap or a wasted range.
          </p>
          <p class="body-md text-pretty text-body">
            This splitter subtracts what you have already handed out and reports the remaining space
            as the minimal set of CIDRs — then splits a block into /N subnets and points at the next
            free one. For IPv4 and IPv6 alike, entirely in the browser, with nothing to install.
          </p>
          <p class="body-sm text-mute">
            Need to confirm a list does not overlap first? Try the
            <a class="link-inline" href="/cidr-checker">CIDR / Subnet Checker</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ToolPipeline
    id="how-it-works"
    eyebrow="The Pipeline"
    heading="How it works."
    lead="Four deterministic steps run on every keystroke — all inside your browser tab, with exact BigInt arithmetic."
    steps={pipeline}
  />

  <section id="reference" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">A Worked Example</p>
        <h2 class="display-lg mt-3 text-ink">Two /26s in a /24, what is left?</h2>
        <p class="body-md mx-auto mt-3 max-w-xl text-pretty text-body">
          Subtract the used blocks from the parent and the free space falls out as aligned CIDRs —
          minimal even when the gaps are different sizes.
        </p>
      </div>
      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-2">
        <div class="min-w-0">
          <h3 class="display-sm text-ink">Even split</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            With the first and third <span class="code-mono text-ink" translate="no">/26</span> used,
            the free space is the other two — and the next free /26 is
            <span class="code-mono text-ink" translate="no">10.0.0.64/26</span>.
          </p>
          <CodeBlock lang="text" filename="split-/24" code={splitExample} />
        </div>
        <div class="min-w-0">
          <h3 class="display-sm text-ink">A VLSM gap</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            When allocations are unequal, the leftover does not fit one prefix — it becomes the
            minimal mix of a <span class="code-mono text-ink" translate="no">/27</span> and a
            <span class="code-mono text-ink" translate="no">/26</span>.
          </p>
          <CodeBlock lang="text" filename="vlsm-gap" code={vlsmExample} />
        </div>
      </div>
    </div>
  </section>

  <section id="next" class="scroll-mt-24 bg-inverse text-inverse-fg">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
        <div class="min-w-0">
          <p class="eyebrow !text-cyan">Next Step</p>
          <h2 class="display-lg mt-3 text-balance text-inverse-fg">
            Got a list of subnets? Check them for overlaps.
          </h2>
          <p class="body-md mt-4 text-pretty text-white/70">
            Before you carve out more space, the
            <span translate="no">CIDR / Subnet Checker</span> takes your existing allocations and
            finds overlaps and containment, then aggregates everything into the minimal covering
            set — so the parent you feed the splitter is clean to begin with.
          </p>
          <div class="mt-7 flex flex-wrap items-center gap-3">
            <Button href="/cidr-checker" variant="secondary">Open the CIDR Checker</Button>
          </div>
        </div>
        <CodeBlock
          lang="text"
          filename="free.txt"
          code={`10.0.0.0/24
  − 10.0.0.0/26
  − 10.0.0.128/26
  →  10.0.0.64/26
  →  10.0.0.192/26`}
        />
      </div>
    </div>
  </section>

  <FaqList faqs={faqs} />

  <ToolCrossLinks>
    <Fragment slot="lead">
      The Subnet Splitter is one tool in
      <span translate="no">{site.name}</span> — a growing canopy of browser-based validators,
      converters and testers that never touch a server.
    </Fragment>
    <Fragment slot="links">
      More networking: the
      <a class="link-inline" href="/cidr-checker">CIDR / Subnet Checker</a> and the
      <a class="link-inline" href="/subnet-calculator">Subnet Calculator</a>, or browse the full
      <a class="link-inline" href={navLinks[0].href}>tools directory</a>.
    </Fragment>
    <Fragment slot="disclaimer">
      Provided as-is for convenience; always confirm critical network changes against your own
      authority. <span translate="no">{site.name}</span> is free and open.
    </Fragment>
  </ToolCrossLinks>
</Shell>
