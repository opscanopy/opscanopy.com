---
/**
 * /about — localized copy. Content is data-driven from src/i18n/pages and
 * selected by the active locale (this file's folder). English source lives at
 * src/pages/about.astro.
 */
import Shell from '../../components/Shell.astro';
import InfoPage from '../../components/page/InfoPage.astro';
import { getPagesContent } from '../../i18n/pages';
import { DEFAULT_LOCALE, type Locale } from '../../i18n/config';
import { site } from '../../data/site';

const lang = (Astro.currentLocale as Locale) ?? DEFAULT_LOCALE;
const content = getPagesContent(lang);
const doc = content.about;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: doc.metaTitle,
  description: doc.description,
  url: `${site.url}/about/`,
  isPartOf: { '@type': 'WebSite', name: site.name, url: site.url },
};
---

<Shell
  title={`${doc.metaTitle} — ${site.name}`}
  description={doc.description}
  canonical="/about"
  jsonLd={jsonLd}
>
  <InfoPage doc={doc} lang={lang} updatedLabel={content.ui.updatedLabel} />
  <p class="container-page pb-16 text-center">
    <button type="button" data-install-cta class="link-inline body-sm font-medium" hidden>
      Install OpsCanopy as an app
    </button>
  </p>
</Shell>
