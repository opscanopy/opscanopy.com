---
/**
 * Case Converter — the case-converter tool page (SEO surface).
 * Convert any identifier or phrase between camelCase, PascalCase, snake_case,
 * SCREAMING_SNAKE_CASE, kebab-case, Title Case and more — all in the browser.
 */
import Shell from '../../components/Shell.astro';
import CaseConverterPlayground from '../../components/CaseConverterPlayground.astro';
import Button from '../../components/Button.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ToolHero from '../../components/ToolHero.astro';
import ToolPipeline from '../../components/ToolPipeline.astro';
import FaqList from '../../components/FaqList.astro';
import ToolCrossLinks from '../../components/ToolCrossLinks.astro';
import { site, navLinks } from '../../data/site';
import { getTool } from '../../data/tools';
import { softwareAppLd, faqPageLd } from '../../lib/jsonld';

const tool = getTool('case-converter');
const pagePath = '/case-converter/';
const pageUrl = `${site.url}${pagePath}`;

const faqs = [
  {
    q: 'Quais estilos de caixa o conversor suporta?',
    a: 'Onze de uma vez: camelCase, PascalCase, snake_case, SCREAMING_SNAKE_CASE, CONSTANT_CASE, kebab-case, Train-Case, Title Case, sentence case, dot.case e path/case. Digite uma vez e cada estilo aparece como uma linha copiável — pegue o que sua linguagem, arquivo de configuração ou URL precisa.',
  },
  {
    q: 'Como os limites de palavras são detectados?',
    a: 'O tokenizador reconhece Unicode. Ele divide em espaços, hifens, sublinhados, pontos, barras e outros símbolos, e também dentro das corcovas de camelCase e PascalCase — de modo que userProfileID, user_profile-id e "user profile ID" resolvem nas mesmas três palavras. Transições de letra para número e de número para letra também dividem, então v2Release vira v / 2 / release.',
  },
  {
    q: 'Como acrônimos como HTTP ou URL são tratados?',
    a: 'Acrônimos são normalizados, não preservados em maiúsculas. getURLFromString é tokenizado como get / url / from / string, então sua forma camelCase é getUrlFromString e sua forma snake_case é get_url_from_string. Isso é mais simples e estável em ida e volta: reintroduzir a saída camelCase produz as mesmas palavras, algo que a alternativa em maiúsculas não pode garantir.',
  },
  {
    q: 'Qual é a diferença entre SCREAMING_SNAKE_CASE e CONSTANT_CASE?',
    a: 'Na prática, nenhuma — ambas são palavras em maiúsculas unidas por sublinhados (USER_PROFILE_ID). Elas são listadas como duas linhas porque comunidades diferentes usam nomes diferentes: muitos guias de estilo dizem "SCREAMING_SNAKE_CASE" enquanto outros (e alguns linters) chamam a mesma convenção de "CONSTANT_CASE" para constantes e variáveis de ambiente.',
  },
  {
    q: 'Meu texto sai do meu navegador em algum momento?',
    a: 'Não. A conversão roda 100% do lado do cliente na sua aba — não há servidor, nem conta, nem registro. Você pode colar identificadores, nomes de colunas ou cadeias privadas com segurança; nada trafega pela rede.',
  },
  {
    q: 'Ele lida com texto não ASCII e Unicode?',
    a: 'Sim. A detecção de limites usa as propriedades Unicode de letras e números, então letras acentuadas e não latinas permanecem dentro de sua palavra — straßeName divide em straße / name, e os caracteres acentuados são preservados na saída onde o estilo mantém as letras como estão.',
  },
  {
    q: 'Por que não pedir a uma IA para converter a caixa?',
    a: 'Um modelo de linguagem prevê caracteres; ele não executa um tokenizador determinístico. Para qualquer coisa maior que algumas palavras, ele pode descartar, mesclar ou capitalizar errado tokens de formas difíceis de perceber. Esta ferramenta aplica as mesmas regras de limite explícitas toda vez, então a saída é reproduzível — a mesma entrada sempre produz as mesmas onze linhas.',
  },
  {
    q: 'Posso compartilhar uma conversão específica?',
    a: 'Sim. Assim que tiver entrada, use "Copy link" para copiar uma URL com seu texto codificado em um fragmento #q=. Abrir esse link restaura a entrada e reexecuta a conversão — útil para colar um exemplo em uma revisão de código ou uma issue.',
  },
];

const softwareApp = softwareAppLd({
  name: 'Case Converter',
  description:
    'Conversor de caixa on-line e gratuito. Converta qualquer cadeia entre camelCase, PascalCase, snake_case, SCREAMING_SNAKE_CASE, kebab-case, Title Case e mais de uma vez. Reconhece Unicode, 100% no navegador, sem cadastro.',
  url: pageUrl,
  subCategory: 'Utilities',
  featureList: [
    'Converte para camelCase, PascalCase, snake_case e mais oito estilos de uma vez',
    'Detecção de limites de palavras com reconhecimento de Unicode e divisão de corcovas camelCase',
    'Cópia por linha, copiar tudo e links profundos compartilháveis',
    '100% do lado do cliente, sem upload, sem cadastro',
  ],
  keywords: tool?.keywords.join(', '),
});
const faqPage = faqPageLd(faqs);

const pipeline = [
  {
    title: 'Dividir em palavras.',
    body: 'Seu texto é tokenizado em espaços, símbolos e corcovas camelCase — getHTTPResponse vira get / http / response.',
  },
  {
    title: 'Normalizar os tokens.',
    body: 'Cada palavra é passada para minúsculas e os acrônimos são incorporados, de modo que a mesma frase sempre produz a mesma lista de palavras.',
  },
  {
    title: 'Recombinar por estilo.',
    body: 'As palavras são unidas e capitalizadas para cada convenção — um camelCase com minúscula inicial, snake_case com sublinhado, kebab-case com hifen, e assim por diante.',
  },
  {
    title: 'Copiar a que você precisa.',
    body: 'Cada estilo é exibido como uma linha rotulada com seu próprio botão Copiar — ou "Copy all" para pegar o conjunto completo de uma vez.',
  },
];

const caseGrid = `input    userProfileID   ("user profile ID")

camelCase             userProfileId
PascalCase            UserProfileId
snake_case            user_profile_id
SCREAMING_SNAKE_CASE  USER_PROFILE_ID
CONSTANT_CASE         USER_PROFILE_ID
kebab-case            user-profile-id
Train-Case            User-Profile-Id
Title Case            User Profile Id
sentence case         User profile id
dot.case              user.profile.id
path/case             user/profile/id`;

const tokenExample = `getHTTPResponse   ->  get / http / response
user_profile-id   ->  user / profile / id
XMLHttpRequest    ->  xml / http / request
v2Release         ->  v / 2 / release
Release2          ->  release / 2`;

import type { Locale as __Locale } from '../../i18n/config';
import { localizeKey as __l } from '../../i18n/utils';
const __lang = (Astro.currentLocale ?? 'en') as __Locale;
---

<Shell
  title="Case Converter — camelCase, snake_case e mais, no navegador"
  description="Conversor de caixa gratuito. Converta qualquer cadeia entre camelCase, PascalCase, snake_case, SCREAMING_SNAKE_CASE, kebab-case, Title Case e mais de uma vez. Reconhece Unicode, 100% no navegador, sem cadastro."
  canonical="/case-converter"
  jsonLd={[softwareApp, faqPage]}
>
  <ToolHero
    eyebrow="Case Converter · Utilities"
    badges={[
      { label: 'Roda no seu navegador', variant: 'live' },
      { label: '11 estilos de caixa', variant: 'neutral' },
      { label: 'Sem cadastro', variant: 'neutral' },
    ]}
  >
    <Fragment slot="headline">Uma frase, cada estilo de caixa.</Fragment>
    <Fragment slot="lead">
      Digite ou cole qualquer identificador e leia-o de volta como
      <span class="code-mono text-ink" translate="no">camelCase</span>,
      <span class="code-mono text-ink" translate="no">snake_case</span>,
      <span class="code-mono text-ink" translate="no">kebab-case</span> e mais oito — cada linha
      copiável, com reconhecimento de Unicode e calculada inteiramente no seu navegador. Grátis, sem
      cadastro, e seu texto nunca sai do seu dispositivo.
    </Fragment>
  </ToolHero>

  <section id="playground" class="scroll-mt-24 bg-canvas-soft pt-8 pb-20 sm:pb-24">
    <div class="container-page">
      <h2 class="sr-only">Playground do conversor de caixa</h2>
      <CaseConverterPlayground />
    </div>
  </section>

  <section id="why" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
        <div>
          <p class="eyebrow">A lacuna</p>
          <h2 class="display-lg mt-3 text-balance text-ink">
            As palavras certas, o formato errado.
          </h2>
        </div>
        <div class="space-y-4">
          <p class="body-md text-pretty text-body">
            Renomear um identificador raramente é algo único. O banco de dados quer
            <span class="code-mono text-ink" translate="no">snake_case</span>, a API JSON quer
            <span class="code-mono text-ink" translate="no">camelCase</span>, a variável de ambiente
            quer <span class="code-mono text-ink" translate="no">SCREAMING_SNAKE_CASE</span>
            e o slug de URL quer <span class="code-mono text-ink" translate="no">kebab-case</span>
            — redigitar as mesmas três palavras em cinco formatos é exatamente onde um erro de digitação
            se infiltra.
          </p>
          <p class="body-md text-pretty text-body">
            Este conversor de caixa gratuito lê seu texto uma vez, detecta limites de palavras mesmo
            dentro de corcovas camelCase e acrônimos, e emite cada estilo de uma vez para que você
            copie o de que precisa. Ele reconhece Unicode, então identificadores acentuados e não
            latinos dividem corretamente — e roda inteiramente no navegador, sem nada para instalar e
            sem que nenhum dado saia do seu dispositivo.
          </p>
          <p class="body-md text-pretty text-body">
            Também não peça a uma IA para remodelá-lo: um modelo de linguagem prevê caracteres, não
            executa um tokenizador, e vai descartar ou capitalizar errado em silêncio uma palavra em um
            identificador longo. Esta ferramenta aplica regras de limite explícitas toda vez, então a
            mesma entrada sempre produz as mesmas linhas.
          </p>
          <p class="body-sm text-mute">
            Precisa de um slug de URL em vez disso? A
            <a class="link-inline" href={__l("/slugify", __lang)}>ferramenta Slugify</a> lida com
            diacríticos, separadores e limites de comprimento.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ToolPipeline
    id="how-it-works"
    eyebrow="O pipeline"
    heading="Como funciona."
    lead="Quatro passos determinísticos rodam a cada tecla — tudo dentro da aba do seu navegador, com o mesmo tokenizador aplicado a cada estilo de caixa."
    steps={pipeline}
  />

  <section id="reference" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Referência de caixas</p>
        <h2 class="display-lg mt-3 text-ink">Cada estilo, lado a lado.</h2>
        <p class="body-md mx-auto mt-3 max-w-xl text-pretty text-body">
          Uma entrada, onze convenções. Os limites de palavras são detectados uma vez; entre as linhas,
          só mudam o conector e a capitalização.
        </p>
      </div>
      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-2">
        <div class="min-w-0">
          <h3 class="display-sm text-ink">Os onze estilos</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            De uma frase — <span class="code-mono text-ink" translate="no">userProfileID</span> —
            cada estilo de caixa que o conversor emite.
          </p>
          <CodeBlock lang="text" filename="case-styles" code={caseGrid} />
        </div>
        <div class="min-w-0">
          <h3 class="display-sm text-ink">Como os limites dividem</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            Separadores, corcovas camelCase, sequências de acrônimos e transições letra/número tornam-se
            todos limites de palavras.
          </p>
          <CodeBlock lang="text" filename="tokenizer" code={tokenExample} />
        </div>
      </div>
    </div>
  </section>

  <section id="next" class="scroll-mt-24 bg-inverse text-inverse-fg">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
        <div class="min-w-0">
          <p class="eyebrow !text-cyan">Próximo passo</p>
          <h2 class="display-lg mt-3 text-balance text-inverse-fg">
            Transformar um título em URL? Faça o slug dele.
          </h2>
          <p class="body-md mt-4 text-pretty text-white/70">
            kebab-case chega perto, mas um slug de URL também precisa dobrar diacríticos, remover
            símbolos e limitar o comprimento. A ferramenta <span translate="no">Slugify</span> faz
            exatamente isso — ou explore o resto da prateleira
            <span translate="no">Utilities</span> para mais auxiliares de identificadores e texto, tudo
            no seu navegador.
          </p>
          <div class="mt-7 flex flex-wrap items-center gap-3">
            <Button href={__l("/slugify", __lang)} variant="secondary">Abrir Slugify</Button>
            <Button href="/tools/utilities/" variant="secondary">Explorar Utilities</Button>
          </div>
        </div>
        <CodeBlock
          lang="text"
          filename="slug.txt"
          code={`Case Converter Guide   (title)
->  kebab-case            case-converter-guide
->  Slugify               case-converter-guide  (url-safe)`}
        />
      </div>
    </div>
  </section>

  <FaqList faqs={faqs} />

  <ToolCrossLinks slug="case-converter" lang={__lang}>
    <Fragment slot="lead">
      O Case Converter é uma das ferramentas do
      <span translate="no">{site.name}</span> — uma copa crescente de validadores, conversores e
      testadores baseados no navegador que nunca tocam um servidor.
    </Fragment>
    <Fragment slot="links">
      Ferramentas relacionadas: a
      <a class="link-inline" href={__l("/slugify", __lang)}>ferramenta Slugify</a> para slugs seguros
      em URL, ou explore o
      <a class="link-inline" href={__l(navLinks[0].href, __lang)}>diretório de ferramentas</a>
      completo.
    </Fragment>
    <Fragment slot="disclaimer">
      Fornecido como está para sua conveniência. <span translate="no">{site.name}</span> é gratuito e
      aberto.
    </Fragment>
  </ToolCrossLinks>
</Shell>
