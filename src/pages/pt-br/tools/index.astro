---
/**
 * /pt-br/tools — the OpsCanopy catalog, Brazilian Portuguese.
 * The interactive body (search/chips/sort/empty-state/grid) is the shared
 * ToolsCatalog component — see src/components/ToolsCatalog.astro — so this
 * page owns only the translated header prose and JSON-LD. Tool
 * name/tagline/description/keywords stay English — no translated tool-copy
 * source exists yet.
 */
import Shell from '../../../components/Shell.astro';
import ToolsCatalog from '../../../components/ToolsCatalog.astro';
import { liveTools } from '../../../data/tools';
import { site } from '../../../data/site';
import { DEFAULT_LOCALE, type Locale } from '../../../i18n/config';
import { useTranslations } from '../../../i18n/utils';

const lang: Locale = (Astro.currentLocale as Locale) ?? DEFAULT_LOCALE;
const t = useTranslations(lang);

// ItemList JSON-LD over the live catalog (ordered, with positions).
const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'OpsCanopy tools',
  description:
    'Ferramentas gratuitas e que rodam no navegador para engenheiros de plataforma e DevOps. Sem cadastro, sem servidores; seus dados ficam no seu dispositivo.',
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  numberOfItems: liveTools.length,
  itemListElement: liveTools.map((tool, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: tool.name,
    description: tool.tagline,
    url: `${site.url}/${tool.slug}/`,
  })),
};
---

<Shell
  title="Ferramentas — OpsCanopy"
  description="Ferramentas gratuitas e que rodam no navegador para engenheiros de plataforma e DevOps. Sem cadastro, sem servidores; seus dados ficam no seu dispositivo."
  canonical="/tools"
  jsonLd={itemList}
>
  <!-- ── Header block ─────────────────────────────────────────────────── -->
  <section class="border-b border-hairline bg-canvas-soft">
    <div class="container-page py-8 sm:py-10">
      <div class="max-w-3xl">
        <h1 class="display-lg text-balance text-ink">Toda a caixa de ferramentas, a uma aba de distância.</h1>
        <p class="body-md mt-3 max-w-2xl text-pretty text-body">
          Ferramentas DevOps especializadas que rodam inteiramente no seu navegador: grátis, sem cadastro e nada do que você colar sai do seu dispositivo.
        </p>
        <div class="mt-5 flex flex-wrap items-center gap-3">
          <span class="badge">
            <span class="size-1.5 rounded-full bg-success" aria-hidden="true"></span>
            <span class="tabular-nums">{liveTools.length}</span> no ar
          </span>
          <span class="badge">{t('tools.clientSideBadge')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Live tools ───────────────────────────────────────────────────── -->
  <section aria-labelledby="live-heading" class="bg-canvas">
    <div class="container-page py-16 sm:py-24">
      <ToolsCatalog />
    </div>
  </section>
</Shell>
