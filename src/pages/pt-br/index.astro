---
/**
 * OpsCanopy hub homepage — the flagship marketing surface.
 * Composes the Vercel-inspired design system defined in global.css / DESIGN.md.
 *
 * Component prop contracts (provided by sibling agents in src/components/*):
 *  - <MeshGradient class="…" />                          atmospheric hero backdrop
 *  - <Button href variant="primary|secondary" size? />   marketing pill CTA (label via slot)
 *  - <Card class? as?>…</Card>                            canvas card chrome (slot body)
 *  - <Badge variant?>…</Badge>                            inline status pill (label via slot)
 *  - <CodeBlock code lang? filename? />                   dark mono code surface
 *  - <Banner href>…</Banner>                              "Introducing X" announcement pill
 */
import Shell from '../../components/Shell.astro';
import MeshGradient from '../../components/MeshGradient.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import Badge from '../../components/Badge.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import Banner from '../../components/Banner.astro';
import FaqList from '../../components/FaqList.astro';
import { site } from '../../data/site';
import { tools, liveTools, accentEdgeClass } from '../../data/tools';
import { faqPageLd } from '../../lib/jsonld';

const alertLint = liveTools[0] ?? tools[0];

const faqs = [
  {
    q: 'As ferramentas do OpsCanopy são realmente gratuitas?',
    a: 'Sim. Toda ferramenta é completamente gratuita, sem paywalls, limites de uso ou planos premium. Não há nenhum tipo de exigência de conta: abra uma ferramenta no seu navegador e comece a usar na hora.',
  },
  {
    q: 'Preciso me cadastrar para usar essas ferramentas de DevOps online?',
    a: 'Não. Não há cadastro, login nem captura de e-mail. Abra qualquer ferramenta em uma aba do navegador e use na hora: sem conta, sem barreira de consentimento de cookies, sem atrito.',
  },
  {
    q: 'Meus dados são enviados para um servidor quando uso as ferramentas?',
    a: 'Não. Toda ferramenta roda 100% no lado do cliente, na aba do seu navegador; nada do que você cola é registrado, armazenado ou enviado. Seus dados nunca saem do navegador.',
  },
  {
    q: 'É seguro colar um JWT ou uma configuração em uma ferramenta baseada em navegador?',
    a: 'No OpsCanopy, sim. A decodificação e a análise acontecem inteiramente em JavaScript local, com zero chamadas ao servidor, algo que você mesmo pode verificar na aba de rede do navegador. Como boa prática geral, nunca compartilhe segredos de assinatura com terceiros, mas o OpsCanopy não transmite nada.',
  },
  {
    q: 'As ferramentas funcionam offline?',
    a: 'Depois que a página de uma ferramenta carrega, ela continua funcionando mesmo que você se desconecte da internet, porque todo o processamento é local e não há backend para chamar. Ficar offline também é uma forma fácil de você mesmo verificar a garantia de privacidade do lado do cliente.',
  },
  {
    q: 'Para quem são essas ferramentas de DevOps baseadas em navegador?',
    a: 'Engenheiros de DevOps, SREs, administradores de sistemas, engenheiros de plataforma e de backend: qualquer pessoa que precise de cálculos rápidos de sub-rede e CIDR, agendamentos de cron, consultas PromQL ou LogQL, utilitários de JWT, Base64 e hash, conversão de timestamps, validação de GitHub Actions ou dimensionamento de recursos do Kubernetes sem instalar nada.',
  },
  {
    q: 'Como o OpsCanopy se diferencia de outras coletâneas de ferramentas para desenvolvedores online?',
    a: 'A maioria das coletâneas de ferramentas foca em formatadores genéricos. O OpsCanopy é especializado em fluxos de trabalho de DevOps e SRE: planejamento de CIDR, cron, PromQL e LogQL, capacidade do Kubernetes, validadores de CI, com as mesmas garantias o tempo todo: grátis, sem cadastro, 100% no lado do cliente, sem enviar nem registrar nada.',
  },
];

// Quietly-stated trust principles for the value strip.
const principles = [
  { label: 'PREÇO', title: 'Grátis para sempre', body: 'Toda ferramenta, sem paywall, sem período de teste.' },
  { label: 'EXECUÇÃO', title: 'Roda no seu navegador', body: 'Puro lado do cliente. Nada para instalar.' },
  { label: 'PRIVACIDADE', title: 'Seus dados ficam no local', body: 'As entradas nunca saem do dispositivo.' },
  { label: 'ACESSO', title: 'Sem cadastro', body: 'Abra a página e comece a trabalhar.' },
];

// "Why a hub" value props, drawn from the strategy.
const whyCards = [
  {
    eyebrow: 'EFEITO COMPOSTO',
    title: 'Um hub se acumula.',
    body: 'Cada ferramenta focada e orientada à busca conquista suas próprias palavras-chave e aponta de volta para o resto. O catálogo fica mais fácil de descobrir a cada lançamento.',
  },
  {
    eyebrow: 'ESTÁTICO + BARATO',
    title: 'Barato de operar, rápido de carregar.',
    body: 'Tudo é estático e do lado do cliente, então não há servidores para escalar nem contas para pagar. As páginas continuam instantâneas sob qualquer volume de tráfego.',
  },
  {
    eyebrow: 'PRIVACIDADE',
    title: 'Privacidade é um recurso.',
    body: 'Suas regras, configurações e logs são seus. Nada é enviado, registrado ou mandado de volta para casa: esse é justamente o sentido de rodar tudo na sua aba.',
  },
];

// Loki rule + test snippet for the featured AlertLint band.
const alertLintSnippet = `# rules.yml — the Loki alert under test
groups:
  - name: ingest
    rules:
      - alert: HighErrorRate
        expr: |
          sum(rate({app="api"} |= "level=error" [5m])) > 10
        for: 2m

# tests.yml — assert it fires (and doesn't, when quiet)
tests:
  - name: fires when errors spike
    input:
      - logs: 'level=error'
        rate: 25/min
    expect: { alert: HighErrorRate, fires: true }
  - name: stays quiet under threshold
    input:
      - logs: 'level=error'
        rate: 3/min
    expect: { alert: HighErrorRate, fires: false }`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: site.name,
    url: site.url,
    description: site.description,
    sameAs: [site.github],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: site.name,
    url: site.url,
    description: site.description,
  },
  faqPageLd(faqs),
];
import type { Locale as __Locale } from '../../i18n/config';
import { localizeKey as __l } from '../../i18n/utils';
const __lang = (Astro.currentLocale ?? 'en') as __Locale;

---

<Shell
  title="OpsCanopy — Ferramentas de DevOps e SRE online, grátis e sem cadastro"
  description="Ferramentas de DevOps online e gratuitas que rodam 100% no seu navegador: calculadoras de sub-rede/CIDR, testadores de cron, decodificador de JWT e mais. Sem cadastro, sem enviar nada."
  canonical="/"
  jsonLd={jsonLd}
>
  {/* ─────────────────────────── 1 · HERO ─────────────────────────── */}
  <section class="relative isolate overflow-hidden bg-canvas-soft">
    <MeshGradient class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[90%] opacity-90" />
    {/* Soft top sheen + bottom fade frame the mesh so it reads as ambient light,
        keeping crisp ink contrast under the headline. */}
    <div
      class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-32 bg-gradient-to-b from-canvas-soft to-transparent"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-48 bg-gradient-to-b from-transparent to-canvas-soft"
      aria-hidden="true"
    >
    </div>

    <div class="container-page relative z-10 flex flex-col items-center py-10 text-center sm:py-12 lg:py-14">
      <Banner href={__l(`/${alertLint.slug}`, __lang)}>
        <span class="eyebrow text-ink">Novo</span>
        <span class="text-body">
          Apresentamos o <span translate="no">AlertLint</span>: testes unitários para regras de alerta do Loki.
        </span>
      </Banner>

      <h1 class="display-xl mt-6 max-w-3xl text-balance text-ink">
        Um dossel de ferramentas para as operações que você realmente faz.
      </h1>

      <p class="body-md mx-auto mt-4 max-w-2xl text-pretty text-body">
        Ferramentas para desenvolvedores online e gratuitas que rodam inteiramente no navegador:
        validadores, conversores, testadores e linters para engenheiros de DevOps e SRE. Sem cadastro, sem servidores,
        sem rastreamento: seus dados nunca saem do dispositivo.
      </p>
    </div>
  </section>

  {/* ─── 2 · TOOLS PREVIEW (the catalog leads — MVP first) ─── */}
  <section class="bg-canvas pt-10 pb-20 sm:pt-12 sm:pb-24" aria-labelledby="tools-preview">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">O catálogo</span>
          <h2 id="tools-preview" class="display-lg mt-3 text-balance text-ink">Ferramentas no dossel.</h2>
          <p class="body-md mt-3 text-pretty text-body">
            Utilitários focados e de propósito único para engenheiros de plataforma e DevOps: cada um no ar,
            gratuito e rodando inteiramente no seu navegador.
          </p>
        </div>
        <a
          href={__l("/tools", __lang)}
          class="link-inline group body-md inline-flex shrink-0 items-center gap-1 whitespace-nowrap font-medium"
        >
          Ver todas as ferramentas
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>

      <ul class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-3">
        {
          liveTools.map((tool) => (
            <li class="h-full">
              <a
                href={__l(`/${tool.slug}`, __lang)}
                class="card-interactive group relative flex h-full min-w-0 flex-col overflow-hidden rounded-lg bg-canvas shadow-soft"
              >
                <span
                  aria-hidden="true"
                  class:list={['h-1 w-full bg-gradient-to-r', accentEdgeClass[tool.accent]]}
                />
                <div class="flex h-full min-w-0 flex-col p-6 sm:p-7">
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="display-sm min-w-0 break-words text-ink" translate="no">
                      {tool.name}
                    </h3>
                    <Badge variant="live" class="shrink-0">No ar</Badge>
                  </div>
                  <p class="caption mt-1 text-mute">{tool.category}</p>
                  <p class="body-md mt-4 flex-1 text-pretty text-body">{tool.tagline}</p>
                  <span class="body-sm mt-6 inline-flex items-center gap-1 font-medium text-link">
                    Abrir ferramenta
                    <span
                      aria-hidden="true"
                      class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
                    >
                      &rarr;
                    </span>
                  </span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ─────────────────── 3 · FEATURED TOOL BAND (AlertLint) ─────────────────── */}
  <section class="bg-canvas-soft py-16 sm:py-24" aria-labelledby="featured-tool">
    <div class="container-page">
      <div
        class="overflow-hidden rounded-xl bg-inverse text-inverse-fg shadow-float"
      >
        <div class="grid grid-cols-1 gap-10 p-8 sm:p-12 lg:grid-cols-2 lg:items-center lg:gap-12 lg:p-16">
          <div class="flex min-w-0 flex-col">
            <span class="eyebrow text-cyan">Ferramenta&nbsp;01 · Observabilidade</span>
            <h2 id="featured-tool" class="display-lg mt-4 text-balance text-inverse-fg">
              Teste suas regras de alerta do Loki antes que elas disparem em produção.
            </h2>
            <p class="body-lg mt-5 max-w-xl text-pretty text-white/80">
              Cole suas regras de alerta e de gravação junto a fluxos de logs sintéticos e então afirme
              exatamente o que deveria — e o que não deveria — disparar. O equivalente ao <span translate="no">promtool</span>
              que o Loki nunca lançou, rodando inteiramente no seu navegador.
            </p>
            <div class="mt-8">
              <Button href={__l(`/${alertLint.slug}`, __lang)} variant="secondary">Abrir o <span translate="no">AlertLint</span></Button>
            </div>
          </div>

          <div class="min-w-0 lg:pl-2">
            <CodeBlock
              code={alertLintSnippet}
              lang="yaml"
              filename="alertlint test ./tests"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ───────────────────── 4 · VALUE / TRUST STRIP ───────────────────── */}
  <section class="bg-canvas" aria-label="Por que o OpsCanopy é diferente">
    <div class="container-page border-t border-hairline py-12 sm:py-14">
      <ul class="grid grid-cols-1 gap-x-8 gap-y-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          principles.map((p) => (
            <li class="flex min-w-0 flex-col gap-2 sm:[&:not(:first-child)]:border-l sm:[&:not(:first-child)]:border-hairline sm:[&:not(:first-child)]:pl-8">
              <span class="eyebrow">{p.label}</span>
              <span class="body-md font-medium text-ink">{p.title}</span>
              <span class="body-sm text-pretty text-mute">{p.body}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ─── 5 · WHY A HUB (the thesis sits below the catalog) ─── */}
  <section id="why" class="section-pad bg-canvas-soft">
    <div class="container-page">
      <div class="max-w-2xl">
        <span class="eyebrow">A tese</span>
        <h2 class="display-lg mt-4 text-balance text-ink">Por que construir um hub, e não uma única ferramenta.</h2>
        <p class="body-lg mt-5 text-pretty text-body">
          Um ótimo utilitário é um projeto paralelo. Um dossel deles é uma plataforma: cada ferramenta alimenta
          a seguinte com tráfego, confiança e reaproveitamento.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 lg:grid-cols-3">
        {
          whyCards.map((c) => (
            <Card class="flex h-full min-w-0 flex-col p-6 sm:p-8">
              <span class="eyebrow">{c.eyebrow}</span>
              <h3 class="display-sm mt-3 text-balance text-ink">{c.title}</h3>
              <p class="body-md mt-3 text-pretty text-body">{c.body}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  {/* ─────────────────────────── 6 · PRIVACY ─────────────────────────── */}
  <section id="privacy" class="section-pad bg-canvas" aria-labelledby="privacy-heading">
    <div class="container-page">
      <Card class="flex flex-col gap-6 p-8 sm:p-12 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">Privacidade</span>
          <h2 id="privacy-heading" class="display-md mt-3 text-balance text-ink">
            Nada do que você cola sai da sua aba.
          </h2>
          <p class="body-md mt-4 text-pretty text-body">
            Cada ferramenta do <span translate="no">OpsCanopy</span> roda como JavaScript estático no seu
            navegador. Não há backend para receber suas regras, configurações ou logs: sem envios, sem
            telemetria sobre suas entradas, sem conta para criar. Feche a aba e tudo desaparece.
          </p>
        </div>
        <div class="shrink-0">
          <span class="badge">
            <span aria-hidden="true" class="size-1.5 rounded-full bg-cyan"></span>
            100%&nbsp;no lado do cliente
          </span>
        </div>
      </Card>
    </div>
  </section>

  {/* ─────────────────────────── 7 · FAQ ─────────────────────────── */}
  <FaqList faqs={faqs} />

  {/* ───────────────────────── 8 · FOOTER CTA ───────────────────────── */}
  <section class="section-pad bg-canvas-soft" aria-labelledby="closing-cta">
    <div class="container-page">
      <div class="flex flex-col items-center gap-6 text-center">
        <h2 id="closing-cta" class="display-xl max-w-3xl text-balance text-ink">
          Encontre a ferramenta. Pule a instalação.
        </h2>
        <p class="body-lg max-w-xl text-pretty text-body">
          Grátis, privada e instantânea. Explore o dossel e coloque-a para trabalhar no seu próximo deploy.
        </p>
        <div class="mt-2">
          <Button href={__l("/tools", __lang)} variant="primary">Explorar todas as ferramentas</Button>
        </div>
      </div>
    </div>
  </section>
</Shell>
