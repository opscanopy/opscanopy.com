---
/**
 * OpsCanopy hub homepage — the flagship marketing surface.
 * Composes the Vercel-inspired design system defined in global.css / DESIGN.md.
 * Structural mirror of src/pages/index.astro (English) — see that file for the
 * canonical section order; keep both in sync when the layout changes.
 *
 * Component prop contracts (provided by sibling agents in src/components/*):
 *  - <MeshGradient class="…" />                          atmospheric hero backdrop
 *  - <Button href variant="primary|secondary" size? />   marketing pill CTA (label via slot)
 *  - <Card class? as?>…</Card>                            canvas card chrome (slot body)
 *  - <Badge variant?>…</Badge>                            inline status pill (label via slot)
 *  - <CodeBlock code lang? filename? />                   dark mono code surface
 */
import Shell from '../../components/Shell.astro';
import MeshGradient from '../../components/MeshGradient.astro';
import HeroDemo from '../../components/home/HeroDemo.astro';
import TerminalPlay from '../../components/TerminalPlay.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import Badge from '../../components/Badge.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import FaqList from '../../components/FaqList.astro';
import JumpBackIn from '../../components/JumpBackIn.astro';
import ToolArt from '../../components/ToolArt.astro';
import TrackCard from '../../components/learn/TrackCard.astro';
import { site } from '../../data/site';
import { tools, liveTools, getTool, categoryAccent } from '../../data/tools';
import { tracks } from '../../data/learn';
import { program, phases as m90Phases, missions as m90Missions, totalCoreMinutes } from '../../data/mission90';
import { trackIcon } from '../../data/track-icons';
import { getGuidesForLocale, estimateReadingTime } from '../../lib/learn/guides';
import { faqPageLd } from '../../lib/jsonld';
import type { Locale as __Locale } from '../../i18n/config';
import { localizeKey as __l, localizeNavHref as __nav } from '../../i18n/utils';

const __lang = (Astro.currentLocale ?? 'en') as __Locale;

const alertLint = liveTools[0] ?? tools[0];
// Featured lead-band tool — mirrors the English homepage (see src/pages/index.astro):
// the universally-recognized subnet calculator, not the niche flagship.
const leadTool = getTool('subnet-calculator') ?? alertLint;

// Featured catalog grid — a CURATED set of 8 representative tools, mirrors English.
const featuredSlugs = [
  'loki-alert-rule-tester',
  'github-actions-validator',
  'subnet-calculator',
  'jwt-decoder',
  'docker-run-to-compose',
  'kubernetes-resource-calculator',
  'cron-expression-tester',
  'base64-encoder-decoder',
];
const featuredTools = featuredSlugs
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t) && t!.status === 'live');

// Learn band — /learn is English-only content (ENGLISH_ONLY_SECTIONS), so the
// guides themselves are fetched in English regardless of page locale.
const learnGuides = await getGuidesForLocale('en');
const learnByTrack = (slug: string) =>
  learnGuides.filter((g) => g.entry.data.track === slug).sort((x, y) => x.entry.data.order - y.entry.data.order);
const trackMeta = (slug: string) => {
  const gs = learnByTrack(slug);
  return {
    count: gs.length,
    minutes: gs.reduce((s, g) => s + (g.entry.data.estMinutes ?? estimateReadingTime(g.entry.body)), 0),
    difficulty: gs[0]?.entry.data.difficulty ?? 'beginner',
  };
};
const featuredTracks = tracks.filter((t) => ['linux', 'docker', 'kubernetes'].includes(t.slug));
const mission90Icon = trackIcon('mission-90');

// Mission-90 homepage feature band — figures derived from the registry, mirrors
// English. Mission-90 is also English-only content, so the transcript stays English.
const m90LiveMissions = m90Missions.filter((m) => m.status === 'live').length;
const m90Hours = Math.round(totalCoreMinutes / 60 / 10) * 10;
const m90Stats = [
  { n: String(program.totalDays), l: 'dias' },
  { n: String(m90Phases.length), l: 'fases' },
  { n: String(m90LiveMissions), l: 'missões no navegador' },
  { n: `~${m90Hours}`, l: 'horas de conteúdo' },
];
const m90Transcript = `student@prod-web-01:~$ ps aux --sort=-%cpu | head -3
USER   PID   %CPU  COMMAND
root   4521  94.0  /opt/scripts/nightly-backup.sh
student@prod-web-01:~$ kill 4521
student@prod-web-01:~$ systemctl restart nginx
student@prod-web-01:~$ curl -sI localhost | head -1
HTTP/1.1 200 OK
# 02:07 — the site is back. You did that.`;

const faqs = [
  {
    q: 'As ferramentas do OpsCanopy são realmente gratuitas?',
    a: 'Sim. Toda ferramenta é completamente gratuita, sem paywalls, limites de uso ou planos premium. Não há nenhum tipo de exigência de conta: abra uma ferramenta no seu navegador e comece a usar na hora.',
  },
  {
    q: 'Preciso me cadastrar para usar essas ferramentas de DevOps online?',
    a: 'Não. Não há cadastro, login nem captura de e-mail. Abra qualquer ferramenta em uma aba do navegador e use na hora: sem conta, sem banner de cookies, sem atrito. A análise de uso roda sem cookies, a menos que você aceite na página de privacidade.',
  },
  {
    q: 'Meus dados são enviados para um servidor quando uso as ferramentas?',
    a: 'Não. Toda ferramenta roda 100% no lado do cliente, na aba do seu navegador; nada do que você cola é registrado, armazenado ou enviado. Seus dados nunca saem do navegador.',
  },
  {
    q: 'É seguro colar um JWT ou uma configuração em uma ferramenta baseada em navegador?',
    a: 'No OpsCanopy, sim. A decodificação e a análise acontecem inteiramente em JavaScript local — nada do que você cola é transmitido, algo que você mesmo pode verificar na aba de rede do navegador (o único tráfego de saída é uma análise de páginas anônima e sem cookies, descrita na nossa política de privacidade). Como boa prática geral, nunca compartilhe segredos de assinatura com terceiros, mas o OpsCanopy não envia nada do que você digita.',
  },
  {
    q: 'As ferramentas funcionam offline?',
    a: 'Depois que a página de uma ferramenta carrega, ela continua funcionando mesmo que você se desconecte da internet, porque todo o processamento é local e não há backend para chamar. Ficar offline também é uma forma fácil de você mesmo verificar a garantia de privacidade do lado do cliente.',
  },
  {
    q: 'Para quem são essas ferramentas de DevOps baseadas em navegador?',
    a: 'Engenheiros de DevOps, SREs, administradores de sistemas, engenheiros de plataforma e de backend: qualquer pessoa que precise de cálculos rápidos de sub-rede e CIDR, agendamentos de cron, consultas PromQL ou LogQL, utilitários de JWT, Base64 e hash, conversão de timestamps, validação de GitHub Actions ou dimensionamento de recursos do Kubernetes sem instalar nada.',
  },
  {
    q: 'Por que usar essas ferramentas em vez de perguntar ao ChatGPT ou ao Claude?',
    a: 'Use os dois — para trabalhos diferentes. Um assistente de IA é excelente para explicar conceitos e rascunhar configurações, mas ele gera texto plausível em vez de calcular respostas, e a aritmética exata é um ponto fraco documentado: limites de sub-rede, agendamentos de cron, conversões de epoch e comportamento de regex costumam voltar parecendo certos e estando errados. As ferramentas do OpsCanopy calculam as respostas de forma determinística — parsers reais, matemática exata — e recalculam instantaneamente enquanto você ajusta a entrada, sem novos prompts, sem custo de tokens e sem limite de requisições; depois que a página de uma ferramenta carrega, ela continua funcionando offline. Nada do que você cola é transmitido, então logs, tokens e configurações ficam na sua máquina. Várias ferramentas até funcionam como verificadores práticos de IA: passe a mesma sub-rede, expressão cron ou timestamp por elas e você obtém a resposta de referência para comparar.',
  },
  {
    q: 'Como o OpsCanopy se diferencia de outras coletâneas de ferramentas para desenvolvedores online?',
    a: 'A maioria das coletâneas de ferramentas foca em formatadores genéricos. O OpsCanopy é especializado em fluxos de trabalho de DevOps e SRE: planejamento de CIDR, cron, PromQL e LogQL, capacidade do Kubernetes, validadores de CI, com as mesmas garantias o tempo todo: grátis, sem cadastro, 100% no lado do cliente, sem enviar nem registrar nada.',
  },
  {
    q: 'Quero me tornar um engenheiro DevOps — por onde começo?',
    a: 'Comece com o OpsCanopy Learn em /learn. Ele combina um roteiro de carreira em DevOps por etapas (/learn/roadmaps/devops) com guias gratuitos e práticos cobrindo Linux, Docker, Kubernetes, AWS e redes — indo do básico até estar pronto para o mercado. Enquanto lê, você pode praticar imediatamente com as ferramentas correspondentes no catálogo, sem necessidade de cadastro.',
  },
];

// Quietly-stated trust principles for the value strip.
const principles = [
  { label: 'PREÇO', title: 'Grátis para sempre', body: 'Toda ferramenta, sem paywall, sem período de teste.', icon: '<path d="M3 11.4 11.4 3H19a2 2 0 0 1 2 2v7.6l-8.4 8.4a1.5 1.5 0 0 1-2.1 0L3 13.5a1.5 1.5 0 0 1 0-2.1Z"/><circle cx="15.8" cy="8.2" r="1.4"/>' },
  { label: 'EXECUÇÃO', title: 'Roda no seu navegador', body: 'Puro lado do cliente. Nada para instalar.', icon: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 9h18"/><circle cx="6" cy="7" r="0.6" fill="currentColor"/>' },
  { label: 'PRIVACIDADE', title: 'Seus dados ficam no local', body: 'As entradas nunca saem do dispositivo. Código aberto — audite você mesmo.', icon: '<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>' },
  { label: 'ACESSO', title: 'Sem cadastro', body: 'Abra a página e comece a trabalhar.', icon: '<path d="M14 4h5a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1h-5"/><path d="M3 12h11m0 0-4-4m4 4-4 4"/>' },
];

// "Why a hub" value props, mirrors English.
const whyCards = [
  {
    eyebrow: 'UM SÓ LUGAR',
    title: 'Tudo em uma aba.',
    body: 'Salve um único favorito em vez de uma dúzia. Quando precisar de um conversor, validador ou calculadora, ele já está aqui — mesmo visual, mesmos atalhos, nada novo para aprender.',
    icon: '<path d="M3 20h18"/><path d="M6 20v-4M12 20V8M18 20v-9"/>',
  },
  {
    eyebrow: 'SEMPRE RÁPIDO',
    title: 'Instantâneo, toda vez.',
    body: 'Cada ferramenta é estática e roda no cliente: sem filas de servidor nem cold starts para esperar. As páginas carregam na hora, seja você sozinho ou dez mil pessoas de uma vez.',
    icon: '<path d="M13 3 5 13h6l-1 8 9-11h-6l1-7Z"/>',
  },
  {
    eyebrow: 'PRIVACIDADE',
    title: 'Privacidade é um recurso.',
    body: 'Suas regras, configurações e logs são seus. Nada é enviado, registrado ou mandado de volta para casa: esse é justamente o sentido de rodar tudo na sua aba.',
    icon: '<path d="M12 3 5 6v5c0 4.6 3.1 8.2 7 10 3.9-1.8 7-5.4 7-10V6l-7-3Z"/>',
  },
];


const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: site.name,
    url: site.url,
    description: site.description,
    sameAs: [site.github, `https://x.com/${site.twitter.replace('@', '')}`],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: site.name,
    url: site.url,
    description: site.description,
    publisher: { '@type': 'Organization', name: site.name, url: site.url },
  },
  faqPageLd(faqs),
];
---

<Shell
  title="OpsCanopy — Ferramentas de DevOps e SRE online, grátis e sem cadastro"
  description="Ferramentas de DevOps online e gratuitas que rodam 100% no seu navegador: calculadoras de sub-rede/CIDR, testadores de cron, decodificador de JWT e mais. Sem cadastro, sem enviar nada."
  canonical="/"
  jsonLd={jsonLd}
>
  {/* ─────────────────────────── 1 · HERO ─────────────────────────── */}
  <section class="section-pad relative isolate overflow-hidden bg-canvas-soft">
    <MeshGradient class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[90%] opacity-90" />
    <div
      class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-32 bg-gradient-to-b from-canvas-soft to-transparent"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-48 bg-gradient-to-b from-transparent to-canvas-soft"
      aria-hidden="true"
    >
    </div>

    <div class="container-page relative z-10">
      <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[5fr_7fr] lg:gap-14">
        <div class="flex flex-col">
      <p class="eyebrow flex flex-wrap items-center gap-x-2 gap-y-1 text-mute">
        <span>{liveTools.length} ferramentas</span>
        <span aria-hidden="true" class="text-hairline">&bull;</span>
        <span>100% no lado do cliente</span>
        <span aria-hidden="true" class="text-hairline">&bull;</span>
        <a
          href="https://github.com/opscanopy/opscanopy.com"
          target="_blank"
          rel="noopener noreferrer"
          class="underline decoration-hairline underline-offset-4 transition-colors hover:text-ink"
          >Código aberto</a
        >
      </p>

      <h1 class="display-hero mt-4 max-w-xl text-balance text-ink">
        Um dossel de ferramentas para as operações que você realmente faz.
      </h1>

      <p class="body-md mt-4 max-w-xl text-pretty text-body">
        Validadores, conversores, testadores e linters para engenheiros de DevOps e SRE — cálculos de
        sub-rede e CIDR, cron, PromQL e LogQL, JWT e dimensionamento do Kubernetes. Sem cadastro, e
        nada do que você cola sai do seu dispositivo.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3">
        <Button href={__l('/tools', __lang)} variant="primary">Explorar ferramentas — sem cadastro</Button>
        <a
          href={__nav('/learn', __lang)}
          class="link-inline group body-md inline-flex items-center gap-1 font-medium"
        >
          Aprender DevOps
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>
        </div>

        <div class="flex justify-center lg:justify-end">
          <HeroDemo />
        </div>
      </div>
    </div>
  </section>

  {/* ─────────────────── 1b · JUMP BACK IN (pinned/recent tools) ─────────────────── */}
  <JumpBackIn heading="Continue de onde parou" lang="pt-br" />

  {/* ─── 3 · TOOLS PREVIEW (the catalog leads — MVP first) ─── */}
  <section class="section-pad-lg bg-canvas" aria-labelledby="tools-preview">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">O catálogo</span>
          <h2 id="tools-preview" class="display-lg mt-3 text-balance text-ink">Ferramentas no dossel.</h2>
          <p class="body-md mt-3 text-pretty text-body">
            Utilitários focados e de propósito único para engenheiros de plataforma e DevOps: cada um
            no ar, gratuito e rodando inteiramente no seu navegador.
          </p>
        </div>
        <a
          href={__l('/tools', __lang)}
          class="link-inline group body-md inline-flex shrink-0 items-center gap-1 whitespace-nowrap font-medium"
        >
          Ver todas as ferramentas
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>

      <ul class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          featuredTools.map((tool) => (
            <li class="h-full">
              <a
                href={__l(`/${tool.slug}`, __lang)}
                class="card-interactive group relative flex h-full min-w-0 flex-col overflow-hidden rounded-lg bg-canvas shadow-soft"
              >
                <ToolArt
                  slug={tool.slug}
                  accent={categoryAccent[tool.category]}
                  class="border-b border-hairline"
                />
                <div class="flex h-full min-w-0 flex-col p-6 sm:p-7">
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="display-sm min-w-0 break-words text-ink" translate="no">
                      {tool.name}
                    </h3>
                    <Badge variant="live" class="shrink-0">No ar</Badge>
                  </div>
                  <p class="caption mt-2 inline-flex items-center gap-1.5 font-medium uppercase tracking-wide text-body">
                    <span
                      aria-hidden="true"
                      class="size-1.5 rounded-full"
                      style={`background:${categoryAccent[tool.category]}`}
                    />
                    {tool.category}
                  </p>
                  <p class="body-md mt-4 flex-1 text-pretty text-body">{tool.tagline}</p>
                  <span class="body-sm mt-6 inline-flex items-center gap-1 font-medium text-link">
                    Abrir ferramenta
                    <span
                      aria-hidden="true"
                      class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
                    >
                      &rarr;
                    </span>
                  </span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>

      <div class="mt-10 flex justify-center">
        <a
          href={__l('/tools', __lang)}
          class="group inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-6 py-3 text-link shadow-soft transition-colors duration-150 ease-out hover:border-brand-strong"
        >
          <span class="body-md font-medium">Explorar todas as {liveTools.length} ferramentas</span>
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>
    </div>
  </section>

  {/* ─── 3b · MISSION 90 — the flagship guided program, its own moment ─── */}
  <section class="section-pad bg-canvas-soft" aria-labelledby="mission90-home">
    <div class="container-page">
      <div class="overflow-hidden rounded-xl bg-inverse text-inverse-fg shadow-float">
        <div class="grid grid-cols-1 gap-10 p-8 sm:p-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-14 lg:p-16">
          <div class="flex min-w-0 flex-col">
            <span
              class="grid size-12 place-items-center rounded-xl border border-brand/30 bg-brand/10 text-brand"
              aria-hidden="true"
            >
              <svg width="26" height="26" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={mission90Icon} />
            </span>
            <span class="eyebrow mt-5 text-brand">Mission · 90 Days · DevOps</span>
            <h2 id="mission90-home" class="display-lg mt-3 text-balance text-inverse-fg">
              De desenvolvedor a engenheiro DevOps em 90 dias.
            </h2>
            <p class="body-lg mt-5 max-w-xl text-pretty text-white/80">
              Um caminho gratuito e guiado — uma lição focada por dia e, no fim de cada semana, uma
              missão narrativa que você joga direto no terminal do seu navegador para consertar um
              sistema quebrado. Os 90 dias e as 10 missões já estão disponíveis — sem cadastro.
            </p>

            <dl class="mt-8 grid grid-cols-2 gap-x-6 gap-y-5 sm:grid-cols-4">
              {
                m90Stats.map((s) => (
                  <div class="flex flex-col gap-1 border-l border-white/15 pl-4">
                    <dt class="display-sm text-inverse-fg">{s.n}</dt>
                    <dd class="caption text-white/60">{s.l}</dd>
                  </div>
                ))
              }
            </dl>

            <div class="mt-9 flex flex-wrap items-center gap-x-6 gap-y-3">
              <Button href={__nav('/mission-90', __lang)} variant="secondary">Começar o dia 1 — grátis, sem cadastro</Button>
              <a
                href={__nav('/mission-90/missions', __lang)}
                class="link-inline group body-md inline-flex items-center gap-1 font-medium text-white/85 hover:text-white"
              >
                Explorar as missões
                <span
                  aria-hidden="true"
                  class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
                >
                  &rarr;
                </span>
              </a>
            </div>
          </div>

          <div class="min-w-0">
            <TerminalPlay transcript={m90Transcript} title="mission: server-down" class="shadow-float" />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ─── 4 · LEARN DEVOPS (route homepage authority into /learn) ─── */}
  <section class="section-pad-lg bg-canvas-soft" aria-labelledby="learn-devops">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">Learn DevOps</span>
          <h2 id="learn-devops" class="display-lg mt-3 text-balance text-ink">
            Roteiros e guias práticos gratuitos.
          </h2>
          <p class="body-md mt-3 text-pretty text-body">
            Vá do básico até estar pronto para o mercado com roteiros de carreira em etapas e guias
            práticos e aprofundados — Linux, Docker, Kubernetes, AWS e redes. Grátis, sem cadastro, e
            você pode praticar com as ferramentas enquanto aprende.
          </p>
        </div>
        <a
          href={__nav('/learn', __lang)}
          class="link-inline group body-md inline-flex shrink-0 items-center gap-1 whitespace-nowrap font-medium"
        >
          Ver todos os guias
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >
            &rarr;
          </span>
        </a>
      </div>

      <div class="mt-8">
        <Button href={__nav('/learn/roadmaps/devops', __lang)} variant="primary">Começar com o roteiro de DevOps</Button>
      </div>

      <ul role="list" class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredTracks.map((track) => {
          const m = trackMeta(track.slug);
          return <TrackCard track={track} guideCount={m.count} difficulty={m.difficulty} minutes={m.minutes} />;
        })}
      </ul>
    </div>
  </section>

  {/* ───────────────────── 5 · VALUE / TRUST STRIP ───────────────────── */}
  <section class="section-pad-sm bg-canvas" aria-label="Por que o OpsCanopy é diferente">
    <div class="container-page border-t border-hairline pt-12 sm:pt-14">
      <ul class="grid grid-cols-1 gap-x-8 gap-y-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          principles.map((p) => (
            <li class="flex min-w-0 flex-col gap-2 sm:[&:not(:first-child)]:border-l sm:[&:not(:first-child)]:border-hairline sm:[&:not(:first-child)]:pl-8">
              <span class="mb-1 inline-flex size-9 items-center justify-center rounded-lg bg-brand/10 text-brand-strong">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={p.icon} />
              </span>
              <span class="eyebrow">{p.label}</span>
              <span class="body-md font-medium text-ink">{p.title}</span>
              <span class="body-sm text-pretty text-mute">{p.body}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ─── 6 · WHY A HUB (what you get, not our business thesis) ─── */}
