---
/**
 * Env Example Checker — the tool page (primary SEO surface).
 * Paste your code plus your .env.example and find environment variables that
 * the code reads but the example is missing (plus keys the example declares
 * that nothing reads), entirely in the browser. No server, no signup.
 *
 * Imports the interactive island (EnvCheckerPlayground, self-mounting) plus the
 * brand primitives. JSON-LD (SoftwareApplication + FAQPage) is assembled in
 * frontmatter and handed to Shell via the `jsonLd` prop.
 */
import Shell from '../components/Shell.astro';
import EnvCheckerPlayground from '../components/EnvCheckerPlayground.astro';
import CodeBlock from '../components/CodeBlock.astro';
import ToolHero from '../components/ToolHero.astro';
import ToolPipeline from '../components/ToolPipeline.astro';
import FaqList from '../components/FaqList.astro';
import ToolCrossLinks from '../components/ToolCrossLinks.astro';
import { site, navLinks } from '../data/site';
import { getTool } from '../data/tools';
import { softwareAppLd, faqPageLd } from '../lib/jsonld';

const tool = getTool('env-example-checker');

const pagePath = '/env-example-checker';
const pageUrl = `${site.url}${pagePath}`;

// ── FAQ content — single source for both the rendered section and FAQPage LD ─
const faqs = [
  {
    q: 'What does the Env Example Checker do?',
    a: 'It compares the environment variables your code actually reads against the keys declared in your .env.example. Paste both, press Check, and it reports two gaps: variables used in code but missing from the example (the ones that bite a new developer or a fresh deploy), and keys declared in the example that nothing reads (stale entries worth pruning). Everything is computed in your browser.',
  },
  {
    q: 'Does my code or .env.example ever leave my browser?',
    a: 'No. The checker runs 100% client-side. Your source and your example file are parsed and diffed in your browser tab — nothing is uploaded to a server, and there is no account or signup. It is safe to paste internal code and config keys.',
  },
  {
    q: 'Which languages and access patterns does it detect?',
    a: 'It recognises the common ways code reads environment variables across popular ecosystems — process.env.NAME and process.env["NAME"] in Node and TypeScript, import.meta.env.NAME in Vite, os.environ["NAME"] / os.getenv("NAME") in Python, ENV["NAME"] in Ruby, os.Getenv("NAME") in Go, and bare $NAME / ${NAME} references in shell. The .env.example side is parsed as standard KEY=value lines, ignoring comments and blanks.',
  },
  {
    q: 'Why does .env.example drift from the code in the first place?',
    a: 'A new variable gets added to the code and the local .env, but .env.example — which is the file committed to the repo and the one teammates copy — is forgotten. The drift is invisible until someone clones the project, copies the example, and the app crashes on a missing key, or until a deploy fails because a required variable was never documented. This tool surfaces that drift before it ships.',
  },
  {
    q: 'Can it tell which missing variables are required versus optional?',
    a: 'It reports every variable the code reads that the example does not declare; whether a given variable is strictly required is a judgement only your code can make (a default fallback may make it optional). Treat the missing list as the set to review and document — add each to .env.example with a safe placeholder or a comment noting it is optional.',
  },
  {
    q: 'Is this an official tool for any framework?',
    a: 'No. This is an independent, community utility and is not affiliated with or endorsed by any framework, runtime or dotenv library. It models the widely used .env / .env.example convention and common env-access patterns only to describe what it checks.',
  },
];

// ── JSON-LD: SoftwareApplication ─────────────────────────────────────────────
const softwareApp = softwareAppLd({
  name: 'Env Example Checker',
  description:
    'Paste your code and your .env.example to find environment variables used in code but missing from the example, plus unused keys — 100% in your browser, no server, no signup.',
  url: pageUrl,
  subCategory: 'Configuration',
  featureList: [
    'Find env vars used in code but missing from .env.example',
    'Flag keys declared in .env.example that nothing reads',
    'Detects Node, Vite, Python, Ruby, Go and shell env access',
    '100% client-side, no upload, no signup',
  ],
  keywords: tool?.keywords.join(', '),
});

// ── JSON-LD: FAQPage (mirrors the rendered FAQ) ──────────────────────────────
const faqPage = faqPageLd(faqs);

// ── HOW IT WORKS pipeline ────────────────────────────────────────────────────
const pipeline = [
  {
    title: 'Scan the code.',
    body: 'Your source is swept for every environment-variable read — process.env, os.environ, $NAME and the rest.',
  },
  {
    title: 'Parse the example.',
    body: 'Your .env.example is read as KEY=value lines, with comments and blank lines skipped, into a key set.',
  },
  {
    title: 'Diff the two sets.',
    body: 'The names used in code are compared against the keys declared in the example, both directions at once.',
  },
  {
    title: 'Surface the gaps.',
    body: 'Variables used but undeclared are flagged as missing; declared-but-unread keys are flagged as unused.',
  },
  {
    title: 'Fix & re-check.',
    body: 'Add the missing keys to your example, prune the stale ones, then run again until the report is clean.',
  },
];

// ── Example: application code that reads env vars ────────────────────────────
const codeExample = `// server.ts
const port = process.env.PORT ?? '3000';
const dbUrl = process.env.DATABASE_URL;
const apiKey = process.env["STRIPE_SECRET_KEY"];

if (!dbUrl) {
  throw new Error('DATABASE_URL is required');
}`;

// ── Example: the .env.example that has drifted ───────────────────────────────
const exampleEnvExample = `# .env.example
PORT=3000
DATABASE_URL=postgres://localhost:5432/app

# STRIPE_SECRET_KEY is used in server.ts but
# was never added here — the checker flags it.

# Declared below but nothing reads it — flagged as unused.
LEGACY_FEATURE_FLAG=false`;

// ── CLI teaser ───────────────────────────────────────────────────────────────
const cliExample = `# Coming soon — the same check in CI
$ envcheck ./src --example .env.example

  ✗ Missing from .env.example (1)
      STRIPE_SECRET_KEY   used in src/server.ts

  ! Unused in .env.example (1)
      LEGACY_FEATURE_FLAG

  1 missing, 1 unused`;
---

<Shell
  title="env.example Checker — Find Missing Env Vars vs Code Online"
  description="Paste your code and your .env.example to find environment variables used in code but missing from the example (and unused keys) — 100% in your browser."
  canonical="/env-example-checker"
  jsonLd={[softwareApp, faqPage]}
>
  <!-- ════════════════════════════════════════════════════════════════════
       1) HERO — compact, mesh gradient behind
       ════════════════════════════════════════════════════════════════════ -->
  <ToolHero
    eyebrow="Env Example Checker · Config"
    badges={[
      { label: 'Runs in your browser', variant: 'live' },
      { label: 'No signup', variant: 'neutral' },
      { label: 'Free & open', variant: 'neutral' },
    ]}
    primaryCta={{ label: 'Check My Env', href: '#playground' }}
    secondaryCta={{ label: 'See How It Works', href: '#how-it-works' }}
  >
    <Fragment slot="headline">
      Catch the env vars missing from your <span class="code-mono text-ink" translate="no"
        >.env.example</span
      >.
    </Fragment>
    <Fragment slot="lead">
      Your code reads <span class="code-mono text-ink" translate="no">process.env.SECRET</span>, but
      did anyone add it to the <span class="code-mono text-ink" translate="no">.env.example</span> a
      teammate copies on day one? Paste your code and your example and get the two gaps that break a
      fresh checkout: variables used in code but missing from the example, and keys the example
      declares that nothing reads. It all runs in your browser.
    </Fragment>
  </ToolHero>

  <!-- ════════════════════════════════════════════════════════════════════
       2) THE PLAYGROUND
       ════════════════════════════════════════════════════════════════════ -->
  <section id="playground" class="scroll-mt-24 bg-canvas-soft pb-20 sm:pb-24">
    <div class="container-page">
      <div class="mx-auto mb-6 max-w-3xl text-center">
        <h2 class="display-lg text-ink">The playground.</h2>
        <p class="body-md mx-auto mt-3 max-w-2xl text-pretty text-body">
          Paste your code on one side and your <span class="code-mono text-ink" translate="no"
            >.env.example</span
          > on the other, then press <strong class="font-medium text-ink">Check</strong> — or load an
          example to see drift caught instantly. Everything runs locally in your tab; nothing is uploaded.
        </p>
      </div>
      <EnvCheckerPlayground />
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       3) WHY IT EXISTS — the gap
       ════════════════════════════════════════════════════════════════════ -->
  <section id="why" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
        <div>
          <p class="eyebrow">The Gap</p>
          <h2 class="display-lg mt-3 text-balance text-ink">
            <span class="code-mono text-ink" translate="no">.env.example</span> always drifts.
          </h2>
        </div>
        <div class="space-y-4">
          <p class="body-md text-pretty text-body">
            A new variable lands in the code and your local
            <span class="code-mono text-ink" translate="no">.env</span> — and the
            <span class="code-mono text-ink" translate="no">.env.example</span>, the file actually
            committed to the repo and copied by every teammate, is quietly left behind.
            <span class="code-mono text-ink" translate="no">.env</span> is git-ignored, so nothing
            warns you. The drift stays invisible until someone clones the project and the app crashes
            on a missing key, or a deploy fails because a required variable was never documented.
          </p>
          <p class="body-md text-pretty text-body">
            Checking it by eye across a sprawling codebase is exactly the kind of mechanical diff a
            tool should do. This checker reads both directions at once: it lists the variables your
            code uses but the example is missing — the ones that break a fresh checkout — and the keys
            the example still declares that nothing reads, so you can prune the stale ones with
            confidence.
          </p>
          <p class="body-sm text-mute">
            Want to see it first? Jump to <a class="link-inline" href="#formats">the two inputs</a> or
            try the <a class="link-inline" href="#playground">live playground</a> above.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       4) HOW IT WORKS — numbered pipeline
       ════════════════════════════════════════════════════════════════════ -->
  <ToolPipeline
    id="how-it-works"
    eyebrow="The Pipeline"
    heading="How it works."
    lead="Five deterministic steps diff your code against your example — all inside your browser tab, every time."
    steps={pipeline}
  />

  <!-- ════════════════════════════════════════════════════════════════════
       5) FORMATS — the two inputs
       ════════════════════════════════════════════════════════════════════ -->
  <section id="formats" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">The Inputs</p>
        <h2 class="display-lg mt-3 text-ink">Two inputs, both familiar.</h2>
        <p class="body-md mx-auto mt-3 max-w-xl text-pretty text-body">
          The checker reads exactly two things: your application code and your
          <span class="code-mono text-ink" translate="no">.env.example</span>. If you have written
          either before, these will feel like home.
        </p>
      </div>

      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-2">
        <div class="min-w-0">
          <h3 class="display-sm text-ink">The code</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            Any source that reads environment variables. The scanner recognises
            <span class="code-mono text-ink" translate="no">process.env.NAME</span> and
            <span class="code-mono text-ink" translate="no">import.meta.env.NAME</span> in Node / Vite,
            <span class="code-mono text-ink" translate="no">os.environ["NAME"]</span> /
            <span class="code-mono text-ink" translate="no">os.getenv("NAME")</span> in Python,
            <span class="code-mono text-ink" translate="no">os.Getenv("NAME")</span> in Go, and bare
            <span class="code-mono text-ink" translate="no">$NAME</span> in shell.
          </p>
          <CodeBlock lang="typescript" filename="server.ts" code={codeExample} />
        </div>

        <div class="min-w-0">
          <h3 class="display-sm text-ink">The .env.example</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            Standard dotenv lines —
            <span class="code-mono text-ink" translate="no">KEY=value</span> per line, with
            <span class="code-mono text-ink" translate="no">#</span> comments and blank lines ignored.
            Only the key names matter for the diff, so placeholder values are fine. This is the file
            your teammates copy to a real <span class="code-mono text-ink" translate="no">.env</span>.
          </p>
          <CodeBlock lang="dotenv" filename=".env.example" code={exampleEnvExample} />
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       6) CLI TEASER — polarity-flipped dark band
       ════════════════════════════════════════════════════════════════════ -->
  <section id="cli" class="scroll-mt-24 bg-primary text-on-primary">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl items-center gap-10 lg:grid-cols-2 lg:gap-16">
        <div class="min-w-0">
          <p class="eyebrow !text-cyan">On the Roadmap</p>
          <h2 class="display-lg mt-3 text-balance text-on-primary">Fail the build on drift.</h2>
          <p class="body-md mt-4 text-pretty text-white/70">
            The browser checker is step one. A drop-in CLI will run the identical diff over your repo
            in CI, so a forgotten <span class="code-mono text-white/90" translate="no"
              >.env.example</span
            > entry fails the build instead of breaking a teammate's first
            <span class="code-mono text-white/90" translate="no">git clone</span>.
          </p>
          <p class="body-sm mt-4 text-pretty text-white/55">
            A first-party <span translate="no">GitHub</span> Action that wraps the CLI is planned
            alongside it. Both are on the roadmap — the in-browser checker above works today.
          </p>
        </div>
        <CodeBlock lang="bash" filename="ci.sh" code={cliExample} />
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       7) NOTE — honest scope callout
       ════════════════════════════════════════════════════════════════════ -->
  <section class="bg-canvas-soft">
    <div class="container-page py-12 sm:py-16">
      <div class="card-soft mx-auto max-w-3xl p-6">
        <p class="eyebrow">A Note on Scope</p>
        <p class="body-md mt-3 text-pretty text-body">
          How the detection works: the checker matches environment-variable reads by their common,
          literal access patterns — <span class="code-mono text-ink" translate="no"
            >process.env.NAME</span
          >, <span class="code-mono text-ink" translate="no">os.environ["NAME"]</span>,
          <span class="code-mono text-ink" translate="no">$NAME</span> and the like. Names built
          dynamically at runtime (for example
          <span class="code-mono text-ink" translate="no">process.env[someVariable]</span>) can't be
          resolved statically, so they won't appear in the used set. Treat a clean report as strong
          confidence that your documented config matches your code — and still skim any computed
          lookups by hand.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       8) FAQ
       ════════════════════════════════════════════════════════════════════ -->
  <FaqList faqs={faqs} />

  <!-- ════════════════════════════════════════════════════════════════════
       Cross-links + footer note
       ════════════════════════════════════════════════════════════════════ -->
  <ToolCrossLinks>
    <Fragment slot="lead">
      The Env Example Checker is one tool in
      <span translate="no">{site.name}</span> — a growing canopy of browser-based validators,
      converters and testers that never touch a server.
    </Fragment>
    <Fragment slot="links">
      Validating config and pipelines? Pair this with the
      <a class="link-inline" href="/github-actions-validator">GitHub Actions Validator</a> to catch workflow
      issues before push, or browse the full
      <a class="link-inline" href={navLinks[0].href}>tools directory</a>.
    </Fragment>
    <Fragment slot="disclaimer">
      Not affiliated with or endorsed by any framework, runtime or
      <span translate="no">dotenv</span> library. The
      <span class="code-mono" translate="no">.env</span> /
      <span class="code-mono" translate="no">.env.example</span> convention and env-access patterns are
      referenced only to describe what this tool checks.
    </Fragment>
  </ToolCrossLinks>
</Shell>
