---
/**
 * 500 — branded server-error page.
 * Mirrors 404.astro: calm, centered, on-brand. Static hosts (Vercel/Netlify)
 * serve this as the custom 500 response; the layout never hits a real server.
 */
import Shell from '../components/Shell.astro';
import Button from '../components/Button.astro';
import MeshGradient from '../components/MeshGradient.astro';
---

<Shell
  title="Something went wrong — OpsCanopy"
  description="An unexpected error interrupted the canopy."
  canonical="/500"
  noindex={true}
  noAlternates={true}
>
  <section class="relative isolate overflow-hidden">
    <MeshGradient class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[420px] opacity-60" />

    <div class="container-page flex min-h-[70vh] flex-col items-center justify-center py-24 text-center sm:py-32">
      <p class="eyebrow mb-5">Error 500</p>

      <h1 class="display-xl text-ink">500<span class="sr-only"> — internal server error</span></h1>

      <p class="body-lg mt-5 max-w-md text-balance text-body">
        Something went wrong on our end. The page could not be loaded. Try again in a
        moment, or head back to a known-good spot.
      </p>

      <div class="mt-9 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
        <Button href="/" variant="primary">Back to Home</Button>
        <Button href="/tools" variant="secondary">Browse All Tools</Button>
      </div>

      <p class="body-sm mt-8 text-mute">
        Looking for something specific?{' '}
        <a class="link-inline" href="/tools">Check the catalog.</a>
      </p>
    </div>
  </section>
</Shell>
