---
/**
 * 500 — branded server-error page, rendered as a terminal request/response slab
 * to match 404/offline. Static hosts serve this as the custom 500 response; the
 * layout never hits a real server.
 */
import Shell from '../components/Shell.astro';
import Button from '../components/Button.astro';
import ErrorTerminal from '../components/ErrorTerminal.astro';
---

<Shell
  title="Something went wrong — OpsCanopy"
  description="An unexpected error interrupted the canopy."
  canonical="/500"
  noindex={true}
  noAlternates={true}
>
  <ErrorTerminal
    eyebrow="Error 500"
    command="GET / HTTP/1.1"
    statusLine="HTTP/1.1 500 Internal Server Error"
    note="something failed on our end — try again in a moment, or head back to a known-good spot."
    srHeading="500 — internal server error"
  >
    <Button href="/" variant="primary">Back to home</Button>
    <Button href="/tools/" variant="secondary">Browse all tools</Button>
  </ErrorTerminal>
</Shell>
