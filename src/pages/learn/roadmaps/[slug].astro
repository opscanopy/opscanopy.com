---
import Shell from '../../../components/Shell.astro';
import Roadmap from '../../../components/Roadmap.astro';
import { roadmaps } from '../../../data/roadmaps';
import { getTrack } from '../../../data/learn';
import { trackIcon } from '../../../data/track-icons';
import { accentGradients } from '../../../data/tools';
import { breadcrumbLd } from '../../../lib/jsonld';
import { site } from '../../../data/site';

export function getStaticPaths() {
  return roadmaps.map((roadmap) => ({ params: { slug: roadmap.slug }, props: { roadmap } }));
}

const { roadmap } = Astro.props;
const canonical = `/learn/roadmaps/${roadmap.slug}`;
const jsonLd = breadcrumbLd([
  { name: 'Home', item: `${site.url}/` },
  { name: 'Learn', item: `${site.url}/learn` },
  { name: roadmap.title, item: `${site.url}${canonical}` },
]);

// Carry the track's identity (icon + accent) from the hub onto the roadmap header.
const track = getTrack(roadmap.track);
const accent = track?.accent ?? 'ship';
const icon = trackIcon(roadmap.track);
// Raw hex over canvas-soft-2 (theme vars in inline styles get tree-shaken by Tailwind v4).
const [iw1, iw2] = accentGradients[accent] ?? accentGradients.develop;
const iconWash = `background-image:linear-gradient(135deg, color-mix(in srgb, ${iw1} 30%, var(--color-canvas-soft-2)), color-mix(in srgb, ${iw2} 30%, var(--color-canvas-soft-2)))`;
---
<Shell title={`${roadmap.title} — OpsCanopy`} description={roadmap.description} canonical={canonical} jsonLd={jsonLd} noAlternates>
  <section class="bg-canvas-soft">
    <div class="container-page py-16 sm:py-24">
      <div class="mx-auto max-w-[48rem]">
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol role="list" class="caption flex flex-wrap items-center gap-x-1.5 text-mute">
            <li><a href="/" class="hover:text-ink">Home</a></li>
            <li aria-hidden="true">/</li>
            <li><a href="/learn" class="hover:text-ink">Learn</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-body" aria-current="page">{roadmap.title}</li>
          </ol>
        </nav>
        <div class="flex items-start gap-4">
          {icon && (
            <span
              class="hidden size-14 shrink-0 place-items-center rounded-xl border border-hairline sm:grid"
              style={iconWash}
              aria-hidden="true"
            >
              <svg width="32" height="32" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink/85"><Fragment set:html={icon} /></svg>
            </span>
          )}
          <div class="min-w-0">
            <h1 class="display-lg text-balance text-ink">{roadmap.title}</h1>
            <p class="body-lg mt-3 text-pretty text-body">{roadmap.description}</p>
          </div>
        </div>
      </div>

      <div class="mx-auto mt-12 max-w-5xl">
        <Roadmap roadmap={roadmap} accent={accent} />
      </div>
    </div>
  </section>
</Shell>
