---
import Shell from '../../components/Shell.astro';
import TrackCard from '../../components/learn/TrackCard.astro';
import { tracks } from '../../data/learn';
import { roadmaps } from '../../data/roadmaps';
import { trackIcon } from '../../data/track-icons';
import { getGuidesForLocale, estimateReadingTime } from '../../lib/learn/guides';
import { breadcrumbLd } from '../../lib/jsonld';
import { site } from '../../data/site';

const all = await getGuidesForLocale('en');
const guidesByTrack = (slug: string) =>
  all
    .filter((g) => g.entry.data.track === slug)
    .sort((x, y) => x.entry.data.order - y.entry.data.order);

const trackMeta = (slug: string) => {
  const gs = guidesByTrack(slug);
  const minutes = gs.reduce(
    (sum, g) => sum + (g.entry.data.estMinutes ?? estimateReadingTime(g.entry.body)),
    0,
  );
  return { count: gs.length, minutes, difficulty: gs[0]?.entry.data.difficulty ?? 'beginner' };
};

// Master DevOps roadmap — the spine that ties every track together.
const devops = roadmaps.find((r) => r.slug === 'devops');
const devopsStages = devops?.stages.map((s) => s.title) ?? [];
const devopsTopics = devops?.stages.reduce((acc, s) => acc + s.nodes.length, 0) ?? 0;
const devopsIcon = trackIcon('devops');

const canonical = '/learn';
const jsonLd = breadcrumbLd([
  { name: 'Home', item: `${site.url}/` },
  { name: 'Learn', item: `${site.url}/learn` },
]);
---
<Shell
  title="Learn DevOps: Free Roadmaps & Guides — OpsCanopy"
  description="Your free DevOps learning hub. Step-by-step roadmaps and guides for Linux, Docker, AWS, Kubernetes, and networking — plus free browser-based tools."
  canonical={canonical}
  jsonLd={jsonLd}
  noAlternates
>
  <section class="bg-canvas-soft">
    <div class="container-page py-16 sm:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="display-lg text-balance text-ink">Learn DevOps — Free Roadmaps & Hands-On Guides</h1>
        <p class="body-lg mt-5 text-pretty text-body">
          Practical, no-fluff guides and career roadmaps for Linux, Docker, AWS, Kubernetes, and networking — with free, browser-based tools to practice as you go.
        </p>
      </div>

      {/* Master path — the flagship roadmap, given the visual centrepiece. */}
      {devops && (
        <a
          href="/learn/roadmaps/devops"
          class="card-interactive group mx-auto mt-12 flex max-w-4xl flex-col gap-6 overflow-hidden rounded-xl border border-brand/30 bg-brand/[0.06] p-6 shadow-soft sm:flex-row sm:items-center sm:p-8"
        >
          <span
            class="grid size-16 shrink-0 place-items-center rounded-xl border border-brand/30 bg-brand/10 text-brand-strong"
            aria-hidden="true"
          >
            <svg width="36" height="36" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={devopsIcon} /></svg>
          </span>
          <div class="min-w-0 flex-1">
            <p class="eyebrow text-brand-strong">Start here · the full path</p>
            <h2 class="display-sm mt-1 text-ink">DevOps Engineer Roadmap</h2>
            <p class="body-sm mt-2 text-pretty text-body">
              The complete end-to-end path — Linux & networking foundations, containers, cloud, Kubernetes, CI/CD, observability, and a portfolio of real projects.
            </p>
            {devopsStages.length > 0 && (
              <p class="mt-3 flex flex-wrap items-center gap-x-1.5 gap-y-1 text-[12px] text-mute">
                {devopsStages.map((s, i) => (
                  <>
                    {i > 0 && <span aria-hidden="true" class="text-hairline-strong">→</span>}
                    <span class="whitespace-nowrap">{s}</span>
                  </>
                ))}
              </p>
            )}
          </div>
          <span class="inline-flex shrink-0 items-center gap-1.5 self-start sm:self-center">
            <span class="btn btn-primary btn-sm pointer-events-none">Start the roadmap</span>
          </span>
        </a>
      )}

      <p class="mt-14 text-center text-[13px] font-medium uppercase tracking-wide text-mute">Or jump straight to a track</p>
      <ul role="list" class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {tracks.map((track) => {
          const m = trackMeta(track.slug);
          return <TrackCard track={track} guideCount={m.count} difficulty={m.difficulty} minutes={m.minutes} />;
        })}
      </ul>
    </div>
  </section>
</Shell>
