---
/**
 * /tools/{category} — static category landing pages.
 *
 * One page per distinct category that has at least one LIVE tool, emitted via
 * getStaticPaths. The URL slug is derived from the category label by
 * categoryToSlug ("CI/CD" → "ci-cd"); slugToCategory resolves it back.
 *
 * Scope: DEFAULT (en) locale only. The /tools catalog has localized
 * /es|/de|/fr|/pt-br variants owned elsewhere, but those use a different
 * (older) filter implementation and are not in this phase's scope. Localized
 * category pages are a documented FOLLOW-UP — emitting them here would require
 * editing the i18n dictionaries this agent does not own. Linking stays within
 * the en tree so i18n is not broken.
 *
 * Each page reuses the shared ToolCard so its grid never drifts from the
 * catalog, and renders a breadcrumb (Home / Tools / {category}) with matching
 * BreadcrumbList JSON-LD plus an ItemList of the category's tools.
 */
import Shell from '../../components/Shell.astro';
import ToolCard from '../../components/ToolCard.astro';
import {
  categories,
  toolsInCategory,
  slugToCategory,
  categoryAccent,
  categoryBlurb,
} from '../../data/tools';
import { site } from '../../data/site';
import { breadcrumbLd } from '../../lib/jsonld';

export function getStaticPaths() {
  return categories.map((c) => ({
    params: { category: c.slug },
    props: { category: c.category, count: c.count },
  }));
}

interface Props {
  category: string;
  count: number;
}

const { category, count } = Astro.props;
// Defensive resolve — params win, but props carry the canonical label.
const resolved = slugToCategory(Astro.params.category as string) ?? category;
const slug = (Astro.params.category as string) ?? '';
const tools = toolsInCategory(resolved);
const accent = categoryAccent[resolved] ?? 'var(--color-mute)';
const blurb =
  categoryBlurb[resolved] ??
  `Free, browser-based ${resolved} tools for platform and DevOps engineers — no signup, no servers.`;

const pageUrl = `${site.url}/tools/${slug}`;
const title = `${resolved} tools — OpsCanopy`;
const description = blurb;

// BreadcrumbList + ItemList JSON-LD for the category page.
const jsonLd = [
  breadcrumbLd([
    { name: 'Home', item: `${site.url}/` },
    { name: 'Tools', item: `${site.url}/tools` },
    { name: resolved, item: pageUrl },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `OpsCanopy ${resolved} tools`,
    description,
    itemListOrder: 'https://schema.org/ItemListOrderAscending',
    numberOfItems: tools.length,
    itemListElement: tools.map((tool, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: tool.name,
      description: tool.tagline,
      url: `${site.url}/${tool.slug}`,
    })),
  },
];
---

<Shell title={title} description={description} canonical={`/tools/${slug}`} jsonLd={jsonLd} noAlternates>
  <!-- ── Header block ─────────────────────────────────────────────────── -->
  <section class="border-b border-hairline bg-canvas-soft">
    <div class="container-page py-8 sm:py-10">
      <nav aria-label="Breadcrumb" class="mb-4 text-sm text-mute">
        <ol class="flex flex-wrap items-center gap-1.5">
          <li><a href="/" class="transition-colors hover:text-brand">Home</a></li>
          <li aria-hidden="true" class="text-hairline">/</li>
          <li><a href="/tools" class="transition-colors hover:text-brand">Tools</a></li>
          <li aria-hidden="true" class="text-hairline">/</li>
          <li aria-current="page" class="text-body">{resolved}</li>
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex items-center gap-2">
          <span class="size-2 shrink-0 rounded-full" style={`background-color: ${accent}`} aria-hidden="true"></span>
          <p class="eyebrow">Category</p>
        </div>
        <h1 class="display-lg mt-3 text-balance text-ink">{resolved} tools.</h1>
        <p class="body-md mt-3 max-w-2xl text-pretty text-body">{blurb}</p>
        <div class="mt-5 flex flex-wrap items-center gap-3">
          <span class="badge">
            <span class="size-1.5 rounded-full bg-success" aria-hidden="true"></span>
            <span class="tabular-nums">{count}</span>
            {count === 1 ? 'tool' : 'tools'}
          </span>
          <a href="/tools" class="link-inline body-sm inline-flex items-center gap-1 font-medium">
            <span aria-hidden="true">&larr;</span>
            All tools
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Category tools ───────────────────────────────────────────────── -->
  <section aria-labelledby="cat-heading" class="bg-canvas">
    <div class="container-page py-16 sm:py-24">
      <h2 id="cat-heading" class="sr-only">{resolved} tools</h2>
      <ul role="list" class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
        {tools.map((tool, i) => <ToolCard tool={tool} order={i} />)}
      </ul>

      <div class="mt-12 border-t border-hairline pt-8">
        <a href="/tools" class="link-inline body-sm inline-flex items-center gap-1 font-medium">
          <span aria-hidden="true">&larr;</span>
          Back to all tools
        </a>
      </div>
    </div>
  </section>
</Shell>
