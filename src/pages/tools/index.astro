---
/**
 * /tools — the OpsCanopy catalog.
 * Sequential-shipping philosophy: one excellent, fully-polished tool at a time.
 * Live tools render as accented cards; planned tools render as an honest,
 * ordered roadmap. Catalog content is sourced from ../../data/tools — never
 * hardcoded here.
 */
import Shell from '../../components/Shell.astro';
import Card from '../../components/Card.astro';
import Badge from '../../components/Badge.astro';
import { liveTools, plannedTools, accentGradients } from '../../data/tools';
import { site } from '../../data/site';

// Map each accent to a complete, static gradient class string. Tailwind v4
// scans source as text, so these must be full literals — never concatenated.
const accentBar: Record<string, string> = {
  develop: 'from-[#007cf0] to-[#00dfd8]',
  preview: 'from-[#7928ca] to-[#ff0080]',
  ship: 'from-[#ff4d4d] to-[#f9cb28]',
};

// ItemList JSON-LD over the full live + planned catalog (ordered, with positions).
const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'OpsCanopy tools',
  description:
    'Free, browser-based tools for platform and DevOps engineers. No signup, no servers, your data stays on your device.',
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  numberOfItems: liveTools.length + plannedTools.length,
  itemListElement: [...liveTools, ...plannedTools].map((tool, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: tool.name,
    description: tool.tagline,
    url: `${site.url}/${tool.slug}`,
  })),
};
---

<Shell
  title="Tools — OpsCanopy"
  description="Free, browser-based tools for platform and DevOps engineers. No signup, no servers, your data stays on your device."
  canonical="/tools"
  jsonLd={itemList}
>
  <!-- ── Header block ─────────────────────────────────────────────────── -->
  <section class="border-b border-hairline bg-canvas-soft">
    <div class="container-page py-16 sm:py-24">
      <div class="max-w-3xl">
        <p class="eyebrow">The catalog</p>
        <h1 class="display-xl mt-4 text-balance text-ink">The whole toolbox, one tab away.</h1>
        <p class="body-lg mt-6 max-w-2xl text-pretty text-body">
          <span translate="no">OpsCanopy</span> ships one excellent tool at a time. Rather than a sprawling
          grid of half-finished utilities, every tool here is built to do a single job
          completely — and runs entirely in your browser, so nothing you paste ever
          leaves the device. Below is what is live today and what is next.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <span class="badge">
            <span class="size-1.5 rounded-full bg-success" aria-hidden="true"></span>
            <span class="tabular-nums">{liveTools.length}</span> live
          </span>
          <span class="badge"><span class="tabular-nums">{plannedTools.length}</span> on the roadmap</span>
          <span class="badge">100%&nbsp;client-side</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Live tools ───────────────────────────────────────────────────── -->
  <section aria-labelledby="live-heading" class="bg-canvas">
    <div class="container-page py-16 sm:py-24">
      <div class="flex items-end justify-between gap-6">
        <div class="min-w-0">
          <p class="eyebrow">Available now</p>
          <h2 id="live-heading" class="display-lg mt-3 text-balance text-ink">Live tools.</h2>
        </div>
        <a href="#roadmap" class="link-inline body-sm hidden whitespace-nowrap sm:inline">
          Jump to roadmap&nbsp;&darr;
        </a>
      </div>

      {
        liveTools.length === 0 ? (
          <div class="card-soft mt-10 flex flex-col items-center rounded-lg px-6 py-16 text-center">
            <p class="display-sm text-ink">Nothing live just yet.</p>
            <p class="body-md mt-3 max-w-md text-pretty text-body">
              The first tool is being polished to ship. Watch the{' '}
              <a href="#roadmap" class="link-inline">roadmap</a> below to see what is coming.
            </p>
          </div>
        ) : (
          <ul role="list" class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
            {liveTools.map((tool) => (
              <li class="h-full">
                <Card class="group relative flex h-full flex-col overflow-hidden p-0 shadow-soft transition-[transform,box-shadow] duration-150 hover:-translate-y-0.5 hover:shadow-float focus-within:shadow-float focus-within:ring-2 focus-within:ring-link focus-within:ring-offset-2">
                  <span
                    class:list={[
                      'block h-1 w-full bg-gradient-to-r',
                      accentBar[tool.accent],
                    ]}
                    aria-hidden="true"
                  />
                  <div class="flex h-full flex-col p-6">
                    <div class="flex items-center justify-between gap-3">
                      <p class="eyebrow min-w-0 truncate">{tool.category}</p>
                      <Badge variant="live">Live</Badge>
                    </div>

                    <h3 class="display-sm mt-4 text-balance text-ink">
                      <a
                        href={`/${tool.slug}`}
                        class="rounded-sm outline-none after:absolute after:inset-0 after:content-['']"
                      >
                        {tool.name}
                      </a>
                    </h3>
                    <p class="body-md mt-1.5 font-medium text-pretty text-ink">{tool.tagline}</p>
                    <p class="body-sm mt-3 text-pretty text-body">{tool.description}</p>

                    <ul role="list" class="mt-5 flex flex-wrap gap-2">
                      {tool.keywords.slice(0, 3).map((keyword) => (
                        <li class="min-w-0">
                          <span class="badge code-mono max-w-full break-words lowercase text-body">{keyword}</span>
                        </li>
                      ))}
                    </ul>

                    <div class="mt-auto pt-6">
                      <span class="link-inline body-sm inline-flex items-center gap-1 font-medium">
                        Open tool
                        <span
                          class="transition-transform duration-150 group-hover:translate-x-0.5"
                          aria-hidden="true"
                        >
                          &rarr;
                        </span>
                      </span>
                    </div>
                  </div>
                </Card>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>

  <!-- ── Roadmap ──────────────────────────────────────────────────────── -->
  <section
    id="roadmap"
    aria-labelledby="roadmap-heading"
    class="border-t border-hairline bg-canvas-soft"
  >
    <div class="container-page py-16 sm:py-24">
      <div class="max-w-2xl">
        <p class="eyebrow">What is next</p>
        <h2 id="roadmap-heading" class="display-lg mt-3 text-balance text-ink">On the roadmap.</h2>
        <p class="body-md mt-4 text-pretty text-body">
          These are the tools we are building next, in order. We ship them one at a
          time and only when each is genuinely finished — no betas left to rot, no
          half-working stubs. Want one sooner?
          <a class="link-inline" href={site.github} target="_blank" rel="noopener noreferrer">Open an issue</a>.
        </p>
      </div>

      {
        plannedTools.length === 0 ? (
          <div class="card-soft mt-10 flex flex-col items-center rounded-lg px-6 py-16 text-center">
            <p class="display-sm text-ink">The roadmap is clear.</p>
            <p class="body-md mt-3 max-w-md text-pretty text-body">
              Every planned tool has shipped. Have an idea for the next one?{' '}
              <a class="link-inline" href={site.github} target="_blank" rel="noopener noreferrer">
                Open an issue
              </a>
              .
            </p>
          </div>
        ) : (
          <ol role="list" class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
            {plannedTools.map((tool, i) => (
              <li class="h-full">
                <Card class="card-soft flex h-full flex-col p-6">
                  <div class="flex items-center justify-between gap-3">
                    <span class="eyebrow tabular-nums" aria-hidden="true">
                      {String(i + 1).padStart(2, '0')}
                    </span>
                    <Badge variant="planned">Coming soon</Badge>
                  </div>

                  <h3 class="display-sm mt-4 text-balance text-ink">{tool.name}</h3>
                  <p class="body-md mt-1.5 font-medium text-pretty text-body">{tool.tagline}</p>
                  <p class="body-sm mt-3 text-pretty text-mute">{tool.description}</p>

                  <div class="mt-auto pt-6">
                    <span class="eyebrow min-w-0 truncate">{tool.category}</span>
                  </div>
                </Card>
              </li>
            ))}
          </ol>
        )
      }

      <p class="caption mt-10 max-w-2xl text-pretty text-mute">
        Ordered by what we will build next. Dates are intentionally omitted — each
        tool ships when it is fully polished, not before.
      </p>
    </div>
  </section>
</Shell>
