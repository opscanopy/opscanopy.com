---
/**
 * /tools — the OpsCanopy catalog.
 * Users come here to use a tool, so the live-tools grid sits at the top with
 * minimal scroll. Live tools render as accented cards. Catalog content is
 * sourced from ../../data/tools — never hardcoded here.
 */
import Shell from '../../components/Shell.astro';
import ToolCard from '../../components/ToolCard.astro';
import { liveTools, categories, categoryAccent } from '../../data/tools';
import { site } from '../../data/site';

// ItemList JSON-LD over the live catalog (ordered, with positions).
const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'OpsCanopy tools',
  description:
    'Free, browser-based tools for platform and DevOps engineers. No signup, no servers, your data stays on your device.',
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  numberOfItems: liveTools.length,
  itemListElement: liveTools.map((tool, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: tool.name,
    description: tool.tagline,
    url: `${site.url}/${tool.slug}`,
  })),
};
---

<Shell
  title="DevOps & SRE Tools — Free Online Validators & Converters · OpsCanopy"
  description="Free, browser-based tools for platform and DevOps engineers. No signup, no servers, your data stays on your device."
  canonical="/tools"
  jsonLd={itemList}
>
  <!-- ── Header block ─────────────────────────────────────────────────── -->
  <section class="border-b border-hairline bg-canvas-soft">
    <div class="container-page py-8 sm:py-10">
      <div class="max-w-3xl">
        <h1 class="display-lg text-balance text-ink">The whole toolbox, one tab away.</h1>
        <p class="body-md mt-3 max-w-2xl text-pretty text-body">
          Focused DevOps tools that run entirely in your browser — free, no signup, nothing you paste ever leaves your device.
        </p>
        <div class="mt-5 flex flex-wrap items-center gap-3">
          <span class="badge">
            <span class="size-1.5 rounded-full bg-success" aria-hidden="true"></span>
            <span class="tabular-nums">{liveTools.length}</span> live
          </span>
          <span class="badge">100%&nbsp;client-side</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Live tools ───────────────────────────────────────────────────── -->
  <section aria-labelledby="live-heading" class="bg-canvas">
    <div class="container-page py-16 sm:py-24">
      <div class="flex items-end justify-between gap-6">
        <div class="min-w-0">
          <p class="eyebrow">Available now</p>
          <h2 id="live-heading" class="display-lg mt-3 text-balance text-ink">Live tools.</h2>
        </div>
      </div>

      {
        liveTools.length > 0 && (
          <nav aria-label="Browse tools by category" class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-2">
            <span class="text-xs font-semibold uppercase tracking-wide text-mute">Browse by category</span>
            {categories.map((c) => (
              <a
                href={`/tools/${c.slug}`}
                class="badge cursor-pointer select-none text-body transition-colors hover:bg-brand/10"
              >
                <span
                  class="size-1.5 shrink-0 rounded-full"
                  style={`background-color: ${categoryAccent[c.category]}`}
                  aria-hidden="true"
                />
                {c.category}
                <span class="tabular-nums text-mute">{c.count}</span>
              </a>
            ))}
          </nav>
        )
      }

      {
        liveTools.length === 0 ? (
          <div class="card-soft mt-10 flex flex-col items-center rounded-lg px-6 py-16 text-center">
            <p class="display-sm text-ink">Nothing live just yet.</p>
            <p class="body-md mt-3 max-w-md text-pretty text-body">
              The first tool is being polished to ship — check back soon to see what is coming.
            </p>
          </div>
        ) : (
          <div class="mb-8 space-y-4">
  <input
    id="tool-search"
    type="search"
    placeholder="Search tools…"
    autocomplete="off"
    class="input-focus w-full rounded-lg border border-hairline bg-canvas px-4 py-3 sm:py-2.5 text-sm text-ink placeholder:text-mute"
    aria-label="Search tools"
  />
  <div class="cat-filter-row flex items-center gap-x-4">
    <div class="cat-chips-scroll min-w-0 flex-1">
      <div id="cat-filters" role="group" aria-label="Filter by category" class="flex flex-wrap gap-2">
        <button data-cat="all" class="cat-chip is-active badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="true">All</button>
        <button data-cat="networking" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">Networking</button>
        <button data-cat="security" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">Security</button>
        <button data-cat="encoding" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">Encoding</button>
        <button data-cat="kubernetes" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">Kubernetes</button>
        <button data-cat="observability" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">Observability</button>
        <button data-cat="ci/cd" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">CI/CD</button>
        <button data-cat="scheduling" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">Scheduling</button>
        <button data-cat="logs" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">Logs</button>
        <button data-cat="config" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">Config</button>
        <button data-cat="docker" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">Docker</button>
      </div>
    </div>
    <div class="flex shrink-0 items-center gap-2">
      <label for="tool-sort" class="text-xs font-semibold uppercase tracking-wide text-mute">Sort</label>
      <select
        id="tool-sort"
        class="input-focus cursor-pointer rounded-lg border border-hairline bg-canvas py-1.5 pl-3 pr-8 text-sm font-medium text-ink"
        aria-label="Sort tools"
      >
        <option value="default">Default</option>
        <option value="az">A–Z</option>
        <option value="newest">Newest</option>
      </select>
    </div>
  </div>
  <div id="tool-empty" class="hidden py-6" role="status" aria-live="polite">
    <p class="body-md text-ink">No tools match <span id="tool-empty-query" class="font-semibold">your search</span>.</p>
    <p class="body-sm mt-1 text-body">Try one of these, or clear the filters to see everything.</p>
    <div class="mt-4 flex flex-wrap items-center gap-2">
      <button type="button" data-example="subnet" class="example-chip badge cursor-pointer select-none hover:bg-brand/10">subnet</button>
      <button type="button" data-example="jwt" class="example-chip badge cursor-pointer select-none hover:bg-brand/10">jwt</button>
      <button type="button" data-example="cron" class="example-chip badge cursor-pointer select-none hover:bg-brand/10">cron</button>
      <button type="button" data-example="regex" class="example-chip badge cursor-pointer select-none hover:bg-brand/10">regex</button>
    </div>
    <button id="tool-clear" type="button" class="link-inline body-sm mt-4 inline-flex items-center gap-1 font-medium">Clear filters</button>
  </div>
</div>
          <ul id="tool-grid" role="list" class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
            {liveTools.map((tool, i) => (
              <ToolCard tool={tool} order={i} />
            ))}
          </ul>
        )
      }
    </div>
  </section>
</Shell>

<script>
  (function () {
    var search = document.getElementById("tool-search");
    var empty = document.getElementById("tool-empty");
    var emptyQuery = document.getElementById("tool-empty-query");
    var sortSelect = document.getElementById("tool-sort");
    var grid = document.getElementById("tool-grid");
    var SORT_KEY = "opscanopy:tools:sort";
    var activeCat = "all";
    var activeSort = "default";

    // ── Sort ────────────────────────────────────────────────────────────
    // "Default" + "Newest" both key off the registry index (data-order):
    // Default is ascending (curated order); Newest is descending, treating
    // later-registered tools as newer — the documented proxy for recency.
    // "A–Z" sorts by tool name. The chosen mode persists in localStorage.
    function applySort() {
      if (!grid) return;
      var cards = Array.prototype.slice.call(grid.querySelectorAll(".tool-card"));
      cards.sort(function (a, b) {
        if (activeSort === "az") {
          return (a.dataset.name || "").localeCompare(b.dataset.name || "");
        }
        var oa = parseInt(a.dataset.order || "0", 10);
        var ob = parseInt(b.dataset.order || "0", 10);
        return activeSort === "newest" ? ob - oa : oa - ob;
      });
      // Re-append in the new order; appendChild moves existing nodes (no clone),
      // so visibility (display) and event wiring are preserved.
      cards.forEach(function (card) { grid.appendChild(card); });
    }
    function setSort(mode) {
      activeSort = mode === "az" || mode === "newest" ? mode : "default";
      if (sortSelect) sortSelect.value = activeSort;
      try { localStorage.setItem(SORT_KEY, activeSort); } catch (e) {}
      applySort();
    }

    // Reflect the active category onto the chips (extracted so the Clear-filters
    // action can reuse the exact same activation logic).
    function setActiveCat(cat) {
      activeCat = cat || "all";
      document.querySelectorAll(".cat-chip").forEach(function(b) {
        var on = (b.dataset.cat || "all") === activeCat;
        b.setAttribute("aria-pressed", on ? "true" : "false");
        b.classList.toggle("is-active", on);
      });
    }
    function filter() {
      var raw = search ? search.value.trim() : "";
      var q = raw.toLowerCase();
      var cards = document.querySelectorAll(".tool-card");
      var visible = 0;
      cards.forEach(function(card) {
        var name = (card.dataset.name || "");
        var cat = (card.dataset.category || "");
        var tagline = (card.dataset.tagline || "");
        var desc = (card.dataset.desc || "");
        var keywords = (card.dataset.keywords || "");
        var matchSearch = !q ||
          name.indexOf(q) !== -1 ||
          tagline.indexOf(q) !== -1 ||
          desc.indexOf(q) !== -1 ||
          keywords.indexOf(q) !== -1;
        var matchCat = activeCat === "all" || cat === activeCat;
        var show = matchSearch && matchCat;
        card.style.display = show ? "" : "none";
        if (show) visible++;
      });
      // Echo the query (or just say "your search" when filtering by category only).
      if (emptyQuery) emptyQuery.textContent = raw ? '"' + raw + '"' : "your search";
      if (empty) empty.classList.toggle("hidden", visible > 0);
    }
    if (search) search.addEventListener("input", filter);
    document.querySelectorAll(".cat-chip").forEach(function(btn) {
      btn.addEventListener("click", function() {
        setActiveCat(btn.dataset.cat);
        filter();
      });
    });
    if (sortSelect) {
      sortSelect.addEventListener("change", function () { setSort(sortSelect.value); });
    }
    // Empty-state escape hatches.
    var clearBtn = document.getElementById("tool-clear");
    if (clearBtn) {
      clearBtn.addEventListener("click", function() {
        if (search) search.value = "";
        setActiveCat("all");
        filter();
        if (search) search.focus();
      });
    }
    document.querySelectorAll(".example-chip").forEach(function(chip) {
      chip.addEventListener("click", function() {
        if (search) search.value = chip.dataset.example || "";
        setActiveCat("all");
        filter();
        if (search) search.focus();
      });
    });

    // Restore the persisted sort on load (defaults to curated order), then sort.
    var saved = "default";
    try { saved = localStorage.getItem(SORT_KEY) || "default"; } catch (e) {}
    setSort(saved);
  })();
</script>

<style>
  /* Active filter chip — emerald-strong (#047857) for AA-safe white-on-fill.
     Driven by the .is-active class (JS-toggled) so the selected state is always
     visible regardless of Tailwind's aria-pressed variant emission. */
  .cat-chip {
    transition: background-color 120ms ease, color 120ms ease;
  }
  .cat-chip.is-active {
    background-color: var(--color-brand-strong);
    color: #fff;
  }
  .cat-chip.is-active:hover {
    background-color: var(--color-brand-strong);
  }

  /* Task 3 — Focus ring on active chip: emerald-on-emerald is invisible, so we
     use a white outline with offset so it shows on the dark fill. */
  .cat-chip.is-active:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  /* Dark theme: the active fill is light emerald (--color-brand-strong: #34d399),
     so a white ring drops to ~1.6:1 (below the 3:1 focus-indicator minimum).
     Re-point the outline to a dark emerald so it stays visible on the fill. */
  html[data-theme='dark'] .cat-chip.is-active:focus-visible {
    outline-color: #022c22;
  }

  /* Task 1 — Mobile filter strip: below 640px collapse the chip row into a
     single-row horizontal scroll strip. The scroll container (cat-chips-scroll)
     clips and scrolls; the inner flex row switches to nowrap so chips stay in
     one line. -webkit-overflow-scrolling:touch ensures momentum scroll on iOS.
     Scrollbar is hidden across all engines without hiding the content.
     44px min-height preserves coarse-pointer tap targets. */
  @media (max-width: 639px) {
    .cat-chips-scroll {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      /* hide scrollbar — WebKit */
      scrollbar-width: none; /* Firefox */
    }
    .cat-chips-scroll::-webkit-scrollbar {
      display: none; /* Chrome/Safari/Edge */
    }
    /* Switch inner flex row to nowrap so all chips stay on one line */
    .cat-chips-scroll #cat-filters {
      flex-wrap: nowrap;
      min-height: 44px;
      align-items: center;
      padding-bottom: 2px; /* prevent focus rings being clipped at the bottom */
      padding-right: 2px; /* and the last chip's focus ring at the right edge */
    }
    /* Ensure each chip meets the 44px coarse-pointer tap target */
    .cat-chips-scroll .cat-chip {
      flex-shrink: 0;
      min-height: 44px;
      display: inline-flex;
      align-items: center;
    }
  }
</style>
