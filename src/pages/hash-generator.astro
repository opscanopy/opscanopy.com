---
/**
 * Hash Generator — the hash-generator tool page (SEO surface).
 * Compute MD5, SHA-1, SHA-256 and SHA-512 digests of any text, plus an
 * optional HMAC with a key — all via the Web Crypto API, entirely in the
 * browser.
 */
import Shell from '../components/Shell.astro';
import HashGeneratorPlayground from '../components/HashGeneratorPlayground.astro';
import Button from '../components/Button.astro';
import CodeBlock from '../components/CodeBlock.astro';
import ToolHero from '../components/ToolHero.astro';
import ToolPipeline from '../components/ToolPipeline.astro';
import FaqList from '../components/FaqList.astro';
import ToolCrossLinks from '../components/ToolCrossLinks.astro';
import { site, navLinks } from '../data/site';
import { getTool } from '../data/tools';
import { softwareAppLd, faqPageLd } from '../lib/jsonld';

const tool = getTool('hash-generator');
const pagePath = '/hash-generator';
const pageUrl = `${site.url}${pagePath}`;

const faqs = [
  {
    q: 'What is a hash?',
    a: 'A hash function takes any input — a word, a file, a megabyte of text — and produces a fixed-length string of bytes called a digest. The same input always yields the same digest, while even a one-character change produces a completely different one, and you cannot reverse a digest back into the original. That makes hashes ideal for verifying integrity (did this content change?) and for fingerprinting data, rather than for hiding it.',
  },
  {
    q: 'Which algorithms does this support, and what size is each digest?',
    a: 'It computes MD5 (128-bit, 32 hex characters), SHA-1 (160-bit, 40 hex), SHA-256 (256-bit, 64 hex) and SHA-512 (512-bit, 128 hex). SHA-1, SHA-256 and SHA-512 are computed by the browser’s native Web Crypto API; MD5 is computed in pure JavaScript because Web Crypto deliberately does not expose it. The digest length depends only on the algorithm, never on how long your input is.',
  },
  {
    q: 'Are MD5 and SHA-1 safe to use?',
    a: 'Not for anything security-sensitive. MD5 and SHA-1 are both broken against collision attacks — an attacker can craft two different inputs that share the same digest — so they must not be used for signatures, certificates or password storage. They are still fine as fast, non-adversarial checksums (for example, matching a file against a vendor-published MD5). For security, reach for SHA-256 or SHA-512.',
  },
  {
    q: 'Does my text ever leave my browser?',
    a: 'No. Every digest is computed locally through the Web Crypto API (and a pure-JS routine for MD5) inside your tab — there is no server, no account and no logging. You can safely hash tokens, config snippets or private data; nothing is ever uploaded over the network.',
  },
  {
    q: 'What is HMAC?',
    a: 'HMAC (Hash-based Message Authentication Code) combines a hash function with a secret key to prove both the integrity and the authenticity of a message: only someone holding the key can produce a matching code, so it detects tampering as well as confirming the sender. Provide a key here and the tool computes HMAC-SHA-256 (and the other SHA variants) over your text using the Web Crypto API, again entirely in your browser.',
  },
];

const softwareApp = softwareAppLd({
  name: 'Hash Generator',
  description:
    'Compute MD5, SHA-1, SHA-256 and SHA-512 digests of any text, plus an optional HMAC with a key — all via the Web Crypto API, 100% in your browser.',
  url: pageUrl,
  subCategory: 'Security',
  featureList: [
    'Compute MD5, SHA-1, SHA-256 and SHA-512 digests of any text',
    'Optional HMAC with a secret key',
    'Native Web Crypto API for SHA, pure JS for MD5',
    '100% client-side, no upload, no signup',
  ],
  keywords: tool?.keywords.join(', '),
});
const faqPage = faqPageLd(faqs);

const pipeline = [
  {
    title: 'Read the text as bytes.',
    body: 'Your input is encoded to UTF-8 first, so emoji and accents become the exact bytes the hash will consume.',
  },
  {
    title: 'Digest the bytes.',
    body: 'SHA-1, SHA-256 and SHA-512 run through the native Web Crypto API; MD5 runs in a pure-JS routine since the browser omits it.',
  },
  {
    title: 'Hex-encode the result.',
    body: 'The raw digest bytes are rendered as lowercase hexadecimal — the canonical form you compare against published checksums.',
  },
  {
    title: 'Sign with a key (optional).',
    body: 'Add a secret key and the same text is run through HMAC, producing a keyed code that proves authenticity, not just integrity.',
  },
];

const digestSizes = `algorithm   digest size   hex chars   security
MD5         128-bit       32          broken — checksums only
SHA-1       160-bit       40          broken — avoid for security
SHA-256     256-bit       64          recommended
SHA-512     512-bit       128         recommended

Note: MD5 and SHA-1 are unsafe for signatures, certificates
or passwords — both have practical collision attacks.
Use SHA-256 or SHA-512 for anything security-sensitive.`;

const hmacExample = `text   "hello"

SHA-256        2cf24dba5fb0a30e26e83b2ac5b9e29e
               1b161e5c1fa7425e73043362938b9824
HMAC-SHA-256   key="s3cret"
               e5a01537481fa0b2c697f787c7aff885
               412cf0760d08e08502259b39d2d6ae68

Same text, a key — a completely different, keyed digest.`;
---

<Shell
  title="Hash Generator — MD5, SHA-1, SHA-256, SHA-512 & HMAC Online"
  description="Compute MD5, SHA-1, SHA-256 and SHA-512 digests of any text, plus an optional HMAC with a key — all via the Web Crypto API, 100% in your browser."
  canonical="/hash-generator"
  jsonLd={[softwareApp, faqPage]}
>
  <ToolHero
    eyebrow="Hash Generator · Security"
    badges={[
      { label: 'Runs in your browser', variant: 'live' },
      { label: 'MD5 · SHA · HMAC', variant: 'neutral' },
      { label: 'No signup', variant: 'neutral' },
    ]}
  >
    <Fragment slot="headline">Hash any text, locally, in a keystroke.</Fragment>
    <Fragment slot="lead">
      Compute <span class="code-mono text-ink" translate="no">MD5</span>,
      <span class="code-mono text-ink" translate="no">SHA-1</span>,
      <span class="code-mono text-ink" translate="no">SHA-256</span> and
      <span class="code-mono text-ink" translate="no">SHA-512</span> digests — plus an optional
      <span class="code-mono text-ink" translate="no">HMAC</span> with a key — all through the Web
      Crypto API, entirely in your browser.
    </Fragment>
  </ToolHero>

  <section id="playground" class="scroll-mt-24 bg-canvas-soft pt-8 pb-20 sm:pb-24">
    <div class="container-page">
      <h2 class="sr-only">Hash generator playground</h2>
      <HashGeneratorPlayground />
    </div>
  </section>

  <section id="why" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
        <div>
          <p class="eyebrow">The Gap</p>
          <h2 class="display-lg mt-3 text-balance text-ink">
            One stray byte, a checksum that no longer matches.
          </h2>
        </div>
        <div class="space-y-4">
          <p class="body-md text-pretty text-body">
            Verifying a download, fingerprinting a payload or building an HMAC signature usually means
            reaching for a CLI you half-remember — and the moment you paste a secret into an online
            hasher, you are trusting an unknown server with it. The maths is standard; the risk is
            where it runs.
          </p>
          <p class="body-md text-pretty text-body">
            This generator computes every digest right in the page through the browser&rsquo;s native
            Web Crypto API (with a pure-JS routine for MD5, which the API omits on purpose), so you can
            confirm a hash or sign a message without anything leaving your tab. Entirely in the
            browser, with nothing to install.
          </p>
          <p class="body-sm text-mute">
            Reading a token instead of hashing one? The
            <a class="link-inline" href="/jwt-decoder">JWT Decoder</a> splits and base64url-decodes its
            three parts for you.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ToolPipeline
    id="how-it-works"
    eyebrow="The Pipeline"
    heading="How it works."
    lead="Four deterministic steps run on every keystroke — all inside your browser tab, with the text read as UTF-8 before the bytes are digested."
    steps={pipeline}
  />

  <section id="reference" class="scroll-mt-24 border-t border-hairline bg-canvas">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Digest Reference</p>
        <h2 class="display-lg mt-3 text-ink">How big is each digest?</h2>
        <p class="body-md mx-auto mt-3 max-w-xl text-pretty text-body">
          The algorithm alone fixes the digest length, never your input. Pick by security need —
          MD5 and SHA-1 are fast but broken, so keep them for non-adversarial checksums only.
        </p>
      </div>
      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-2">
        <div class="min-w-0">
          <h3 class="display-sm text-ink">Digest sizes</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            A digest is rendered as <span class="code-mono text-ink" translate="no">bits / 4</span>
            hexadecimal characters — so SHA-256 is 64 hex chars, SHA-512 is 128.
          </p>
          <CodeBlock lang="text" filename="digest-sizes" code={digestSizes} />
        </div>
        <div class="min-w-0">
          <h3 class="display-sm text-ink">Adding a key (HMAC)</h3>
          <p class="body-sm mt-2 mb-4 text-pretty text-body">
            A plain hash proves integrity; an
            <span class="code-mono text-ink" translate="no">HMAC</span> mixes in a secret key to prove
            authenticity too — same text, a different keyed digest.
          </p>
          <CodeBlock lang="text" filename="hmac-vs-hash" code={hmacExample} />
        </div>
      </div>
    </div>
  </section>

  <section id="next" class="scroll-mt-24 bg-inverse text-inverse-fg">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto grid max-w-5xl items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
        <div class="min-w-0">
          <p class="eyebrow !text-cyan">Next Step</p>
          <h2 class="display-lg mt-3 text-balance text-inverse-fg">
            Need to encode bytes, not fingerprint them?
          </h2>
          <p class="body-md mt-4 text-pretty text-white/70">
            A hash is one-way; when you need a reversible, text-safe representation of bytes, the
            <span translate="no">Base64 Encoder / Decoder</span> turns any text into
            <span translate="no">base64url</span> and back. And when that encoded value is a token, the
            <span translate="no">JWT Decoder</span> splits and decodes its three parts — both in your
            browser.
          </p>
          <div class="mt-7 flex flex-wrap items-center gap-3">
            <Button href="/base64-encoder-decoder" variant="secondary">Open the Base64 Tool</Button>
            <Button href="/jwt-decoder" variant="secondary">Open the JWT Decoder</Button>
          </div>
        </div>
        <CodeBlock
          lang="text"
          filename="digest.txt"
          code={`text     "ops"

SHA-256  a92c...b132   ←  one-way fingerprint
base64   b3Bz         ←  reversible encoding`}
        />
      </div>
    </div>
  </section>

  <FaqList faqs={faqs} />

  <ToolCrossLinks>
    <Fragment slot="lead">
      The Hash Generator is one tool in
      <span translate="no">{site.name}</span> — a growing canopy of browser-based validators,
      converters and testers that never touch a server.
    </Fragment>
    <Fragment slot="links">
      Related tools: the
      <a class="link-inline" href="/base64-encoder-decoder">Base64 Encoder / Decoder</a> and the
      <a class="link-inline" href="/jwt-decoder">JWT Decoder</a>, or browse the full
      <a class="link-inline" href={navLinks[0].href}>tools directory</a>.
    </Fragment>
    <Fragment slot="disclaimer">
      Provided as-is for convenience; MD5 and SHA-1 are broken and must not be used for security.
      Always confirm critical integrity checks against a trusted source.
      <span translate="no">{site.name}</span> is free and open.
    </Fragment>
  </ToolCrossLinks>
</Shell>
