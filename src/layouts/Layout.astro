---
/**
 * Base layout — the platform shell wrapper. Imports the global stylesheet,
 * renders <head> via SEO, and provides named slots for header/footer
 * (filled by pages or a higher-level shell). Most pages should use
 * <Shell> (src/components/Shell.astro) which composes Header + Footer here.
 */
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import { site } from '../data/site';
import { BCP47, DEFAULT_LOCALE, type Locale } from '../i18n/config';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noAlternates?: boolean;
  availableLocales?: Locale[];
}

const { title, description, canonical, image, type, noindex, jsonLd, noAlternates, availableLocales } =
  Astro.props;
const fullTitle = title.includes(site.name) ? title : `${title} · ${site.name}`;
const lang: Locale = (Astro.currentLocale as Locale) ?? DEFAULT_LOCALE;
---

<!doctype html>
<html lang={BCP47[lang]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#fafafa" />
    {/* No-flash theme init — runs before paint. Saved choice wins, else OS preference. */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t !== 'dark' && t !== 'light') {
            t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.setAttribute('data-theme', t);
          var m = document.querySelector('meta[name="theme-color"]');
          if (m) m.setAttribute('content', t === 'dark' ? '#0a0a0a' : '#fafafa');
        } catch (e) {}
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    {/* Google tag (gtag.js) */}
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-EGNWVFWMP0"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-EGNWVFWMP0');
    </script>
    {/* GA4 engagement events — tool_engaged (first interaction in #playground) + result_copied (copy controls). Defensive, dependency-free. */}
    <script is:inline>
      (function () {
        var engaged = false;
        function send(name) {
          try {
            if (typeof window.gtag !== 'function' || !window.dataLayer) return;
            window.gtag('event', name, { tool: location.pathname });
          } catch (e) {}
        }
        function inPlayground(node) {
          try {
            return !!(node && node.closest && node.closest('#playground'));
          } catch (e) {
            return false;
          }
        }
        function isCopyControl(node) {
          try {
            if (!node || !node.closest) return false;
            if (node.closest('[data-copy],[data-copy-value],[data-copy-all],[data-copy-link]')) return true;
            var btn = node.closest('button,[role="button"]');
            if (btn) {
              var cls = btn.className && btn.className.baseVal !== undefined ? btn.className.baseVal : btn.className;
              if (typeof cls === 'string' && /(^|[\s-])copy([\s-]|$)|copy-btn|-copy/.test(cls)) return true;
              var al = btn.getAttribute && btn.getAttribute('aria-label');
              if (al && /^copy/i.test(al)) return true;
            }
            return false;
          } catch (e) {
            return false;
          }
        }
        function onFirst(e) {
          var t = e.target;
          if (!engaged && inPlayground(t)) {
            engaged = true;
            send('tool_engaged');
          }
        }
        ['input', 'change', 'keydown', 'click'].forEach(function (type) {
          document.addEventListener(type, onFirst, true);
        });
        document.addEventListener(
          'click',
          function (e) {
            var t = e.target;
            if (inPlayground(t) && isCopyControl(t)) send('result_copied');
          },
          true
        );
      })();
    </script>
    <SEO
      title={fullTitle}
      description={description}
      canonical={canonical}
      image={image}
      type={type}
      noindex={noindex}
      jsonLd={jsonLd}
      noAlternates={noAlternates}
      availableLocales={availableLocales}
    />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
