---
/**
 * Base layout — the platform shell wrapper. Imports the global stylesheet,
 * renders <head> via SEO, and provides named slots for header/footer
 * (filled by pages or a higher-level shell). Most pages should use
 * <Shell> (src/components/Shell.astro) which composes Header + Footer here.
 */
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import { site } from '../data/site';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, canonical, image, type, noindex, jsonLd } = Astro.props;
const fullTitle = title.includes(site.name) ? title : `${title} · ${site.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#fafafa" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <SEO
      title={fullTitle}
      description={description}
      canonical={canonical}
      image={image}
      type={type}
      noindex={noindex}
      jsonLd={jsonLd}
    />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
