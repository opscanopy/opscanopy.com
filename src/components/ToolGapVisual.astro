---
/**
 * ToolGapVisual — a small, decorative, theme-aware SVG that fills the otherwise
 * empty left column of each tool page's "why / The Gap" section.
 *
 * It draws an abstract input → evaluate → result motif, which fits every tool on
 * the site (all take some input, process it in the browser, and return a result).
 * Purely decorative: aria-hidden, and `hidden lg:block` by default so it only
 * appears on the wide two-column layout where the blank space exists. Colours are
 * driven by the design tokens in global.css, so it adapts to light/dark.
 */
interface Props {
  /** Extra classes; defaults position + reveal-on-desktop. */
  class?: string;
}
const { class: className = 'mt-10 hidden lg:block' } = Astro.props;
---

<div class:list={['tgv', className]} aria-hidden="true">
  <svg viewBox="0 0 380 320" fill="none" xmlns="http://www.w3.org/2000/svg" role="presentation">
    <defs>
      <linearGradient id="tgvGrad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" class="tgv-g0"></stop>
        <stop offset="1" class="tgv-g1"></stop>
      </linearGradient>
    </defs>

    {/* soft brand accent behind the result node */}
    <circle cx="300" cy="74" r="80" fill="url(#tgvGrad)" class="tgv-blob"></circle>

    {/* input surface — an abstract editor card */}
    <rect x="20" y="26" width="214" height="158" rx="16" class="tgv-surface"></rect>
    <circle cx="42" cy="48" r="4" class="tgv-dot"></circle>
    <circle cx="58" cy="48" r="4" class="tgv-dot"></circle>
    <circle cx="74" cy="48" r="4" class="tgv-dot"></circle>
    <line x1="20" y1="66" x2="234" y2="66" class="tgv-hair"></line>
    <rect x="42" y="86" width="150" height="9" rx="4.5" class="tgv-bar"></rect>
    <rect x="42" y="108" width="104" height="9" rx="4.5" class="tgv-bar-accent"></rect>
    <rect x="42" y="130" width="170" height="9" rx="4.5" class="tgv-bar"></rect>
    <rect x="42" y="152" width="88" height="9" rx="4.5" class="tgv-bar"></rect>

    {/* flow connector with arrowhead */}
    <path d="M234 150 C 302 168, 314 196, 300 224" class="tgv-flow"></path>
    <path d="M291 214 l9 12 l12 -7" class="tgv-arrow"></path>

    {/* result node — a verified output */}
    <rect x="206" y="224" width="156" height="74" rx="16" class="tgv-surface"></rect>
    <circle cx="240" cy="261" r="15" class="tgv-check-bg"></circle>
    <path d="M233 261 l5 6 l10 -12" class="tgv-check"></path>
    <rect x="266" y="252" width="74" height="8" rx="4" class="tgv-bar"></rect>
    <rect x="266" y="268" width="52" height="8" rx="4" class="tgv-bar"></rect>
  </svg>
</div>

<style>
  .tgv {
    width: 100%;
    max-width: 22rem;
  }
  .tgv svg {
    width: 100%;
    height: auto;
    display: block;
  }
  /* gradient stops + fills use the global design tokens → theme-aware. */
  .tgv-g0 {
    stop-color: var(--color-brand);
  }
  .tgv-g1 {
    stop-color: var(--color-brand-strong);
  }
  .tgv-blob {
    opacity: 0.1;
  }
  .tgv-surface {
    fill: var(--color-canvas);
    stroke: var(--color-hairline-strong);
    stroke-width: 1.5;
  }
  .tgv-dot {
    fill: var(--color-mute);
    opacity: 0.45;
  }
  .tgv-hair {
    stroke: var(--color-hairline);
    stroke-width: 1;
  }
  .tgv-bar {
    fill: var(--color-mute);
    opacity: 0.22;
  }
  .tgv-bar-accent {
    fill: var(--color-brand);
    opacity: 0.55;
  }
  .tgv-flow {
    stroke: var(--color-brand-strong);
    stroke-width: 1.5;
    stroke-dasharray: 4 5;
    stroke-linecap: round;
    opacity: 0.75;
  }
  .tgv-arrow {
    stroke: var(--color-brand-strong);
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0.85;
  }
  .tgv-check-bg {
    fill: var(--color-brand);
    opacity: 0.12;
  }
  .tgv-check {
    stroke: var(--color-brand-strong);
    stroke-width: 2.4;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
  }
</style>
