---
/**
 * M90SkipAhead — collapsed "already know some of this?" disclosure at the
 * end of the hub's "Is this for you?" band. Lists all five phases with a
 * live done/total count and a Mark done / Marked — undo toggle per phase.
 *
 * Pure markup — no script here. Matches every other hub disclosure (backup/
 * restore, the 5-phase journey counts): the hub page's single boot script
 * (index.astro) queries these data-* hooks, fills the live counts, and wires
 * the toggle. Collapsed by default so it never competes with the primary
 * "start at Day 1" path.
 */
import { phases } from '../../data/mission90';
---

<details class="mx-auto max-w-4xl" data-m90-skip-ahead>
  <summary
    class="body-sm inline-flex cursor-pointer items-center gap-1.5 text-mute [touch-action:manipulation] hover:text-ink"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 17l5-5-5-5M6 17l5-5-5-5"/></svg>
    Already know some of this? Jump ahead
  </summary>
  <div class="mt-3 rounded-lg border border-hairline bg-canvas p-4">
    <p class="body-sm text-pretty text-body">
      Start at Day 1 if you're new to any of this — each day builds on the last. If you've
      already got a whole phase down elsewhere, mark it done and the hub will pick up right
      after it.
    </p>
    <ul role="list" class="mt-4 flex flex-col gap-2">
      {
        phases.map((p) => (
          <li
            class="flex flex-wrap items-center justify-between gap-3 rounded-lg border border-hairline bg-canvas-soft px-3 py-2.5"
            data-skip-phase
            data-skip-phase-range={`${p.days[0]}-${p.days[1]}`}
          >
            <div class="min-w-0">
              <p class="body-sm font-medium text-ink">{p.name}</p>
              <p class="caption text-mute" data-skip-phase-count>
                0/{p.days[1] - p.days[0] + 1} done
              </p>
            </div>
            <button
              type="button"
              class="btn btn-secondary btn-sm shrink-0"
              style="touch-action: manipulation;"
              data-skip-phase-toggle
              data-state="pending"
            >
              Mark done
            </button>
          </li>
        ))
      }
    </ul>
    <p class="caption mt-3 text-mute" role="status" data-skip-ahead-status></p>
  </div>
</details>
