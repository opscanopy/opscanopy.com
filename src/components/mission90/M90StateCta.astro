---
/**
 * M90StateCta — the Mission 90 hub's stateful hero call-to-action.
 *
 * All THREE states live in the DOM at once; the hub page script (index.astro)
 * reads `oc-m90-v1` progress and toggles `[hidden]` on the wrong two, then fills
 * the dynamic day number / title / count into the returning state. The first
 * visit state renders visible by default, so with JavaScript or storage blocked
 * the cold-start CTA is exactly what a brand-new learner should see.
 *
 * There is at most ONE visible `btn-primary` at any time (one per state).
 */
import Button from '../Button.astro';
import { missions } from '../../data/mission90';

export interface Props {
  /** The next day that will drop, or null when every day is already live. */
  firstDraftDay: number | null;
}

const { firstDraftDay } = Astro.props;

// Play href is derived from the registry's live mission (mirrors the hub teaser
// + missions index) so a future mission going live needs zero edits here. The
// all-done "replay" nudge points at the same live mission. Falls back to the
// missions index if nothing is live yet.
const liveMission = missions.find((m) => m.status === 'live');
const playHref = liveMission ? `/mission-90/missions/${liveMission.id}/` : '/mission-90/missions/';
const missionNumber = liveMission?.week ?? 1;

const gamepadPath =
  '<line x1="6" y1="11" x2="10" y2="11"/><line x1="8" y1="9" x2="8" y2="13"/><line x1="15" y1="12" x2="15.01" y2="12"/><line x1="18" y1="10" x2="18.01" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.544-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/>';
---

<div class="flex flex-col items-center" data-m90-cta>
  {/* State 1 — first visit (default visible; the no-JS / no-storage cold start).
      ONE primary = the instant, zero-setup win. Reading Day 1 is a co-secondary,
      and the WSL2 lab setup is demoted to a quiet ghost link. */}
  <div data-m90-cta-first>
    <div class="flex flex-col items-center gap-3">
      <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-3">
        <Button href={playHref} variant="primary" data-cta="hero_play_mission">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            set:html={gamepadPath}
          />
          Play Mission {missionNumber} — no setup
        </Button>
        <a
          href="/mission-90/day/1/"
          class="link-inline group body-md inline-flex items-center gap-1 font-medium"
          data-cta="hero_read_day_1"
        >
          Read Day 1 free
          <span
            aria-hidden="true"
            class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
          >&rarr;</span>
        </a>
      </div>
      <a
        href="/mission-90/setup/"
        class="body-sm text-mute underline-offset-4 hover:text-ink hover:underline"
        data-cta="hero_setup"
      >
        Set up your lab <span class="text-mute">(when you&rsquo;re ready for the labs)</span>
      </a>
    </div>
  </div>

  {/* State 2 — returning learner (script fills day, title, href + count). */}
  <div data-m90-cta-returning hidden>
    <div class="flex flex-col items-center gap-2">
      <a
        href="/mission-90/day/1/"
        class="btn btn-primary [touch-action:manipulation]"
        data-m90-continue
        data-cta="hero_continue"
      >
        <span data-m90-continue-label>Continue your mission</span>
        <span aria-hidden="true">&rarr;</span>
      </a>
      <p class="body-sm text-mute" data-m90-continue-caption></p>
    </div>
  </div>

  {/* State 3 — every shipped day complete. When days remain, nudge a replay
      while the next drops; once all 90 are live, this is a graduation beat. */}
  <div data-m90-cta-done hidden>
    <div class="flex flex-col items-center gap-2">
      <Button href={playHref} variant="primary" data-cta="hero_replay_mission">
        Replay a mission
      </Button>
      <p class="body-sm text-mute">
        {firstDraftDay !== null
          ? `Day ${firstDraftDay} drops soon — I'm writing it live.`
          : 'You’ve finished all 90 days. Replay a mission or revisit any day whenever you like.'}
      </p>
    </div>
  </div>
</div>
