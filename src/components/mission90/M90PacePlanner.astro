---
/**
 * M90PacePlanner — the hub's pace-planning card, sitting above the 90-day
 * table (section 6). Days/week chips → a forward-computed "you'd finish
 * around <date>" projection → download an .ics calendar of the remaining
 * live days at that pace, or save the pace for next visit.
 *
 * Pure markup — no script here. The hub's single boot script owns chip
 * selection, the projection text, the .ics blob download, and the save
 * write, matching every other hub disclosure/card.
 */
---

<div class="rounded-xl border border-hairline bg-canvas p-5 sm:p-6" data-m90-pace>
  <p class="eyebrow text-brand-strong">Plan your pace</p>
  <p class="body-sm mt-2 text-pretty text-body">
    Pick how many days a week you can realistically commit, and see when you'd finish the
    days you have left.
  </p>

  <div class="mt-4">
    <span class="eyebrow" id="m90-pace-chips-label">Days per week</span>
    <div class="m90p-chips mt-2" role="group" aria-labelledby="m90-pace-chips-label" data-pace-chips>
      {
        [1, 2, 3, 4, 5, 6, 7].map((n) => (
          <button type="button" class="m90p-chip" data-pace-value={n} aria-pressed="false">
            {n}
          </button>
        ))
      }
    </div>
  </div>

  <p class="body-sm mt-4 text-ink" data-pace-result>
    Pick a pace above to see your projected finish date.
  </p>

  <div class="mt-4 flex flex-wrap gap-3">
    <button
      type="button"
      class="btn btn-secondary btn-sm"
      style="touch-action: manipulation;"
      data-pace-ics
      data-cta="pace_ics"
      disabled
    >
      Add to my calendar (.ics)
    </button>
    <button
      type="button"
      class="btn btn-secondary btn-sm"
      style="touch-action: manipulation;"
      data-pace-save
      data-cta="pace_save"
      disabled
    >
      Save this pace
    </button>
  </div>
  <p class="caption mt-2 text-mute" role="status" data-pace-status></p>
</div>

<style>
  .m90p-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .m90p-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.25rem;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    border: none;
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    font-size: 13px;
    font-weight: 500;
    line-height: 18px;
    color: var(--color-brand-strong);
    cursor: pointer;
    transition:
      background 0.12s ease,
      box-shadow 0.12s ease;
  }
  .m90p-chip:hover,
  .m90p-chip.is-active {
    background: var(--color-brand-soft);
    box-shadow: inset 0 0 0 1px var(--color-brand);
  }
  .m90p-chip:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 1px;
  }
  @media (pointer: coarse) {
    .m90p-chip {
      min-height: 44px;
    }
  }
</style>
