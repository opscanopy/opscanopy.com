---
/**
 * M90ProgressCard — compact clone of Roadmap.astro's `.rm-progress-card` idiom
 * for the Mission 90 hub. Static markup only: the hub page script (index.astro)
 * reads the `oc-m90-v1` progress and fills the count + bar. It renders inside
 * the resume section, which stays `[hidden]` until progress exists — so with
 * JS or storage blocked this card simply never shows (cold-start default).
 */
export interface Props {
  /** Total number of days in the program (90). Drives the "n of {total} days" copy. */
  total: number;
}

const { total } = Astro.props;
---

<div class="m90-progress-card">
  <p class="m90-progress-count" data-m90-progress-count>0 of {total} days</p>
  <div
    class="m90-bar"
    role="progressbar"
    aria-label="Mission 90 progress"
    aria-valuemin="0"
    aria-valuemax={String(total)}
    aria-valuenow="0"
    data-m90-barwrap
  >
    <span class="m90-bar-fill" data-m90-bar style="width:0%"></span>
  </div>
</div>

<style>
  .m90-progress-card {
    min-width: 200px;
  }
  .m90-progress-count {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-body);
    font-variant-numeric: tabular-nums;
  }
  .m90-bar {
    margin-top: 0.5rem;
    height: 8px;
    border-radius: 9999px;
    background: var(--color-canvas-soft-2);
    overflow: hidden;
  }
  .m90-bar-fill {
    display: block;
    height: 100%;
    border-radius: 9999px;
    background: linear-gradient(90deg, var(--color-brand), var(--color-brand-strong));
    transition: width 0.4s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    .m90-bar-fill {
      transition: none;
    }
  }
</style>
