---
/**
 * M90DayCheck — the optional per-day "quick check" (1-3 questions), rendered
 * between the interview QA bank and M90CompleteCheck. Formative only: no
 * answer is ever persisted (no localStorage write, no pass/fail tracking) —
 * this is a self-check, not a gate, so it renders identically on every visit.
 *
 * Self-contained island with its own script (matches M90CompleteCheck and
 * Roadmap.astro — day-page components each own their interactivity, unlike
 * the hub's single centralized boot script).
 */
export interface Props {
  checks: {
    q: string;
    options: string[];
    answerIndex: number;
    explain?: string;
  }[];
}
const { checks } = Astro.props;
---

{
  checks.length > 0 && (
    <div class="m90dc" data-m90-day-check>
      <p class="eyebrow text-brand-strong">Quick check</p>
      <div class="mt-3 flex flex-col gap-5">
        {checks.map((c, qi) => (
          <fieldset class="m90dc-q" data-check-fieldset data-answer-index={c.answerIndex} data-explain={c.explain ?? ''}>
            <legend class="body-sm font-medium text-ink">{c.q}</legend>
            <div class="mt-2 flex flex-col gap-1.5">
              {c.options.map((opt, oi) => (
                <label class="m90dc-opt">
                  <input type="radio" name={`m90dc-${qi}`} value={oi} class="sr-only" data-check-radio />
                  <span class="m90dc-dot" aria-hidden="true">
                    <svg class="m90dc-tick" viewBox="0 0 16 16" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M4 8.4 6.8 11.2 12 5" />
                    </svg>
                  </span>
                  <span class="body-sm text-pretty">{opt}</span>
                </label>
              ))}
            </div>
            <p class="caption mt-2 text-pretty" role="status" data-check-feedback />
          </fieldset>
        ))}
      </div>
    </div>
  )
}

<style>
  .m90dc-opt {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.4rem 0.5rem;
    margin: 0 -0.5rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background-color 0.15s ease;
  }
  .m90dc-opt:hover {
    background: var(--color-canvas-soft-2);
  }
  .m90dc-dot {
    position: relative;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    margin-top: 1px;
    border-radius: 9999px;
    border: 2px solid var(--color-mute);
    background: var(--color-canvas);
    transition:
      background-color 0.15s ease,
      border-color 0.15s ease;
  }
  .m90dc-tick {
    width: 11px;
    height: 11px;
    stroke: #fff;
    stroke-width: 2.5;
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .m90dc-opt.is-correct .m90dc-dot {
    background: var(--color-success);
    border-color: var(--color-success);
  }
  .m90dc-opt.is-correct .m90dc-tick {
    opacity: 1;
  }
  .m90dc-opt.is-wrong .m90dc-dot {
    border-color: var(--color-error);
    background: color-mix(in srgb, var(--color-error) 12%, transparent);
  }
  [data-check-feedback]:empty {
    display: none;
  }
  [data-check-feedback].is-correct {
    color: var(--color-success);
  }
  [data-check-feedback].is-wrong {
    color: var(--color-error-deep);
  }
  @media (pointer: coarse) {
    .m90dc-opt {
      min-height: 44px;
    }
  }
</style>

<script>
  function initM90DayCheck(): void {
    document.querySelectorAll<HTMLFieldSetElement>('[data-check-fieldset]').forEach((fieldset) => {
      if (fieldset.dataset.bound === 'true') return;
      fieldset.dataset.bound = 'true';

      const answerIndex = Number(fieldset.dataset.answerIndex);
      const explain = fieldset.dataset.explain ?? '';
      const feedback = fieldset.querySelector<HTMLElement>('[data-check-feedback]');
      const radios = Array.from(fieldset.querySelectorAll<HTMLInputElement>('[data-check-radio]'));
      const options = Array.from(fieldset.querySelectorAll<HTMLElement>('.m90dc-opt'));
      let misses = 0;

      radios.forEach((radio, i) => {
        radio.addEventListener('change', () => {
          // Clear the previous selection's visual state before applying the new one.
          options.forEach((opt) => opt.classList.remove('is-correct', 'is-wrong'));
          feedback?.classList.remove('is-correct', 'is-wrong');

          if (i === answerIndex) {
            options[i].classList.add('is-correct');
            if (feedback) {
              feedback.textContent = explain ? `Correct! ${explain}` : 'Correct!';
              feedback.classList.add('is-correct');
            }
            radios.forEach((r) => (r.disabled = true));
            return;
          }

          options[i].classList.add('is-wrong');
          misses++;
          if (misses >= 2) {
            // Two misses: resolve the question rather than leave it open-ended.
            options[answerIndex].classList.add('is-correct');
            if (feedback) {
              feedback.textContent = explain
                ? `Not quite. ${explain}`
                : 'Not quite — the correct answer is highlighted above.';
              feedback.classList.add('is-wrong');
            }
            radios.forEach((r) => (r.disabled = true));
          } else if (feedback) {
            feedback.textContent = 'Not quite — try again.';
            feedback.classList.add('is-wrong');
          }
        });
      });
    });
  }

  initM90DayCheck();
  document.addEventListener('astro:page-load', initM90DayCheck);
</script>
