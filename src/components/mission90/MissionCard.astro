---
/**
 * MissionCard — one mission's card for the /mission-90/missions/ list (and any
 * future mission grid). Shares its chassis with the hub's missions-teaser card:
 * the site `Card` chrome + a dark inverse header strip (CodeBlock traffic dots +
 * a mono mission id) so the list and the teaser read as one system.
 *
 * FOUR states (see the T13 spec):
 *   - playable    live, not yet completed — the default a live mission renders.
 *   - completed   live + finished — SAME live template as `playable`, differing
 *                 only in badge/CTA text + a revealed stats line. Applied
 *                 client-side by missions/index.astro from localStorage; the
 *                 hooks (`[data-mc-*]`) live in the shared live template so the
 *                 swap is a few `textContent` writes, never innerHTML.
 *   - planned     not yet built — NON-link, dimmed dots, "In production". Never
 *                 claims free-play, never links to a play page.
 *   - locked-live Phase-B display for a live mission gated behind its unlock day.
 *                 Body dimmed except the full-opacity unlock line. UNUSED at
 *                 launch (kept for the day-gating phase).
 *
 * Colors on the inverse strip are LITERAL (`text-white/*`), never theme tokens —
 * the strip is dark in both themes, where the light-surface tokens fail AA.
 */
import Card from '../Card.astro';
import Badge from '../Badge.astro';
import type { Mission90Mission } from '../../data/mission90';

export interface Props {
  mission: Mission90Mission;
  state: 'playable' | 'completed' | 'planned' | 'locked-live';
}

const { mission, state } = Astro.props;

// A live mission renders one shared template for its two runtime states.
const isLive = state === 'playable' || state === 'completed';
const playHref = `/mission-90/missions/${mission.id}/`;

// Dots dim only for planned; every other state keeps the brighter neutral dots.
const dotClass = state === 'planned' ? 'bg-white/10' : 'bg-white/15';

// Live template initial text — the client flips these on completion.
const badgeLabel = state === 'completed' ? 'Completed' : 'Ready to play';
const ctaLabel = state === 'completed' ? 'Replay' : 'Start mission';
// Stats line is present-but-hidden until there's a stored run to show.
const statsHidden = state !== 'completed';

// Inline glyph paths (aria-hidden), mirroring the hub's SVG-constant approach.
const gamepadPath =
  '<line x1="6" y1="11" x2="10" y2="11"/><line x1="8" y1="9" x2="8" y2="13"/><line x1="15" y1="12" x2="15.01" y2="12"/><line x1="18" y1="10" x2="18.01" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.544-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/>';
const constructionPath =
  '<rect x="2" y="6" width="20" height="8" rx="1"/><path d="M17 14v7"/><path d="M7 14v7"/><path d="M17 3v3"/><path d="M7 3v3"/><path d="m10 14-7.7-7.7"/><path d="m14 6 7.7 7.7"/><path d="m8 6 8 8"/>';
const lockPath =
  '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>';

const noCodeLines = ['No setup — runs in your browser', 'No programming required'];

// Live missions get the interactive hover-lift chassis + a stretched-link h3
// (ToolCard idiom). Planned / locked cards are non-interactive divs.
const cardClass = [
  'group relative flex h-full flex-col overflow-hidden rounded-lg p-0 shadow-soft',
  isLive ? 'card-interactive' : null,
]
  .filter(Boolean)
  .join(' ');
---

<Card class={cardClass}>
  <div class="flex h-full flex-col" data-mission-card data-mission-id={mission.id} data-mission-state={state}>
    {/* Inverse header strip — traffic dots + mono mission id (literal colors). */}
    <div class="flex items-center gap-2 bg-inverse px-4 py-2.5">
      <span class:list={['size-3 rounded-full', dotClass]} aria-hidden="true"></span>
      <span class:list={['size-3 rounded-full', dotClass]} aria-hidden="true"></span>
      <span class:list={['size-3 rounded-full', dotClass]} aria-hidden="true"></span>
      <span class="code-mono ml-2 truncate text-white/45">{mission.id}</span>
    </div>

    {
      isLive ? (
        <div class="flex flex-1 flex-col p-5 sm:p-6">
          <div class="flex items-start justify-between gap-3">
            <p class="eyebrow">Week {mission.week}</p>
            <Badge variant="live" class="shrink-0">
              <span data-mc-badge-label>{badgeLabel}</span>
            </Badge>
          </div>

          <h3 class="display-sm mt-3 text-balance text-ink">
            <a
              href={playHref}
              class="rounded-sm outline-none after:absolute after:inset-0 after:content-['']"
            >
              {mission.title}
            </a>
          </h3>

          <p class="body-sm mt-2 text-pretty text-body">{mission.blurb}</p>

          {mission.noCodeFriendly && (
            <ul class="mt-4 space-y-1.5" role="list">
              {noCodeLines.map((line) => (
                <li class="body-sm flex items-start gap-2 text-body">
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 16 16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    class="mt-0.5 shrink-0 text-brand-strong"
                  >
                    <path d="M3 8.5l3.5 3.5L13 4.5" />
                  </svg>
                  {line}
                </li>
              ))}
            </ul>
          )}

          {/* Completed-run stats — filled + revealed client-side (textContent). */}
          <p class:list={['caption code-mono mt-4 text-body', statsHidden && 'hidden']} data-mc-stats />
          <p class:list={['caption mt-1 text-mute', statsHidden && 'hidden']} data-mc-date />

          <div class="mt-auto pt-5">
            <span class="link-inline body-sm inline-flex items-center gap-1.5 font-medium">
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={gamepadPath}
              />
              <span data-mc-cta-label>{ctaLabel}</span>
              <span aria-hidden="true" class="transition-transform duration-150 ease-out group-hover:translate-x-0.5">
                &rarr;
              </span>
            </span>
          </div>
        </div>
      ) : state === 'planned' ? (
        <div class="flex flex-1 flex-col p-5 sm:p-6">
          <div class="flex items-start justify-between gap-3">
            <p class="eyebrow text-mute">Week {mission.week}</p>
            <Badge variant="planned" class="shrink-0">
              In production
            </Badge>
          </div>

          <h3 class="display-sm mt-3 text-balance text-ink">{mission.title}</h3>
          <p class="body-sm mt-2 text-pretty text-body">{mission.blurb}</p>

          <p class="caption mt-auto flex items-center gap-2 pt-5 text-mute">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="shrink-0"
              set:html={constructionPath}
            />
            Drops around week {mission.week} — pairs with Day {mission.unlockAfterDay}
          </p>
        </div>
      ) : (
        /* locked-live — UNUSED at launch; kept for the day-gating phase. */
        <div class="flex flex-1 flex-col p-5 sm:p-6">
          <div class="opacity-60">
            <div class="flex items-start justify-between gap-3">
              <p class="eyebrow text-mute">Week {mission.week}</p>
              <Badge variant="neutral" class="shrink-0">
                Locked
              </Badge>
            </div>
            <h3 class="display-sm mt-3 text-balance text-ink">{mission.title}</h3>
            <p class="body-sm mt-2 text-pretty text-body">{mission.blurb}</p>
          </div>

          <p class="caption mt-auto flex items-center gap-2 pt-5 font-medium text-brand-strong">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="shrink-0"
              set:html={lockPath}
            />
            Unlocks after Day {mission.unlockAfterDay} · or free-play
          </p>
        </div>
      )
    }
  </div>
</Card>
