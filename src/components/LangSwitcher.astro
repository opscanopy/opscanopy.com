---
/**
 * Language switcher — links to the EQUIVALENT page in each locale (same page
 * key, just re-prefixed), so switching language keeps you on the same page.
 * Zero-JS: a native <details> disclosure. For pages that exist only in some
 * locales (blog posts), pass `available` so we don't link to missing pages.
 */
import { LOCALES, LOCALE_LABELS, DEFAULT_LOCALE, type Locale } from '../i18n/config';
import { useTranslations, stripLocale, localizeKey } from '../i18n/utils';

interface Props {
  lang: Locale;
  /** Locales this page actually exists in. Defaults to all. */
  available?: Locale[];
  /** Icon-only below lg — for the desktop header, where the longer locale
      labels ("Português (BR)") crush the centre nav row at md widths. The
      summary keeps its aria-label/title, so it stays accessible. */
  compact?: boolean;
}

const { lang, available = [...LOCALES], compact = false } = Astro.props;
const t = useTranslations(lang);
const pageKey = stripLocale(Astro.url.pathname);
const options = LOCALES.filter((l) => available.includes(l)).map((l) => ({
  locale: l,
  label: LOCALE_LABELS[l],
  href: localizeKey(pageKey, l),
  current: l === lang,
}));
---

<details class="lang-switcher relative">
  <summary
    class="body-sm inline-flex h-9 cursor-pointer list-none items-center gap-1.5 rounded-md px-2.5 text-body transition-colors hover:bg-canvas-soft-2 hover:text-ink"
    aria-label={t('lang.switcherLabel')}
    title={t('lang.switcherLabel')}
  >
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <path d="M2 12h20"></path>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10Z"></path>
    </svg>
    <span class:list={['font-medium', compact && 'max-lg:hidden']} translate="no">{LOCALE_LABELS[lang]}</span>
  </summary>
  <ul
    class="absolute right-0 z-50 mt-1 min-w-[10rem] rounded-lg border border-hairline bg-canvas py-1 shadow-modal"
  >
    {
      options.map((opt) => (
        <li>
          <a
            href={opt.href}
            hreflang={opt.locale === 'pt-br' ? 'pt-BR' : opt.locale}
            rel="alternate"
            aria-current={opt.current ? 'true' : undefined}
            translate="no"
            class:list={[
              'body-sm flex min-h-10 items-center px-3 transition-colors hover:bg-canvas-soft-2 hover:text-ink',
              opt.current ? 'font-medium text-ink' : 'text-body',
            ]}
          >
            {opt.label}
          </a>
        </li>
      ))
    }
  </ul>
</details>

<style>
  .lang-switcher > summary::-webkit-details-marker {
    display: none;
  }
  /* Close the dropdown when focus leaves — progressive enhancement only. */
  .lang-switcher[open] > summary::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 40;
    cursor: default;
  }
</style>

<script>
  // Close any open language dropdown on outside click / Escape.
  function wireLangSwitchers() {
    const switchers = document.querySelectorAll<HTMLDetailsElement>('details.lang-switcher');
    switchers.forEach((d) => {
      if (d.dataset.wired === 'true') return;
      d.dataset.wired = 'true';
      const summary = d.querySelector('summary');
      summary?.addEventListener('click', () => {
        // Defer so the toggle state is final before we read it.
        setTimeout(() => {
          if (!d.open) return;
          const onDoc = (e: MouseEvent) => {
            if (!d.contains(e.target as Node)) {
              d.open = false;
              document.removeEventListener('click', onDoc);
            }
          };
          document.addEventListener('click', onDoc);
        }, 0);
      });
      d.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Escape') d.open = false;
      });
    });
  }
  wireLangSwitchers();
  document.addEventListener('astro:page-load', wireLangSwitchers);
</script>
