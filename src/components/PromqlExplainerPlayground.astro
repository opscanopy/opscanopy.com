---
/**
 * PromqlExplainerPlayground — the interactive PromQL Explainer island.
 *
 * A no-framework, server-rendered shell hydrated by a single module <script>
 * that lazily boots one CodeMirror 6 editor for a PromQL query, wires an
 * example picker and an "Explain" action, then renders a plain-English
 * explanation card plus a token → meaning breakdown list. It runs entirely
 * client-side — no upload, no network.
 *
 * Runtime contract (built by sibling agents — imported lazily in the script):
 *   ../lib/promql-explainer/engine →
 *     explain(query: string) => ExplainResult
 *   ../lib/promql-explainer/types →
 *     type ExplainPart = { token: string; meaning: string }
 *     type ExplainResult = { error?: string; explanation: string; breakdown: ExplainPart[] }
 *   ../lib/promql-explainer/examples →
 *     examples: { id: string; label: string; query: string }[]
 *
 * The dark editor surface follows DESIGN.md `code-editor-mockup`; the
 * explanation uses the canvas surface, errors the semantic error tokens.
 * Headlines stay sentence-case, weight 600.
 */
---

<section class="pq-pg" aria-label="PromQL Explainer playground">
  <div class="card shadow-float rounded-lg overflow-hidden">
    {/* ── Toolbar ──────────────────────────────────────────────────────── */}
    <div
      class="flex flex-col gap-3 border-b border-hairline px-4 py-3 sm:flex-row sm:items-center sm:justify-between sm:px-5"
    >
      <div class="flex min-w-0 items-center gap-3">
        <label class="eyebrow shrink-0" for="pq-example">Example</label>
        <div class="pq-select-wrap relative min-w-0">
          <select id="pq-example" class="pq-select code-mono" autocomplete="off">
            {/* Options injected by the hydration script from `examples`. */}
            <option value="">Loading examples…</option>
          </select>
          <svg
            class="pq-select-caret pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-mute"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 6l4 4 4-4"></path>
          </svg>
        </div>
      </div>

      <div class="flex shrink-0 flex-wrap items-center gap-2">
        <span class="caption text-mute hidden items-center sm:inline-flex">⌘/Ctrl + Enter</span>
        <button
          id="pq-explain"
          type="button"
          class="btn btn-primary btn-sm pq-tap"
          title="Explain (⌘/Ctrl + Enter)"
          aria-keyshortcuts="Meta+Enter Control+Enter"
        >
          <svg
            class="pq-explain-icon h-4 w-4 shrink-0"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="8" cy="8" r="6"></circle>
            <path d="M8 7.5v3"></path>
            <path d="M8 5.4v.01"></path>
          </svg>
          <span class="pq-explain-label">Explain</span>
        </button>
      </div>
    </div>

    {/* ── Query editor (single dark pane) ──────────────────────────────── */}
    <div class="flex min-w-0 flex-col bg-primary">
      <div class="flex items-center gap-2 border-b border-white/10 px-4 py-2.5">
        <span class="flex shrink-0 items-center gap-1.5" aria-hidden="true">
          <span class="h-2.5 w-2.5 rounded-full bg-white/15"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-white/15"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-white/15"></span>
        </span>
        <span class="code-mono text-white/45">query.promql</span>
      </div>
      <div
        id="pq-editor"
        class="pq-editor min-h-40"
        aria-label="PromQL query"
      >
      </div>
      <p class="text-xs text-mute mt-1" style="padding: 0 16px 8px;">Tip: press <kbd style="border:1px solid currentColor;border-radius:3px;padding:0 3px;font-size:0.85em">Esc</kbd> to release focus.</p>
    </div>

    {/* ── Explanation panel ────────────────────────────────────────────── */}
    <div class="border-t border-hairline bg-canvas-soft px-4 py-4 sm:px-5">
      <div class="mb-3 flex items-center justify-between gap-3">
        <span class="eyebrow">Explanation</span>
        <span
          id="pq-summary"
          class="pq-summary code-mono text-mute"
          role="status"
          aria-live="polite"
        ></span>
      </div>

      <div id="pq-results" class="pq-results" aria-live="polite" aria-atomic="false">
        <p class="pq-empty body-sm text-mute">
          Load an example or paste your own PromQL query, then explain it to see
          a plain-English summary and a token-by-token breakdown here.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../styles/global.css";

  /* Tap targets opt into fast-tap + no double-tap-zoom on touch. */
  .pq-tap {
    touch-action: manipulation;
  }

  /* The example picker: a 6px-radius in-app form control (form-input-sm scale). */
  .pq-select {
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    height: 32px;
    min-width: 0;
    max-width: 280px;
    padding: 0 32px 0 12px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-hairline);
    font-size: 13px;
    line-height: 20px;
    cursor: pointer;
    text-overflow: ellipsis;
    touch-action: manipulation;
    transition: box-shadow 0.15s ease;
  }
  @media (min-width: 640px) {
    .pq-select {
      width: auto;
      min-width: 220px;
    }
  }
  .pq-select:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .pq-select:disabled {
    cursor: not-allowed;
    color: var(--color-mute);
    opacity: 0.7;
  }
  .pq-select-caret {
    transition: color 0.15s ease;
  }
  .pq-select-wrap:hover .pq-select-caret {
    color: var(--color-body);
  }

  /* CodeMirror host — fills the dark pane, scrolls internally. */
  .pq-editor {
    overflow: hidden;
  }
  .pq-editor :global(.cm-editor) {
    height: 100%;
    background: transparent;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 20px;
  }
  .pq-editor :global(.cm-editor.cm-focused) {
    /* Replace CM's default outline with a brand-blue ring (a11y: keep a ring). */
    outline: 2px solid var(--color-link);
    outline-offset: -2px;
  }
  .pq-editor :global(.cm-scroller) {
    overflow: auto;
    max-height: 320px;
    font-family: var(--font-mono);
    /* Thin, theme-matched scrollbars on the dark surface. */
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.18) transparent;
  }
  .pq-editor :global(.cm-scroller)::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }
  .pq-editor :global(.cm-scroller)::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.16);
    border-radius: var(--radius-pill);
    border: 3px solid transparent;
    background-clip: content-box;
  }
  .pq-editor :global(.cm-scroller)::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.28);
    background-clip: content-box;
  }
  .pq-editor :global(.cm-gutters) {
    background: transparent;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
  }
  .pq-editor :global(.cm-lineNumbers .cm-gutterElement) {
    color: rgba(255, 255, 255, 0.32);
  }
  .pq-editor :global(.cm-content) {
    padding: 14px 0 16px;
  }
  .pq-editor :global(.cm-line) {
    padding-inline: 4px;
  }

  /* Summary — right-aligned counts use tabular figures so they don't jitter. */
  .pq-summary {
    font-variant-numeric: tabular-nums;
    font-feature-settings: 'tnum';
    white-space: nowrap;
  }

  /* Results region. */
  .pq-results {
    min-height: 44px;
  }

  /* The plain-English explanation card. */
  :global(.pq-explanation) {
    padding: 14px 16px;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    animation: pq-rise 0.18s ease both;
  }
  :global(.pq-explanation__text) {
    font-size: 15px;
    line-height: 24px;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    text-wrap: pretty;
    word-break: break-word;
  }

  /* Token → meaning breakdown list. */
  :global(.pq-breakdown) {
    margin-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    list-style: none;
    padding: 0;
  }
  :global(.pq-part) {
    display: flex;
    gap: 12px;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    animation: pq-rise 0.18s ease both;
  }
  :global(.pq-part:hover) {
    box-shadow: var(--shadow-subtle);
  }
  :global(.pq-part__token) {
    flex: 0 0 auto;
    max-width: 42%;
    align-self: flex-start;
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas-soft-2);
    box-shadow: var(--shadow-hairline);
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 20px;
    color: var(--color-ink);
    white-space: pre-wrap;
    word-break: break-word;
  }
  :global(.pq-part__meaning) {
    min-width: 0;
    flex: 1 1 auto;
    font-size: 14px;
    line-height: 22px;
    color: var(--color-body);
    text-wrap: pretty;
    word-break: break-word;
  }

  @keyframes pq-rise {
    from {
      opacity: 0;
      transform: translateY(3px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.pq-explanation),
    :global(.pq-part) {
      animation: none;
    }
  }

  /* Parse-error banner. */
  :global(.pq-error) {
    display: flex;
    gap: 10px;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    background: var(--color-error-soft);
    box-shadow: inset 0 0 0 1px var(--color-error);
    color: var(--color-error-deep);
    animation: pq-rise 0.18s ease both;
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.pq-error) {
      animation: none;
    }
  }
  :global(.pq-error__icon) {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
    margin-top: 1px;
  }
  :global(.pq-error__body) {
    min-width: 0;
  }
  :global(.pq-error__title) {
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
  }
  :global(.pq-error__detail) {
    margin-top: 2px;
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 18px;
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* Empty state — generous, centered frame (ex-empty-state-card scale). */
  :global(.pq-empty) {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 64px;
    padding: 20px 16px;
    text-align: center;
    text-wrap: pretty;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
  }

  /* Loading dots — animate opacity only; reduced-motion handled globally. */
  :global(.pq-loading) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 14px;
    font-size: 14px;
    line-height: 20px;
    color: var(--color-body);
  }
  :global(.pq-loading__dot) {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: var(--color-mute);
    animation: pq-pulse 1.1s ease-in-out infinite;
  }
  :global(.pq-loading__dot:nth-child(2)) {
    animation-delay: 0.18s;
  }
  :global(.pq-loading__dot:nth-child(3)) {
    animation-delay: 0.36s;
  }
  @keyframes pq-pulse {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 1;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.pq-loading__dot) {
      animation: none;
      opacity: 0.6;
    }
  }

  .is-busy {
    opacity: 0.65;
    pointer-events: none;
    cursor: progress;
  }
  .is-busy .pq-explain-icon {
    display: none;
  }
  /* Reduced motion is handled globally (animations clamped); the “Explaining…”
     label + aria-busy still convey the in-flight state without a spin. */
</style>

<script>
  import { EditorState } from '@codemirror/state';
  import { EditorView, keymap, lineNumbers, highlightActiveLine } from '@codemirror/view';
  import { defaultKeymap, history, historyKeymap, indentWithTab } from '@codemirror/commands';
  import { oneDark } from '@codemirror/theme-one-dark';
  import { escapeHtml } from '../lib/escape-html';

  /* ---- Types mirrored from the engine contract (structural, not imported). -- */
  type ExplainPart = { token: string; meaning: string };
  type ExplainResult = { error?: string; explanation: string; breakdown?: ExplainPart[] };
  type EngineModule = {
    explain: (query: string) => ExplainResult | Promise<ExplainResult>;
  };
  type Example = { id: string; label: string; query: string };

  const ROOT_SEL = '.pq-pg';

  /** Boot every (so far un-hydrated) playground instance on the page. */
  function boot(): void {
    document.querySelectorAll<HTMLElement>(ROOT_SEL).forEach((root) => {
      if (root.dataset.pqWired === 'true') return;
      root.dataset.pqWired = 'true';
      void init(root);
    });
  }

  /* ---- Small helpers -------------------------------------------------------- */

  function el<T extends HTMLElement>(root: HTMLElement, sel: string): T | null {
    return root.querySelector<T>(sel);
  }

  /** Normalise the sibling `examples` array defensively. */
  function normaliseExamples(raw: unknown): Example[] {
    if (!Array.isArray(raw)) return [];
    return raw
      .map((item, i) => {
        const o = (item ?? {}) as Record<string, unknown>;
        return {
          id: typeof o.id === 'string' && o.id ? o.id : `example-${i + 1}`,
          label: typeof o.label === 'string' && o.label ? o.label : `Example ${i + 1}`,
          query: typeof o.query === 'string' ? o.query : '',
        } satisfies Example;
      })
      .filter((e) => e.query.length > 0);
  }

  /** Normalise an ExplainResult's breakdown into a clean part list. */
  function normaliseBreakdown(raw: unknown): ExplainPart[] {
    if (!Array.isArray(raw)) return [];
    return raw
      .map((item) => {
        const o = (item ?? {}) as Record<string, unknown>;
        return {
          token: typeof o.token === 'string' ? o.token : '',
          meaning: typeof o.meaning === 'string' ? o.meaning : '',
        } satisfies ExplainPart;
      })
      .filter((p) => p.token.length > 0 || p.meaning.length > 0);
  }

  /* ---- Editor factory ------------------------------------------------------- */

  const baseTheme = EditorView.theme({
    '&': { color: '#e6e6e6' },
    '.cm-content': { caretColor: '#e6e6e6' },
    '.cm-cursor, .cm-dropCursor': { borderLeftColor: '#e6e6e6' },
    '&.cm-focused .cm-selectionBackground, .cm-selectionBackground, ::selection': {
      backgroundColor: 'rgba(0, 112, 243, 0.32)',
    },
    '.cm-activeLine': { backgroundColor: 'rgba(255, 255, 255, 0.035)' },
    '.cm-activeLineGutter': { backgroundColor: 'transparent' },
  });

  function makeEditor(host: HTMLElement, doc: string): EditorView {
    const state = EditorState.create({
      doc,
      extensions: [
        lineNumbers(),
        history(),
        highlightActiveLine(),
        EditorView.lineWrapping,
        keymap.of([
          { key: 'Escape', run: function(view) { view.contentDOM.blur(); return true; } },
          ...defaultKeymap,
          ...historyKeymap,
          indentWithTab,
        ]),
        oneDark,
        baseTheme,
      ],
    });
    // The host already carries the aria-label/role for screen readers; CM mounts inside.
    return new EditorView({ state, parent: host });
  }

  function setEditorDoc(view: EditorView, doc: string): void {
    view.dispatch({ changes: { from: 0, to: view.state.doc.length, insert: doc } });
  }

  /* ---- Result rendering ----------------------------------------------------- */

  const ALERT_SVG =
    '<svg class="pq-error__icon" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 2.5L18.5 17H1.5z"></path><path d="M10 8v4"></path><path d="M10 14.6v.01"></path></svg>';

  function renderEmpty(container: HTMLElement, summary: HTMLElement): void {
    summary.textContent = '';
    summary.classList.remove('text-error');
    summary.classList.add('text-mute');
    container.innerHTML =
      '<p class="pq-empty body-sm text-mute">Load an example or paste your own PromQL query, then explain it to see a plain-English summary and a token-by-token breakdown here.</p>';
  }

  function renderLoading(container: HTMLElement, summary: HTMLElement): void {
    summary.textContent = '';
    summary.classList.remove('text-error');
    summary.classList.add('text-mute');
    container.innerHTML =
      '<div class="pq-loading"><span class="pq-loading__dot"></span>' +
      '<span class="pq-loading__dot"></span><span class="pq-loading__dot"></span>' +
      '<span>Explaining…</span></div>';
  }

  function renderError(container: HTMLElement, summary: HTMLElement, message: string): void {
    summary.textContent = 'Error';
    summary.classList.remove('text-mute');
    summary.classList.add('text-error');
    container.innerHTML =
      '<div class="pq-error" role="alert">' +
      ALERT_SVG +
      '<div class="pq-error__body"><p class="pq-error__title">Could not explain this query</p>' +
      `<p class="pq-error__detail">${escapeHtml(message)}</p></div></div>`;
  }

  function partHtml(p: ExplainPart): string {
    const token = p.token
      ? `<code class="pq-part__token">${escapeHtml(p.token)}</code>`
      : '';
    const meaning = p.meaning
      ? `<span class="pq-part__meaning">${escapeHtml(p.meaning)}</span>`
      : '';
    return `<li class="pq-part">${token}${meaning}</li>`;
  }

  function renderResult(
    container: HTMLElement,
    summary: HTMLElement,
    result: ExplainResult
  ): void {
    if (!result || result.error) {
      renderError(container, summary, result?.error ?? 'Unknown error while explaining the query.');
      return;
    }

    const breakdown = normaliseBreakdown(result.breakdown);
    const explanation = typeof result.explanation === 'string' ? result.explanation : '';

    if (!explanation && breakdown.length === 0) {
      renderEmpty(container, summary);
      return;
    }

    const n = breakdown.length;
    summary.textContent = n > 0 ? `${n} ${n === 1 ? 'part' : 'parts'}` : 'Explained';
    summary.classList.remove('text-error');
    summary.classList.add('text-mute');

    const explanationHtml = explanation
      ? '<div class="pq-explanation">' +
        `<p class="pq-explanation__text">${escapeHtml(explanation)}</p></div>`
      : '';
    const breakdownHtml =
      breakdown.length > 0
        ? `<ul class="pq-breakdown">${breakdown.map(partHtml).join('')}</ul>`
        : '';
    container.innerHTML = explanationHtml + breakdownHtml;
  }

  /* ---- Instance init -------------------------------------------------------- */

  async function init(root: HTMLElement): Promise<void> {
    const editorHost = el<HTMLElement>(root, '#pq-editor');
    const select = el<HTMLSelectElement>(root, '#pq-example');
    const explainBtn = el<HTMLButtonElement>(root, '#pq-explain');
    const resultsBox = el<HTMLElement>(root, '#pq-results');
    const summaryEl = el<HTMLElement>(root, '#pq-summary');

    if (!editorHost || !select || !explainBtn || !resultsBox || !summaryEl) {
      return;
    }

    // Lazily load the sibling engine + examples (kept out of the initial path).
    let engine: EngineModule;
    let examples: Example[] = [];
    try {
      const [engineMod, examplesMod] = await Promise.all([
        import('../lib/promql-explainer/engine'),
        import('../lib/promql-explainer/examples'),
      ]);
      engine = engineMod as unknown as EngineModule;
      examples = normaliseExamples((examplesMod as { examples?: unknown }).examples);
    } catch (err) {
      renderError(
        resultsBox,
        summaryEl,
        'The PromQL Explainer engine failed to load. Reload the page to try again.'
      );
      // eslint-disable-next-line no-console
      console.error('[PromqlExplainer] engine/examples import failed:', err);
      return;
    }

    // Seed content from the first example when present.
    const seedExample = examples[0] ?? { id: 'empty', label: 'Example', query: '' };
    const view = makeEditor(editorHost, seedExample.query);

    // Populate the example picker.
    select.innerHTML = '';
    if (examples.length === 0) {
      const opt = document.createElement('option');
      opt.value = '';
      opt.textContent = 'No examples available';
      select.appendChild(opt);
      select.disabled = true;
    } else {
      examples.forEach((ex, i) => {
        const opt = document.createElement('option');
        opt.value = String(i);
        opt.textContent = ex.label;
        select.appendChild(opt);
      });
      select.value = '0';
    }

    // Swap the editor doc when a different example is chosen.
    select.addEventListener('change', () => {
      const idx = Number(select.value);
      if (!Number.isInteger(idx) || idx < 0 || idx >= examples.length) return;
      setEditorDoc(view, examples[idx].query);
      renderEmpty(resultsBox, summaryEl);
    });

    // Explain — non-blocking; show loading, yield a frame, then render.
    let running = false;
    const explainLabel = explainBtn.querySelector<HTMLElement>('.pq-explain-label');
    let spinner: HTMLElement | null = null;

    async function explainNow(): Promise<void> {
      if (running) return;
      running = true;
      explainBtn.classList.add('is-busy');
      // Keep focus on the control for keyboard users: mark busy, not disabled.
      explainBtn.setAttribute('aria-disabled', 'true');
      explainBtn.setAttribute('aria-busy', 'true');
      if (!spinner) {
        spinner = document.createElement('span');
        spinner.setAttribute('aria-hidden', 'true');
        // Inline the visual so it never depends on Astro's scoped CSS — this
        // span is created at runtime and would not receive the component's scope hash.
        spinner.style.cssText =
          'display:inline-block;width:14px;height:14px;flex:0 0 auto;border-radius:9999px;' +
          'border:2px solid currentColor;border-top-color:transparent;';
        if (!window.matchMedia || !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          spinner.animate(
            [{ transform: 'rotate(0deg)' }, { transform: 'rotate(360deg)' }],
            { duration: 700, iterations: Infinity }
          );
        }
        explainBtn.insertBefore(spinner, explainBtn.firstChild);
      }
      if (explainLabel) explainLabel.textContent = 'Explaining…';
      renderLoading(resultsBox!, summaryEl!);

      // Yield so the loading state paints before (potentially heavy) work runs.
      await new Promise<void>((resolve) => {
        if ('requestAnimationFrame' in window) requestAnimationFrame(() => resolve());
        else setTimeout(resolve, 0);
      });

      try {
        const query = view.state.doc.toString();
        const result = await Promise.resolve(engine.explain(query));
        renderResult(resultsBox!, summaryEl!, result);
      } catch (err) {
        const msg =
          err instanceof Error ? err.message : 'Unexpected error while explaining the query.';
        renderError(resultsBox!, summaryEl!, msg);
      } finally {
        running = false;
        explainBtn.classList.remove('is-busy');
        explainBtn.removeAttribute('aria-disabled');
        explainBtn.removeAttribute('aria-busy');
        if (spinner) {
          spinner.remove();
          spinner = null;
        }
        if (explainLabel) explainLabel.textContent = 'Explain';
      }
    }

    explainBtn.addEventListener('click', () => void explainNow());

    // Cmd/Ctrl+Enter from inside the editor / toolbar triggers an explain.
    root.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
        e.preventDefault();
        void explainNow();
      }
    });

    // Initial results state.
    renderEmpty(resultsBox, summaryEl);
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
