---
/**
 * K8sResourceCalculatorPlayground — the interactive Kubernetes Resource Calculator island.
 *
 * Given a Pod's CPU request / limit, memory request / limit, and a replica
 * count, it renders a per-pod and total-across-replicas breakdown as a rows
 * table (mono values) plus any advisory warnings (limit below request, no
 * limit set, …). Updates live (debounced), fully client-side.
 *
 * Runtime contract (lazy-imported):
 *   ../lib/k8s-resources/engine   → calculate({ cpuRequest, cpuLimit, memRequest, memLimit, replicas }) → K8sResult
 *   ../lib/k8s-resources/examples → examples: { id; label; input: {...five fields} }[]
 */
---

<section class="k8s-pg" aria-label="Kubernetes Resource Calculator playground">
  <div class="card shadow-float overflow-hidden rounded-lg">
    <div class="flex flex-col gap-1 border-b border-hairline px-4 py-3 sm:px-5">
      <label class="eyebrow shrink-0" for="k8s-example">Example</label>
      <div class="k8s-select-wrap relative min-w-0">
        <select id="k8s-example" class="k8s-select code-mono" autocomplete="off">
          <option value="">Loading examples…</option>
        </select>
        <svg
          class="k8s-select-caret pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-mute"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 6l4 4 4-4"></path>
        </svg>
      </div>
    </div>

    <div class="border-b border-hairline px-4 py-4 sm:px-5">
      <div class="k8s-fields">
        <div class="k8s-field" data-k8s-field="cpuRequest">
          <label class="eyebrow mb-2 block" for="k8s-cpu-req">CPU request</label>
          <input
            id="k8s-cpu-req"
            class="k8s-text code-mono"
            type="text"
            spellcheck="false"
            autocapitalize="off"
            autocorrect="off"
            autocomplete="off"
            placeholder="500m"
            aria-describedby="k8s-input-hint"
          />
        </div>
        <div class="k8s-field" data-k8s-field="cpuLimit">
          <label class="eyebrow mb-2 block" for="k8s-cpu-lim">CPU limit</label>
          <input
            id="k8s-cpu-lim"
            class="k8s-text code-mono"
            type="text"
            spellcheck="false"
            autocapitalize="off"
            autocorrect="off"
            autocomplete="off"
            placeholder="1"
            aria-describedby="k8s-input-hint"
          />
        </div>
        <div class="k8s-field" data-k8s-field="memRequest">
          <label class="eyebrow mb-2 block" for="k8s-mem-req">Memory request</label>
          <input
            id="k8s-mem-req"
            class="k8s-text code-mono"
            type="text"
            spellcheck="false"
            autocapitalize="off"
            autocorrect="off"
            autocomplete="off"
            placeholder="256Mi"
            aria-describedby="k8s-input-hint"
          />
        </div>
        <div class="k8s-field" data-k8s-field="memLimit">
          <label class="eyebrow mb-2 block" for="k8s-mem-lim">Memory limit</label>
          <input
            id="k8s-mem-lim"
            class="k8s-text code-mono"
            type="text"
            spellcheck="false"
            autocapitalize="off"
            autocorrect="off"
            autocomplete="off"
            placeholder="512Mi"
            aria-describedby="k8s-input-hint"
          />
        </div>
        <div class="k8s-field" data-k8s-field="replicas">
          <label class="eyebrow mb-2 block" for="k8s-replicas">Replicas</label>
          <input
            id="k8s-replicas"
            class="k8s-text code-mono"
            type="number"
            inputmode="numeric"
            min="1"
            step="1"
            autocomplete="off"
            placeholder="1"
            aria-describedby="k8s-input-hint"
          />
        </div>
      </div>
      <p id="k8s-input-hint" class="k8s-hint caption text-mute">
        CPU takes cores or millicores (<span class="code-mono">500m</span>, <span class="code-mono">1</span>,
        <span class="code-mono">2.5</span>). Memory takes binary (<span class="code-mono">256Mi</span>,
        <span class="code-mono">4Gi</span>) or decimal (<span class="code-mono">1G</span>) suffixes, or bytes.
        Leave a field blank to skip it.
      </p>
    </div>

    <div class="bg-canvas-soft px-4 py-4 sm:px-5">
      <div class="mb-3 flex flex-wrap items-center justify-between gap-x-3 gap-y-2">
        <span class="flex flex-wrap items-center gap-2">
          <span class="eyebrow">Result</span>
          <button id="k8s-share" type="button" class="k8s-share-btn" data-copy="" hidden>
            <svg
              class="k8s-share-icon"
              width="13"
              height="13"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M6.75 9.25l2.5-2.5"></path>
              <path d="M8.75 4.25l1.5-1.5a2.47 2.47 0 0 1 3.5 3.5l-1.5 1.5"></path>
              <path d="M7.25 11.75l-1.5 1.5a2.47 2.47 0 0 1-3.5-3.5l1.5-1.5"></path>
            </svg>
            <span class="k8s-share-label">Copy link</span>
          </button>
          <button id="k8s-copy-md" type="button" class="k8s-share-btn" hidden>
            <svg
              class="k8s-share-icon"
              width="13"
              height="13"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="3.25" y="3.25" width="7" height="9" rx="1.25"></rect>
              <path d="M6.25 3.25V2.75A1.25 1.25 0 0 1 7.5 1.5h3.25a1.25 1.25 0 0 1 1.25 1.25V10a1.25 1.25 0 0 1-1.25 1.25h-.5"></path>
            </svg>
            <span class="k8s-copy-md-label">Copy as Markdown</span>
          </button>
        </span>
        <span id="k8s-summary" class="k8s-summary code-mono text-mute" role="status" aria-live="polite"></span>
      </div>
      <div id="k8s-results" class="k8s-results" aria-live="polite" aria-atomic="false">
        <p class="k8s-empty body-sm text-mute">
          Enter a CPU or memory value — or pick an example — to see a per-pod and total-across-replicas
          breakdown here.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../styles/global.css";

  .k8s-select {
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    height: 32px;
    min-width: 0;
    max-width: 360px;
    padding: 0 32px 0 12px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-hairline);
    font-size: 13px;
    line-height: 20px;
    cursor: pointer;
    text-overflow: ellipsis;
    touch-action: manipulation;
    transition: box-shadow 0.15s ease;
  }
  @media (min-width: 640px) {
    .k8s-select {
      width: auto;
      min-width: 300px;
    }
  }
  .k8s-select:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .k8s-select:disabled {
    cursor: not-allowed;
    color: var(--color-mute);
    opacity: 0.7;
  }
  .k8s-select-wrap:hover .k8s-select-caret {
    color: var(--color-body);
  }

  .k8s-fields {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px 16px;
  }
  @media (min-width: 480px) {
    .k8s-fields {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 768px) {
    .k8s-fields {
      grid-template-columns: repeat(5, 1fr);
    }
  }
  .k8s-field {
    min-width: 0;
  }

  .k8s-text {
    width: 100%;
    height: 40px;
    padding: 0 14px;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-hairline);
    font-size: 14px;
    line-height: 22px;
    transition: box-shadow 0.15s ease;
  }
  .k8s-text::placeholder {
    color: var(--color-mute);
  }
  .k8s-text:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .k8s-text:focus {
    outline: none;
  }
  .k8s-text:focus-visible {
    box-shadow: inset 0 0 0 2px var(--color-link);
    outline: none;
  }
  .k8s-hint {
    margin-top: 12px;
    text-wrap: pretty;
  }
  .k8s-summary {
    white-space: nowrap;
  }
  .k8s-results {
    min-height: 44px;
  }

  .k8s-share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 26px;
    padding: 0 10px;
    border-radius: var(--radius-sm);
    border: none;
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    color: var(--color-mute);
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 16px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    cursor: pointer;
    touch-action: manipulation;
    transition: color 0.12s ease, background 0.12s ease;
  }
  .k8s-share-btn:hover {
    color: var(--color-brand-strong);
    background: var(--color-hairline);
  }
  .k8s-share-btn:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 1px;
  }
  .k8s-share-btn.k8s-share-btn--copied {
    color: var(--color-brand-strong);
    background: var(--color-brand-soft);
  }
  @media (pointer: coarse) {
    .k8s-share-btn {
      height: auto;
      min-height: 36px;
    }
  }

  /* ── Runtime-injected markup ─────────────────────────────────────────── */
  :global(.k8s-table) {
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    overflow: hidden;
    animation: k8s-rise 0.18s ease both;
  }
  :global(.k8s-row) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 14px;
    padding: 9px 14px;
    font-size: 13px;
    line-height: 20px;
  }
  :global(.k8s-row + .k8s-row) {
    border-top: 1px solid var(--color-hairline);
  }
  :global(.k8s-row__label) {
    flex: 1 1 auto;
    min-width: 0;
    color: var(--color-mute);
    word-break: break-word;
  }
  :global(.k8s-row__value) {
    flex: 0 1 auto;
    text-align: right;
    color: var(--color-ink);
    word-break: break-word;
  }
  :global(.k8s-row__value--mono) {
    font-family: var(--font-mono);
  }

  :global(.k8s-warnings) {
    margin-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  :global(.k8s-warn) {
    display: flex;
    gap: 8px;
    padding: 9px 12px;
    border-radius: var(--radius-md);
    background: var(--color-warning-soft);
    box-shadow: inset 0 0 0 1px var(--color-warning);
    color: var(--color-warning-deep);
    font-size: 12px;
    line-height: 18px;
    text-wrap: pretty;
  }
  :global(.k8s-warn__icon) {
    flex: 0 0 auto;
    width: 15px;
    height: 15px;
    margin-top: 1px;
  }

  @keyframes k8s-rise {
    from {
      opacity: 0;
      transform: translateY(3px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.k8s-table) {
      animation: none;
    }
  }

  :global(.k8s-error) {
    display: flex;
    gap: 10px;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    background: var(--color-error-soft);
    box-shadow: inset 0 0 0 1px var(--color-error);
    color: var(--color-error-deep);
  }
  :global(.k8s-error__icon) {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
    margin-top: 1px;
  }
  :global(.k8s-error__title) {
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
  }
  :global(.k8s-error__detail) {
    margin-top: 2px;
    font-size: 13px;
    line-height: 18px;
    text-wrap: pretty;
  }
  .k8s-text--error {
    box-shadow: inset 0 0 0 2px var(--color-error) !important;
  }
  .k8s-field-error {
    margin-top: 5px;
    font-size: 12px;
    line-height: 16px;
    color: var(--color-error-deep);
  }

  :global(.k8s-empty) {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 64px;
    padding: 20px 16px;
    text-align: center;
    text-wrap: pretty;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
  }
</style>

<script>
  import { escapeHtml } from '../lib/escape-html';
  import { copyTextToClipboard } from '../lib/clipboard';
  import { buildMarkdownBlock } from '../lib/share-md';

  type Row = { label: string; value: string; mono?: boolean };
  type Result = {
    valid: boolean;
    error?: string;
    rows: Row[];
    warnings: string[];
  };
  type Input = {
    cpuRequest?: string;
    cpuLimit?: string;
    memRequest?: string;
    memLimit?: string;
    replicas?: string;
  };
  type ExampleInput = {
    cpuRequest: string;
    cpuLimit: string;
    memRequest: string;
    memLimit: string;
    replicas: string;
  };
  type Example = { id: string; label: string; input: ExampleInput };
  type EngineModule = {
    calculate: (input: Input) => Result;
    encodeState: (rows: Input[]) => string;
    decodeState: () => { rows: Input[] } | null;
  };

  const ROOT_SEL = '.k8s-pg';
  const DEBOUNCE_MS = 220;

  function boot(): void {
    document.querySelectorAll<HTMLElement>(ROOT_SEL).forEach((root) => {
      if (root.dataset.k8sWired === 'true') return;
      root.dataset.k8sWired = 'true';
      void init(root);
    });
  }

  function el<T extends HTMLElement>(root: HTMLElement, sel: string): T | null {
    return root.querySelector<T>(sel);
  }

  function str(o: Record<string, unknown>, key: string): string {
    const v = o[key];
    return typeof v === 'string' ? v : '';
  }

  function normaliseExamples(raw: unknown): Example[] {
    if (!Array.isArray(raw)) return [];
    return raw
      .map((item, i) => {
        const o = (item ?? {}) as Record<string, unknown>;
        const input = (o.input ?? {}) as Record<string, unknown>;
        return {
          id: typeof o.id === 'string' && o.id ? o.id : `example-${i + 1}`,
          label: typeof o.label === 'string' && o.label ? o.label : `Example ${i + 1}`,
          input: {
            cpuRequest: str(input, 'cpuRequest'),
            cpuLimit: str(input, 'cpuLimit'),
            memRequest: str(input, 'memRequest'),
            memLimit: str(input, 'memLimit'),
            replicas: str(input, 'replicas'),
          },
        } satisfies Example;
      })
      .filter(
        (e) =>
          e.input.cpuRequest.length > 0 ||
          e.input.cpuLimit.length > 0 ||
          e.input.memRequest.length > 0 ||
          e.input.memLimit.length > 0,
      );
  }

  const ALERT_SVG =
    '<svg class="k8s-error__icon" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 2.5L18.5 17H1.5z"></path><path d="M10 8v4"></path><path d="M10 14.6v.01"></path></svg>';

  const WARN_SVG =
    '<svg class="k8s-warn__icon" width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 2.5L18.5 17H1.5z"></path><path d="M10 8v4"></path><path d="M10 14.6v.01"></path></svg>';

  function renderEmpty(container: HTMLElement, summary: HTMLElement): void {
    summary.textContent = '';
    container.innerHTML =
      '<p class="k8s-empty body-sm text-mute">Enter a CPU or memory value — or pick an example — to see a per-pod and total-across-replicas breakdown here.</p>';
  }

  function renderError(container: HTMLElement, summary: HTMLElement, message: string): void {
    summary.textContent = '';
    container.innerHTML =
      '<div class="k8s-error" role="alert">' +
      ALERT_SVG +
      '<div><p class="k8s-error__title">Nothing to calculate</p>' +
      `<p class="k8s-error__detail">${escapeHtml(message)}</p></div></div>`;
  }

  /** Labels that are "Total …" rows produced by the engine. */
  const TOTAL_LABELS = new Set([
    'Total CPU request',
    'Total CPU limit',
    'Total memory request',
    'Total memory limit',
  ]);

  function rowsHtml(rows: Row[], replicas: number): string {
    const hideTotals = replicas <= 1;
    const lines = rows
      .filter((r) => !(hideTotals && TOTAL_LABELS.has(r.label)))
      .map((r) => {
        const cls = r.mono ? 'k8s-row__value k8s-row__value--mono' : 'k8s-row__value';
        return (
          '<div class="k8s-row">' +
          `<span class="k8s-row__label">${escapeHtml(r.label)}</span>` +
          `<span class="${cls}">${escapeHtml(r.value)}</span></div>`
        );
      })
      .join('');
    return '<div class="k8s-table">' + lines + '</div>';
  }

  function warningsHtml(warnings: string[]): string {
    if (!warnings.length) return '';
    const notes = warnings
      .map((w) => '<p class="k8s-warn">' + WARN_SVG + `<span>${escapeHtml(w)}</span></p>`)
      .join('');
    return `<div class="k8s-warnings">${notes}</div>`;
  }

  function renderResult(container: HTMLElement, summary: HTMLElement, result: Result, replicas: number): void {
    const warnCount = result.warnings?.length ?? 0;
    summary.textContent = warnCount
      ? `${warnCount} warning${warnCount === 1 ? '' : 's'}`
      : 'ok';
    container.innerHTML = rowsHtml(result.rows ?? [], replicas) + warningsHtml(result.warnings ?? []);
  }

  /**
   * Build the {label, value} fields for "Copy as Markdown" — the same rows
   * the results table shows (per-pod values + totals, with totals hidden
   * when replicas <= 1, matching rowsHtml's own filtering) plus any advisory
   * warnings, so the pasted block matches what's on screen.
   */
  function markdownFields(result: Result, replicas: number): Array<{ label: string; value: string }> {
    const hideTotals = replicas <= 1;
    const fields = (result.rows ?? [])
      .filter((r) => !(hideTotals && TOTAL_LABELS.has(r.label)))
      .map((r) => ({ label: r.label, value: r.value }));
    for (const w of result.warnings ?? []) {
      fields.push({ label: 'Warning', value: w });
    }
    return fields;
  }

  async function init(root: HTMLElement): Promise<void> {
    const cpuReqInput = el<HTMLInputElement>(root, '#k8s-cpu-req');
    const cpuLimInput = el<HTMLInputElement>(root, '#k8s-cpu-lim');
    const memReqInput = el<HTMLInputElement>(root, '#k8s-mem-req');
    const memLimInput = el<HTMLInputElement>(root, '#k8s-mem-lim');
    const replicasInput = el<HTMLInputElement>(root, '#k8s-replicas');
    const exampleSel = el<HTMLSelectElement>(root, '#k8s-example');
    const resultsBox = el<HTMLElement>(root, '#k8s-results');
    const summaryEl = el<HTMLElement>(root, '#k8s-summary');
    const shareBtn = el<HTMLButtonElement>(root, '#k8s-share');
    const mdBtn = el<HTMLButtonElement>(root, '#k8s-copy-md');
    if (
      !cpuReqInput ||
      !cpuLimInput ||
      !memReqInput ||
      !memLimInput ||
      !replicasInput ||
      !exampleSel ||
      !resultsBox ||
      !summaryEl ||
      !shareBtn ||
      !mdBtn
    )
      return;

    const shareLabel = shareBtn.querySelector<HTMLElement>('.k8s-share-label');
    const mdLabel = mdBtn.querySelector<HTMLElement>('.k8s-copy-md-label');
    let lastMarkdownFields: Array<{ label: string; value: string }> = [];

    function hideShare(): void {
      shareBtn!.hidden = true;
      shareBtn!.dataset.copy = '';
    }
    function hideMarkdown(): void {
      mdBtn!.hidden = true;
    }
    /** Replace the URL hash without adding a history entry; null clears it. */
    function writeHash(hash: string | null): void {
      const base = window.location.pathname + window.location.search;
      const url = hash ? `${base}${hash.startsWith('#') ? hash : `#${hash}`}` : base;
      window.history.replaceState(null, '', url);
    }

    let engine: EngineModule;
    let examples: Example[] = [];
    try {
      const [engineMod, examplesMod] = await Promise.all([
        import('../lib/k8s-resources/engine'),
        import('../lib/k8s-resources/examples'),
      ]);
      engine = engineMod as unknown as EngineModule;
      examples = normaliseExamples((examplesMod as { examples?: unknown }).examples);
    } catch (err) {
      renderError(resultsBox, summaryEl, 'The calculator engine failed to load. Reload the page to try again.');
      console.error('[K8sResourceCalculator] engine import failed:', err);
      return;
    }

    exampleSel.innerHTML = '';
    const customOpt = document.createElement('option');
    customOpt.value = '-1';
    customOpt.textContent = examples.length ? 'Custom' : 'No examples';
    exampleSel.appendChild(customOpt);
    examples.forEach((ex, i) => {
      const opt = document.createElement('option');
      opt.value = String(i);
      opt.textContent = ex.label;
      exampleSel.appendChild(opt);
    });
    if (!examples.length) exampleSel.disabled = true;

    // ── Per-field error helpers ──────────────────────────────────────────────
    /** Map from engine field name to the corresponding input element. */
    const fieldInputMap: Record<string, HTMLInputElement> = {
      cpuRequest: cpuReqInput!,
      cpuLimit: cpuLimInput!,
      memRequest: memReqInput!,
      memLimit: memLimInput!,
      replicas: replicasInput!,
    };

    function clearFieldErrors(): void {
      root.querySelectorAll<HTMLInputElement>('.k8s-text--error').forEach((inp) => {
        inp.classList.remove('k8s-text--error');
      });
      root.querySelectorAll<HTMLElement>('.k8s-field-error').forEach((el) => el.remove());
    }

    /**
     * Highlight a specific field input and append an error message below it.
     * fieldName matches keys in fieldInputMap (cpuRequest, cpuLimit, etc.).
     */
    function setFieldError(fieldName: string, message: string): void {
      const inp = fieldInputMap[fieldName];
      if (!inp) return;
      inp.classList.add('k8s-text--error');
      const fieldDiv = inp.closest<HTMLElement>('[data-k8s-field]');
      if (fieldDiv) {
        const errEl = document.createElement('p');
        errEl.className = 'k8s-field-error';
        errEl.setAttribute('aria-live', 'polite');
        errEl.textContent = message;
        fieldDiv.appendChild(errEl);
      }
    }

    /**
     * Extract the field name from an engine error string.
     * Engine errors follow the pattern: `<fieldName> "..." is not a valid...`
     * or `replicas "..." must be a positive integer.`
     */
    function parseErrorField(error: string): string | null {
      const match = /^(cpuRequest|cpuLimit|memRequest|memLimit|replicas)\s+"/.exec(error);
      return match ? match[1] : null;
    }

    /**
     * Re-evaluate the current fields and re-render the results panel.
     * `userInitiated` gates whether this call writes the URL hash — only
     * user-driven recalculations do; the initial default/example/share seed
     * render never does (see the boot sequence at the end of init()).
     */
    function evaluate(userInitiated = true): void {
      clearFieldErrors();
      const input: Input = {
        cpuRequest: cpuReqInput!.value,
        cpuLimit: cpuLimInput!.value,
        memRequest: memReqInput!.value,
        memLimit: memLimInput!.value,
        replicas: replicasInput!.value,
      };
      if (
        input.cpuRequest!.trim().length === 0 &&
        input.cpuLimit!.trim().length === 0 &&
        input.memRequest!.trim().length === 0 &&
        input.memLimit!.trim().length === 0
      ) {
        renderEmpty(resultsBox!, summaryEl!);
        hideShare();
        hideMarkdown();
        if (userInitiated) writeHash(null);
        return;
      }
      let result: Result | null = null;
      try {
        result = engine.calculate(input);
      } catch {
        renderError(resultsBox!, summaryEl!, 'Unexpected error while calculating resources.');
        hideShare();
        hideMarkdown();
        if (userInitiated) writeHash(null);
        return;
      }
      if (!result || result.valid === false) {
        const errMsg = result?.error ?? 'Enter at least one valid resource value.';
        renderError(resultsBox!, summaryEl!, errMsg);
        const fieldName = parseErrorField(errMsg);
        if (fieldName) setFieldError(fieldName, errMsg);
        hideShare();
        hideMarkdown();
        if (userInitiated) writeHash(null);
        return;
      }
      const replicas = Number(input.replicas) || 1;
      renderResult(resultsBox!, summaryEl!, result, replicas);

      // Share link + Markdown export are only ever shown for a valid,
      // non-empty result (mirrors CronTesterPlayground's hideShare discipline).
      let hash = '';
      try {
        hash = engine.encodeState([input]);
      } catch {
        hash = '';
      }
      if (hash) {
        const frag = hash.startsWith('#') ? hash : `#${hash}`;
        shareBtn!.hidden = false;
        shareBtn!.dataset.copy =
          window.location.origin + window.location.pathname + window.location.search + frag;
        if (userInitiated) writeHash(frag);
      } else {
        hideShare();
      }

      mdBtn!.hidden = false;
      lastMarkdownFields = markdownFields(result, replicas);
    }

    let shareCopyTimer: number | undefined;
    shareBtn.addEventListener('click', () => {
      const text = shareBtn!.dataset.copy ?? '';
      void copyTextToClipboard(text).then((ok) => {
        if (!ok) return;
        shareBtn!.classList.add('k8s-share-btn--copied');
        if (shareLabel) shareLabel.textContent = 'Copied';
        window.clearTimeout(shareCopyTimer);
        shareCopyTimer = window.setTimeout(() => {
          shareBtn!.classList.remove('k8s-share-btn--copied');
          if (shareLabel) shareLabel.textContent = 'Copy link';
        }, 1500);
      });
    });

    let mdCopyTimer: number | undefined;
    mdBtn.addEventListener('click', () => {
      const text = buildMarkdownBlock('Kubernetes Resource Calculator', lastMarkdownFields);
      void copyTextToClipboard(text).then((ok) => {
        if (!ok) return;
        mdBtn!.classList.add('k8s-share-btn--copied');
        if (mdLabel) mdLabel.textContent = 'Copied';
        window.clearTimeout(mdCopyTimer);
        mdCopyTimer = window.setTimeout(() => {
          mdBtn!.classList.remove('k8s-share-btn--copied');
          if (mdLabel) mdLabel.textContent = 'Copy as Markdown';
        }, 1500);
      });
    });

    let timer: number | undefined;
    function scheduleEvaluate(): void {
      window.clearTimeout(timer);
      timer = window.setTimeout(evaluate, DEBOUNCE_MS);
    }

    function onUserInput(): void {
      if (exampleSel!.value !== '-1') exampleSel!.value = '-1';
      scheduleEvaluate();
    }

    cpuReqInput.addEventListener('input', onUserInput);
    cpuLimInput.addEventListener('input', onUserInput);
    memReqInput.addEventListener('input', onUserInput);
    memLimInput.addEventListener('input', onUserInput);
    replicasInput.addEventListener('input', onUserInput);
    exampleSel.addEventListener('change', () => {
      const idx = Number(exampleSel.value);
      if (!Number.isInteger(idx) || idx < 0 || idx >= examples.length) return;
      const ex = examples[idx];
      cpuReqInput.value = ex.input.cpuRequest;
      cpuLimInput.value = ex.input.cpuLimit;
      memReqInput.value = ex.input.memRequest;
      memLimInput.value = ex.input.memLimit;
      replicasInput.value = ex.input.replicas;
      window.clearTimeout(timer);
      evaluate();
    });

    // Seed priority: a valid #s= share link > the first bundled example.
    // Neither seed path writes the hash — only user-initiated evaluations do.
    let seedRow: Input | null = null;
    try {
      const decoded = engine.decodeState();
      if (decoded && Array.isArray(decoded.rows) && decoded.rows.length > 0) {
        const first = decoded.rows[0];
        const hasContent =
          (first.cpuRequest ?? '').trim().length > 0 ||
          (first.cpuLimit ?? '').trim().length > 0 ||
          (first.memRequest ?? '').trim().length > 0 ||
          (first.memLimit ?? '').trim().length > 0;
        if (hasContent) seedRow = first;
      }
    } catch {
      /* malformed hash — fall back to the example seed */
    }

    if (seedRow) {
      cpuReqInput.value = seedRow.cpuRequest ?? '';
      cpuLimInput.value = seedRow.cpuLimit ?? '';
      memReqInput.value = seedRow.memRequest ?? '';
      memLimInput.value = seedRow.memLimit ?? '';
      replicasInput.value = seedRow.replicas ?? '';
      exampleSel.value = '-1';
      evaluate(false);
    } else {
      const seed = examples[0];
      if (seed) {
        cpuReqInput.value = seed.input.cpuRequest;
        cpuLimInput.value = seed.input.cpuLimit;
        memReqInput.value = seed.input.memRequest;
        memLimInput.value = seed.input.memLimit;
        replicasInput.value = seed.input.replicas;
        exampleSel.value = '0';
        evaluate(false);
      } else {
        renderEmpty(resultsBox, summaryEl);
      }
    }
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
