---
import Logo from './Logo.astro';
import { site, footerColumns } from '../data/site';

const year = new Intl.NumberFormat('en-US', { useGrouping: false }).format(
  new Date().getFullYear()
);
---

<footer class="bg-canvas border-t border-hairline">
  <div class="container-page py-16 sm:py-20">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12 md:gap-8">
      <!-- Brand column -->
      <div class="md:col-span-4 lg:col-span-5">
        <a
          href="/"
          class="text-ink hover:text-ink/80 inline-flex items-center rounded-sm transition-opacity"
          style="touch-action: manipulation;"
          aria-label={`${site.name} — home`}
        >
          <Logo />
        </a>
        <p class="body-sm text-body mt-5 max-w-xs text-pretty">{site.tagline}</p>
        <a
          href={site.github}
          rel="noopener noreferrer"
          target="_blank"
          class="body-sm text-body hover:text-ink mt-5 inline-flex min-h-11 items-center gap-2 rounded-sm transition-colors"
          style="touch-action: manipulation;"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="currentColor"
            aria-hidden="true"
            class="shrink-0"
          >
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
            ></path>
          </svg>
          <span translate="no">GitHub</span>
          <span class="sr-only">(opens in a new tab)</span>
        </a>
      </div>

      <!-- Footer nav columns -->
      <nav
        aria-label="Footer"
        class="grid grid-cols-2 gap-x-8 gap-y-10 sm:grid-cols-4 md:col-span-8 lg:col-span-7"
      >
        {
          footerColumns.map((column) => (
            <div class="min-w-0">
              <h2 class="eyebrow">{column.title}</h2>
              <ul class="mt-4 space-y-1">
                {column.links.map((link) => {
                  const isExternal = link.href.startsWith('http');
                  return (
                    <li class="min-w-0">
                      {isExternal ? (
                        <a
                          href={link.href}
                          rel="noopener noreferrer"
                          target="_blank"
                          class="body-sm text-body hover:text-ink inline-flex min-h-11 items-center rounded-sm text-pretty transition-colors"
                          style="touch-action: manipulation;"
                        >
                          {link.label}
                          <span class="sr-only">(opens in a new tab)</span>
                        </a>
                      ) : (
                        <a
                          href={link.href}
                          class="body-sm text-body hover:text-ink inline-flex min-h-11 items-center rounded-sm text-pretty transition-colors"
                          style="touch-action: manipulation;"
                        >
                          {link.label}
                        </a>
                      )}
                    </li>
                  );
                })}
              </ul>
            </div>
          ))
        }
      </nav>
    </div>

    <!-- Divider + bottom row -->
    <div
      class="border-hairline mt-14 flex flex-col gap-3 border-t pt-8 sm:flex-row sm:items-start sm:justify-between sm:gap-8"
    >
      <p class="caption text-mute">
        &copy;&nbsp;<span class="tabular-nums">{year}</span>&nbsp;<span translate="no"
          >OpsCanopy</span
        >. Free &amp; open.
      </p>
      <p class="caption text-mute max-w-xl text-pretty sm:text-right">
        Not affiliated with or endorsed by Grafana&nbsp;Labs.
        <span translate="no">Loki</span> and <span translate="no">Grafana</span> are trademarks of
        Raintank,&nbsp;Inc.
      </p>
    </div>
  </div>
</footer>
