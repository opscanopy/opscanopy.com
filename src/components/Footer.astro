---
import Logo from './Logo.astro';
import { site } from '../data/site';
import { BCP47, DEFAULT_LOCALE, type Locale } from '../i18n/config';
import { useTranslations, localizeKey } from '../i18n/utils';
import { getSiteContent } from '../i18n/site';

const lang: Locale = (Astro.currentLocale as Locale) ?? DEFAULT_LOCALE;
const t = useTranslations(lang);
const { tagline, footer: footerColumns } = getSiteContent(lang);
const href = (key: string) => (key.startsWith('http') ? key : localizeKey(key, lang));

const year = new Intl.NumberFormat(BCP47[lang], { useGrouping: false }).format(
  new Date().getFullYear()
);
---

<footer class="bg-canvas border-t border-hairline">
  <div class="container-page pt-16 pb-8 sm:pt-20 sm:pb-10">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12 md:gap-8">
      <!-- Brand column -->
      <div class="md:col-span-4 lg:col-span-5">
        <a
          href={localizeKey('/', lang)}
          class="text-ink hover:text-ink/80 inline-flex items-center rounded-sm transition-opacity"
          style="touch-action: manipulation;"
          aria-label={t('a11y.homeLabel', { name: site.name })}
        >
          <Logo />
        </a>
        <p class="body-sm text-body mt-5 max-w-xs text-pretty">{tagline}</p>
      </div>

      <!-- Footer nav columns -->
      <nav
        aria-label="Footer"
        class="grid grid-cols-2 gap-x-8 gap-y-10 sm:grid-cols-4 md:col-span-8 lg:col-span-7"
      >
        {
          footerColumns.map((column) => (
            <div class="min-w-0">
              <p class="eyebrow">{column.title}</p>
              <ul class="mt-4 space-y-1">
                {column.links.map((link) => {
                  const isExternal = link.href.startsWith('http');
                  return (
                    <li class="min-w-0">
                      {isExternal ? (
                        <a
                          href={link.href}
                          rel="noopener noreferrer"
                          target="_blank"
                          class="body-sm text-body hover:text-ink inline-flex min-h-11 items-center rounded-sm text-pretty transition-colors"
                          style="touch-action: manipulation;"
                        >
                          {link.label}
                          <span class="sr-only">{t('a11y.opensNewTab')}</span>
                        </a>
                      ) : (
                        <a
                          href={href(link.href)}
                          class="body-sm text-body hover:text-ink inline-flex min-h-11 items-center rounded-sm text-pretty transition-colors"
                          style="touch-action: manipulation;"
                        >
                          {link.label}
                        </a>
                      )}
                    </li>
                  );
                })}
              </ul>
            </div>
          ))
        }
      </nav>
    </div>

    <!-- Divider + bottom row -->
    <div
      class="border-hairline mt-14 flex flex-col gap-3 border-t pt-8 sm:flex-row sm:items-start sm:justify-between sm:gap-8"
    >
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-5">
        <p class="caption text-mute">
          &copy;&nbsp;<span class="tabular-nums">{year}</span>&nbsp;<span translate="no"
            >OpsCanopy</span
          >. {t('footer.copyright')}
        </p>
        <a
          href="/sitemap-index.xml"
          class="caption text-mute hover:text-ink inline-flex min-h-11 items-center rounded-sm transition-colors sm:min-h-0"
          style="touch-action: manipulation;"
        >
          Sitemap
        </a>
        <p class="caption text-mute">
          {t('footer.builtBy')} <span translate="no">Pushkar Kumar</span> &amp;
          <span translate="no">Asif Khan</span>
        </p>
      </div>
      <p class="caption text-mute max-w-xl text-pretty sm:text-right">
        {t('footer.disclaimer.lead')}
        <span translate="no">Loki</span> {t('footer.disclaimer.trademark')}
        <span translate="no">Grafana</span> {t('footer.disclaimer.tail')}
      </p>
    </div>
  </div>
</footer>
