---
/**
 * TimestampConverterPlayground — the interactive Timestamp Converter island.
 *
 * Single-input, live tool: type a Unix epoch (seconds / milliseconds /
 * microseconds) or a parseable date string and every representation of that
 * instant is rendered. A "Now" button fills the current epoch seconds. Fully
 * client-side, no framework.
 *
 * Runtime contract (lazy-imported):
 *   ../lib/timestamp-converter/engine   → convert(input: string, nowMs?: number): TimeResult
 *   ../lib/timestamp-converter/examples → examples: { id; label; input }[]
 */
---

<section class="ts-pg" aria-label="Timestamp Converter playground">
  <div class="card shadow-float overflow-hidden rounded-lg">
    <div class="flex flex-col gap-1 border-b border-hairline px-4 py-3 sm:px-5">
      <label class="eyebrow shrink-0" for="ts-example">Example</label>
      <div class="ts-select-wrap relative min-w-0">
        <select id="ts-example" class="ts-select code-mono" autocomplete="off">
          <option value="">Loading examples…</option>
        </select>
        <svg
          class="ts-select-caret pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-mute"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 6l4 4 4-4"></path>
        </svg>
      </div>
    </div>

    <div class="border-b border-hairline px-4 py-4 sm:px-5">
      <div class="ts-label-row mb-2 flex items-center gap-2">
        <label class="eyebrow" for="ts-input">Timestamp</label>
        <span id="ts-sample-badge" class="ts-sample-badge" aria-label="pre-filled sample value" hidden>(sample)</span>
      </div>
      <div class="ts-input-row">
        <div class="ts-input-wrap">
          <svg
            class="ts-input-icon pointer-events-none"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="10" cy="10" r="7.25"></circle>
            <path d="M10 6v4l2.5 2.5"></path>
          </svg>
          <input
            id="ts-input"
            type="text"
            class="ts-input code-mono"
            spellcheck="false"
            autocapitalize="off"
            autocorrect="off"
            autocomplete="off"
            placeholder="1516239022"
            aria-describedby="ts-input-hint"
          />
        </div>
        <button id="ts-now" type="button" class="ts-now code-mono">Now</button>
      </div>
      <p id="ts-input-hint" class="ts-hint caption text-mute">
        A Unix epoch in seconds <span class="code-mono">1516239022</span>, milliseconds
        <span class="code-mono">1516239022000</span>, or a date string
        <span class="code-mono">2018-01-18T01:30:22Z</span>.
      </p>
    </div>

    <div class="bg-canvas-soft px-4 py-4 sm:px-5">
      <div class="mb-3 flex flex-wrap items-center justify-between gap-x-3 gap-y-1">
        <span class="flex items-center gap-2">
          <span class="eyebrow">Result</span>
          <button id="ts-share" type="button" class="ts-share-btn" data-copy="" hidden>
            <svg
              class="ts-share-icon"
              width="13"
              height="13"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M6.75 9.25l2.5-2.5"></path>
              <path d="M8.75 4.25l1.5-1.5a2.47 2.47 0 0 1 3.5 3.5l-1.5 1.5"></path>
              <path d="M7.25 11.75l-1.5 1.5a2.47 2.47 0 0 1-3.5-3.5l1.5-1.5"></path>
            </svg>
            <span class="ts-share-label">Copy link</span>
          </button>
          <button id="ts-md" type="button" class="ts-share-btn" data-copy="" hidden>
            <svg
              class="ts-share-icon"
              width="13"
              height="13"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M2.5 4.5h11v7h-11z"></path>
              <path d="M4.5 10V6l1.75 2L8 6v4"></path>
              <path d="M9.75 6.5v3.25M9.75 9.75l1.25-1.25M9.75 9.75l-1.25-1.25"></path>
            </svg>
            <span class="ts-md-label">Copy as Markdown</span>
          </button>
        </span>
        <span id="ts-summary" class="ts-summary code-mono text-mute" role="status" aria-live="polite"></span>
      </div>
      <div id="ts-results" class="ts-results" aria-live="polite" aria-atomic="false">
        <p class="ts-empty body-sm text-mute">
          Type a Unix timestamp or date string, pick an example, or hit Now to see it in seconds,
          milliseconds, ISO 8601, UTC and local time here.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../styles/global.css";

  .ts-select {
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    height: 32px;
    min-width: 0;
    max-width: 320px;
    padding: 0 32px 0 12px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-hairline);
    font-size: 13px;
    line-height: 20px;
    cursor: pointer;
    text-overflow: ellipsis;
    touch-action: manipulation;
    transition: box-shadow 0.15s ease;
  }
  @media (min-width: 640px) {
    .ts-select {
      width: auto;
      min-width: 260px;
    }
  }
  .ts-select:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .ts-select:disabled {
    cursor: not-allowed;
    color: var(--color-mute);
    opacity: 0.7;
  }
  .ts-select-wrap:hover .ts-select-caret {
    color: var(--color-body);
  }

  .ts-input-row {
    display: flex;
    align-items: stretch;
    gap: 10px;
  }
  .ts-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
    flex: 1 1 auto;
    min-width: 0;
  }
  .ts-input-icon {
    position: absolute;
    left: 14px;
    width: 18px;
    height: 18px;
    color: var(--color-mute);
    pointer-events: none;
  }
  .ts-input {
    width: 100%;
    height: 48px;
    padding: 0 16px 0 42px;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-hairline);
    font-size: 15px;
    line-height: 24px;
    letter-spacing: 0.01em;
    transition: box-shadow 0.15s ease;
  }
  .ts-input::placeholder {
    color: var(--color-mute);
  }
  .ts-input:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .ts-input:focus {
    outline: none;
  }
  .ts-input:focus-visible {
    box-shadow: inset 0 0 0 2px var(--color-link);
    outline: none;
  }
  .ts-input.ts-input--error {
    box-shadow: inset 0 0 0 1px var(--color-error);
  }
  .ts-input.ts-input--error:focus-visible {
    box-shadow: inset 0 0 0 2px var(--color-error);
  }

  .ts-now {
    flex: 0 0 auto;
    height: 48px;
    padding: 0 18px;
    border-radius: var(--radius-md);
    background: var(--color-primary);
    color: var(--color-on-primary);
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
    cursor: pointer;
    touch-action: manipulation;
    transition:
      box-shadow 0.15s ease,
      background 0.15s ease;
  }
  .ts-now:hover {
    background: var(--color-primary-hover);
  }
  .ts-now:focus {
    outline: none;
  }
  .ts-now:focus-visible {
    box-shadow: inset 0 0 0 2px var(--color-link);
    outline: none;
  }

  .ts-hint {
    margin-top: 8px;
    text-wrap: pretty;
  }
  .ts-summary {
    white-space: nowrap;
  }
  .ts-share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 26px;
    padding: 0 10px;
    border-radius: var(--radius-sm);
    border: none;
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    color: var(--color-mute);
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 16px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 0.12s ease, background 0.12s ease;
  }
  .ts-share-btn:hover {
    color: var(--color-brand-strong);
    background: var(--color-hairline);
  }
  .ts-share-btn:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 1px;
  }
  .ts-share-btn.ts-share-btn--copied {
    color: var(--color-brand-strong);
    background: var(--color-brand-soft);
  }
  @media (pointer: coarse) {
    .ts-share-btn {
      height: auto;
      min-height: 36px;
    }
  }
  .ts-results {
    min-height: 44px;
  }

  :global(.ts-card) {
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    overflow: hidden;
    animation: ts-rise 0.18s ease both;
  }
  :global(.ts-title) {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-hairline);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 18px;
    color: var(--color-mute);
  }
  :global(.ts-title__badge) {
    flex: 0 0 auto;
    font-size: 11px;
    line-height: 16px;
    padding: 1px 8px;
    border-radius: 9999px;
    background: var(--color-brand-soft);
    color: var(--color-brand-strong);
    text-transform: capitalize;
  }
  :global(.ts-row) {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr) 30px;
    gap: 12px;
    padding: 9px 14px;
    align-items: center;
  }
  :global(.ts-row + .ts-row) {
    border-top: 1px solid var(--color-hairline);
  }
  :global(.ts-row__k) {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 18px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-mute);
  }
  :global(.ts-row__v) {
    min-width: 0;
    font-size: 14px;
    line-height: 20px;
    color: var(--color-ink);
    word-break: break-word;
  }
  :global(.ts-row__v.is-mono) {
    font-family: var(--font-mono);
    font-size: 13px;
    font-variant-numeric: tabular-nums;
    font-feature-settings: 'tnum';
  }

  @keyframes ts-rise {
    from {
      opacity: 0;
      transform: translateY(3px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.ts-card) {
      animation: none;
    }
  }

  :global(.ts-error) {
    display: flex;
    gap: 10px;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    background: var(--color-error-soft);
    box-shadow: inset 0 0 0 1px var(--color-error);
    color: var(--color-error-deep);
  }
  :global(.ts-error__icon) {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
    margin-top: 1px;
  }
  :global(.ts-error__title) {
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
  }
  :global(.ts-error__detail) {
    margin-top: 2px;
    font-size: 13px;
    line-height: 18px;
    text-wrap: pretty;
  }
  .ts-sample-badge {
    display: inline-block;
    font-size: 11px;
    line-height: 16px;
    padding: 1px 7px;
    border-radius: 9999px;
    background: var(--color-canvas-soft, #f3f4f6);
    color: var(--color-mute);
    font-family: var(--font-sans);
    font-weight: 400;
    vertical-align: middle;
  }
  .ts-sample-badge[hidden] {
    display: none;
  }

  :global(.ts-copy-btn) {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-mute);
    cursor: pointer;
    transition: background 0.12s ease, color 0.12s ease;
  }
  :global(.ts-copy-btn:hover) {
    background: var(--color-canvas-soft, #f3f4f6);
    color: var(--color-ink);
  }
  :global(.ts-copy-btn.ts-copied) {
    color: var(--color-success, #16a34a);
  }
  :global(.ts-copy-btn svg) {
    width: 14px;
    height: 14px;
    pointer-events: none;
  }

  :global(.ts-empty) {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 64px;
    padding: 20px 16px;
    text-align: center;
    text-wrap: pretty;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
  }
</style>

<script>
  import { escapeHtml } from '../lib/escape-html';
  import { copyTextToClipboard } from '../lib/clipboard';
  import { createHashState } from '../lib/hash-state';
  import { buildMarkdownBlock } from '../lib/share-md';

  type Row = { label: string; value: string; mono?: boolean };
  type Result = { valid: boolean; error?: string; detected?: string; rows: Row[] };
  type Example = { id: string; label: string; input: string };
  type EngineModule = { convert: (input: string, nowMs?: number) => Result };

  const ROOT_SEL = '.ts-pg';
  const DEBOUNCE_MS = 140;

  function boot(): void {
    document.querySelectorAll<HTMLElement>(ROOT_SEL).forEach((root) => {
      if (root.dataset.tsWired === 'true') return;
      root.dataset.tsWired = 'true';
      void init(root);
    });
  }

  function el<T extends HTMLElement>(root: HTMLElement, sel: string): T | null {
    return root.querySelector<T>(sel);
  }

  function normaliseExamples(raw: unknown): Example[] {
    if (!Array.isArray(raw)) return [];
    return raw
      .map((item, i) => {
        const o = (item ?? {}) as Record<string, unknown>;
        return {
          id: typeof o.id === 'string' && o.id ? o.id : `example-${i + 1}`,
          label: typeof o.label === 'string' && o.label ? o.label : `Example ${i + 1}`,
          input: typeof o.input === 'string' ? o.input : '',
        } satisfies Example;
      })
      .filter((e) => e.input.length > 0);
  }

  const COPY_SVG =
    '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="5" width="8" height="9" rx="1.2"></rect><path d="M3 11V3a1 1 0 0 1 1-1h7"></path></svg>';
  const CHECK_SVG =
    '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.5 8.5l3.5 3.5 7-7"></path></svg>';

  const ALERT_SVG =
    '<svg class="ts-error__icon" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 2.5L18.5 17H1.5z"></path><path d="M10 8v4"></path><path d="M10 14.6v.01"></path></svg>';

  function renderEmpty(container: HTMLElement, summary: HTMLElement): void {
    summary.textContent = '';
    summary.classList.remove('text-error');
    summary.classList.add('text-mute');
    container.innerHTML =
      '<p class="ts-empty body-sm text-mute">Type a Unix timestamp or date string, pick an example, or hit Now to see it in seconds, milliseconds, ISO 8601, UTC and local time here.</p>';
  }

  function renderError(container: HTMLElement, summary: HTMLElement, message: string): void {
    summary.textContent = 'Invalid';
    summary.classList.remove('text-mute');
    summary.classList.add('text-error');
    container.innerHTML =
      '<div class="ts-error" role="alert">' +
      ALERT_SVG +
      '<div><p class="ts-error__title">Could not read that timestamp</p>' +
      `<p class="ts-error__detail">${escapeHtml(message)}</p></div></div>`;
  }

  function renderResult(container: HTMLElement, summary: HTMLElement, result: Result): void {
    const detected = result.detected ?? '';
    summary.textContent = detected;
    summary.classList.remove('text-error');
    summary.classList.add('text-mute');
    const rows = Array.isArray(result.rows) ? result.rows : [];
    const rowsHtml = rows
      .map((r) => {
        const v = typeof r.value === 'string' ? r.value : '';
        const cls = r.mono ? 'ts-row__v is-mono' : 'ts-row__v';
        return (
          '<div class="ts-row">' +
          `<span class="ts-row__k">${escapeHtml(r.label ?? '')}</span>` +
          `<span class="${cls}">${escapeHtml(v)}</span>` +
          `<button class="ts-copy-btn" type="button" data-copy-value="${escapeHtml(v)}" aria-label="Copy ${escapeHtml(r.label ?? '')} value">${COPY_SVG}</button>` +
          '</div>'
        );
      })
      .join('');
    const badge = detected ? `read as ${detected}` : 'instant';
    container.innerHTML =
      '<div class="ts-card">' +
      `<div class="ts-title"><span class="ts-title__badge">${escapeHtml(detected || 'parsed')}</span><span>${escapeHtml(badge)}</span></div>` +
      rowsHtml +
      '</div>';
  }

  function wireResultCopyClicks(container: HTMLElement): void {
    container.addEventListener('click', (e) => {
      const btn = (e.target as Element).closest<HTMLButtonElement>('.ts-copy-btn');
      if (!btn) return;
      const text = btn.dataset.copyValue ?? '';
      void copyTextToClipboard(text).then((ok) => {
        if (!ok) return;
        btn.innerHTML = CHECK_SVG;
        btn.classList.add('ts-copied');
        setTimeout(() => {
          btn.innerHTML = COPY_SVG;
          btn.classList.remove('ts-copied');
        }, 1500);
      });
    });
  }

  async function init(root: HTMLElement): Promise<void> {
    const input = el<HTMLInputElement>(root, '#ts-input');
    const exampleSel = el<HTMLSelectElement>(root, '#ts-example');
    const nowBtn = el<HTMLButtonElement>(root, '#ts-now');
    const resultsBox = el<HTMLElement>(root, '#ts-results');
    const summaryEl = el<HTMLElement>(root, '#ts-summary');
    const sampleBadge = el<HTMLElement>(root, '#ts-sample-badge');
    const shareBtn = el<HTMLButtonElement>(root, '#ts-share');
    const mdBtn = el<HTMLButtonElement>(root, '#ts-md');
    if (!input || !exampleSel || !nowBtn || !resultsBox || !summaryEl || !shareBtn || !mdBtn) return;

    const hashState = createHashState('t');

    wireResultCopyClicks(resultsBox);

    let engine: EngineModule;
    let examples: Example[] = [];
    try {
      const [engineMod, examplesMod] = await Promise.all([
        import('../lib/timestamp-converter/engine'),
        import('../lib/timestamp-converter/examples'),
      ]);
      engine = engineMod as unknown as EngineModule;
      examples = normaliseExamples((examplesMod as { examples?: unknown }).examples);
    } catch (err) {
      renderError(resultsBox, summaryEl, 'The converter engine failed to load. Reload the page to try again.');
      console.error('[TimestampConverter] engine import failed:', err);
      return;
    }

    exampleSel.innerHTML = '';
    const customOpt = document.createElement('option');
    customOpt.value = '-1';
    customOpt.textContent = examples.length ? 'Custom input' : 'No examples';
    exampleSel.appendChild(customOpt);
    examples.forEach((ex, i) => {
      const opt = document.createElement('option');
      opt.value = String(i);
      opt.textContent = ex.label;
      exampleSel.appendChild(opt);
    });
    if (!examples.length) exampleSel.disabled = true;

    function hideShare(): void {
      shareBtn!.hidden = true;
      shareBtn!.dataset.copy = '';
      mdBtn!.hidden = true;
    }

    let shareCopyTimer: number | undefined;
    shareBtn.addEventListener('click', () => {
      const text = shareBtn.dataset.copy ?? '';
      void copyTextToClipboard(text).then((ok) => {
        if (!ok) return;
        shareBtn.classList.add('ts-share-btn--copied');
        const label = shareBtn.querySelector('.ts-share-label');
        if (label) label.textContent = 'Copied';
        window.clearTimeout(shareCopyTimer);
        shareCopyTimer = window.setTimeout(() => {
          shareBtn.classList.remove('ts-share-btn--copied');
          if (label) label.textContent = 'Copy link';
        }, 1500);
      });
    });

    let mdCopyTimer: number | undefined;
    mdBtn.addEventListener('click', () => {
      const text = mdBtn.dataset.copy ?? '';
      void copyTextToClipboard(text).then((ok) => {
        if (!ok) return;
        mdBtn.classList.add('ts-share-btn--copied');
        const label = mdBtn.querySelector('.ts-md-label');
        if (label) label.textContent = 'Copied';
        window.clearTimeout(mdCopyTimer);
        mdCopyTimer = window.setTimeout(() => {
          mdBtn.classList.remove('ts-share-btn--copied');
          if (label) label.textContent = 'Copy as Markdown';
        }, 1500);
      });
    });

    function evaluate(userInitiated = true): void {
      const value = input!.value.trim();
      if (value.length === 0) {
        input!.classList.remove('ts-input--error');
        hideShare();
        renderEmpty(resultsBox!, summaryEl!);
        if (userInitiated) hashState.write(null);
        return;
      }
      let result: Result | null = null;
      try {
        result = engine.convert(value);
      } catch {
        input!.classList.add('ts-input--error');
        hideShare();
        renderError(resultsBox!, summaryEl!, 'Unexpected error while converting.');
        if (userInitiated) hashState.write(null);
        return;
      }
      if (!result || result.valid === false) {
        input!.classList.add('ts-input--error');
        hideShare();
        renderError(resultsBox!, summaryEl!, result?.error ?? 'This is not a valid timestamp.');
        if (userInitiated) hashState.write(null);
        return;
      }
      input!.classList.remove('ts-input--error');
      renderResult(resultsBox!, summaryEl!, result);
      shareBtn!.hidden = false;
      shareBtn!.dataset.copy = location.origin + location.pathname + location.search + hashState.build(value);
      if (userInitiated) hashState.write(value);

      mdBtn!.hidden = false;
      const rows = Array.isArray(result.rows) ? result.rows : [];
      mdBtn!.dataset.copy = buildMarkdownBlock('Timestamp Converter', [
        { label: 'Input', value },
        ...rows.map((r) => ({ label: r.label ?? '', value: typeof r.value === 'string' ? r.value : '' })),
      ]);
    }

    let timer: number | undefined;
    function scheduleEvaluate(): void {
      window.clearTimeout(timer);
      timer = window.setTimeout(evaluate, DEBOUNCE_MS);
    }

    input.addEventListener('input', () => {
      if (exampleSel.value !== '-1') exampleSel.value = '-1';
      if (sampleBadge) sampleBadge.hidden = true;
      scheduleEvaluate();
    });
    exampleSel.addEventListener('change', () => {
      const idx = Number(exampleSel.value);
      if (!Number.isInteger(idx) || idx < 0 || idx >= examples.length) return;
      input.value = examples[idx].input;
      if (sampleBadge) sampleBadge.hidden = idx !== 0;
      window.clearTimeout(timer);
      evaluate();
    });
    nowBtn.addEventListener('click', () => {
      input.value = String((Date.now() / 1000) | 0);
      exampleSel.value = '-1';
      if (sampleBadge) sampleBadge.hidden = true;
      window.clearTimeout(timer);
      evaluate();
      input.focus();
    });

    // Seed priority: #t= deep link > seeded example. Neither seed path writes
    // the hash — only user-initiated evaluations do.
    const hashValue = hashState.read();
    if (hashValue) {
      input.value = hashValue;
      exampleSel.value = '-1';
      if (sampleBadge) sampleBadge.hidden = true;
      evaluate(false);
    } else {
      const seed = examples[0];
      if (seed) {
        input.value = seed.input;
        exampleSel.value = '0';
        if (sampleBadge) sampleBadge.hidden = false;
        evaluate(false);
      } else {
        renderEmpty(resultsBox, summaryEl);
      }
    }
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
