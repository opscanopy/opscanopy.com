---
/**
 * PtrHelperPlayground — the interactive Reverse DNS / PTR Helper island.
 *
 * Single-input, live tool: type an IP address or IP/prefix and the PTR record
 * name, reverse-delegation zone, and a ready-to-run `dig -x` command are
 * rendered. No button, fully client-side.
 *
 * Runtime contract (lazy-imported):
 *   ../lib/ptr-helper/engine   → generate(input: string): PtrResult
 *   ../lib/ptr-helper/examples → examples: { id; label; input }[]
 */
---

<section class="ptr-pg" aria-label="Reverse DNS / PTR Helper playground">
  <div class="card shadow-float overflow-hidden rounded-lg">
    <div class="flex flex-col gap-1 border-b border-hairline px-4 py-3 sm:px-5">
      <label class="eyebrow shrink-0" for="ptr-example">Example</label>
      <div class="ptr-select-wrap relative min-w-0">
        <select id="ptr-example" class="ptr-select code-mono" autocomplete="off">
          <option value="">Loading examples…</option>
        </select>
        <svg
          class="ptr-select-caret pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-mute"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 6l4 4 4-4"></path>
        </svg>
      </div>
    </div>

    <div class="border-b border-hairline px-4 py-4 sm:px-5">
      <label class="eyebrow mb-2 block" for="ptr-input">IP address or CIDR <span class="ptr-sample-cue">(sample)</span></label>
      <div class="ptr-input-wrap">
        <svg
          class="ptr-input-icon pointer-events-none"
          viewBox="0 0 20 20"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 10h12M10 4v12"></path>
          <circle cx="10" cy="10" r="7.25"></circle>
        </svg>
        <input
          id="ptr-input"
          type="text"
          class="ptr-input code-mono"
          spellcheck="false"
          autocapitalize="off"
          autocorrect="off"
          autocomplete="off"
          placeholder="192.0.2.1"
          aria-describedby="ptr-input-hint"
        />
      </div>
      <p id="ptr-input-hint" class="ptr-hint caption text-mute">
        IPv4 or IPv6 — host <span class="code-mono">192.0.2.1</span> or
        <span class="code-mono">2001:db8::1</span>. Add a prefix like
        <span class="code-mono">192.0.2.0/24</span> to get the reverse zone.
      </p>
    </div>

    <div class="bg-canvas-soft px-4 py-4 sm:px-5">
      <div class="mb-3 flex items-center justify-between gap-3">
        <span class="eyebrow">Result</span>
        <span id="ptr-summary" class="ptr-summary code-mono text-mute" role="status" aria-live="polite"></span>
      </div>
      <div id="ptr-results" class="ptr-results" aria-live="polite" aria-atomic="false">
        <p class="ptr-empty body-sm text-mute">
          Type an IP address or IP/prefix or pick an example to see its PTR record name, reverse
          zone and a ready-to-run dig command here.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../styles/global.css";

  .ptr-select {
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    height: 32px;
    min-width: 0;
    max-width: 320px;
    padding: 0 32px 0 12px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-hairline);
    font-size: 13px;
    line-height: 20px;
    cursor: pointer;
    text-overflow: ellipsis;
    touch-action: manipulation;
    transition: box-shadow 0.15s ease;
  }
  @media (min-width: 640px) {
    .ptr-select {
      width: auto;
      min-width: 260px;
    }
  }
  .ptr-select:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .ptr-select:disabled {
    cursor: not-allowed;
    color: var(--color-mute);
    opacity: 0.7;
  }
  .ptr-select-wrap:hover .ptr-select-caret {
    color: var(--color-body);
  }

  .ptr-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .ptr-input-icon {
    position: absolute;
    left: 14px;
    width: 18px;
    height: 18px;
    color: var(--color-mute);
    pointer-events: none;
  }
  .ptr-input {
    width: 100%;
    height: 48px;
    padding: 0 16px 0 42px;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-hairline);
    font-size: 15px;
    line-height: 24px;
    letter-spacing: 0.01em;
    transition: box-shadow 0.15s ease;
  }
  .ptr-input::placeholder {
    color: var(--color-mute);
  }
  .ptr-input:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .ptr-input:focus {
    outline: none;
  }
  .ptr-input:focus-visible {
    box-shadow: inset 0 0 0 2px var(--color-link);
    outline: none;
  }
  .ptr-input.ptr-input--error {
    box-shadow: inset 0 0 0 1px var(--color-error);
  }
  .ptr-input.ptr-input--error:focus-visible {
    box-shadow: inset 0 0 0 2px var(--color-error);
  }
  .ptr-sample-cue {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    color: var(--color-mute);
    font-family: var(--font-sans);
  }
  .ptr-sample-cue.is-hidden {
    display: none;
  }
  .ptr-hint {
    margin-top: 8px;
    text-wrap: pretty;
  }
  .ptr-summary {
    white-space: nowrap;
  }
  .ptr-results {
    min-height: 44px;
  }

  :global(.ptr-card) {
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    overflow: hidden;
    animation: ptr-rise 0.18s ease both;
  }
  :global(.ptr-title) {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-hairline);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 18px;
    color: var(--color-mute);
  }
  :global(.ptr-title__badge) {
    flex: 0 0 auto;
    font-size: 11px;
    line-height: 16px;
    padding: 1px 8px;
    border-radius: 9999px;
    background: var(--color-brand-soft);
    color: var(--color-brand-strong);
  }
  :global(.ptr-row) {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr) auto;
    gap: 12px;
    padding: 9px 14px;
    align-items: center;
  }
  :global(.ptr-row + .ptr-row) {
    border-top: 1px solid var(--color-hairline);
  }
  :global(.ptr-row__k) {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 18px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-mute);
  }
  :global(.ptr-row__v) {
    min-width: 0;
    font-size: 14px;
    line-height: 20px;
    color: var(--color-ink);
    word-break: break-word;
  }
  :global(.ptr-row__v.is-mono) {
    font-family: var(--font-mono);
    font-size: 13px;
    font-variant-numeric: tabular-nums;
    font-feature-settings: 'tnum';
  }
  :global(.ptr-copy-btn) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    border: none;
    background: transparent;
    color: var(--color-mute);
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.12s ease, color 0.12s ease;
  }
  :global(.ptr-copy-btn:hover) {
    background: var(--color-canvas-soft, rgba(0,0,0,0.05));
    color: var(--color-ink);
  }
  :global(.ptr-copy-btn.is-copied) {
    color: var(--color-brand-strong);
  }
  :global(.ptr-copy-btn svg) {
    pointer-events: none;
  }

  @keyframes ptr-rise {
    from {
      opacity: 0;
      transform: translateY(3px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.ptr-card) {
      animation: none;
    }
  }

  :global(.ptr-error) {
    display: flex;
    gap: 10px;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    background: var(--color-error-soft);
    box-shadow: inset 0 0 0 1px var(--color-error);
    color: var(--color-error-deep);
  }
  :global(.ptr-error__icon) {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
    margin-top: 1px;
  }
  :global(.ptr-error__title) {
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
  }
  :global(.ptr-error__detail) {
    margin-top: 2px;
    font-size: 13px;
    line-height: 18px;
    text-wrap: pretty;
  }
  :global(.ptr-empty) {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 64px;
    padding: 20px 16px;
    text-align: center;
    text-wrap: pretty;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
  }
</style>

<script>
  import { escapeHtml } from '../lib/escape-html';
  import { readIpHash } from '../lib/ip-hash';

  type Row = { label: string; value: string; mono?: boolean };
  type Result = { valid: boolean; error?: string; version?: 4 | 6; rows: Row[] };
  type Example = { id: string; label: string; input: string };
  type EngineModule = { generate: (input: string) => Result };

  const ROOT_SEL = '.ptr-pg';
  const DEBOUNCE_MS = 140;

  function boot(): void {
    document.querySelectorAll<HTMLElement>(ROOT_SEL).forEach((root) => {
      if (root.dataset.ptrWired === 'true') return;
      root.dataset.ptrWired = 'true';
      void init(root);
    });
  }

  function el<T extends HTMLElement>(root: HTMLElement, sel: string): T | null {
    return root.querySelector<T>(sel);
  }

  function normaliseExamples(raw: unknown): Example[] {
    if (!Array.isArray(raw)) return [];
    return raw
      .map((item, i) => {
        const o = (item ?? {}) as Record<string, unknown>;
        return {
          id: typeof o.id === 'string' && o.id ? o.id : `example-${i + 1}`,
          label: typeof o.label === 'string' && o.label ? o.label : `Example ${i + 1}`,
          input: typeof o.input === 'string' ? o.input : '',
        } satisfies Example;
      })
      .filter((e) => e.input.length > 0);
  }

  const ALERT_SVG =
    '<svg class="ptr-error__icon" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 2.5L18.5 17H1.5z"></path><path d="M10 8v4"></path><path d="M10 14.6v.01"></path></svg>';

  const COPY_SVG =
    '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="5" width="9" height="9" rx="1.5"></rect><path d="M3 11H2a1 1 0 01-1-1V2a1 1 0 011-1h8a1 1 0 011 1v1"></path></svg>';
  const CHECK_SVG =
    '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.5 8l4 4 7-7"></path></svg>';

  function attachCopyHandlers(container: HTMLElement): void {
    container.querySelectorAll<HTMLButtonElement>('.ptr-copy-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const text = btn.dataset.copyValue ?? '';
        navigator.clipboard.writeText(text).then(() => {
          btn.innerHTML = CHECK_SVG;
          btn.classList.add('is-copied');
          setTimeout(() => {
            btn.innerHTML = COPY_SVG;
            btn.classList.remove('is-copied');
          }, 1500);
        }).catch(() => {});
      });
    });
  }

  function renderEmpty(container: HTMLElement, summary: HTMLElement): void {
    summary.textContent = '';
    summary.classList.remove('text-error');
    summary.classList.add('text-mute');
    container.innerHTML =
      '<p class="ptr-empty body-sm text-mute">Type an IP address or IP/prefix or pick an example to see its PTR record name, reverse zone and a ready-to-run dig command here.</p>';
  }

  function renderError(container: HTMLElement, summary: HTMLElement, message: string): void {
    summary.textContent = 'Invalid';
    summary.classList.remove('text-mute');
    summary.classList.add('text-error');
    container.innerHTML =
      '<div class="ptr-error" role="alert">' +
      ALERT_SVG +
      '<div><p class="ptr-error__title">Could not read that address</p>' +
      `<p class="ptr-error__detail">${escapeHtml(message)}</p></div></div>`;
  }

  function renderResult(container: HTMLElement, summary: HTMLElement, result: Result): void {
    const version = result.version === 6 ? 'IPv6' : 'IPv4';
    summary.textContent = version;
    summary.classList.remove('text-error');
    summary.classList.add('text-mute');
    const rows = Array.isArray(result.rows) ? result.rows : [];
    const rowsHtml = rows
      .map((r) => {
        const v = typeof r.value === 'string' ? r.value : '';
        const cls = r.mono ? 'ptr-row__v is-mono' : 'ptr-row__v';
        const copyBtn = v
          ? `<button class="ptr-copy-btn" data-copy-value="${escapeHtml(v)}" title="Copy" aria-label="Copy ${escapeHtml(r.label ?? '')}">${COPY_SVG}</button>`
          : '<span></span>';
        return (
          '<div class="ptr-row">' +
          `<span class="ptr-row__k">${escapeHtml(r.label ?? '')}</span>` +
          `<span class="${cls}">${escapeHtml(v)}</span>` +
          copyBtn +
          '</div>'
        );
      })
      .join('');
    container.innerHTML =
      '<div class="ptr-card">' +
      `<div class="ptr-title"><span class="ptr-title__badge">${version}</span><span>reverse DNS</span></div>` +
      rowsHtml +
      '</div>';
    attachCopyHandlers(container);
  }

  async function init(root: HTMLElement): Promise<void> {
    const input = el<HTMLInputElement>(root, '#ptr-input');
    const exampleSel = el<HTMLSelectElement>(root, '#ptr-example');
    const resultsBox = el<HTMLElement>(root, '#ptr-results');
    const summaryEl = el<HTMLElement>(root, '#ptr-summary');
    if (!input || !exampleSel || !resultsBox || !summaryEl) return;

    let engine: EngineModule;
    let examples: Example[] = [];
    try {
      const [engineMod, examplesMod] = await Promise.all([
        import('../lib/ptr-helper/engine'),
        import('../lib/ptr-helper/examples'),
      ]);
      engine = engineMod as unknown as EngineModule;
      examples = normaliseExamples((examplesMod as { examples?: unknown }).examples);
    } catch (err) {
      renderError(resultsBox, summaryEl, 'The PTR helper engine failed to load. Reload the page to try again.');
      console.error('[PtrHelper] engine import failed:', err);
      return;
    }

    exampleSel.innerHTML = '';
    const customOpt = document.createElement('option');
    customOpt.value = '-1';
    customOpt.textContent = examples.length ? 'Custom input' : 'No examples';
    exampleSel.appendChild(customOpt);
    examples.forEach((ex, i) => {
      const opt = document.createElement('option');
      opt.value = String(i);
      opt.textContent = ex.label;
      exampleSel.appendChild(opt);
    });
    if (!examples.length) exampleSel.disabled = true;

    function evaluate(): void {
      const value = input!.value.trim();
      if (value.length === 0) {
        input!.classList.remove('ptr-input--error');
        renderEmpty(resultsBox!, summaryEl!);
        return;
      }
      let result: Result | null = null;
      try {
        result = engine.generate(value);
      } catch {
        input!.classList.add('ptr-input--error');
        renderError(resultsBox!, summaryEl!, 'Unexpected error while generating the PTR record.');
        return;
      }
      if (!result || result.valid === false) {
        input!.classList.add('ptr-input--error');
        renderError(resultsBox!, summaryEl!, result?.error ?? 'This is not a valid IP address or CIDR.');
        return;
      }
      input!.classList.remove('ptr-input--error');
      renderResult(resultsBox!, summaryEl!, result);
    }

    let timer: number | undefined;
    function scheduleEvaluate(): void {
      window.clearTimeout(timer);
      timer = window.setTimeout(evaluate, DEBOUNCE_MS);
    }

    const sampleCue = root.querySelector<HTMLElement>('.ptr-sample-cue');
    input.addEventListener('input', () => {
      if (exampleSel.value !== '-1') exampleSel.value = '-1';
      if (sampleCue) sampleCue.classList.add('is-hidden');
      scheduleEvaluate();
    });
    exampleSel.addEventListener('change', () => {
      const idx = Number(exampleSel.value);
      if (!Number.isInteger(idx) || idx < 0 || idx >= examples.length) return;
      input.value = examples[idx].input;
      window.clearTimeout(timer);
      evaluate();
    });

    // Deep link: #ip=<address> (written by the IP Address Converter) prefills
    // the input and replaces the default seeded example.
    const shared = readIpHash();
    const seed = examples[0];
    if (shared) {
      input.value = shared;
      exampleSel.value = '-1';
      if (sampleCue) sampleCue.classList.add('is-hidden');
      evaluate();
    } else if (seed) {
      input.value = seed.input;
      exampleSel.value = '0';
      evaluate();
    } else {
      renderEmpty(resultsBox, summaryEl);
    }
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
