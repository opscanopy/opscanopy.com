---
/**
 * FaqList — the shared FAQ section used across every tool page.
 *
 * Reproduces the established tool-page FAQ chrome verbatim: a centered
 * eyebrow + display-lg heading over a hairline-divided <dl> of question /
 * answer pairs. Extracted so the markup lives in one place; the rendered
 * output is byte-for-byte identical to the inlined version it replaces.
 */
export interface Props {
  id?: string;
  eyebrow?: string;
  heading?: string;
  faqs: { q: string; a: string }[];
}

const {
  id = 'faq',
  eyebrow = 'FAQ',
  heading = 'Questions, answered.',
  faqs,
} = Astro.props;
---

<section id={id} class="scroll-mt-24 border-t border-hairline bg-canvas">
  <div class="container-page py-16 sm:py-20">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow">{eyebrow}</p>
      <h2 class="display-lg mt-3 text-ink">{heading}</h2>
    </div>
    <dl class="mx-auto mt-10 max-w-3xl divide-y divide-hairline">
      {
        faqs.map((f) => (
          <div class="py-6 first:pt-0">
            <dt class="display-sm text-balance text-ink">{f.q}</dt>
            <dd class="body-md mt-3 text-pretty text-body">{f.a}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
