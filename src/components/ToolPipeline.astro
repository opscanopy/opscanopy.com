---
/**
 * ToolPipeline — the shared "how it works" numbered card grid.
 *
 * A centered header (optional eyebrow, heading, optional lead) over an ordered
 * list of steps. Each step is a card with a numbered circular marker, title and
 * body. The column count is derived from the number of steps as a full static
 * Tailwind literal (5 steps → 5 columns, otherwise 4) so the class survives the
 * compiler's static-extraction.
 */
interface Step {
  title: string;
  body: string;
}

interface Props {
  id?: string;
  eyebrow?: string;
  heading: string;
  lead?: string;
  steps: Step[];
}

const { id, eyebrow, heading, lead, steps } = Astro.props;

// Full literal classes — never interpolated — so Tailwind keeps them.
const cols = steps.length === 5 ? 'lg:grid-cols-5' : 'lg:grid-cols-4';
---

<section id={id} class="scroll-mt-24 bg-canvas py-16 sm:py-20">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h2 class="display-lg mt-3 text-balance text-ink">{heading}</h2>
      {lead && <p class="body-lg mt-5 text-pretty text-body">{lead}</p>}
    </div>
    <ol class={`mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 ${cols}`}>
      {
        steps.map((step, i) => (
          <li class="card flex h-full flex-col p-5">
            <span
              class="code-mono inline-flex h-7 min-w-7 items-center justify-center rounded-sm border border-hairline-muted bg-canvas-soft px-1.5 text-[13px] font-medium text-accent-ink"
              aria-hidden="true"
            >
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="display-sm mt-4 text-ink">{step.title}</h3>
            <p class="body-sm mt-2 text-body">{step.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
