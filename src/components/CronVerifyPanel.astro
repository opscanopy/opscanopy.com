---
/**
 * CronVerifyPanel — "Verify the AI" panel for the Cron Expression Tester.
 *
 * Rendered inside #playground directly below CronTesterPlayground, as a
 * collapsed <details id="verify-ai"> — it inherits the #playground
 * tool_engaged/result_copied analytics listener for free (Layout.astro scopes
 * both to any control inside #playground) and needs zero translation
 * (playground-internal UI is English everywhere, by contract).
 *
 * Reads the cron expression currently in the sibling playground's
 * #cron-input (no duplicate expression field) and checks it against up to 3
 * static claim ROWS — each row a { kind, when, claimedNext? } triple — via
 * ../lib/cron-tester/verify (lazy-imported in the boot closure). This tool's
 * claims aren't a fixed set of named fields, so the UI is a small repeatable
 * list of rows rather than the labeled-field grid the Subnet Calculator uses.
 * Never writes to the URL hash (V1 has no shareable verify state).
 */
---

<details id="verify-ai" class="cvp-panel mt-4 overflow-hidden rounded-lg border border-hairline bg-canvas">
  <summary
    class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-3 sm:px-5"
    style="touch-action: manipulation; min-height: 44px;"
  >
    <span class="flex items-center gap-2">
      <svg
        class="size-4 shrink-0 text-brand-strong"
        viewBox="0 0 20 20"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M4 10.5l3.5 3.5L16 5.5"></path>
      </svg>
      <span class="body-sm font-medium text-ink">Verify an AI's answer</span>
    </span>
    <svg
      class="cvp-chevron size-4 shrink-0 text-mute transition-transform duration-200"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </summary>

  <div class="border-t border-hairline px-4 py-4 sm:px-5">
    <p class="caption text-mute">
      Paste what ChatGPT or Claude told you — this recomputes it exactly, locally.
      <a href="/verify-ai/" class="link-inline">Why AI needs checking &rarr;</a>
    </p>

    <div class="mt-3">
      <button
        type="button"
        id="cvp-sample"
        class="btn btn-secondary btn-sm"
        style="touch-action: manipulation;"
      >
        Try a common AI mistake
      </button>
    </div>

    <div id="cvp-claims" class="mt-4 space-y-3">
      <fieldset class="cvp-row rounded-lg border border-hairline p-3" data-row>
        <legend class="caption px-1 text-mute">Claim 1</legend>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
          <label class="block">
            <span class="caption text-mute">Claim type</span>
            <select
              data-row-kind
              class="cvp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 text-sm text-ink"
            >
              <option value="">— unused —</option>
              <option value="fires-at">Fires at</option>
              <option value="does-not-fire-at">Does not fire at</option>
              <option value="next-run-after">Next run after</option>
            </select>
          </label>
          <label class="block">
            <span class="caption text-mute">Date &amp; time</span>
            <input
              type="datetime-local"
              data-row-when
              class="cvp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 font-mono text-sm text-ink"
            />
          </label>
          <label class="block" data-row-next-wrap hidden>
            <span class="caption text-mute">Claimed next run</span>
            <input
              type="datetime-local"
              data-row-next
              class="cvp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 font-mono text-sm text-ink"
            />
          </label>
        </div>
      </fieldset>

      <fieldset class="cvp-row rounded-lg border border-hairline p-3" data-row>
        <legend class="caption px-1 text-mute">Claim 2</legend>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
          <label class="block">
            <span class="caption text-mute">Claim type</span>
            <select
              data-row-kind
              class="cvp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 text-sm text-ink"
            >
              <option value="">— unused —</option>
              <option value="fires-at">Fires at</option>
              <option value="does-not-fire-at">Does not fire at</option>
              <option value="next-run-after">Next run after</option>
            </select>
          </label>
          <label class="block">
            <span class="caption text-mute">Date &amp; time</span>
            <input
              type="datetime-local"
              data-row-when
              class="cvp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 font-mono text-sm text-ink"
            />
          </label>
          <label class="block" data-row-next-wrap hidden>
            <span class="caption text-mute">Claimed next run</span>
            <input
              type="datetime-local"
              data-row-next
              class="cvp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 font-mono text-sm text-ink"
            />
          </label>
        </div>
      </fieldset>

      <fieldset class="cvp-row rounded-lg border border-hairline p-3" data-row>
        <legend class="caption px-1 text-mute">Claim 3</legend>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
          <label class="block">
            <span class="caption text-mute">Claim type</span>
            <select
              data-row-kind
              class="cvp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 text-sm text-ink"
            >
              <option value="">— unused —</option>
              <option value="fires-at">Fires at</option>
              <option value="does-not-fire-at">Does not fire at</option>
              <option value="next-run-after">Next run after</option>
            </select>
          </label>
          <label class="block">
            <span class="caption text-mute">Date &amp; time</span>
            <input
              type="datetime-local"
              data-row-when
              class="cvp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 font-mono text-sm text-ink"
            />
          </label>
          <label class="block" data-row-next-wrap hidden>
            <span class="caption text-mute">Claimed next run</span>
            <input
              type="datetime-local"
              data-row-next
              class="cvp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 font-mono text-sm text-ink"
            />
          </label>
        </div>
      </fieldset>
    </div>

    <p id="cvp-empty" class="caption mt-4 text-mute">
      Enter a cron expression above, then paste in what an AI told you to check it.
    </p>

    <div id="cvp-results" class="mt-4" hidden>
      <div class="cvp-table-wrap overflow-x-auto rounded-lg border border-hairline">
        <table class="cvp-table w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-hairline bg-canvas-soft text-left">
              <th class="px-3 py-2 caption text-mute">Claim</th>
              <th class="px-3 py-2 caption text-mute">Actual</th>
              <th class="px-3 py-2 caption text-mute text-center">Verdict</th>
            </tr>
          </thead>
          <tbody id="cvp-rows"></tbody>
        </table>
      </div>
      <p id="cvp-summary" role="status" class="caption mt-2 text-mute"></p>
    </div>
  </div>
</details>

<style>
  @reference "../styles/global.css";

  .cvp-panel[open] > summary .cvp-chevron {
    transform: rotate(180deg);
  }
  .cvp-input:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .cvp-row legend {
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .cvp-table th,
  .cvp-table td {
    vertical-align: top;
  }
  .cvp-table tbody tr + tr {
    border-top: 1px solid var(--color-hairline);
  }
  .cvp-table td {
    padding: 8px 12px;
  }
  :global(.cvp-pill) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 9999px;
  }
  :global(.cvp-pill--match) {
    background: var(--color-brand-soft);
    color: var(--color-brand-strong);
  }
  :global(.cvp-pill--mismatch) {
    background: var(--color-error-soft);
    color: var(--color-error-deep);
  }
  :global(.cvp-pill--unreadable) {
    background: var(--color-hairline);
    color: var(--color-mute);
  }
  :global(.cvp-note-row td) {
    padding-top: 0;
    font-size: 12px;
    line-height: 16px;
    color: var(--color-mute);
  }
</style>

<script>
  import { escapeHtml } from '../lib/escape-html';
  import { safeGtag } from '../lib/gtag';

  type CronClaimKind = 'fires-at' | 'does-not-fire-at' | 'next-run-after';
  interface CronClaimRow {
    kind: CronClaimKind;
    when: string;
    claimedNext?: string;
  }
  type ClaimVerdict = 'match' | 'mismatch' | 'unreadable';
  interface ClaimCheck {
    field: string;
    label: string;
    claimed: string;
    actual: string;
    verdict: ClaimVerdict;
    note?: string;
  }
  interface VerifyResult {
    valid: boolean;
    error?: string;
    summary: string;
    checks: ClaimCheck[];
    mismatchCount: number;
  }
  type EngineModule = {
    verifyClaims: (expr: string, rows: CronClaimRow[]) => VerifyResult;
  };

  const DEBOUNCE_MS = 180;
  const ANALYTICS_THROTTLE_MS = 2000;
  const TOOL = 'cron-expression-tester';

  const SAMPLE = {
    expr: '0 0 1 * 1',
    row: { kind: 'does-not-fire-at' as CronClaimKind, when: '2024-01-08T00:00' },
  };

  function boot(): void {
    document.querySelectorAll<HTMLDetailsElement>('#verify-ai.cvp-panel').forEach((root) => {
      if (root.dataset.cvpWired === 'true') return;
      root.dataset.cvpWired = 'true';
      init(root);
    });
  }

  function init(root: HTMLDetailsElement): void {
    const claimsWrap = root.querySelector<HTMLElement>('#cvp-claims');
    const emptyEl = root.querySelector<HTMLElement>('#cvp-empty');
    const resultsEl = root.querySelector<HTMLElement>('#cvp-results');
    const rowsEl = root.querySelector<HTMLElement>('#cvp-rows');
    const summaryEl = root.querySelector<HTMLElement>('#cvp-summary');
    const sampleBtn = root.querySelector<HTMLButtonElement>('#cvp-sample');
    const rowEls = claimsWrap ? Array.from(claimsWrap.querySelectorAll<HTMLElement>('[data-row]')) : [];
    if (!claimsWrap || !emptyEl || !resultsEl || !rowsEl || !summaryEl || !sampleBtn) return;

    let engine: EngineModule | null = null;
    let engineLoad: Promise<EngineModule> | null = null;
    function loadEngine(): Promise<EngineModule> {
      if (!engineLoad) {
        engineLoad = import('../lib/cron-tester/verify').then((mod) => {
          engine = mod as unknown as EngineModule;
          return engine;
        });
      }
      return engineLoad;
    }

    function mainInput(): HTMLInputElement | null {
      return document.querySelector<HTMLInputElement>('#cron-input');
    }

    function currentRows(): CronClaimRow[] {
      const rows: CronClaimRow[] = [];
      for (const rowEl of rowEls) {
        const kindSel = rowEl.querySelector<HTMLSelectElement>('[data-row-kind]');
        const whenInput = rowEl.querySelector<HTMLInputElement>('[data-row-when]');
        const nextInput = rowEl.querySelector<HTMLInputElement>('[data-row-next]');
        const kind = (kindSel?.value ?? '') as CronClaimKind | '';
        const when = whenInput?.value ?? '';
        if (!kind || !when) continue;
        if (kind === 'next-run-after') {
          const claimedNext = nextInput?.value ?? '';
          if (!claimedNext) continue;
          rows.push({ kind, when, claimedNext });
        } else {
          rows.push({ kind, when });
        }
      }
      return rows;
    }

    function verdictPill(verdict: ClaimVerdict): string {
      if (verdict === 'match') {
        return (
          '<span class="cvp-pill cvp-pill--match" role="img" aria-label="Match">' +
          '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8.5l3.5 3.5L13 4.5"/></svg></span>'
        );
      }
      if (verdict === 'mismatch') {
        return (
          '<span class="cvp-pill cvp-pill--mismatch" role="img" aria-label="Mismatch">' +
          '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4l8 8M12 4l-8 8"/></svg></span>'
        );
      }
      return (
        '<span class="cvp-pill cvp-pill--unreadable" role="img" aria-label="Unreadable">' +
        '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6.2c0-1.1.9-1.9 2-1.9s2 .8 2 1.7c0 1.2-1.3 1.4-1.7 2.3-.1.3-.2.5-.2.9"/><path d="M8 12v.01"/></svg></span>'
      );
    }

    function renderRows(checks: ClaimCheck[]): void {
      rowsEl!.innerHTML = checks
        .map((c) => {
          const noteRow = c.note
            ? `<tr class="cvp-note-row"><td colspan="3">${escapeHtml(c.note)}</td></tr>`
            : '';
          return (
            '<tr>' +
            `<td class="body-sm text-ink">${escapeHtml(c.label)}</td>` +
            `<td class="font-mono text-xs text-body">${escapeHtml(c.claimed)} <span class="text-mute">→</span> ` +
            `<span class="text-ink">${escapeHtml(c.actual)}</span></td>` +
            `<td class="text-center">${verdictPill(c.verdict)}</td>` +
            '</tr>' +
            noteRow
          );
        })
        .join('');
    }

    let lastAnalyticsAt = 0;
    function maybeFireAnalytics(checks: number, mismatches: number): void {
      const now = Date.now();
      if (now - lastAnalyticsAt < ANALYTICS_THROTTLE_MS) return;
      lastAnalyticsAt = now;
      safeGtag('event', 'verify_run', { tool: TOOL, claims: checks, mismatches });
    }

    async function runVerify(): Promise<void> {
      const expr = mainInput()?.value.trim() ?? '';
      const rows = currentRows();
      if (!expr) {
        emptyEl!.hidden = false;
        emptyEl!.textContent = 'Enter a cron expression above, then paste in what an AI told you to check it.';
        resultsEl!.hidden = true;
        return;
      }
      let mod: EngineModule;
      try {
        mod = engine ?? (await loadEngine());
      } catch {
        emptyEl!.hidden = false;
        emptyEl!.textContent = 'The verify engine failed to load. Reload the page to try again.';
        resultsEl!.hidden = true;
        return;
      }
      const result = mod.verifyClaims(expr, rows);
      if (!result.valid) {
        emptyEl!.hidden = false;
        emptyEl!.textContent = result.error || 'Enter a valid cron expression above to check claims against it.';
        resultsEl!.hidden = true;
        return;
      }
      if (result.checks.length === 0) {
        emptyEl!.hidden = false;
        emptyEl!.textContent = 'Fill in at least one claim row above to check it against this expression.';
        resultsEl!.hidden = true;
        return;
      }
      emptyEl!.hidden = true;
      resultsEl!.hidden = false;
      renderRows(result.checks);
      summaryEl!.textContent = result.summary;
      maybeFireAnalytics(result.checks.length, result.mismatchCount);
    }

    let timer: number | undefined;
    function scheduleVerify(): void {
      window.clearTimeout(timer);
      timer = window.setTimeout(() => void runVerify(), DEBOUNCE_MS);
    }

    for (const rowEl of rowEls) {
      const kindSel = rowEl.querySelector<HTMLSelectElement>('[data-row-kind]');
      const whenInput = rowEl.querySelector<HTMLInputElement>('[data-row-when]');
      const nextInput = rowEl.querySelector<HTMLInputElement>('[data-row-next]');
      const nextWrap = rowEl.querySelector<HTMLElement>('[data-row-next-wrap]');

      kindSel?.addEventListener('change', () => {
        if (nextWrap) nextWrap.hidden = kindSel.value !== 'next-run-after';
        scheduleVerify();
      });
      whenInput?.addEventListener('input', scheduleVerify);
      nextInput?.addEventListener('input', scheduleVerify);
    }

    // The cron expression itself lives in the sibling playground, not this
    // panel — react to it changing so the checks always run against what's
    // visible above.
    document.addEventListener('input', (e) => {
      if ((e.target as HTMLElement | null)?.id === 'cron-input') scheduleVerify();
    });

    sampleBtn.addEventListener('click', () => {
      const main = mainInput();
      if (main) {
        main.value = SAMPLE.expr;
        main.dispatchEvent(new Event('input', { bubbles: true }));
      }
      rowEls.forEach((rowEl, i) => {
        const kindSel = rowEl.querySelector<HTMLSelectElement>('[data-row-kind]');
        const whenInput = rowEl.querySelector<HTMLInputElement>('[data-row-when]');
        const nextInput = rowEl.querySelector<HTMLInputElement>('[data-row-next]');
        const nextWrap = rowEl.querySelector<HTMLElement>('[data-row-next-wrap]');
        if (i === 0) {
          if (kindSel) kindSel.value = SAMPLE.row.kind;
          if (whenInput) whenInput.value = SAMPLE.row.when;
        } else {
          if (kindSel) kindSel.value = '';
          if (whenInput) whenInput.value = '';
        }
        if (nextInput) nextInput.value = '';
        if (nextWrap) nextWrap.hidden = true;
      });
      root.open = true;
      scheduleVerify();
    });

    let openFired = false;
    root.addEventListener('toggle', () => {
      if (root.open && !openFired) {
        openFired = true;
        safeGtag('event', 'cta_click', { cta: 'verify_open' });
        scheduleVerify();
      }
    });

    if (location.hash === '#verify-ai') {
      root.open = true;
      root.scrollIntoView({ block: 'start' });
    }
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
