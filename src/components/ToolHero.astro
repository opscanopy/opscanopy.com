---
/**
 * ToolHero — the shared, established tool-page hero chrome.
 *
 * Extracts the byte-for-byte hero the tool pages inline: a mesh-gradient
 * backdrop (inset-0, opacity-80) framed by a soft top-sheen and bottom-fade
 * scrim, with a centered eyebrow / headline / lead / badge-row / CTA-row stack.
 *
 * Headline and lead are supplied via named slots so each page keeps its own
 * inline <span translate="no"> markup, curly quotes, and emphasis exactly as
 * before. Badges and CTAs are data-driven props.
 */
import MeshGradient from './MeshGradient.astro';
import Button from './Button.astro';
import Badge from './Badge.astro';

export interface Props {
  eyebrow: string;
  badges?: { label: string; variant?: string }[];
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const { eyebrow, badges = [], primaryCta, secondaryCta } = Astro.props;
---

<section class="relative isolate overflow-hidden bg-canvas-soft">
  <MeshGradient class="pointer-events-none absolute inset-0 -z-10 h-full opacity-80" />
  <!-- Soft top sheen + bottom fade frame the mesh so it reads as ambient light
       behind the hero, keeping crisp ink contrast under the headline. -->
  <div
    class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-24 bg-gradient-to-b from-canvas-soft to-transparent"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-48 bg-gradient-to-b from-transparent to-canvas-soft"
    aria-hidden="true"
  >
  </div>
  <div class="container-page relative z-10 py-12 sm:py-14 lg:py-16">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">{eyebrow}</p>
      <h1 class="display-xl mt-4 text-balance text-ink">
        <slot name="headline" />
      </h1>
      <p class="body-lg mx-auto mt-6 max-w-2xl text-pretty text-body">
        <slot name="lead" />
      </p>
      <div class="mt-7 flex flex-wrap justify-center gap-2">
        {badges.map((b) => <Badge variant={b.variant ?? 'neutral'}>{b.label}</Badge>)}
      </div>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href={primaryCta.href}>{primaryCta.label}</Button>
        {
          secondaryCta && (
            <Button href={secondaryCta.href} variant="secondary">
              {secondaryCta.label}
            </Button>
          )
        }
      </div>
    </div>
  </div>
</section>
