---
/**
 * ToolHero — the compact tool-page masthead.
 *
 * Tool pages are tool-first: the interactive playground sits directly beneath
 * this masthead, so the masthead is intentionally tight (small padding, no CTA
 * row) to keep the tool itself at the top of the viewport with minimal scroll.
 *
 * Renders a mesh-gradient backdrop framed by soft scrims, with a centered
 * eyebrow / headline / lead / badge-row stack. Headline and lead come via named
 * slots so each page keeps its own inline markup; badges are data-driven.
 *
 * `primaryCta` / `secondaryCta` are accepted for backwards-compatibility with
 * existing page calls but are no longer rendered (the tool is the call to action).
 */
import MeshGradient from './MeshGradient.astro';
import Badge from './Badge.astro';
import { getTool } from '../data/tools';
import { site } from '../data/site';
import { breadcrumbLd } from '../lib/jsonld';

export interface Props {
  eyebrow: string;
  badges?: { label: string; variant?: string }[];
  /**
   * Optional tool slug. When provided, the masthead renders a full
   * Home / Tools / {category} / {name} breadcrumb trail (with matching
   * BreadcrumbList JSON-LD) instead of the bare "All tools" back-link.
   */
  slug?: string;
  /** @deprecated no longer rendered — kept so existing page calls don't break. */
  primaryCta?: { label: string; href: string };
  /** @deprecated no longer rendered. */
  secondaryCta?: { label: string; href: string };
}

const { eyebrow, badges = [], slug } = Astro.props;

// When a slug resolves to a registered tool, build the breadcrumb trail + LD.
// Category is plain text (no category pages yet) so it is omitted from the LD.
const tool = slug ? getTool(slug) : undefined;
const breadcrumbJson = tool
  ? JSON.stringify(
      breadcrumbLd([
        { name: 'Home', item: `${site.url}/` },
        { name: 'Tools', item: `${site.url}/tools` },
        { name: tool.name, item: `${site.url}/${slug}` },
      ]),
    )
  : null;
---

<section class="relative isolate overflow-hidden bg-canvas-soft">
  <MeshGradient class="pointer-events-none absolute inset-0 -z-10 h-full opacity-70" />
  <!-- Soft top sheen + bottom fade frame the mesh so it reads as ambient light
       behind the masthead, keeping crisp ink contrast under the headline. -->
  <div
    class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-16 bg-gradient-to-b from-canvas-soft to-transparent"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-28 bg-gradient-to-b from-transparent to-canvas-soft"
    aria-hidden="true"
  >
  </div>
  <div class="container-page relative z-10 py-8 sm:py-10">
    <div class="mx-auto max-w-3xl text-center">
      {
        tool ? (
          <nav aria-label="Breadcrumb" class="mb-4 flex justify-center text-sm text-mute">
            <ol class="flex flex-wrap items-center justify-center gap-1.5">
              <li>
                <a href="/" class="hover:text-brand transition-colors">
                  Home
                </a>
              </li>
              <li aria-hidden="true" class="text-hairline">
                /
              </li>
              <li>
                <a href="/tools" class="hover:text-brand transition-colors">
                  Tools
                </a>
              </li>
              <li aria-hidden="true" class="text-hairline">
                /
              </li>
              <li>{tool.category}</li>
              <li aria-hidden="true" class="text-hairline">
                /
              </li>
              <li aria-current="page" class="text-body">
                {tool.name}
              </li>
            </ol>
          </nav>
        ) : (
          <a
            href="/tools"
            class="inline-flex items-center gap-1 text-sm text-mute hover:text-brand mb-4 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m15 18-6-6 6-6" />
            </svg>
            All tools
          </a>
        )
      }
      <p class="eyebrow">{eyebrow}</p>
      <h1 class="display-lg mt-3 text-balance text-ink">
        <slot name="headline" />
      </h1>
      <p class="body-md mx-auto mt-3 max-w-2xl text-pretty text-body">
        <slot name="lead" />
      </p>
      {
        badges.length > 0 && (
          <div class="mt-5 flex flex-wrap justify-center gap-2">
            {badges.map((b) => (
              <Badge variant={b.variant ?? 'neutral'}>{b.label}</Badge>
            ))}
          </div>
        )
      }
    </div>
  </div>
  {
    breadcrumbJson && (
      <script type="application/ld+json" set:html={breadcrumbJson} />
    )
  }
</section>
