---
/**
 * ToolsCatalog — the shared "Live tools" body for /tools and its 4 localized
 * mirrors (de/es/fr/pt-br). Single source of truth for the eyebrow/heading,
 * browse-by-category nav, search+chips+sort+empty-state, ToolCard grid, and
 * their script/style — previously hand-copied into all 5 pages, which had
 * already drifted (missing the Docker chip, an invisible active-chip state)
 * before this component existed.
 *
 * The <script> below is a REAL module (no define:vars), so Astro bundles it
 * into one hashed, cacheable chunk shared by every page that renders this
 * component — not 5 copies inlined into 5 HTML documents. Locale strings the
 * script needs (the empty-state template + its "your search" fallback) are
 * read from data-* attributes on #tool-empty at init, so the script itself
 * stays 100% locale-agnostic.
 *
 * Self-detects the locale via Astro.currentLocale (same pattern as ToolCard),
 * so callers pass no props. Tool name/tagline/description/keywords stay
 * English everywhere — only this catalog's own chrome is translated.
 */
import ToolCard from './ToolCard.astro';
import { liveTools, categories, categoryAccent } from '../data/tools';
import { DEFAULT_LOCALE, type Locale } from '../i18n/config';
import { useTranslations, localizeKey } from '../i18n/utils';
import type { UiKey } from '../i18n/ui/en';

const lang: Locale = (Astro.currentLocale as Locale) ?? DEFAULT_LOCALE;
const t = useTranslations(lang);
const catLabel = (cat: string) => t(`category.${cat}` as UiKey);
---

<div class="flex items-end justify-between gap-6">
  <div class="min-w-0">
    <p class="eyebrow">{t('tools.availableNow')}</p>
    <h2 id="live-heading" class="display-lg mt-3 text-balance text-ink">{t('tools.liveToolsHeading')}</h2>
  </div>
</div>

{/* Pinned/recent shelf — every live tool gets a hidden tile so the client
    script needs no metadata of its own; it only reveals + reorders. Stays
    hidden entirely when there are no saved prefs (zero CLS) or storage is
    blocked. */}
<div id="tools-shelf" class="mt-6" hidden>
  <p class="eyebrow">{t('tools.jumpBackIn')}</p>
  <p class="caption mt-1 text-mute">{t('tools.jumpBackInCaption')}</p>
  <ul id="tools-shelf-list" role="list" class="mt-3 flex flex-wrap gap-2">
    {
      liveTools.map((tool) => (
        <li data-shelf-slug={tool.slug} hidden>
          <a
            href={localizeKey(`/${tool.slug}`, lang)}
            class="badge inline-flex items-center gap-1.5 hover:bg-brand/10"
          >
            <span class="shelf-pin-dot hidden size-1.5 rounded-full bg-brand-strong" aria-hidden="true" />
            {tool.name}
          </a>
        </li>
      ))
    }
  </ul>
</div>

{
  liveTools.length > 0 && (
    <nav aria-label={t('tools.browseByCategory')} class="cat-browse-nav mt-5">
      <span class="cat-browse-label text-xs font-semibold uppercase tracking-wide text-mute">{t('tools.browseByCategory')}</span>
      <div class="cat-browse-scroll">
        <div class="cat-browse-inner">
          {categories.map((c) => (
            <a
              href={`/tools/${c.slug}/`}
              class="badge cursor-pointer select-none text-body transition-colors hover:bg-brand/10"
            >
              <span
                class="size-1.5 shrink-0 rounded-full"
                style={`background-color: ${categoryAccent[c.category]}`}
                aria-hidden="true"
              />
              {catLabel(c.category)}
              <span class="tabular-nums text-mute">{c.count}</span>
            </a>
          ))}
        </div>
      </div>
    </nav>
  )
}

{
  liveTools.length === 0 ? (
    <div class="card-soft mt-10 flex flex-col items-center rounded-lg px-6 py-16 text-center">
      <p class="display-sm text-ink">{t('tools.zeroLiveTitle')}</p>
      <p class="body-md mt-3 max-w-md text-pretty text-body">{t('tools.zeroLiveBody')}</p>
    </div>
  ) : (
    <>
      <div class="mb-8 space-y-4">
        <input
          id="tool-search"
          type="search"
          placeholder={t('tools.searchPlaceholder')}
          autocomplete="off"
          class="input-focus w-full rounded-lg border border-hairline bg-canvas px-4 py-3 sm:py-2.5 text-sm text-ink placeholder:text-mute"
          aria-label={t('tools.searchLabel')}
        />
        <div class="cat-filter-row flex items-center gap-x-4">
          <div class="cat-chips-scroll min-w-0 flex-1">
            <div id="cat-filters" role="group" aria-label={t('tools.filterLabel')} class="flex flex-wrap gap-2">
              <button data-cat="all" class="cat-chip is-active badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="true">{t('category.all')}</button>
              <button data-cat="networking" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">{t('category.Networking')}</button>
              <button data-cat="security" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">{t('category.Security')}</button>
              <button data-cat="encoding" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">{t('category.Encoding')}</button>
              <button data-cat="kubernetes" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">{t('category.Kubernetes')}</button>
              <button data-cat="observability" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">{t('category.Observability')}</button>
              <button data-cat="ci/cd" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">{t('category.CI/CD')}</button>
              <button data-cat="scheduling" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">{t('category.Scheduling')}</button>
              <button data-cat="logs" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">{t('category.Logs')}</button>
              <button data-cat="config" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">{t('category.Config')}</button>
              <button data-cat="docker" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">{t('category.Docker')}</button>
              <button data-cat="utilities" class="cat-chip badge cursor-pointer select-none hover:bg-brand/10" aria-pressed="false">{t('category.Utilities')}</button>
            </div>
          </div>
          <div class="flex shrink-0 items-center gap-2">
            <label for="tool-sort" class="text-xs font-semibold uppercase tracking-wide text-mute">{t('tools.sortLabel')}</label>
            <select
              id="tool-sort"
              class="input-focus cursor-pointer rounded-lg border border-hairline bg-canvas py-1.5 pl-3 pr-8 text-sm font-medium text-ink"
              aria-label={t('tools.sortAriaLabel')}
            >
              <option value="default">{t('tools.sortDefault')}</option>
              <option value="az">{t('tools.sortAZ')}</option>
              <option value="newest">{t('tools.sortNewest')}</option>
            </select>
          </div>
        </div>
        <div
          id="tool-empty"
          class="hidden py-6"
          role="status"
          aria-live="polite"
          data-empty-tpl={t('tools.emptyTitle')}
          data-empty-fallback={t('tools.emptyQueryFallback')}
        >
          <p class="body-md text-ink"><span id="tool-empty-msg"></span></p>
          <p class="body-sm mt-1 text-body">{t('tools.emptyHint')}</p>
          <div class="mt-4 flex flex-wrap items-center gap-2">
            <button type="button" data-example="subnet" class="example-chip badge cursor-pointer select-none hover:bg-brand/10">subnet</button>
            <button type="button" data-example="jwt" class="example-chip badge cursor-pointer select-none hover:bg-brand/10">jwt</button>
            <button type="button" data-example="cron" class="example-chip badge cursor-pointer select-none hover:bg-brand/10">cron</button>
            <button type="button" data-example="regex" class="example-chip badge cursor-pointer select-none hover:bg-brand/10">regex</button>
          </div>
          <button id="tool-clear" type="button" class="link-inline body-sm mt-4 inline-flex items-center gap-1 font-medium">{t('tools.clearFilters')}</button>
        </div>
      </div>
      <ul id="tool-grid" role="list" class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
        {liveTools.map((tool, i) => (
          <ToolCard tool={tool} order={i} />
        ))}
      </ul>
    </>
  )
}

<script>
  import { TOOL_PREFS_KEY, parseToolPrefs, unpinnedRecentSlugs } from '../lib/tool-prefs/prefs';

  (function initShelf() {
    var shelf = document.getElementById('tools-shelf');
    var list = document.getElementById('tools-shelf-list');
    if (!shelf || !list) return;
    var prefs;
    try {
      prefs = parseToolPrefs(localStorage.getItem(TOOL_PREFS_KEY));
    } catch (e) {
      prefs = parseToolPrefs(null);
    }
    var order = prefs.pins.concat(unpinnedRecentSlugs(prefs));
    if (order.length === 0) return; // stays hidden — zero CLS
    // A Map, not a plain object: a tampered oc-tools-v1 blob (devtools, a
    // shared computer) could otherwise contain a slug like "constructor"
    // that collides with Object.prototype and throws when treated as an
    // element, taking the whole catalog script (search/sort/filter) down
    // with it.
    var bySlug = new Map();
    list.querySelectorAll('[data-shelf-slug]').forEach(function (li) {
      bySlug.set(li.dataset.shelfSlug, li);
    });
    var shown = false;
    order.forEach(function (slug) {
      var li = bySlug.get(slug);
      if (!li) return; // renamed/removed tool — silently skip
      li.hidden = false;
      shown = true;
      if (prefs.pins.indexOf(slug) !== -1) {
        var dot = li.querySelector('.shelf-pin-dot');
        if (dot) dot.classList.remove('hidden');
      }
      list.appendChild(li); // moves the existing node, building the order
    });
    if (shown) shelf.hidden = false;
  })();

  (function () {
    var search = document.getElementById('tool-search');
    var empty = document.getElementById('tool-empty');
    var emptyMsg = document.getElementById('tool-empty-msg');
    var sortSelect = document.getElementById('tool-sort');
    var grid = document.getElementById('tool-grid');
    var SORT_KEY = 'opscanopy:tools:sort';
    var activeCat = 'all';
    var activeSort = 'default';

    // Locale strings, read from the DOM (not define:vars) so this script is
    // identical — and therefore one cacheable chunk — across every locale.
    var emptyTitleTpl = (empty && empty.dataset.emptyTpl) || 'No tools match {query}.';
    var emptyFallback = (empty && empty.dataset.emptyFallback) || 'your search';

    // ── Sort ────────────────────────────────────────────────────────────
    // "Default" is ascending registry order (data-order). "Newest" prefers
    // the git-derived data-added date (real recency, from scripts/gen-tool-
    // meta.mjs) when BOTH cards being compared have one, falling back to the
    // registry-order proxy otherwise (e.g. before a build has generated
    // dates, or for a tool with no resolvable commit history). "A–Z" sorts
    // by tool name. The chosen mode persists in localStorage.
    function applySort() {
      if (!grid) return;
      var cards = Array.prototype.slice.call(grid.querySelectorAll('.tool-card'));
      cards.sort(function (a, b) {
        if (activeSort === 'az') {
          return (a.dataset.name || '').localeCompare(b.dataset.name || '');
        }
        var oa = parseInt(a.dataset.order || '0', 10);
        var ob = parseInt(b.dataset.order || '0', 10);
        if (activeSort === 'newest') {
          var da = a.dataset.added, db = b.dataset.added;
          if (da && db) {
            var diff = new Date(db).getTime() - new Date(da).getTime();
            if (diff !== 0) return diff;
          }
          return ob - oa;
        }
        return oa - ob;
      });
      // Re-append in the new order; appendChild moves existing nodes (no clone),
      // so visibility (display) and event wiring are preserved.
      cards.forEach(function (card) { grid.appendChild(card); });
    }
    function setSort(mode) {
      activeSort = mode === 'az' || mode === 'newest' ? mode : 'default';
      if (sortSelect) sortSelect.value = activeSort;
      try { localStorage.setItem(SORT_KEY, activeSort); } catch (e) {}
      applySort();
    }

    // Reflect the active category onto the chips (extracted so the Clear-filters
    // action can reuse the exact same activation logic).
    function setActiveCat(cat) {
      activeCat = cat || 'all';
      document.querySelectorAll('.cat-chip').forEach(function (b) {
        var on = (b.dataset.cat || 'all') === activeCat;
        b.setAttribute('aria-pressed', on ? 'true' : 'false');
        b.classList.toggle('is-active', on);
      });
    }
    function filter() {
      var raw = search ? search.value.trim() : '';
      var q = raw.toLowerCase();
      var cards = document.querySelectorAll('.tool-card');
      var visible = 0;
      cards.forEach(function (card) {
        var name = card.dataset.name || '';
        var cat = card.dataset.category || '';
        var tagline = card.dataset.tagline || '';
        var desc = card.dataset.desc || '';
        var keywords = card.dataset.keywords || '';
        var matchSearch =
          !q ||
          name.indexOf(q) !== -1 ||
          tagline.indexOf(q) !== -1 ||
          desc.indexOf(q) !== -1 ||
          keywords.indexOf(q) !== -1;
        var matchCat = activeCat === 'all' || cat === activeCat;
        var show = matchSearch && matchCat;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      // Echo the query (or the localized "your search" fallback when filtering
      // by category only). Replacement via a function, not a bare string, so
      // a literal "$&"/"$'" typed into the search box is never expanded by
      // String.replace's special replacement-pattern syntax.
      if (emptyMsg) {
        var label = raw ? '"' + raw + '"' : emptyFallback;
        emptyMsg.textContent = emptyTitleTpl.replace('{query}', function () {
          return label;
        });
      }
      if (empty) empty.classList.toggle('hidden', visible > 0);
    }
    if (search) search.addEventListener('input', filter);
    document.querySelectorAll('.cat-chip').forEach(function (btn) {
      btn.addEventListener('click', function () {
        setActiveCat(btn.dataset.cat);
        filter();
      });
    });
    if (sortSelect) {
      sortSelect.addEventListener('change', function () { setSort(sortSelect.value); });
    }
    // Empty-state escape hatches.
    var clearBtn = document.getElementById('tool-clear');
    if (clearBtn) {
      clearBtn.addEventListener('click', function () {
        if (search) search.value = '';
        setActiveCat('all');
        filter();
        if (search) search.focus();
      });
    }
    document.querySelectorAll('.example-chip').forEach(function (chip) {
      chip.addEventListener('click', function () {
        if (search) search.value = chip.dataset.example || '';
        setActiveCat('all');
        filter();
        if (search) search.focus();
      });
    });

    // Restore the persisted sort on load (defaults to curated order), then sort.
    var saved = 'default';
    try { saved = localStorage.getItem(SORT_KEY) || 'default'; } catch (e) {}
    setSort(saved);
  })();
</script>

<style>
  /* Browse-by-category pill row — wraps freely on wide screens; collapses to a
     single-row horizontal-scroll strip below 640px (mirrors the filter-chip row).
     The label sits above the scroll strip on mobile so it doesn't steal space. */
  .cat-browse-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
  }
  .cat-browse-scroll {
    display: contents; /* transparent wrapper on desktop — no layout impact */
  }
  .cat-browse-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
  }
  @media (max-width: 639px) {
    .cat-browse-nav {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    .cat-browse-scroll {
      display: block; /* restore box layout so overflow-x works */
      width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none; /* Firefox */
    }
    .cat-browse-scroll::-webkit-scrollbar {
      display: none; /* Chrome/Safari/Edge */
    }
    .cat-browse-inner {
      flex-wrap: nowrap;
      min-height: 44px;
      align-items: center;
      padding-bottom: 2px;
      padding-right: 2px;
    }
    .cat-browse-inner .badge {
      flex-shrink: 0;
      min-height: 44px;
      display: inline-flex;
      align-items: center;
      white-space: nowrap;
    }
  }

  /* Active filter chip — leaf brand-strong (#33652c) for AA-safe white-on-fill.
     Driven by the .is-active class (JS-toggled) so the selected state is always
     visible regardless of Tailwind's aria-pressed variant emission. */
  .cat-chip {
    transition: background-color 120ms ease, color 120ms ease;
  }
  .cat-chip.is-active {
    background-color: var(--color-brand-strong);
    color: #fff;
  }
  .cat-chip.is-active:hover {
    background-color: var(--color-brand-strong);
  }

  /* Focus ring on active chip: emerald-on-emerald is invisible, so we use a
     white outline with offset so it shows on the dark fill. */
  .cat-chip.is-active:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  /* Dark theme: the active fill is light leaf (--color-brand-strong: #8fc97a),
     so a white ring drops below the 3:1 focus-indicator minimum.
     Re-point the outline to a dark leaf so it stays visible on the fill. */
  html[data-theme='dark'] .cat-chip.is-active:focus-visible {
    outline-color: #163315;
  }

  /* Mobile filter strip: below 640px collapse the chip row into a single-row
     horizontal scroll strip. The scroll container (cat-chips-scroll) clips and
     scrolls; the inner flex row switches to nowrap so chips stay in one line.
     -webkit-overflow-scrolling:touch ensures momentum scroll on iOS. Scrollbar
     is hidden across all engines without hiding the content. 44px min-height
     preserves coarse-pointer tap targets. */
  @media (max-width: 639px) {
    .cat-chips-scroll {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none; /* Firefox */
    }
    .cat-chips-scroll::-webkit-scrollbar {
      display: none; /* Chrome/Safari/Edge */
    }
    /* Switch inner flex row to nowrap so all chips stay on one line */
    .cat-chips-scroll #cat-filters {
      flex-wrap: nowrap;
      min-height: 44px;
      align-items: center;
      padding-bottom: 2px; /* prevent focus rings being clipped at the bottom */
      padding-right: 2px; /* and the last chip's focus ring at the right edge */
    }
    /* Ensure each chip meets the 44px coarse-pointer tap target */
    .cat-chips-scroll .cat-chip {
      flex-shrink: 0;
      min-height: 44px;
      display: inline-flex;
      align-items: center;
    }
  }
</style>
