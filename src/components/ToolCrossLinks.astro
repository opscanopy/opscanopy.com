---
/**
 * ToolCrossLinks — the shared cross-link footer that closes every tool page.
 *
 * A centered block: heading, an intro sentence (`lead` slot), the canonical
 * "Browse All Tools" / "Back to OpsCanopy" CTA pair, a cross-link sentence
 * (`links` slot, holding inline <a class="link-inline"> references) and an
 * optional trademark/affiliation disclaimer (`disclaimer` slot) that only
 * renders when the slot is provided.
 */
import Button from './Button.astro';

interface Props {
  heading?: string;
}

const { heading = 'More free, private DevOps tools.' } = Astro.props;
---

<section class="border-t border-hairline bg-canvas-soft py-16 sm:py-20">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center flex flex-col items-center gap-5">
      <h2 class="display-md text-ink">{heading}</h2>
      <p class="body-lg text-pretty text-body"><slot name="lead" /></p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <Button href="/tools">Browse All Tools</Button>
        <Button href="/" variant="secondary">Back to OpsCanopy</Button>
      </div>
      <p class="body-sm text-body"><slot name="links" /></p>
      {
        Astro.slots.has('disclaimer') && (
          <p class="caption mt-2 max-w-3xl text-pretty text-mute">
            <slot name="disclaimer" />
          </p>
        )
      }
    </div>
  </div>
</section>
