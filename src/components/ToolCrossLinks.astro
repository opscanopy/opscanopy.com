---
/**
 * ToolCrossLinks — the shared cross-link footer that closes every tool page.
 *
 * A centered block: heading, an intro sentence (`lead` slot), the canonical
 * "Browse All Tools" / "Back to OpsCanopy" CTA pair, a cross-link sentence
 * (`links` slot, holding inline <a class="link-inline"> references) and an
 * optional trademark/affiliation disclaimer (`disclaimer` slot) that only
 * renders when the slot is provided.
 *
 * When the current tool's category maps to a learning track (Networking,
 * Kubernetes, Docker) a small "New to X? Read the Y guide →" line surfaces
 * above the CTA pair to link readers into /learn.
 */
import Button from './Button.astro';
import { liveTools, categoryAccent, getTool } from '../data/tools';
import { getTrack } from '../data/learn';

interface Props {
  heading?: string;
  /**
   * Optional current-tool slug. When provided, a "More in {category}" strip of
   * 2–3 sibling LIVE tools (same category, excluding the current slug) renders
   * above the CTA pair. With fewer than 2 siblings the strip is omitted.
   */
  slug?: string;
}

const { heading = 'More free, private DevOps tools.', slug } = Astro.props;

// Resolve sibling LIVE tools sharing the current tool's category.
const current = slug ? getTool(slug) : undefined;
const siblings = current
  ? liveTools
      .filter((t) => t.category === current.category && t.slug !== current.slug)
      .slice(0, 3)
  : [];
const showSiblings = siblings.length >= 2;
const categoryDot = current ? categoryAccent[current.category] : undefined;

// Map tool categories to learn track slugs.
const CATEGORY_TO_TRACK: Record<string, string> = {
  Networking: 'networking',
  Kubernetes: 'kubernetes',
  Docker: 'docker',
};

// Resolve a matching learn guide for the current tool's category, if any.
const learnTrackSlug = current ? CATEGORY_TO_TRACK[current.category] : undefined;
const learnTrack = learnTrackSlug ? getTrack(learnTrackSlug) : undefined;
// Use the first guide slug in the track as the primary entry-point guide.
const learnGuideSlug = learnTrack?.guideSlugs[0];
---

<section class="border-t border-hairline bg-canvas-soft py-16 sm:py-20">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center flex flex-col items-center gap-5">
      <h2 class="display-md text-ink">{heading}</h2>
      <p class="body-lg text-pretty text-body"><slot name="lead" /></p>
      {
        showSiblings && (
          <div class="w-full">
            <p class="eyebrow mb-3">More in {current!.category}</p>
            <ul class="grid gap-3 text-left sm:grid-cols-2 lg:grid-cols-3">
              {siblings.map((t) => (
                <li>
                  <a
                    href={`/${t.slug}`}
                    class="card-soft flex h-full flex-col gap-1 p-4 transition-colors hover:border-brand"
                  >
                    <span class="flex items-center gap-2">
                      <span
                        class="inline-block size-2 shrink-0 rounded-full"
                        style={`background-color: ${categoryDot}`}
                        aria-hidden="true"
                      />
                      <span class="body-sm font-medium text-ink">{t.name}</span>
                    </span>
                    <span class="caption text-pretty text-mute">{t.tagline}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
      {
        learnTrack && learnGuideSlug && (
          <p class="body-sm text-body">
            New to {learnTrack.name}?&nbsp;
            <a href={`/learn/guides/${learnGuideSlug}/`} class="link-inline font-medium">
              Read the {learnTrack.name} guide &rarr;
            </a>
          </p>
        )
      }
      <div class="flex flex-wrap items-center justify-center gap-3">
        <Button href="/tools/">Browse All Tools</Button>
        <Button href="/" variant="secondary">Back to OpsCanopy</Button>
      </div>
      <p class="body-sm text-body"><slot name="links" /></p>
      {
        Astro.slots.has('disclaimer') && (
          <p class="caption mt-2 max-w-3xl text-pretty text-mute">
            <slot name="disclaimer" />
          </p>
        )
      }
    </div>
  </div>
</section>
