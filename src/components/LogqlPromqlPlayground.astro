---
/**
 * LogqlPromqlPlayground — the interactive LogQL ↔ PromQL Helper island.
 *
 * A no-framework, server-rendered shell hydrated by a single module <script>
 * that lazily boots a CodeMirror 6 input editor and a read-only output editor,
 * wires a direction toggle (LogQL → PromQL / PromQL → LogQL), an example
 * picker, a "Convert" action, a "Copy output" action, a shareable-URL encoder
 * ("Copy link") and a "Copy as Markdown" action. It runs entirely client-side
 * — no upload, no network.
 *
 * Runtime contract (built by sibling agents — imported lazily in the script):
 *   ../lib/logql-promql/types →
 *     type Direction = "logql-to-promql" | "promql-to-logql"
 *     interface ConvertResult { output: string; notes: string[]; error?: string }
 *     interface ShareState { direction: Direction; query: string }
 *   ../lib/logql-promql/engine →
 *     convert(direction: Direction, query: string): ConvertResult
 *     encodeState(direction: Direction, query: string): string  // hash fragment
 *     decodeState(): ShareState | null
 *   ../lib/logql-promql/examples →
 *     examples: { id: string; label: string; direction: Direction; query: string }[]
 *
 * The dark editor surface follows DESIGN.md `code-editor-mockup`; notes use the
 * neutral / semantic tokens, errors the error tokens. Headlines stay
 * sentence-case, weight 600.
 */
---

<section class="lp-pg" aria-label="LogQL to PromQL helper playground">
  <div class="card shadow-float rounded-lg overflow-hidden">
    {/* ── Toolbar ──────────────────────────────────────────────────────── */}
    <div
      class="flex flex-col gap-3 border-b border-hairline px-4 py-3 lg:flex-row lg:items-end lg:justify-between lg:px-5"
    >
      <div class="flex flex-wrap items-end gap-3">
        <div class="flex min-w-0 flex-col gap-1.5">
          <span class="eyebrow" id="lp-dir-label">Direction</span>
          {/* Segmented direction toggle; options injected by the script. */}
          <div
            id="lp-direction"
            class="lp-seg"
            role="tablist"
            aria-labelledby="lp-dir-label"
          >
            <span class="lp-seg-loading code-mono text-mute">Loading…</span>
          </div>
        </div>

        <div class="flex min-w-0 flex-col gap-1.5">
          <label class="eyebrow" for="lp-example">Example</label>
          <div class="lp-select-wrap relative min-w-0">
            <select id="lp-example" class="lp-select code-mono" autocomplete="off">
              {/* Options injected by the hydration script from `examples`. */}
              <option value="">Loading…</option>
            </select>
            <svg
              class="lp-select-caret pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-mute"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M4 6l4 4 4-4"></path>
            </svg>
          </div>
        </div>
      </div>

      <div class="flex shrink-0 flex-wrap items-center gap-2">
        <span class="caption text-mute hidden items-center sm:inline-flex">⌘/Ctrl + Enter</span>
        <button
          id="lp-copy"
          type="button"
          class="btn btn-secondary btn-sm lp-tap"
          data-default-label="Copy Output"
          disabled
        >
          <svg
            class="h-4 w-4 shrink-0"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="5.5" y="5.5" width="8" height="8" rx="1.5"></rect>
            <path d="M3.5 10.5h-.5a1 1 0 01-1-1v-6a1 1 0 011-1h6a1 1 0 011 1v.5"></path>
          </svg>
          <span class="lp-copy-label">Copy Output</span>
        </button>
        <button
          id="lp-convert"
          type="button"
          class="btn btn-primary btn-sm lp-tap"
          title="Convert (⌘/Ctrl + Enter)"
          aria-keyshortcuts="Meta+Enter Control+Enter"
        >
          <svg
            class="lp-convert-icon h-4 w-4 shrink-0"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M3 5.5h8.5M9 3l2.5 2.5L9 8"></path>
            <path d="M13 10.5H4.5M7 8l-2.5 2.5L7 13"></path>
          </svg>
          <span class="lp-convert-label">Convert</span>
        </button>
      </div>
    </div>

    {/* ── Mobile tab switch (single-pane on small screens) ─────────────── */}
    <div
      class="lp-tabs flex gap-1 border-b border-hairline px-4 py-2 md:hidden"
      role="tablist"
      aria-label="Editor panes"
    >
      <button
        id="lp-tab-input"
        type="button"
        class="lp-tab lp-tap is-active"
        role="tab"
        aria-selected="true"
        aria-controls="lp-pane-input"
        data-pane="input"
        tabindex="0"
      >
        Input
      </button>
      <button
        id="lp-tab-output"
        type="button"
        class="lp-tab lp-tap"
        role="tab"
        aria-selected="false"
        aria-controls="lp-pane-output"
        data-pane="output"
        tabindex="-1"
      >
        Output
      </button>
    </div>

    {/* ── Editor split (side-by-side on desktop, tabbed on mobile) ─────── */}
    <div class="lp-grid grid grid-cols-1 md:grid-cols-2">
      <div
        id="lp-pane-input"
        class="lp-pane lp-pane--active flex min-w-0 flex-col bg-inverse md:border-r md:border-white/10"
        role="tabpanel"
        aria-labelledby="lp-tab-input"
      >
        <div class="flex items-center gap-2 border-b border-white/10 px-4 py-2.5">
          <span class="flex shrink-0 items-center gap-1.5" aria-hidden="true">
            <span class="h-2.5 w-2.5 rounded-full bg-white/15"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-white/15"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-white/15"></span>
          </span>
          <span id="lp-input-name" class="code-mono text-white/45">query.logql</span>
        </div>
        <div
          id="lp-editor-input"
          class="lp-editor min-h-72"
          aria-label="Source query to convert"
        >
        </div>
        <p class="text-xs text-mute mt-1 px-4 pb-2">Tip: press <kbd style="border:1px solid currentColor;border-radius:3px;padding:0 3px;font-size:0.85em">Esc</kbd> to release focus.</p>
      </div>

      <div
        id="lp-pane-output"
        class="lp-pane flex min-w-0 flex-col bg-inverse"
        role="tabpanel"
        aria-labelledby="lp-tab-output"
      >
        <div class="flex items-center justify-between gap-2 border-b border-white/10 px-4 py-2.5">
          <div class="flex min-w-0 items-center gap-2">
            <span class="flex shrink-0 items-center gap-1.5" aria-hidden="true">
              <span class="h-2.5 w-2.5 rounded-full bg-white/15"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-white/15"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-white/15"></span>
            </span>
            <span id="lp-output-name" class="code-mono truncate text-white/45">query.promql</span>
          </div>
          <span class="code-mono shrink-0 text-white/30">read-only</span>
        </div>
        <div
          id="lp-editor-output"
          class="lp-editor min-h-72"
          role="region"
          aria-label="Converted query (read-only)"
        >
        </div>
      </div>
    </div>

    {/* ── Notes panel (what mapped + what did not) ─────────────────────── */}
    <div class="border-t border-hairline bg-canvas-soft px-4 py-4 sm:px-5">
      <div class="mb-3 flex flex-wrap items-center justify-between gap-x-3 gap-y-1">
        <span class="flex items-center gap-2">
          <span class="eyebrow">Notes</span>
          <button id="lp-share" type="button" class="lp-share-btn" data-copy="" hidden>
            <svg
              class="lp-share-icon"
              width="13"
              height="13"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M6.75 9.25l2.5-2.5"></path>
              <path d="M8.75 4.25l1.5-1.5a2.47 2.47 0 0 1 3.5 3.5l-1.5 1.5"></path>
              <path d="M7.25 11.75l-1.5 1.5a2.47 2.47 0 0 1-3.5-3.5l1.5-1.5"></path>
            </svg>
            <span class="lp-share-label">Copy link</span>
          </button>
          <button id="lp-copy-md" type="button" class="lp-share-btn" hidden>
            <svg
              class="lp-share-icon"
              width="13"
              height="13"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M3 2.5h6.5l3 3v7.75a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1v-9.75a1 1 0 0 1 1-1z"></path>
              <path d="M9.5 2.5v3h3"></path>
              <path d="M4.5 9h7M4.5 11.25h4.5"></path>
            </svg>
            <span class="lp-md-label">Copy as Markdown</span>
          </button>
          <a id="lp-explain-chip" class="lp-chain-chip" href="#" hidden>Explain this query &rarr;</a>
        </span>
        <span
          id="lp-summary"
          class="lp-summary code-mono text-mute"
          role="status"
          aria-live="polite"
        ></span>
      </div>

      <div id="lp-notes" class="lp-notes" aria-live="polite" aria-atomic="false">
        <p class="lp-empty body-sm text-mute">
          Pick a direction, paste or load a query, then convert to see the
          translated query and notes on what does and does not map here.
        </p>
      </div>
    </div>
  </div>

  {/* Polite announcer for clipboard + transient toasts. */}
  <span id="lp-announce" class="sr-only" role="status" aria-live="polite"></span>
</section>

<style>
  @reference "../styles/global.css";

  /* Tap targets opt into fast-tap + no double-tap-zoom on touch. */
  .lp-tap {
    touch-action: manipulation;
  }

  /* ── Segmented direction toggle ─────────────────────────────────────── */
  .lp-seg {
    display: inline-flex;
    align-items: stretch;
    gap: 2px;
    padding: 3px;
    border-radius: var(--radius-md);
    background: var(--color-canvas-soft-2);
    box-shadow: var(--shadow-hairline);
  }
  .lp-seg-loading {
    display: inline-flex;
    align-items: center;
    height: 32px;
    padding: 0 12px;
    font-size: 13px;
  }
  /* Segment buttons are injected at runtime → style via :global. */
  :global(.lp-seg__btn) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 32px;
    padding: 0 12px;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-body);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.01em;
    white-space: nowrap;
    cursor: pointer;
    touch-action: manipulation;
    transition: background-color 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
  }
  :global(.lp-seg__btn:hover:not(.is-active)) {
    color: var(--color-ink);
  }
  :global(.lp-seg__btn.is-active) {
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-subtle);
  }
  :global(.lp-seg__btn:focus-visible) {
    outline: 2px solid var(--color-link);
    outline-offset: 2px;
  }

  /* The example picker: a 6px-radius in-app form control. */
  .lp-select {
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    height: 32px;
    min-width: 0;
    max-width: 280px;
    padding: 0 32px 0 12px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-hairline);
    font-size: 13px;
    line-height: 20px;
    cursor: pointer;
    text-overflow: ellipsis;
    touch-action: manipulation;
    transition: box-shadow 0.15s ease;
  }
  @media (min-width: 640px) {
    .lp-select {
      width: auto;
      min-width: 200px;
    }
  }
  .lp-select:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .lp-select:disabled {
    cursor: not-allowed;
    color: var(--color-mute);
    opacity: 0.7;
  }
  .lp-select-caret {
    transition: color 0.15s ease;
  }
  .lp-select-wrap:hover .lp-select-caret {
    color: var(--color-body);
  }

  /* Mobile tab pills (square in-app scale; never the 100px marketing pill). */
  .lp-tab {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 1 1 0;
    min-height: 44px;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-mute);
    background: transparent;
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .lp-tab:hover:not(.is-active) {
    color: var(--color-body);
    background: var(--color-canvas-soft-2);
  }
  .lp-tab.is-active {
    color: var(--color-on-primary);
    background: var(--color-primary);
  }

  /* Visibility is driven by the .lp-pane--active class, NOT the [hidden]
     attribute. Tailwind v4's layered `[hidden]{display:none!important}` (in
     @layer base) beats any unlayered !important override, which would leave the
     output pane invisible on desktop. */
  @media (max-width: 767px) {
    .lp-pane {
      display: none;
    }
    .lp-pane.lp-pane--active {
      display: flex;
    }
  }
  @media (min-width: 768px) {
    /* Desktop: both panes always visible side by side. */
    .lp-pane {
      display: flex;
    }
  }

  /* CodeMirror host — fills the dark pane, scrolls internally. */
  .lp-editor {
    overflow: hidden;
  }
  .lp-editor :global(.cm-editor) {
    height: 100%;
    background: transparent;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 20px;
  }
  .lp-editor :global(.cm-editor.cm-focused) {
    /* Replace CM's default outline with a brand-blue ring (a11y: keep a ring). */
    outline: 2px solid var(--color-link);
    outline-offset: -2px;
  }
  .lp-editor :global(.cm-scroller) {
    overflow: auto;
    max-height: 420px;
    font-family: var(--font-mono);
    /* Thin, theme-matched scrollbars on the dark surface. */
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.18) transparent;
  }
  .lp-editor :global(.cm-scroller)::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }
  .lp-editor :global(.cm-scroller)::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.16);
    border-radius: var(--radius-pill);
    border: 3px solid transparent;
    background-clip: content-box;
  }
  .lp-editor :global(.cm-scroller)::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.28);
    background-clip: content-box;
  }
  .lp-editor :global(.cm-gutters) {
    background: transparent;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
  }
  .lp-editor :global(.cm-lineNumbers .cm-gutterElement) {
    color: rgba(255, 255, 255, 0.32);
  }
  .lp-editor :global(.cm-content) {
    padding: 14px 0 16px;
  }
  .lp-editor :global(.cm-line) {
    padding-inline: 4px;
  }
  /* The read-only output pane: dim the (hidden) cursor and selection chrome. */
  .lp-editor--ro :global(.cm-cursor),
  .lp-editor--ro :global(.cm-dropCursor) {
    display: none;
  }

  /* Summary — right-aligned counts use tabular figures so they don't jitter. */
  .lp-summary {
    font-variant-numeric: tabular-nums;
    font-feature-settings: 'tnum';
    white-space: nowrap;
  }

  /* Share-link / Copy-as-Markdown pill buttons next to the "Notes" eyebrow. */
  .lp-share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 26px;
    padding: 0 10px;
    border-radius: var(--radius-sm);
    border: none;
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    color: var(--color-mute);
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 16px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 0.12s ease, background 0.12s ease;
  }
  .lp-share-btn:hover {
    color: var(--color-brand-strong);
    background: var(--color-hairline);
  }
  .lp-share-btn:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 1px;
  }
  .lp-share-btn.lp-share-btn--copied {
    color: var(--color-brand-strong);
    background: var(--color-brand-soft);
  }
  @media (pointer: coarse) {
    .lp-share-btn {
      height: auto;
      min-height: 36px;
    }
  }

  .lp-chain-chip {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: 9999px;
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    font-size: 12px;
    line-height: 18px;
    color: var(--color-brand-strong);
    text-decoration: none;
    transition: background 0.12s ease, box-shadow 0.12s ease;
  }
  .lp-chain-chip:hover {
    background: var(--color-brand-soft);
    box-shadow: inset 0 0 0 1px var(--color-brand);
  }

  /* Notes list (mapping notes / success / empty). */
  .lp-notes {
    min-height: 44px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* Mapping-notes row (what mapped / what was approximated or dropped). */
  :global(.lp-note) {
    display: flex;
    gap: 10px;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    color: var(--color-body);
    animation: lp-rise 0.18s ease both;
  }
  :global(.lp-note__icon) {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
    margin-top: 1px;
    color: var(--color-mute);
  }
  :global(.lp-note__body) {
    min-width: 0;
    flex: 1 1 auto;
  }
  :global(.lp-note__title) {
    font-size: 13px;
    font-weight: 500;
    line-height: 18px;
    color: var(--color-ink);
  }
  :global(.lp-note__list) {
    margin: 4px 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  :global(.lp-note__item) {
    position: relative;
    padding-left: 16px;
    font-size: 13px;
    line-height: 18px;
    word-break: break-word;
  }
  :global(.lp-note__item::before) {
    content: '';
    position: absolute;
    left: 4px;
    top: 7px;
    width: 4px;
    height: 4px;
    border-radius: 9999px;
    background: currentColor;
    opacity: 0.55;
  }

  /* Success note (conversion clean, nothing to flag). */
  :global(.lp-ok) {
    display: flex;
    gap: 10px;
    align-items: center;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    color: var(--color-body);
    animation: lp-rise 0.18s ease both;
  }
  :global(.lp-ok__icon) {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
    color: var(--color-success);
  }
  :global(.lp-ok__text) {
    font-size: 13px;
    line-height: 18px;
  }

  /* Parse / conversion error banner. */
  :global(.lp-error) {
    display: flex;
    gap: 10px;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    background: var(--color-error-soft);
    box-shadow: inset 0 0 0 1px var(--color-error);
    color: var(--color-error-deep);
    animation: lp-rise 0.18s ease both;
  }
  :global(.lp-error__icon) {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
    margin-top: 1px;
  }
  :global(.lp-error__body) {
    min-width: 0;
  }
  :global(.lp-error__title) {
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
  }
  :global(.lp-error__detail) {
    margin-top: 2px;
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 18px;
    white-space: pre-wrap;
    word-break: break-word;
  }

  @keyframes lp-rise {
    from {
      opacity: 0;
      transform: translateY(3px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.lp-note),
    :global(.lp-ok),
    :global(.lp-error) {
      animation: none;
    }
  }

  /* Empty state — generous, centered frame. */
  :global(.lp-empty) {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 64px;
    padding: 20px 16px;
    text-align: center;
    text-wrap: pretty;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
  }

  /* Loading dots — animate opacity only; reduced-motion handled globally. */
  :global(.lp-loading) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 14px;
    font-size: 14px;
    line-height: 20px;
    color: var(--color-body);
  }
  :global(.lp-loading__dot) {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: var(--color-mute);
    animation: lp-pulse 1.1s ease-in-out infinite;
  }
  :global(.lp-loading__dot:nth-child(2)) {
    animation-delay: 0.18s;
  }
  :global(.lp-loading__dot:nth-child(3)) {
    animation-delay: 0.36s;
  }
  @keyframes lp-pulse {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 1;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.lp-loading__dot) {
      animation: none;
      opacity: 0.6;
    }
  }

  .is-busy {
    opacity: 0.65;
    pointer-events: none;
    cursor: progress;
  }
  .is-busy .lp-convert-icon {
    display: none;
  }
</style>

<script>
  import { copyTextToClipboard as copyText } from '../lib/clipboard';
  import { buildMarkdownBlock } from '../lib/share-md';
  import { buildHashValue } from '../lib/hash-state';
  import type { EditorView } from '@codemirror/view';
  import { escapeHtml } from '../lib/escape-html';

  // CodeMirror is loaded via dynamic import inside init() so its ~200KB runtime
  // code-splits into its own chunk instead of shipping in the page's initial JS.
  // The `EditorView` type above is erased at build time and ships no runtime code.

  /* ---- Types mirrored from the engine contract (structural, not imported). -- */
  type Direction = 'logql-to-promql' | 'promql-to-logql';
  type ConvertResult = { output: string; notes?: string[]; error?: string };
  type ShareState = { direction: Direction; query: string };
  type EngineModule = {
    convert: (direction: Direction, query: string) => ConvertResult | Promise<ConvertResult>;
    encodeState: (direction: Direction, query: string) => string;
    decodeState: () => ShareState | null;
  };
  type Example = { id: string; label: string; direction: Direction; query: string };

  const ROOT_SEL = '.lp-pg';
  const COPIED_RESET_MS = 1800;
  const DIRECTIONS: { value: Direction; label: string; from: string; to: string }[] = [
    { value: 'logql-to-promql', label: 'LogQL → PromQL', from: 'LogQL', to: 'PromQL' },
    { value: 'promql-to-logql', label: 'PromQL → LogQL', from: 'PromQL', to: 'LogQL' },
  ];

  /** Boot every (so far un-hydrated) playground instance on the page. */
  function boot(): void {
    document.querySelectorAll<HTMLElement>(ROOT_SEL).forEach((root) => {
      if (root.dataset.lpWired === 'true') return;
      root.dataset.lpWired = 'true';
      void init(root);
    });
  }

  /* ---- Small helpers -------------------------------------------------------- */

  function el<T extends HTMLElement>(root: HTMLElement, sel: string): T | null {
    return root.querySelector<T>(sel);
  }

  function isDirection(v: unknown): v is Direction {
    return v === 'logql-to-promql' || v === 'promql-to-logql';
  }

  /** Filenames for the dark editor chrome, per direction. */
  function filesFor(direction: Direction): { input: string; output: string } {
    return direction === 'logql-to-promql'
      ? { input: 'query.logql', output: 'query.promql' }
      : { input: 'query.promql', output: 'query.logql' };
  }

  /** Normalise the sibling examples list defensively. */
  function normaliseExamples(raw: unknown): Example[] {
    if (!Array.isArray(raw)) return [];
    return raw
      .map((item, i) => {
        const o = (item ?? {}) as Record<string, unknown>;
        const query = typeof o.query === 'string' ? o.query : '';
        const direction = isDirection(o.direction) ? o.direction : 'logql-to-promql';
        return {
          id: typeof o.id === 'string' && o.id ? o.id : `example-${i + 1}`,
          label: typeof o.label === 'string' && o.label ? o.label : `Example ${i + 1}`,
          direction,
          query,
        } satisfies Example;
      })
      .filter((e) => e.query.length > 0);
  }

  /* ---- Note rendering (mapping notes / errors / success / empty) ------------ */

  const NOTE_SVG =
    '<svg class="lp-note__icon" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="10" cy="10" r="8"></circle><path d="M10 9v4.5"></path><path d="M10 6.4v.01"></path></svg>';
  const ALERT_SVG =
    '<svg class="lp-error__icon" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 2.5L18.5 17H1.5z"></path><path d="M10 8v4"></path><path d="M10 14.6v.01"></path></svg>';
  const CHECK_SVG =
    '<svg class="lp-ok__icon" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="10" cy="10" r="8"></circle><path d="M6.5 10.5l2.4 2.4 4.6-5"></path></svg>';

  function renderEmpty(container: HTMLElement, summary: HTMLElement): void {
    summary.textContent = '';
    summary.classList.remove('text-error');
    summary.classList.add('text-mute');
    container.innerHTML =
      '<p class="lp-empty body-sm text-mute">Pick a direction, paste or load a query, then convert to see the translated query and notes on what does and does not map here.</p>';
  }

  function renderLoading(container: HTMLElement, summary: HTMLElement): void {
    summary.textContent = '';
    summary.classList.remove('text-error');
    summary.classList.add('text-mute');
    container.innerHTML =
      '<div class="lp-loading"><span class="lp-loading__dot"></span>' +
      '<span class="lp-loading__dot"></span><span class="lp-loading__dot"></span>' +
      '<span>Converting…</span></div>';
  }

  function renderError(container: HTMLElement, summary: HTMLElement, message: string): void {
    summary.textContent = 'Error';
    summary.classList.remove('text-mute');
    summary.classList.add('text-error');
    container.innerHTML =
      '<div class="lp-error" role="alert">' +
      ALERT_SVG +
      '<div class="lp-error__body"><p class="lp-error__title">Could not convert</p>' +
      `<p class="lp-error__detail">${escapeHtml(message)}</p></div></div>`;
  }

  function renderNotes(
    container: HTMLElement,
    summary: HTMLElement,
    notes: string[]
  ): void {
    if (notes.length === 0) {
      summary.textContent = 'Converted';
      summary.classList.remove('text-error');
      summary.classList.add('text-mute');
      container.innerHTML =
        '<div class="lp-ok">' +
        CHECK_SVG +
        '<span class="lp-ok__text">Converted with a clean mapping. The translated query is on the right.</span></div>';
      return;
    }
    const n = notes.length;
    summary.textContent = `${n} ${n === 1 ? 'note' : 'notes'}`;
    summary.classList.remove('text-error');
    summary.classList.add('text-mute');
    const items = notes
      .map((w) => `<li class="lp-note__item">${escapeHtml(w)}</li>`)
      .join('');
    container.innerHTML =
      '<div class="lp-note">' +
      NOTE_SVG +
      '<div class="lp-note__body">' +
      `<p class="lp-note__title">${n === 1 ? 'Conversion note' : 'Conversion notes'}</p>` +
      `<ul class="lp-note__list">${items}</ul>` +
      '</div></div>';
  }

  /* ---- Clipboard ------------------------------------------------------------ */

  /* ---- Instance init -------------------------------------------------------- */

  async function init(root: HTMLElement): Promise<void> {
    const inputHost = el<HTMLElement>(root, '#lp-editor-input');
    const outputHost = el<HTMLElement>(root, '#lp-editor-output');
    const dirGroup = el<HTMLElement>(root, '#lp-direction');
    const exampleSel = el<HTMLSelectElement>(root, '#lp-example');
    const convertBtn = el<HTMLButtonElement>(root, '#lp-convert');
    const copyBtn = el<HTMLButtonElement>(root, '#lp-copy');
    const notesBox = el<HTMLElement>(root, '#lp-notes');
    const summaryEl = el<HTMLElement>(root, '#lp-summary');
    const announce = el<HTMLElement>(root, '#lp-announce');
    const inputNameEl = el<HTMLElement>(root, '#lp-input-name');
    const outputNameEl = el<HTMLElement>(root, '#lp-output-name');
    const shareBtn = el<HTMLButtonElement>(root, '#lp-share');
    const mdBtn = el<HTMLButtonElement>(root, '#lp-copy-md');
    const explainChip = el<HTMLAnchorElement>(root, '#lp-explain-chip');
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('.lp-tab'));

    if (
      !inputHost ||
      !outputHost ||
      !dirGroup ||
      !exampleSel ||
      !convertBtn ||
      !copyBtn ||
      !notesBox ||
      !summaryEl ||
      !shareBtn ||
      !mdBtn ||
      !explainChip
    ) {
      return;
    }

    /** Cross-tool chain — LogQL→PromQL output can be explained by PromQL Explainer. */
    function localePath(p: string): string {
      const m = window.location.pathname.match(/^\/(de|es|fr|pt-br)\//);
      return m ? `/${m[1]}${p}` : p;
    }

    // Lazily load CodeMirror + the sibling engine + examples (off the initial
    // path so the ~200KB CM runtime code-splits into its own chunk).
    let engine: EngineModule;
    let examples: Example[] = [];
    let makeInputEditor: (host: HTMLElement, doc: string) => EditorView;
    let makeOutputEditor: (host: HTMLElement, doc: string) => EditorView;
    let setEditorDoc: (view: EditorView, doc: string) => void;
    try {
      const [
        { EditorState },
        { EditorView, keymap, lineNumbers, highlightActiveLine },
        { defaultKeymap, history, historyKeymap, indentWithTab },
        { oneDark },
        engineMod,
        examplesMod,
      ] = await Promise.all([
        import('@codemirror/state'),
        import('@codemirror/view'),
        import('@codemirror/commands'),
        import('@codemirror/theme-one-dark'),
        import('../lib/logql-promql/engine'),
        import('../lib/logql-promql/examples'),
      ]);
      engine = engineMod as unknown as EngineModule;
      examples = normaliseExamples((examplesMod as { examples?: unknown }).examples);

      // Editor factories + doc-setter as closures over the freshly imported CM
      // symbols (so no runtime CM reference lives at module top level).
      const baseTheme = EditorView.theme({
        '&': { color: '#e6e6e6' },
        '.cm-content': { caretColor: '#e6e6e6' },
        '.cm-cursor, .cm-dropCursor': { borderLeftColor: '#e6e6e6' },
        '&.cm-focused .cm-selectionBackground, .cm-selectionBackground, ::selection': {
          backgroundColor: 'rgba(0, 112, 243, 0.32)',
        },
        '.cm-activeLine': { backgroundColor: 'rgba(255, 255, 255, 0.035)' },
        '.cm-activeLineGutter': { backgroundColor: 'transparent' },
      });

      makeInputEditor = (host: HTMLElement, doc: string): EditorView => {
        const state = EditorState.create({
          doc,
          extensions: [
            lineNumbers(),
            history(),
            highlightActiveLine(),
            oneDark,
            EditorView.lineWrapping,
            keymap.of([
              ...defaultKeymap,
              ...historyKeymap,
              indentWithTab,
              { key: 'Escape', run: function(view) { view.contentDOM.blur(); return true; } },
            ]),
            baseTheme,
          ],
        });
        return new EditorView({ state, parent: host });
      };

      makeOutputEditor = (host: HTMLElement, doc: string): EditorView => {
        const state = EditorState.create({
          doc,
          extensions: [
            lineNumbers(),
            oneDark,
            EditorView.lineWrapping,
            EditorView.editable.of(false),
            EditorState.readOnly.of(true),
            baseTheme,
          ],
        });
        host.classList.add('lp-editor--ro');
        return new EditorView({ state, parent: host });
      };

      setEditorDoc = (view: EditorView, doc: string): void => {
        view.dispatch({ changes: { from: 0, to: view.state.doc.length, insert: doc } });
      };
    } catch (err) {
      renderError(
        notesBox,
        summaryEl,
        'The converter engine failed to load. Reload the page to try again.'
      );
      // eslint-disable-next-line no-console
      console.error('[LogqlPromql] engine/examples import failed:', err);
      return;
    }

    // Seed priority: a valid #s= deep link > the first example > LogQL → PromQL.
    let sharedState: ShareState | null = null;
    try {
      sharedState = engine.decodeState();
    } catch {
      sharedState = null;
    }
    const fromShare = !!sharedState && sharedState.query.length > 0;

    const seed = examples[0];
    let direction: Direction = fromShare
      ? (sharedState as ShareState).direction
      : seed?.direction ?? 'logql-to-promql';

    // Build the segmented direction toggle.
    dirGroup.innerHTML = '';
    const dirButtons: HTMLButtonElement[] = DIRECTIONS.map((d) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'lp-seg__btn lp-tap';
      btn.dataset.dir = d.value;
      btn.setAttribute('role', 'tab');
      btn.textContent = d.label;
      dirGroup.appendChild(btn);
      return btn;
    });

    /** Reflect the active direction across the toggle + editor chrome. */
    function syncDirection(): void {
      dirButtons.forEach((b) => {
        const active = b.dataset.dir === direction;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-selected', active ? 'true' : 'false');
        b.tabIndex = active ? 0 : -1;
      });
      const files = filesFor(direction);
      if (inputNameEl) inputNameEl.textContent = files.input;
      if (outputNameEl) outputNameEl.textContent = files.output;
    }

    // Populate the example picker (with a leading "Custom" sentinel).
    exampleSel.innerHTML = '';
    const customOpt = document.createElement('option');
    customOpt.value = '-1';
    customOpt.textContent = examples.length ? 'Custom input' : 'No examples';
    exampleSel.appendChild(customOpt);
    examples.forEach((ex, i) => {
      const opt = document.createElement('option');
      opt.value = String(i);
      opt.textContent = ex.label;
      exampleSel.appendChild(opt);
    });
    exampleSel.value = fromShare ? '-1' : examples.length ? '0' : '-1';
    if (!examples.length) exampleSel.disabled = true;

    // Editors — seed the input from the shared link, else the first example.
    const inputView = makeInputEditor(
      inputHost,
      fromShare ? (sharedState as ShareState).query : seed?.query ?? ''
    );
    const outputView = makeOutputEditor(outputHost, '');

    syncDirection();

    /* ---- Share link + Copy as Markdown --------------------------------------- */

    /** Hide both the "Copy link" and "Copy as Markdown" buttons. */
    function hideShare(): void {
      shareBtn!.hidden = true;
      shareBtn!.dataset.copy = '';
      mdBtn!.hidden = true;
      explainChip!.hidden = true;
    }

    /** Drop the `#s=` fragment back to the bare path (non-fatal if it throws). */
    function clearShareHash(): void {
      try {
        window.history.replaceState(null, '', window.location.pathname + window.location.search);
      } catch {
        /* non-fatal: sharing just won't update */
      }
    }

    /** Reveal both buttons for a freshly-converted, non-empty result. */
    function revealShare(dir: Direction, query: string, output: string, userInitiated: boolean): void {
      try {
        const hash = engine.encodeState(dir, query);
        const frag = hash.startsWith('#') ? hash : `#${hash}`;
        shareBtn!.dataset.copy =
          window.location.origin + window.location.pathname + window.location.search + frag;
        if (userInitiated) window.history.replaceState(null, '', frag);
      } catch {
        // Fall back to the current URL; sharing degrades gracefully.
        shareBtn!.dataset.copy = window.location.href;
      }
      shareBtn!.hidden = false;
      mdBtn!.hidden = false;

      // logql→promql output is itself a valid PromQL query — chain it into
      // PromQL Explainer. The reverse (promql→logql) has no such explainer.
      if (dir === 'logql-to-promql' && output.length > 0) {
        explainChip!.href = localePath('/promql-explainer/') + buildHashValue('q', output);
        explainChip!.hidden = false;
      } else {
        explainChip!.hidden = true;
      }
    }

    /** Reset to the pre-conversion state (output cleared, copy disabled). */
    function resetOutput(): void {
      setEditorDoc(outputView, '');
      copyBtn!.disabled = true;
      renderEmpty(notesBox!, summaryEl!);
      hideShare();
      clearShareHash();
    }

    // Editing the input or direction means the shown output is stale → Custom.
    function markCustom(): void {
      if (exampleSel!.value !== '-1') exampleSel!.value = '-1';
    }

    // Choosing an example swaps the input + direction, then clears the output.
    exampleSel.addEventListener('change', () => {
      const idx = Number(exampleSel.value);
      if (!Number.isInteger(idx) || idx < 0 || idx >= examples.length) return;
      const ex = examples[idx];
      setEditorDoc(inputView, ex.query);
      direction = ex.direction;
      syncDirection();
      resetOutput();
    });

    // Direction toggle: roving-tabindex tablist with arrow-key navigation.
    function selectDirection(value: Direction, focusBtn: boolean): void {
      if (value === direction) {
        if (focusBtn) dirButtons.find((b) => b.dataset.dir === value)?.focus();
        return;
      }
      direction = value;
      markCustom();
      syncDirection();
      resetOutput();
      if (focusBtn) dirButtons.find((b) => b.dataset.dir === value)?.focus();
    }

    dirButtons.forEach((btn, i) => {
      btn.addEventListener('click', () => selectDirection(btn.dataset.dir as Direction, false));
      btn.addEventListener('keydown', (e) => {
        let next = -1;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next = (i + 1) % dirButtons.length;
        else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp')
          next = (i - 1 + dirButtons.length) % dirButtons.length;
        else if (e.key === 'Home') next = 0;
        else if (e.key === 'End') next = dirButtons.length - 1;
        if (next < 0) return;
        e.preventDefault();
        selectDirection(dirButtons[next].dataset.dir as Direction, true);
      });
    });

    // Mobile tab switching (panes are always visible on desktop via CSS).
    const inputPane = el<HTMLElement>(root, '#lp-pane-input');
    const outputPane = el<HTMLElement>(root, '#lp-pane-output');

    function activateTab(tab: HTMLButtonElement, focusTab: boolean): void {
      const showInput = tab.dataset.pane === 'input';
      tabs.forEach((t) => {
        const active = t === tab;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', active ? 'true' : 'false');
        t.tabIndex = active ? 0 : -1;
      });
      inputPane?.classList.toggle('lp-pane--active', showInput);
      outputPane?.classList.toggle('lp-pane--active', !showInput);
      if (focusTab) tab.focus();
      requestAnimationFrame(() => (showInput ? inputView : outputView).requestMeasure());
    }

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => activateTab(tab, false));
      tab.addEventListener('keydown', (e) => {
        let next = -1;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next = (i + 1) % tabs.length;
        else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp')
          next = (i - 1 + tabs.length) % tabs.length;
        else if (e.key === 'Home') next = 0;
        else if (e.key === 'End') next = tabs.length - 1;
        if (next < 0) return;
        e.preventDefault();
        activateTab(tabs[next], true);
      });
    });

    // Convert — non-blocking; show loading, yield a frame, then render.
    let running = false;
    const convertLabel = convertBtn.querySelector<HTMLElement>('.lp-convert-label');
    let spinner: HTMLElement | null = null;

    async function convertNow(userInitiated = true): Promise<void> {
      if (running) return;
      running = true;
      convertBtn.classList.add('is-busy');
      convertBtn.setAttribute('aria-disabled', 'true');
      convertBtn.setAttribute('aria-busy', 'true');
      if (!spinner) {
        spinner = document.createElement('span');
        spinner.setAttribute('aria-hidden', 'true');
        // Inline the visual — this span is created at runtime and would not
        // receive the component's scoped-style hash.
        spinner.style.cssText =
          'display:inline-block;width:14px;height:14px;flex:0 0 auto;border-radius:9999px;' +
          'border:2px solid currentColor;border-top-color:transparent;';
        if (!window.matchMedia || !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          spinner.animate(
            [{ transform: 'rotate(0deg)' }, { transform: 'rotate(360deg)' }],
            { duration: 700, iterations: Infinity }
          );
        }
        convertBtn.insertBefore(spinner, convertBtn.firstChild);
      }
      if (convertLabel) convertLabel.textContent = 'Converting…';
      renderLoading(notesBox!, summaryEl!);

      // Yield so the loading state paints before (potentially heavy) work runs.
      await new Promise<void>((resolve) => {
        if ('requestAnimationFrame' in window) requestAnimationFrame(() => resolve());
        else setTimeout(resolve, 0);
      });

      try {
        const query = inputView.state.doc.toString();
        const result = await Promise.resolve(engine.convert(direction, query));

        if (!result || result.error) {
          setEditorDoc(outputView, '');
          copyBtn!.disabled = true;
          renderError(
            notesBox!,
            summaryEl!,
            result?.error ?? 'Unknown error while converting.'
          );
          hideShare();
          if (userInitiated) clearShareHash();
          return;
        }

        const output = typeof result.output === 'string' ? result.output : '';
        setEditorDoc(outputView, output);
        copyBtn!.disabled = output.length === 0;
        const notes = Array.isArray(result.notes)
          ? result.notes.filter((w): w is string => typeof w === 'string' && w.length > 0)
          : [];
        renderNotes(notesBox!, summaryEl!, notes);
        if (announce) {
          announce.textContent =
            notes.length > 0
              ? `Converted with ${notes.length} ${notes.length === 1 ? 'note' : 'notes'}.`
              : 'Converted successfully.';
        }

        if (output.length > 0) {
          revealShare(direction, query, output, userInitiated);
        } else {
          hideShare();
          if (userInitiated) clearShareHash();
        }
      } catch (err) {
        const msg = err instanceof Error ? err.message : 'Unexpected error while converting.';
        setEditorDoc(outputView, '');
        copyBtn!.disabled = true;
        renderError(notesBox!, summaryEl!, msg);
        hideShare();
        if (userInitiated) clearShareHash();
      } finally {
        running = false;
        convertBtn.classList.remove('is-busy');
        convertBtn.removeAttribute('aria-disabled');
        convertBtn.removeAttribute('aria-busy');
        if (spinner) {
          spinner.remove();
          spinner = null;
        }
        if (convertLabel) convertLabel.textContent = 'Convert';
      }
    }

    convertBtn.addEventListener('click', () => void convertNow());

    // Cmd/Ctrl+Enter from inside the editor / toolbar triggers a conversion.
    root.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
        e.preventDefault();
        void convertNow();
      }
    });

    // Copy output — copies the read-only editor's current document.
    const copyLabel = copyBtn.querySelector<HTMLElement>('.lp-copy-label');
    let copyTimer: number | undefined;
    copyBtn.addEventListener('click', async () => {
      const out = outputView.state.doc.toString();
      if (!out) return;
      const ok = await copyText(out);
      if (copyLabel) copyLabel.textContent = ok ? 'Copied' : 'Copy Failed';
      if (announce) {
        announce.textContent = ok
          ? 'Converted query copied to your clipboard.'
          : 'Could not copy. Select the output text and copy it manually.';
      }
      window.clearTimeout(copyTimer);
      copyTimer = window.setTimeout(() => {
        if (copyLabel) copyLabel.textContent = copyBtn.dataset.defaultLabel ?? 'Copy Output';
      }, COPIED_RESET_MS);
    });

    // Copy link — copies the shareable URL built by the last successful convert.
    const shareLabel = shareBtn.querySelector<HTMLElement>('.lp-share-label');
    let shareCopyTimer: number | undefined;
    shareBtn.addEventListener('click', async () => {
      const text = shareBtn.dataset.copy ?? '';
      if (!text) return;
      const ok = await copyText(text);
      shareBtn.classList.toggle('lp-share-btn--copied', ok);
      if (shareLabel) shareLabel.textContent = ok ? 'Copied' : 'Copy Failed';
      if (announce) {
        announce.textContent = ok
          ? 'Share link copied to your clipboard.'
          : 'Could not copy the link. Copy the URL from your address bar instead.';
      }
      window.clearTimeout(shareCopyTimer);
      shareCopyTimer = window.setTimeout(() => {
        shareBtn.classList.remove('lp-share-btn--copied');
        if (shareLabel) shareLabel.textContent = 'Copy link';
      }, COPIED_RESET_MS);
    });

    // Copy as Markdown — a fenced block with the current direction, query and result.
    const mdLabel = mdBtn.querySelector<HTMLElement>('.lp-md-label');
    let mdCopyTimer: number | undefined;
    mdBtn.addEventListener('click', async () => {
      const dirMeta = DIRECTIONS.find((d) => d.value === direction);
      const md = buildMarkdownBlock('LogQL ↔ PromQL Helper', [
        { label: 'Direction', value: dirMeta?.label ?? direction },
        { label: 'Query', value: inputView.state.doc.toString() },
        { label: 'Result', value: outputView.state.doc.toString() },
      ]);
      const ok = await copyText(md);
      mdBtn.classList.toggle('lp-share-btn--copied', ok);
      if (mdLabel) mdLabel.textContent = ok ? 'Copied' : 'Copy Failed';
      if (announce) {
        announce.textContent = ok
          ? 'Markdown summary copied to your clipboard.'
          : 'Could not copy. Select the text and copy it manually.';
      }
      window.clearTimeout(mdCopyTimer);
      mdCopyTimer = window.setTimeout(() => {
        mdBtn.classList.remove('lp-share-btn--copied');
        if (mdLabel) mdLabel.textContent = 'Copy as Markdown';
      }, COPIED_RESET_MS);
    });

    // Initial results state: a #s= deep link converts immediately (that's the
    // point of sharing); otherwise wait for the user's explicit Convert action.
    if (fromShare) {
      void convertNow(false);
    } else {
      renderEmpty(notesBox, summaryEl);
    }
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
