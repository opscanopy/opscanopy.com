---
/**
 * IpConverterPlayground — the interactive IP Address Converter island.
 *
 * Single-input, live tool: type an IP in any form (dotted decimal, integer,
 * hexadecimal, binary, or IPv6) and every representation is rendered. No button,
 * fully client-side.
 *
 * Runtime contract (lazy-imported):
 *   ../lib/ip-converter/engine   → convert(input: string): ConvertResult
 *   ../lib/ip-converter/examples → examples: { id; label; input }[]
 */
---

<section class="ipc-pg" aria-label="IP Address Converter playground">
  <div class="card shadow-float overflow-hidden rounded-lg">
    <div class="flex flex-col gap-1 border-b border-hairline px-4 py-3 sm:px-5">
      <label class="eyebrow shrink-0" for="ipc-example">Example</label>
      <div class="ipc-select-wrap relative min-w-0">
        <select id="ipc-example" class="ipc-select code-mono" autocomplete="off">
          <option value="">Loading examples…</option>
        </select>
        <svg
          class="ipc-select-caret pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-mute"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 6l4 4 4-4"></path>
        </svg>
      </div>
    </div>

    <div class="border-b border-hairline px-4 py-4 sm:px-5">
      <label class="eyebrow mb-2 block" for="ipc-input">IP address</label>
      <div class="ipc-input-wrap">
        <svg
          class="ipc-input-icon pointer-events-none"
          viewBox="0 0 20 20"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 10h12M10 4v12"></path>
          <circle cx="10" cy="10" r="7.25"></circle>
        </svg>
        <input
          id="ipc-input"
          type="text"
          class="ipc-input code-mono"
          spellcheck="false"
          autocapitalize="off"
          autocorrect="off"
          autocomplete="off"
          placeholder="192.168.1.10"
          aria-describedby="ipc-input-hint"
        />
      </div>
      <p id="ipc-input-hint" class="ipc-hint caption text-mute">
        Any form — dotted decimal <span class="code-mono">192.168.1.10</span>, integer
        <span class="code-mono">3232235786</span>, hex <span class="code-mono">0xC0A8010A</span>, or
        IPv6 <span class="code-mono">2001:db8::1</span>.
      </p>
    </div>

    <div class="bg-canvas-soft px-4 py-4 sm:px-5">
      <div class="mb-3 flex items-center justify-between gap-3">
        <span class="eyebrow">Result</span>
        <span id="ipc-summary" class="ipc-summary code-mono text-mute" role="status" aria-live="polite"></span>
      </div>
      <div id="ipc-results" class="ipc-results" aria-live="polite" aria-atomic="false">
        <p class="ipc-empty body-sm text-mute">
          Type an IP in any form or pick an example to see it in dotted decimal, integer, hex and
          binary here.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../styles/global.css";

  .ipc-select {
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    height: 32px;
    min-width: 0;
    max-width: 320px;
    padding: 0 32px 0 12px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-hairline);
    font-size: 13px;
    line-height: 20px;
    cursor: pointer;
    text-overflow: ellipsis;
    touch-action: manipulation;
    transition: box-shadow 0.15s ease;
  }
  @media (min-width: 640px) {
    .ipc-select {
      width: auto;
      min-width: 260px;
    }
  }
  .ipc-select:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .ipc-select:disabled {
    cursor: not-allowed;
    color: var(--color-mute);
    opacity: 0.7;
  }
  .ipc-select-wrap:hover .ipc-select-caret {
    color: var(--color-body);
  }

  .ipc-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .ipc-input-icon {
    position: absolute;
    left: 14px;
    width: 18px;
    height: 18px;
    color: var(--color-mute);
    pointer-events: none;
  }
  .ipc-input {
    width: 100%;
    height: 48px;
    padding: 0 16px 0 42px;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-hairline);
    font-size: 15px;
    line-height: 24px;
    letter-spacing: 0.01em;
    transition: box-shadow 0.15s ease;
  }
  .ipc-input::placeholder {
    color: var(--color-mute);
  }
  .ipc-input:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .ipc-input:focus {
    outline: none;
  }
  .ipc-input:focus-visible {
    box-shadow: inset 0 0 0 2px var(--color-link);
    outline: none;
  }
  .ipc-input.ipc-input--error {
    box-shadow: inset 0 0 0 1px var(--color-error);
  }
  .ipc-input.ipc-input--error:focus-visible {
    box-shadow: inset 0 0 0 2px var(--color-error);
  }
  .ipc-hint {
    margin-top: 8px;
    text-wrap: pretty;
  }
  .ipc-summary {
    white-space: nowrap;
  }
  .ipc-results {
    min-height: 44px;
  }

  :global(.ipc-card) {
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    overflow: hidden;
    animation: ipc-rise 0.18s ease both;
  }
  :global(.ipc-title) {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-hairline);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 18px;
    color: var(--color-mute);
  }
  :global(.ipc-title__badge) {
    flex: 0 0 auto;
    font-size: 11px;
    line-height: 16px;
    padding: 1px 8px;
    border-radius: 9999px;
    background: var(--color-brand-soft);
    color: var(--color-brand-strong);
  }
  :global(.ipc-row) {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: 12px;
    padding: 9px 14px;
    align-items: baseline;
  }
  :global(.ipc-row + .ipc-row) {
    border-top: 1px solid var(--color-hairline);
  }
  :global(.ipc-row__k) {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 18px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-mute);
  }
  :global(.ipc-row__v-wrap) {
    display: flex;
    align-items: center;
    gap: 6px;
    min-width: 0;
  }
  :global(.ipc-row__v) {
    min-width: 0;
    font-size: 14px;
    line-height: 20px;
    color: var(--color-ink);
    word-break: break-word;
  }
  :global(.ipc-row__v.is-mono) {
    font-family: var(--font-mono);
    font-size: 13px;
    font-variant-numeric: tabular-nums;
    font-feature-settings: 'tnum';
  }
  :global(.ipc-copy-btn) {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: var(--radius-sm);
    border: none;
    background: transparent;
    color: var(--color-mute);
    cursor: pointer;
    transition: color 0.12s ease, background 0.12s ease;
    padding: 0;
  }
  :global(.ipc-copy-btn:hover) {
    color: var(--color-ink);
    background: var(--color-hairline);
  }
  :global(.ipc-copy-btn:focus-visible) {
    outline: 2px solid var(--color-link);
    outline-offset: 1px;
  }
  :global(.ipc-copy-btn--copied) {
    color: var(--color-brand-strong);
    background: var(--color-brand-soft);
  }

  @keyframes ipc-rise {
    from {
      opacity: 0;
      transform: translateY(3px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.ipc-card) {
      animation: none;
    }
  }

  :global(.ipc-error) {
    display: flex;
    gap: 10px;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    background: var(--color-error-soft);
    box-shadow: inset 0 0 0 1px var(--color-error);
    color: var(--color-error-deep);
  }
  :global(.ipc-error__icon) {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
    margin-top: 1px;
  }
  :global(.ipc-error__title) {
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
  }
  :global(.ipc-error__detail) {
    margin-top: 2px;
    font-size: 13px;
    line-height: 18px;
    text-wrap: pretty;
  }
  :global(.ipc-empty) {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 64px;
    padding: 20px 16px;
    text-align: center;
    text-wrap: pretty;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
  }
</style>

<script>
  import { escapeHtml } from '../lib/escape-html';

  type Row = { label: string; value: string; mono?: boolean };
  type Result = { valid: boolean; error?: string; version?: 4 | 6; detected?: string; rows: Row[] };
  type Example = { id: string; label: string; input: string };
  type EngineModule = { convert: (input: string) => Result };

  declare global {
    interface Window { _icDebounce: ReturnType<typeof setTimeout> | undefined; }
  }

  const ROOT_SEL = '.ipc-pg';
  const DEBOUNCE_MS = 300;

  function boot(): void {
    document.querySelectorAll<HTMLElement>(ROOT_SEL).forEach((root) => {
      if (root.dataset.ipcWired === 'true') return;
      root.dataset.ipcWired = 'true';
      void init(root);
    });
  }

  function el<T extends HTMLElement>(root: HTMLElement, sel: string): T | null {
    return root.querySelector<T>(sel);
  }

  function normaliseExamples(raw: unknown): Example[] {
    if (!Array.isArray(raw)) return [];
    return raw
      .map((item, i) => {
        const o = (item ?? {}) as Record<string, unknown>;
        return {
          id: typeof o.id === 'string' && o.id ? o.id : `example-${i + 1}`,
          label: typeof o.label === 'string' && o.label ? o.label : `Example ${i + 1}`,
          input: typeof o.input === 'string' ? o.input : '',
        } satisfies Example;
      })
      .filter((e) => e.input.length > 0);
  }

  const ALERT_SVG =
    '<svg class="ipc-error__icon" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 2.5L18.5 17H1.5z"></path><path d="M10 8v4"></path><path d="M10 14.6v.01"></path></svg>';

  function renderEmpty(container: HTMLElement, summary: HTMLElement): void {
    summary.textContent = '';
    summary.classList.remove('text-error');
    summary.classList.add('text-mute');
    container.innerHTML =
      '<p class="ipc-empty body-sm text-mute">Type an IP in any form or pick an example to see it in dotted decimal, integer, hex and binary here.</p>';
  }

  function renderError(container: HTMLElement, summary: HTMLElement, message: string): void {
    summary.textContent = 'Invalid';
    summary.classList.remove('text-mute');
    summary.classList.add('text-error');
    container.innerHTML =
      '<div class="ipc-error" role="alert">' +
      ALERT_SVG +
      '<div><p class="ipc-error__title">Could not read that address</p>' +
      `<p class="ipc-error__detail">${escapeHtml(message)}</p></div></div>`;
  }

  function renderResult(container: HTMLElement, summary: HTMLElement, result: Result): void {
    const version = result.version === 6 ? 'IPv6' : 'IPv4';
    summary.textContent = version;
    summary.classList.remove('text-error');
    summary.classList.add('text-mute');
    const rows = Array.isArray(result.rows) ? result.rows : [];
    const rowsHtml = rows
      .map((r) => {
        const v = typeof r.value === 'string' ? r.value : '';
        const cls = r.mono ? 'ipc-row__v is-mono' : 'ipc-row__v';
        const copyBtn =
          `<button class="ipc-copy-btn" type="button" aria-label="Copy ${escapeHtml(r.label ?? '')} value" data-copy="${escapeHtml(v)}" title="Copy">` +
          `<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="5" width="9" height="9" rx="1.5"/><path d="M3 11H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v1"/></svg>` +
          `</button>`;
        return (
          '<div class="ipc-row">' +
          `<span class="ipc-row__k">${escapeHtml(r.label ?? '')}</span>` +
          `<span class="ipc-row__v-wrap">${copyBtn}<span class="${cls}">${escapeHtml(v)}</span></span></div>`
        );
      })
      .join('');
    const detected = result.detected ? `read as ${result.detected}` : '';
    container.innerHTML =
      '<div class="ipc-card">' +
      `<div class="ipc-title"><span class="ipc-title__badge">${version}</span><span>${escapeHtml(detected)}</span></div>` +
      rowsHtml +
      '</div>';
  }

  async function init(root: HTMLElement): Promise<void> {
    const input = el<HTMLInputElement>(root, '#ipc-input');
    const exampleSel = el<HTMLSelectElement>(root, '#ipc-example');
    const resultsBox = el<HTMLElement>(root, '#ipc-results');
    const summaryEl = el<HTMLElement>(root, '#ipc-summary');
    if (!input || !exampleSel || !resultsBox || !summaryEl) return;

    let engine: EngineModule;
    let examples: Example[] = [];
    try {
      const [engineMod, examplesMod] = await Promise.all([
        import('../lib/ip-converter/engine'),
        import('../lib/ip-converter/examples'),
      ]);
      engine = engineMod as unknown as EngineModule;
      examples = normaliseExamples((examplesMod as { examples?: unknown }).examples);
    } catch (err) {
      renderError(resultsBox, summaryEl, 'The converter engine failed to load. Reload the page to try again.');
      console.error('[IpConverter] engine import failed:', err);
      return;
    }

    exampleSel.innerHTML = '';
    const customOpt = document.createElement('option');
    customOpt.value = '-1';
    customOpt.textContent = examples.length ? 'Custom input' : 'No examples';
    exampleSel.appendChild(customOpt);
    examples.forEach((ex, i) => {
      const opt = document.createElement('option');
      opt.value = String(i);
      opt.textContent = ex.label;
      exampleSel.appendChild(opt);
    });
    if (!examples.length) exampleSel.disabled = true;

    function evaluate(): void {
      const value = input!.value.trim();
      if (value.length === 0) {
        input!.classList.remove('ipc-input--error');
        renderEmpty(resultsBox!, summaryEl!);
        return;
      }
      let result: Result | null = null;
      try {
        result = engine.convert(value);
      } catch {
        input!.classList.add('ipc-input--error');
        renderError(resultsBox!, summaryEl!, 'Unexpected error while converting.');
        return;
      }
      if (!result || result.valid === false) {
        input!.classList.add('ipc-input--error');
        renderError(resultsBox!, summaryEl!, result?.error ?? 'This is not a valid IP address.');
        return;
      }
      input!.classList.remove('ipc-input--error');
      renderResult(resultsBox!, summaryEl!, result);
    }

    let timer: number | undefined;
    function scheduleEvaluate(): void {
      window.clearTimeout(timer);
      timer = window.setTimeout(evaluate, DEBOUNCE_MS);
    }

    input.addEventListener('input', () => {
      if (exampleSel.value !== '-1') exampleSel.value = '-1';
      clearTimeout(window._icDebounce);
      window._icDebounce = window.setTimeout(function () {
        evaluate();
      }, DEBOUNCE_MS);
    });
    exampleSel.addEventListener('change', () => {
      const idx = Number(exampleSel.value);
      if (!Number.isInteger(idx) || idx < 0 || idx >= examples.length) return;
      input.value = examples[idx].input;
      window.clearTimeout(timer);
      evaluate();
    });

    resultsBox.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.ipc-copy-btn');
      if (!btn) return;
      const text = btn.dataset.copy ?? '';
      if (!navigator.clipboard) return;
      navigator.clipboard.writeText(text).then(() => {
        btn.classList.add('ipc-copy-btn--copied');
        window.setTimeout(() => btn.classList.remove('ipc-copy-btn--copied'), 1500);
      }).catch(() => {/* silently ignore clipboard permission errors */});
    });

    const seed = examples[0];
    if (seed) {
      input.value = seed.input;
      exampleSel.value = '0';
      evaluate();
    } else {
      renderEmpty(resultsBox, summaryEl);
    }
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
