---
/**
 * IpConverterPlayground — the interactive IP Address Converter island.
 *
 * Single-input, live tool: type an IP in any form (dotted decimal, integer,
 * hexadecimal, binary, or IPv6) and every representation is rendered. No button,
 * fully client-side. A Bulk mode converts one IP per line into a table.
 *
 * Runtime contract (lazy-imported):
 *   ../lib/ip-converter/engine   → convert(input: string): ConvertResult
 *   ../lib/ip-converter/examples → examples: { id; label; input }[]
 */
---

<section class="ipc-pg" aria-label="IP Address Converter playground">
  <div class="card shadow-float overflow-hidden rounded-lg">
    <div class="flex flex-col gap-1 border-b border-hairline px-4 py-3 sm:px-5">
      <div class="flex items-center gap-3">
        <label id="ipc-example-label" class="eyebrow shrink-0" for="ipc-example">Example</label>
        <div class="ipc-mode ml-auto" role="group" aria-label="Input mode">
          <button type="button" class="ipc-mode-btn is-active" data-mode="single" aria-pressed="true">Single</button>
          <button type="button" class="ipc-mode-btn" data-mode="bulk" aria-pressed="false">Bulk</button>
        </div>
      </div>
      <div id="ipc-example-wrap" class="ipc-select-wrap relative min-w-0">
        <select id="ipc-example" class="ipc-select code-mono" autocomplete="off">
          <option value="">Examples</option>
        </select>
        <svg
          class="ipc-select-caret pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-mute"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 6l4 4 4-4"></path>
        </svg>
      </div>
    </div>

    <div class="border-b border-hairline px-4 py-4 sm:px-5">
      <div id="ipc-single-wrap">
        <label class="eyebrow mb-2 block" for="ipc-input">IP address</label>
        <div class="ipc-input-wrap">
          <svg
            class="ipc-input-icon pointer-events-none"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 10h12M10 4v12"></path>
            <circle cx="10" cy="10" r="7.25"></circle>
          </svg>
          <input
            id="ipc-input"
            type="text"
            class="ipc-input code-mono"
            spellcheck="false"
            autocapitalize="off"
            autocorrect="off"
            autocomplete="off"
            enterkeyhint="done"
            placeholder="192.168.1.10"
            aria-describedby="ipc-input-hint"
          />
        </div>
        <p id="ipc-input-hint" class="ipc-hint caption text-mute">
          Any form — dotted decimal <span class="code-mono">192.168.1.10</span>, integer
          <span class="code-mono">3232235786</span>, hex <span class="code-mono">0xC0A8010A</span>,
          binary, or IPv6 <span class="code-mono">2001:db8::1</span> — the format is auto-detected.
        </p>
        <div class="ipc-snap-row mt-3 flex flex-wrap items-center gap-2">
          <button id="ipc-snap-save" type="button" class="ipc-snap-btn">Save snapshot</button>
          <select id="ipc-snap-select" class="ipc-snap-select" aria-label="Load a saved snapshot" disabled>
            <option value="">No snapshots yet</option>
          </select>
          <button id="ipc-snap-delete" type="button" class="ipc-snap-delete" aria-label="Delete this snapshot" hidden>&times;</button>
        </div>
      </div>
      <div id="ipc-bulk-wrap" hidden>
        <label class="eyebrow mb-2 block" for="ipc-bulk-input">IP addresses — one per line</label>
        <textarea
          id="ipc-bulk-input"
          class="ipc-textarea code-mono"
          rows="6"
          spellcheck="false"
          autocapitalize="off"
          autocorrect="off"
          autocomplete="off"
          placeholder={'192.168.1.10\n2001:db8::1\n# blank lines and # comments are skipped'}></textarea>
      </div>
      <noscript>
        <p class="ipc-hint caption text-mute">
          This converter runs entirely in your browser — enable JavaScript to use it.
        </p>
      </noscript>
    </div>

    <div class="bg-canvas-soft px-4 py-4 sm:px-5">
      <div class="mb-3 flex flex-wrap items-center justify-between gap-x-3 gap-y-1">
        <span class="flex items-center gap-2">
          <span class="eyebrow">Result</span>
          <button
            id="ipc-share"
            type="button"
            class="ipc-copy-btn ipc-copy-btn--labeled"
            data-copy=""
            data-copy-label="Copy link"
            hidden
          >
            <svg
              class="ipc-copy-icon"
              width="13"
              height="13"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M6.75 9.25l2.5-2.5"></path>
              <path d="M8.75 4.25l1.5-1.5a2.47 2.47 0 0 1 3.5 3.5l-1.5 1.5"></path>
              <path d="M7.25 11.75l-1.5 1.5a2.47 2.47 0 0 1-3.5-3.5l1.5-1.5"></path>
            </svg>
            <svg
              class="ipc-check-icon hidden"
              width="13"
              height="13"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M3 8.5l3.5 3.5L13 4.5"></path>
            </svg>
            <span class="ipc-copy-label">Copy link</span>
          </button>
        </span>
        <span id="ipc-summary" class="ipc-summary code-mono text-mute" role="status" aria-live="polite"></span>
      </div>
      <div id="ipc-results" class="ipc-results">
        <p class="ipc-empty body-sm text-mute">
          Type an IP in any form or pick an example to see it in dotted decimal, integer, hex and
          binary here.
        </p>
      </div>
      <span id="ipc-copy-status" class="sr-only" role="status" aria-live="polite"></span>
    </div>
  </div>
</section>

<style>
  @reference "../styles/global.css";

  .ipc-select {
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    height: 32px;
    min-width: 0;
    max-width: 320px;
    padding: 0 32px 0 12px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-hairline);
    font-size: 13px;
    line-height: 20px;
    cursor: pointer;
    text-overflow: ellipsis;
    touch-action: manipulation;
    transition: box-shadow 0.15s ease;
  }
  @media (min-width: 640px) {
    .ipc-select {
      width: auto;
      min-width: 260px;
    }
  }
  .ipc-select:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .ipc-select:disabled {
    cursor: not-allowed;
    color: var(--color-mute);
    opacity: 0.7;
  }
  .ipc-select-wrap:hover .ipc-select-caret {
    color: var(--color-body);
  }

  .ipc-mode {
    display: inline-flex;
    gap: 2px;
    padding: 2px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
  }
  .ipc-mode-btn {
    border: none;
    background: transparent;
    cursor: pointer;
    padding: 3px 10px;
    border-radius: calc(var(--radius-sm) - 2px);
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 16px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-mute);
    transition: color 0.12s ease, background 0.12s ease;
  }
  .ipc-mode-btn:hover {
    color: var(--color-ink);
  }
  .ipc-mode-btn:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 1px;
  }
  .ipc-mode-btn.is-active {
    background: var(--color-brand-soft);
    color: var(--color-brand-strong);
  }

  .ipc-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .ipc-input-icon {
    position: absolute;
    left: 14px;
    width: 18px;
    height: 18px;
    color: var(--color-mute);
    pointer-events: none;
  }
  .ipc-input {
    width: 100%;
    height: 48px;
    padding: 0 16px 0 42px;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-hairline);
    font-size: 15px;
    line-height: 24px;
    letter-spacing: 0.01em;
    transition: box-shadow 0.15s ease;
  }
  .ipc-input::placeholder {
    color: var(--color-mute);
  }
  .ipc-input:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .ipc-input:focus {
    outline: none;
  }
  .ipc-input:focus-visible {
    box-shadow: inset 0 0 0 2px var(--color-link);
    outline: none;
  }
  .ipc-input.ipc-input--error {
    box-shadow: inset 0 0 0 1px var(--color-error);
  }
  .ipc-input.ipc-input--error:focus-visible {
    box-shadow: inset 0 0 0 2px var(--color-error);
  }
  .ipc-textarea {
    width: 100%;
    min-height: 132px;
    padding: 10px 14px;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-hairline);
    font-size: 13px;
    line-height: 20px;
    resize: vertical;
    transition: box-shadow 0.15s ease;
  }
  .ipc-textarea::placeholder {
    color: var(--color-mute);
  }
  .ipc-textarea:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .ipc-textarea:focus {
    outline: none;
  }
  .ipc-textarea:focus-visible {
    box-shadow: inset 0 0 0 2px var(--color-link);
    outline: none;
  }
  .ipc-hint {
    margin-top: 8px;
    font-size: 12px;
    line-height: 18px;
    text-wrap: pretty;
  }
  .ipc-hint .code-mono {
    font-size: 12px;
  }
  .ipc-snap-btn {
    flex: 0 0 auto;
    height: 30px;
    padding: 0 12px;
    border-radius: var(--radius-sm);
    border: none;
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    color: var(--color-body);
    font-size: 12.5px;
    cursor: pointer;
    transition: background 0.12s ease, box-shadow 0.12s ease;
  }
  .ipc-snap-btn:hover {
    background: var(--color-canvas-soft);
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .ipc-snap-select {
    height: 30px;
    max-width: 220px;
    padding: 0 8px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    color: var(--color-body);
    font-size: 12.5px;
  }
  .ipc-snap-select:disabled {
    color: var(--color-mute);
    cursor: not-allowed;
  }
  .ipc-snap-delete {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    border: none;
    background: transparent;
    color: var(--color-mute);
    cursor: pointer;
    transition: background 0.12s ease, color 0.12s ease;
  }
  .ipc-snap-delete:hover {
    background: var(--color-error-soft);
    color: var(--color-error-deep);
  }
  .ipc-summary {
    min-width: 0;
    text-align: right;
    overflow-wrap: anywhere;
  }
  /* Sized to the seeded 7-row IPv4 card so empty/error states don't collapse
     the panel; smaller content is vertically centered within it. */
  .ipc-results {
    min-height: 310px;
    display: grid;
    align-content: center;
  }
  /* Copy failure message flips from sr-only to a visible caption. */
  .ipc-copy-status--fail {
    display: block;
    margin-top: 10px;
    font-size: 12px;
    line-height: 18px;
    color: var(--color-error-deep);
  }

  :global(.ipc-card) {
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    overflow: hidden;
    animation: ipc-rise 0.18s ease both;
  }
  :global(.ipc-title) {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-hairline);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 18px;
    color: var(--color-mute);
  }
  :global(.ipc-title__badge) {
    flex: 0 0 auto;
    font-size: 11px;
    line-height: 16px;
    padding: 1px 8px;
    border-radius: 9999px;
    background: var(--color-brand-soft);
    color: var(--color-brand-strong);
  }
  :global(.ipc-title__detected) {
    color: var(--color-ink);
  }
  :global(.ipc-row) {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: 12px;
    padding: 9px 14px;
    align-items: baseline;
  }
  /* Below ~480px: stack label above value so long IPv6 addresses don't wrap
     mid-hex-group (ported from SubnetCalculatorPlayground). */
  @media (max-width: 479px) {
    :global(.ipc-row) {
      grid-template-columns: 1fr;
      gap: 2px 8px;
    }
    :global(.ipc-row .ipc-copy-btn) {
      align-self: center;
    }
  }
  :global(.ipc-row + .ipc-row) {
    border-top: 1px solid var(--color-hairline);
  }
  :global(.ipc-row__k) {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 18px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-mute);
  }
  :global(.ipc-chip-input) {
    display: inline-block;
    margin-left: 6px;
    padding: 0 6px;
    border-radius: var(--radius-pill);
    background: var(--color-hairline);
    font-size: 10px;
    line-height: 16px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-mute);
    vertical-align: middle;
  }
  :global(.ipc-row__v-wrap) {
    display: flex;
    align-items: center;
    gap: 6px;
    min-width: 0;
  }
  :global(.ipc-row__v) {
    flex: 1 1 auto;
    min-width: 0;
    font-size: 14px;
    line-height: 20px;
    color: var(--color-ink);
    word-break: break-word;
    overflow-wrap: anywhere;
  }
  :global(.ipc-row__v.is-mono) {
    font-family: var(--font-mono);
    font-size: 13px;
    font-variant-numeric: tabular-nums;
    font-feature-settings: 'tnum';
  }
  :global(.ipc-row__zone-link) {
    flex: 0 0 auto;
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 18px;
    color: var(--color-mute);
    text-decoration: none;
  }
  :global(.ipc-row__zone-link:hover) {
    color: var(--color-brand-strong);
    text-decoration: underline;
  }
  :global(.ipc-copy-btn) {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: var(--radius-sm);
    border: none;
    background: transparent;
    color: var(--color-mute);
    cursor: pointer;
    transition: color 0.12s ease, background 0.12s ease;
    padding: 0;
  }
  :global(.ipc-copy-btn:hover) {
    color: var(--color-brand-strong);
    background: var(--color-hairline);
  }
  :global(.ipc-copy-btn:focus-visible) {
    outline: 2px solid var(--color-link);
    outline-offset: 1px;
  }
  :global(.ipc-copy-btn--labeled) {
    width: auto;
    height: 26px;
    gap: 6px;
    padding: 0 10px;
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 16px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  :global(.ipc-copy-btn--copied) {
    color: var(--color-brand-strong);
    background: var(--color-brand-soft);
  }
  @media (pointer: coarse) {
    :global(.ipc-copy-btn) {
      width: 44px;
      height: 44px;
    }
    :global(.ipc-copy-btn--labeled) {
      width: auto;
      height: auto;
      min-height: 36px;
    }
  }

  :global(.ipc-warnings) {
    margin-bottom: 12px;
    padding: 10px 14px;
    border-radius: var(--radius-md);
    background: var(--color-warning-soft);
    box-shadow: inset 0 0 0 1px var(--color-warning);
    color: var(--color-warning-deep);
  }
  :global(.ipc-warnings__item) {
    font-size: 13px;
    line-height: 18px;
    text-wrap: pretty;
  }
  :global(.ipc-warnings__item + .ipc-warnings__item) {
    margin-top: 4px;
  }

  :global(.ipc-chips) {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }
  :global(.ipc-chip) {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    font-size: 12px;
    line-height: 18px;
    color: var(--color-brand-strong);
    text-decoration: none;
    transition: background 0.12s ease, box-shadow 0.12s ease;
  }
  :global(.ipc-chip:hover) {
    background: var(--color-brand-soft);
    box-shadow: inset 0 0 0 1px var(--color-brand);
  }

  :global(.ipc-bulk-note) {
    margin-bottom: 10px;
    font-size: 13px;
    line-height: 18px;
    color: var(--color-warning-deep);
    text-wrap: pretty;
  }
  :global(.ipc-bulk-bar) {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 10px;
  }
  :global(.ipc-bulk-scroll) {
    overflow-x: auto;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
  }
  :global(.ipc-bulk-table) {
    min-width: 640px;
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    line-height: 18px;
  }
  :global(.ipc-bulk-table th) {
    padding: 8px 12px;
    border-bottom: 1px solid var(--color-hairline);
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 16px;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    text-align: left;
    color: var(--color-mute);
  }
  :global(.ipc-bulk-table td) {
    padding: 7px 12px;
    border-bottom: 1px solid var(--color-hairline);
    vertical-align: top;
    color: var(--color-ink);
  }
  :global(.ipc-bulk-table tbody tr:last-child td) {
    border-bottom: none;
  }
  :global(.ipc-bulk-table td.is-mono) {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  :global(.ipc-bulk-status--ok) {
    color: var(--color-brand-strong);
  }
  :global(.ipc-bulk-status--fail) {
    color: var(--color-error-deep);
  }

  @keyframes ipc-rise {
    from {
      opacity: 0;
      transform: translateY(3px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.ipc-card) {
      animation: none;
    }
  }

  :global(.ipc-error) {
    display: flex;
    gap: 10px;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    background: var(--color-error-soft);
    box-shadow: inset 0 0 0 1px var(--color-error);
    color: var(--color-error-deep);
  }
  :global(.ipc-error__icon) {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
    margin-top: 1px;
  }
  :global(.ipc-error__title) {
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
  }
  :global(.ipc-error__detail) {
    margin-top: 2px;
    font-size: 13px;
    line-height: 18px;
    text-wrap: pretty;
  }
  :global(.ipc-empty) {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 64px;
    padding: 20px 16px;
    text-align: center;
    text-wrap: pretty;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
  }
</style>

<script>
  import { escapeHtml } from '../lib/escape-html';
  import { readIpHash, buildIpHash } from '../lib/ip-hash';
  import { copyTextToClipboard } from '../lib/clipboard';
  import { getRestoredLastInput, recordToolLastInput, wireSnapshotUI } from '../lib/tool-state/wire';

  type Row = { label: string; value: string; mono?: boolean; display?: string; isInput?: boolean };
  type Result = {
    valid: boolean;
    error?: string;
    version?: 4 | 6;
    detected?: string;
    rows: Row[];
    warnings?: string[];
  };
  type Example = { id: string; label: string; input: string };
  type EngineModule = { convert: (input: string) => Result };

  const ROOT_SEL = '.ipc-pg';
  const DEBOUNCE_MS = 140;
  const RESET_MS = 1800;
  const MAX_BULK_LINES = 1000;

  function boot(): void {
    document.querySelectorAll<HTMLElement>(ROOT_SEL).forEach((root) => {
      if (root.dataset.ipcWired === 'true') return;
      root.dataset.ipcWired = 'true';
      void init(root);
    });
  }

  function el<T extends HTMLElement>(root: HTMLElement, sel: string): T | null {
    return root.querySelector<T>(sel);
  }

  function normaliseExamples(raw: unknown): Example[] {
    if (!Array.isArray(raw)) return [];
    return raw
      .map((item, i) => {
        const o = (item ?? {}) as Record<string, unknown>;
        return {
          id: typeof o.id === 'string' && o.id ? o.id : `example-${i + 1}`,
          label: typeof o.label === 'string' && o.label ? o.label : `Example ${i + 1}`,
          input: typeof o.input === 'string' ? o.input : '',
        } satisfies Example;
      })
      .filter((e) => e.input.length > 0);
  }

  const ALERT_SVG =
    '<svg class="ipc-error__icon" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 2.5L18.5 17H1.5z"></path><path d="M10 8v4"></path><path d="M10 14.6v.01"></path></svg>';
  const COPY_ICON_SVG =
    '<svg class="ipc-copy-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="5" width="9" height="9" rx="1.5"/><path d="M3 11H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v1"/></svg>';
  const CHECK_ICON_SVG =
    '<svg class="ipc-check-icon hidden" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8.5l3.5 3.5L13 4.5"/></svg>';

  /** Prefix tool paths with the current locale (e.g. /de) so deep links stay in-locale. */
  function localePath(p: string): string {
    const m = window.location.pathname.match(/^\/(de|es|fr|pt-br)\//);
    return m ? `/${m[1]}${p}` : p;
  }

  /** Escape, then allow soft breaks after separators so long mono values wrap cleanly. */
  function monoHtml(s: string): string {
    return escapeHtml(s).replace(/([.:])/g, '$1<wbr>');
  }

  function copyBtnHtml(label: string, value: string): string {
    return (
      `<button class="ipc-copy-btn" type="button" aria-label="Copy ${escapeHtml(label)} value" data-copy="${escapeHtml(value)}">` +
      COPY_ICON_SVG +
      CHECK_ICON_SVG +
      '</button>'
    );
  }

  function setSummary(summary: HTMLElement, text: string, isError: boolean): void {
    summary.textContent = text;
    summary.classList.toggle('text-error-deep', isError);
    summary.classList.toggle('text-mute', !isError);
  }

  function renderEmpty(container: HTMLElement, summary: HTMLElement): void {
    setSummary(summary, '', false);
    container.innerHTML =
      '<p class="ipc-empty body-sm text-mute">Type an IP in any form or pick an example to see it in dotted decimal, integer, hex and binary here.</p>';
  }

  function renderError(
    container: HTMLElement,
    summary: HTMLElement,
    message: string,
    isAlert = false
  ): void {
    setSummary(summary, `Invalid — ${message}`, true);
    container.innerHTML =
      `<div class="ipc-error"${isAlert ? ' role="alert"' : ''}>` +
      ALERT_SVG +
      '<div><p class="ipc-error__title">Could not read that address</p>' +
      `<p id="ipc-error-detail" class="ipc-error__detail">${escapeHtml(message)}</p></div></div>`;
  }

  function renderResult(
    container: HTMLElement,
    summary: HTMLElement,
    result: Result,
    rawInput: string
  ): void {
    const version = result.version === 6 ? 'IPv6' : 'IPv4';
    const warnings = Array.isArray(result.warnings)
      ? result.warnings.filter((w): w is string => typeof w === 'string' && w.length > 0)
      : [];
    setSummary(
      summary,
      warnings.length
        ? `${version} — ${warnings.length} warning${warnings.length > 1 ? 's' : ''}`
        : version,
      false
    );

    const trimmedInput = rawInput.trim().toLowerCase();
    const rows = Array.isArray(result.rows) ? result.rows : [];
    const rowsHtml = rows
      .map((r) => {
        const label = typeof r.label === 'string' ? r.label : '';
        const value = typeof r.value === 'string' ? r.value : '';
        const shown = typeof r.display === 'string' && r.display ? r.display : value;
        const cls = r.mono ? 'ipc-row__v is-mono' : 'ipc-row__v';
        const shownHtml = r.mono ? monoHtml(shown) : escapeHtml(shown);
        const inputChip = r.isInput
          ? `<span class="ipc-chip-input">${value.toLowerCase() === trimmedInput ? 'input' : 'input format'}</span>`
          : '';
        const zoneLink =
          label === 'PTR name'
            ? `<a class="ipc-row__zone-link" href="${escapeHtml(localePath('/reverse-dns-ptr'))}">reverse zone →</a>`
            : '';
        return (
          '<div class="ipc-row">' +
          `<span class="ipc-row__k">${escapeHtml(label)}${inputChip}</span>` +
          `<span class="ipc-row__v-wrap"><span class="${cls}">${shownHtml}</span>${zoneLink}${copyBtnHtml(label, value)}</span></div>`
        );
      })
      .join('');

    const detected = result.detected ? `read as ${escapeHtml(result.detected)}` : '';
    const warnHtml = warnings.length
      ? `<div class="ipc-warnings">${warnings.map((w) => `<p class="ipc-warnings__item">${escapeHtml(w)}</p>`).join('')}</div>`
      : '';

    const canonical =
      result.version === 6
        ? rows.find((r) => r.label === 'Compressed')?.value
        : rows.find((r) => r.label === 'Dotted decimal')?.value;
    let chipsHtml = '';
    if (canonical) {
      const hash = buildIpHash(canonical);
      const chip = (href: string, text: string): string =>
        `<a class="ipc-chip" href="${escapeHtml(href)}">${text}</a>`;
      chipsHtml =
        '<div class="ipc-chips">' +
        chip(localePath('/subnet-calculator') + hash, 'Open in Subnet Calculator') +
        chip(localePath('/cidr-checker') + hash, 'Check against CIDRs') +
        chip(localePath('/reverse-dns-ptr') + hash, 'Build PTR record') +
        '</div>';
    }

    container.innerHTML =
      warnHtml +
      '<div class="ipc-card">' +
      `<div class="ipc-title"><span class="ipc-title__badge">${version}</span><span class="ipc-title__detected">${detected}</span></div>` +
      rowsHtml +
      '</div>' +
      chipsHtml;
  }

  async function init(root: HTMLElement): Promise<void> {
    const input = el<HTMLInputElement>(root, '#ipc-input');
    const exampleSel = el<HTMLSelectElement>(root, '#ipc-example');
    const exampleLabel = el<HTMLElement>(root, '#ipc-example-label');
    const exampleWrap = el<HTMLElement>(root, '#ipc-example-wrap');
    const singleWrap = el<HTMLElement>(root, '#ipc-single-wrap');
    const bulkWrap = el<HTMLElement>(root, '#ipc-bulk-wrap');
    const bulkInput = el<HTMLTextAreaElement>(root, '#ipc-bulk-input');
    const resultsBox = el<HTMLElement>(root, '#ipc-results');
    const summaryEl = el<HTMLElement>(root, '#ipc-summary');
    const shareBtn = el<HTMLButtonElement>(root, '#ipc-share');
    const copyStatus = el<HTMLElement>(root, '#ipc-copy-status');
    const snapSaveBtn = el<HTMLButtonElement>(root, '#ipc-snap-save');
    const snapSelect = el<HTMLSelectElement>(root, '#ipc-snap-select');
    const snapDeleteBtn = el<HTMLButtonElement>(root, '#ipc-snap-delete');
    if (
      !input ||
      !exampleSel ||
      !exampleLabel ||
      !exampleWrap ||
      !singleWrap ||
      !bulkWrap ||
      !bulkInput ||
      !resultsBox ||
      !summaryEl ||
      !shareBtn ||
      !copyStatus ||
      !snapSaveBtn ||
      !snapSelect ||
      !snapDeleteBtn
    ) {
      return;
    }

    let engine: EngineModule;
    let examples: Example[] = [];
    try {
      const [engineMod, examplesMod] = await Promise.all([
        import('../lib/ip-converter/engine'),
        import('../lib/ip-converter/examples'),
      ]);
      engine = engineMod as unknown as EngineModule;
      examples = normaliseExamples((examplesMod as { examples?: unknown }).examples);
    } catch (err) {
      renderError(
        resultsBox,
        summaryEl,
        'The converter engine failed to load. Reload the page to try again.',
        true
      );
      console.error('[IpConverter] engine import failed:', err);
      return;
    }

    exampleSel.innerHTML = '';
    const customOpt = document.createElement('option');
    customOpt.value = '-1';
    customOpt.textContent = examples.length ? 'Custom input' : 'No examples';
    exampleSel.appendChild(customOpt);
    examples.forEach((ex, i) => {
      const opt = document.createElement('option');
      opt.value = String(i);
      opt.textContent = ex.label;
      exampleSel.appendChild(opt);
    });
    if (!examples.length) exampleSel.disabled = true;

    /* ------------------------------------------------------------------ */
    /* Copy plumbing (shared by row buttons, Copy link, bulk Copy all)     */
    /* ------------------------------------------------------------------ */

    function setCopyStatus(message: string, failed: boolean): void {
      copyStatus!.textContent = message;
      copyStatus!.classList.toggle('sr-only', !failed);
      copyStatus!.classList.toggle('ipc-copy-status--fail', failed);
    }

    function setCopied(btn: HTMLButtonElement, copied: boolean): void {
      btn.classList.toggle('ipc-copy-btn--copied', copied);
      btn.querySelector('.ipc-copy-icon')?.classList.toggle('hidden', copied);
      btn.querySelector('.ipc-check-icon')?.classList.toggle('hidden', !copied);
      const label = btn.querySelector<HTMLElement>('.ipc-copy-label');
      if (label) {
        label.textContent = copied ? 'Copied' : (btn.dataset.copyLabel ?? 'Copy');
      } else if (copied) {
        btn.dataset.prevAriaLabel = btn.getAttribute('aria-label') ?? '';
        btn.setAttribute('aria-label', 'Copied');
      } else if (btn.dataset.prevAriaLabel) {
        btn.setAttribute('aria-label', btn.dataset.prevAriaLabel);
        delete btn.dataset.prevAriaLabel;
      }
    }

    async function handleCopy(btn: HTMLButtonElement): Promise<void> {
      const text = btn.dataset.copy ?? '';
      const ok = await copyTextToClipboard(text);
      if (ok) {
        setCopied(btn, true);
        setCopyStatus('Copied to clipboard.', false);
        window.clearTimeout(Number(btn.dataset.copyTimer));
        btn.dataset.copyTimer = String(
          window.setTimeout(() => {
            setCopied(btn, false);
            if (copyStatus!.textContent === 'Copied to clipboard.') setCopyStatus('', false);
          }, RESET_MS)
        );
      } else {
        setCopyStatus('Copy failed — select the value manually.', true);
      }
    }

    root.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.ipc-copy-btn');
      if (!btn) return;
      void handleCopy(btn);
    });

    /* ------------------------------------------------------------------ */
    /* Single mode                                                          */
    /* ------------------------------------------------------------------ */

    function setErrorState(on: boolean): void {
      input!.classList.toggle('ipc-input--error', on);
      if (on) {
        input!.setAttribute('aria-invalid', 'true');
        input!.setAttribute('aria-describedby', 'ipc-input-hint ipc-error-detail');
      } else {
        input!.removeAttribute('aria-invalid');
        input!.setAttribute('aria-describedby', 'ipc-input-hint');
      }
    }

    let lastWrittenHash: string | null = null;

    function writeHash(value: string | null): void {
      const target = value ? buildIpHash(value) : '';
      if (target === lastWrittenHash) return;
      // Safari throttles replaceState (~100/30s) and throws — never let that break input.
      try {
        if (value) {
          history.replaceState(null, '', target);
        } else {
          history.replaceState(null, '', location.pathname + location.search);
        }
        lastWrittenHash = target;
      } catch {
        /* ignore */
      }
    }

    function hideShare(): void {
      shareBtn!.hidden = true;
      shareBtn!.dataset.copy = '';
    }

    function evaluate(userInitiated: boolean): void {
      const value = input!.value.trim();
      if (value.length === 0) {
        setErrorState(false);
        hideShare();
        renderEmpty(resultsBox!, summaryEl!);
        if (userInitiated) writeHash(null);
        return;
      }
      const fail = (message: string): void => {
        setErrorState(true);
        hideShare();
        renderError(resultsBox!, summaryEl!, message);
        if (userInitiated) writeHash(null);
      };
      let result: Result | null = null;
      try {
        result = engine.convert(value);
      } catch {
        fail('Unexpected error while converting.');
        return;
      }
      if (!result || result.valid === false) {
        fail(result?.error ?? 'This is not a valid IP address.');
        return;
      }
      setErrorState(false);
      renderResult(resultsBox!, summaryEl!, result, value);
      shareBtn!.hidden = false;
      if (userInitiated) writeHash(value);
      if (userInitiated) recordToolLastInput('ip-address-converter', value);
      shareBtn!.dataset.copy =
        location.origin + location.pathname + location.search + buildIpHash(value);
    }

    /* ------------------------------------------------------------------ */
    /* Bulk mode                                                            */
    /* ------------------------------------------------------------------ */

    // Skip the rebuild when the normalized entry list is unchanged; reset on mode switch.
    let lastBulkEntriesKey: string | null = null;

    function evaluateBulk(): void {
      const entries = bulkInput!.value
        .split(/\r?\n/)
        .map((line) => line.trim())
        .filter((line) => line.length > 0 && !line.startsWith('#'));
      const entriesKey = entries.join('\n');
      if (entriesKey === lastBulkEntriesKey) return;
      lastBulkEntriesKey = entriesKey;
      if (!entries.length) {
        setSummary(summaryEl!, '', false);
        resultsBox!.innerHTML =
          '<p class="ipc-empty body-sm text-mute">Paste IPs — one per line. Blank lines and # comments are skipped.</p>';
        return;
      }

      const truncated = entries.length > MAX_BULK_LINES;
      const list = truncated ? entries.slice(0, MAX_BULK_LINES) : entries;
      let converted = 0;
      let failed = 0;
      const bodyHtml: string[] = [];
      const tsvLines = ['Input\tVersion\tCanonical\tInteger\tHexadecimal\tStatus'];

      for (const line of list) {
        let result: Result | null = null;
        try {
          result = engine.convert(line);
        } catch {
          result = null;
        }
        let version = '';
        let canonical = '';
        let integer = '';
        let hex = '';
        let status = '';
        const ok = Boolean(result && result.valid !== false);
        if (result && ok) {
          converted++;
          version = result.version === 6 ? 'IPv6' : 'IPv4';
          const rows = Array.isArray(result.rows) ? result.rows : [];
          const rowValue = (label: string): string =>
            rows.find((r) => r.label === label)?.value ?? '';
          canonical = result.version === 6 ? rowValue('Compressed') : rowValue('Dotted decimal');
          integer = rowValue('Integer (decimal)');
          hex = rowValue('Hexadecimal');
          const warnings = Array.isArray(result.warnings) ? result.warnings : [];
          status = warnings.length ? `OK — ${warnings.join('; ')}` : 'OK';
        } else {
          failed++;
          status = result?.error ?? 'Unexpected error while converting.';
        }
        tsvLines.push([line, version, canonical, integer, hex, status].join('\t'));
        const cell = (v: string, mono: boolean): string =>
          `<td class="${mono ? 'is-mono' : ''}">${v ? escapeHtml(v) : '—'}</td>`;
        bodyHtml.push(
          '<tr>' +
            cell(line, true) +
            cell(version, false) +
            cell(canonical, true) +
            cell(integer, true) +
            cell(hex, true) +
            `<td class="${ok ? 'ipc-bulk-status--ok' : 'ipc-bulk-status--fail'}">${escapeHtml(status)}</td>` +
            '</tr>'
        );
      }

      setSummary(summaryEl!, `${converted} converted, ${failed} failed`, false);

      const noteHtml = truncated
        ? `<p class="ipc-bulk-note">Only the first ${MAX_BULK_LINES} lines were converted — ${entries.length - MAX_BULK_LINES} more skipped.</p>`
        : '';
      const prevScrollLeft =
        resultsBox!.querySelector<HTMLElement>('.ipc-bulk-scroll')?.scrollLeft ?? 0;
      resultsBox!.innerHTML =
        noteHtml +
        '<div class="ipc-bulk-bar">' +
        '<button class="ipc-copy-btn ipc-copy-btn--labeled" type="button" data-copy="" data-copy-label="Copy all">' +
        COPY_ICON_SVG +
        CHECK_ICON_SVG +
        '<span class="ipc-copy-label">Copy all</span></button></div>' +
        '<div class="ipc-bulk-scroll"><table class="ipc-bulk-table">' +
        '<thead><tr><th>Input</th><th>Version</th><th>Canonical</th><th>Integer</th><th>Hexadecimal</th><th>Status</th></tr></thead>' +
        `<tbody>${bodyHtml.join('')}</tbody></table></div>`;
      // The delegated copy handler reads dataset.copy — set the raw TSV directly
      // instead of round-tripping tabs/newlines through the HTML attribute.
      const copyAllBtn = resultsBox!.querySelector<HTMLButtonElement>('.ipc-bulk-bar .ipc-copy-btn');
      if (copyAllBtn) copyAllBtn.dataset.copy = tsvLines.join('\n');
      const scrollBox = resultsBox!.querySelector<HTMLElement>('.ipc-bulk-scroll');
      if (scrollBox && prevScrollLeft) scrollBox.scrollLeft = prevScrollLeft;
    }

    /* ------------------------------------------------------------------ */
    /* Mode toggle                                                          */
    /* ------------------------------------------------------------------ */

    let mode: 'single' | 'bulk' = 'single';
    let timer: number | undefined;
    const modeBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('.ipc-mode-btn'));

    function setMode(next: 'single' | 'bulk'): void {
      if (mode === next) return;
      mode = next;
      window.clearTimeout(timer);
      lastBulkEntriesKey = null;
      const bulk = next === 'bulk';
      modeBtns.forEach((b) => {
        const active = (b.dataset.mode === 'bulk') === bulk;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
      exampleLabel!.hidden = bulk;
      exampleWrap!.hidden = bulk;
      singleWrap!.hidden = bulk;
      bulkWrap!.hidden = !bulk;
      if (bulk) {
        hideShare();
        // Carry the single value across the first time so nothing is lost.
        if (!bulkInput!.value.trim() && input!.value.trim()) bulkInput!.value = input!.value.trim();
        writeHash(null);
        evaluateBulk();
      } else {
        evaluate(false);
      }
    }

    modeBtns.forEach((b) => {
      b.addEventListener('click', () => setMode(b.dataset.mode === 'bulk' ? 'bulk' : 'single'));
    });

    /* ------------------------------------------------------------------ */
    /* Events                                                               */
    /* ------------------------------------------------------------------ */

    input.addEventListener('input', () => {
      if (exampleSel.value !== '-1') exampleSel.value = '-1';
      window.clearTimeout(timer);
      timer = window.setTimeout(() => evaluate(true), DEBOUNCE_MS);
    });
    input.addEventListener('keydown', (e) => {
      if (e.key !== 'Enter') return;
      e.preventDefault();
      window.clearTimeout(timer);
      evaluate(true);
      // Dismiss the on-screen keyboard so the result card is visible.
      if (window.matchMedia?.('(pointer: coarse)').matches) input.blur();
    });
    bulkInput.addEventListener('input', () => {
      window.clearTimeout(timer);
      timer = window.setTimeout(() => evaluateBulk(), DEBOUNCE_MS);
    });
    exampleSel.addEventListener('change', () => {
      const idx = Number(exampleSel.value);
      if (!Number.isInteger(idx) || idx < 0 || idx >= examples.length) return;
      input.value = examples[idx].input;
      window.clearTimeout(timer);
      evaluate(true);
    });

    wireSnapshotUI({
      slug: 'ip-address-converter',
      saveBtn: snapSaveBtn,
      snapshotSelect: snapSelect,
      deleteBtn: snapDeleteBtn,
      getValue: () => input!.value.trim(),
      setValue: (value) => {
        input!.value = value;
        exampleSel!.value = '-1';
        if (mode !== 'single') setMode('single');
        window.clearTimeout(timer);
        evaluate(true);
      },
    });

    /* ------------------------------------------------------------------ */
    /* First load: user-typed value > #ip= deep link > restored last input */
    /* > seeded example. None of these write the hash — only user-         */
    /* initiated evaluations do.                                           */
    /* ------------------------------------------------------------------ */

    const hashValue = readIpHash();
    const restored = getRestoredLastInput('ip-address-converter');

    if (input.value.trim()) {
      exampleSel.value = '-1';
      evaluate(false);
    } else if (hashValue) {
      input.value = hashValue;
      exampleSel.value = '-1';
      evaluate(false);
    } else if (restored) {
      input.value = restored;
      exampleSel.value = '-1';
      evaluate(false);
    } else if (examples[0]) {
      input.value = examples[0].input;
      exampleSel.value = '0';
      evaluate(false);
    } else {
      renderEmpty(resultsBox, summaryEl);
    }
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
