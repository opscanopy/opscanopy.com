---
/**
 * PrivacyProof — the homepage privacy section, told product-forward.
 *
 * Shared component (kills the 5-locale clone tax for this section): the
 * translated eyebrow / heading / body arrive via named slots, while the
 * distinctive part — a faux DevTools "Network" panel rendered as a dark-stable
 * instrument slab proving "0 bytes sent" — lives here once. The readout is
 * technical mono output (English in every locale, like the tool demos).
 */
---

<section id="privacy" class="section-pad bg-canvas" aria-labelledby="privacy-heading">
  <div class="container-page">
    <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[1fr_0.85fr] lg:gap-14">
      <div class="min-w-0">
        <p class="eyebrow"><slot name="eyebrow" /></p>
        <h2 id="privacy-heading" class="display-md mt-3 text-balance text-ink">
          <slot name="heading" />
        </h2>
        <p class="body-md mt-4 max-w-xl text-pretty text-body">
          <slot name="body" />
        </p>
      </div>

      {/* Instrument slab: a devtools Network panel that stays empty on purpose. */}
      <div class="pp-panel">
        <div class="pp-cap">
          <span class="pp-dots" aria-hidden="true"><i></i><i></i><i></i></span>
          <span class="pp-tab">Network</span>
        </div>
        <dl class="pp-readout">
          <div><dt>this page</dt><dd>1 request</dd></div>
          <div><dt>your input</dt><dd>0 bytes sent</dd></div>
          <div><dt>uploads</dt><dd>0</dd></div>
          <div><dt>cookies</dt><dd>0</dd></div>
          <div><dt>accounts</dt><dd>0</dd></div>
        </dl>
        <div class="pp-trust"><span class="pp-dot" aria-hidden="true"></span> all processing is local · 100% client-side</div>
      </div>
    </div>
  </div>
</section>

<style>
  .pp-panel {
    background: var(--color-inverse);
    color: var(--color-inverse-fg);
    border-radius: var(--radius-lg);
    border: 1px solid #ffffff1f;
    box-shadow: 0 24px 48px -24px #00000066, var(--shadow-hairline);
    overflow: hidden;
    width: 100%;
    max-width: 26rem;
    justify-self: center;
  }
  @media (min-width: 1024px) { .pp-panel { justify-self: end; } }
  .pp-cap {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 14px;
    border-bottom: 1px solid #ffffff1f;
    font-family: var(--font-mono);
    font-size: 12px;
    color: #b8b2a4;
  }
  .pp-dots { display: inline-flex; gap: 6px; }
  .pp-dots i { width: 11px; height: 11px; border-radius: 9999px; display: block; }
  .pp-dots i:nth-child(1) { background: #e0685f; }
  .pp-dots i:nth-child(2) { background: #e0b23f; }
  .pp-dots i:nth-child(3) { background: #63c079; }
  .pp-tab { margin-left: auto; opacity: 0.85; }
  .pp-readout {
    display: grid;
    grid-template-columns: auto 1fr;
    margin: 0;
    padding: 6px 18px 4px;
  }
  .pp-readout > div { display: contents; }
  .pp-readout dt,
  .pp-readout dd {
    padding: 8px 0;
    border-bottom: 1px solid #ffffff12;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .pp-readout dt { color: #b8b2a4; font-size: 12px; letter-spacing: 0.02em; }
  .pp-readout dd { color: #8fc97a; text-align: right; font-feature-settings: 'tnum'; }
  .pp-trust {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 18px 16px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: #b8b2a4;
  }
  .pp-dot {
    width: 7px;
    height: 7px;
    border-radius: 9999px;
    background: #8fc97a;
    flex: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .pp-dot { animation: pp-pulse 2.6s ease-in-out infinite; }
  }
  @keyframes pp-pulse {
    0% { box-shadow: 0 0 0 0 #8fc97a66; }
    70% { box-shadow: 0 0 0 7px #8fc97a00; }
    100% { box-shadow: 0 0 0 0 #8fc97a00; }
  }
</style>
