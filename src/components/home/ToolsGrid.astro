---
/**
 * ToolsGrid — the homepage catalog preview as a registry: a flagship tool cell
 * beside a dense mono index of the rest (man-page / registry feel), replacing
 * the uniform 3-col card grid. Shared component (markup lives once); translated
 * copy arrives via named slots + the `openLabel` prop, and tool data + hrefs are
 * localized here, so all 5 locale homepages drop the clone.
 */
import ToolArt from '../ToolArt.astro';
import Badge from '../Badge.astro';
import { categoryAccent } from '../../data/tools';
import { localizeKey } from '../../i18n/utils';
import { DEFAULT_LOCALE, type Locale } from '../../i18n/config';

interface ToolLike {
  slug: string;
  name: string;
  category: string;
  tagline: string;
}
interface Props {
  tools: ToolLike[];
  lang?: Locale;
  openLabel: string;
}
const { tools, lang = DEFAULT_LOCALE, openLabel } = Astro.props;
const toolsHref = localizeKey('/tools', lang);
const hrefFor = (slug: string) => localizeKey(`/${slug}`, lang);
const [flagship, ...rest] = tools;
---

<section class="section-pad-lg bg-canvas" aria-labelledby="tools-preview">
  <div class="container-page">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-2xl">
        <span class="eyebrow"><slot name="eyebrow">The Catalog</slot></span>
        <h2 id="tools-preview" class="display-lg mt-3 text-balance text-ink"><slot name="heading" /></h2>
        <p class="body-md mt-3 text-pretty text-body"><slot name="lead" /></p>
      </div>
      <a
        href={toolsHref}
        class="link-inline group body-md inline-flex shrink-0 items-center gap-1 whitespace-nowrap font-medium"
      >
        <slot name="seeAll" />
        <span aria-hidden="true" class="transition-transform duration-150 ease-out group-hover:translate-x-0.5">&rarr;</span>
      </a>
    </div>

    <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-[1.4fr_1fr]">
      {/* Flagship cell */}
      {
        flagship && (
          <a
            href={hrefFor(flagship.slug)}
            class="card-interactive group relative flex min-w-0 flex-col overflow-hidden rounded-lg bg-card shadow-soft"
          >
            <ToolArt slug={flagship.slug} accent={categoryAccent[flagship.category]} class="border-b border-hairline" />
            <div class="flex min-w-0 flex-1 flex-col p-6 sm:p-7">
              <div class="flex items-start justify-between gap-3">
                <h3 class="display-sm min-w-0 break-words text-ink" translate="no">{flagship.name}</h3>
                <Badge variant="live" class="shrink-0">Live</Badge>
              </div>
              <p class="caption mt-2 inline-flex items-center gap-1.5 font-medium uppercase tracking-wide text-body">
                <span aria-hidden="true" class="size-1.5 rounded-full" style={`background:${categoryAccent[flagship.category]}`} />
                {flagship.category}
              </p>
              <p class="body-md mt-4 flex-1 text-pretty text-body">{flagship.tagline}</p>
              <span class="body-sm mt-6 inline-flex items-center gap-1 font-medium text-link">
                {openLabel}
                <span aria-hidden="true" class="transition-transform duration-150 ease-out group-hover:translate-x-0.5">&rarr;</span>
              </span>
            </div>
          </a>
        )
      }

      {/* Registry index — the rest as dense mono rows */}
      <ul class="flex min-w-0 flex-col overflow-hidden rounded-lg border border-hairline bg-card">
        {
          rest.map((t, i) => (
            <li class="min-w-0">
              <a
                href={hrefFor(t.slug)}
                class="group flex items-center gap-3 border-b border-hairline px-4 py-3.5 transition-colors last:border-b-0 hover:bg-canvas-soft-2"
              >
                <span class="code-mono w-6 shrink-0 text-[11px] text-accent-ink" aria-hidden="true">
                  {String(i + 2).padStart(2, '0')}
                </span>
                <span class="body-sm min-w-0 truncate font-medium text-ink" translate="no">{t.name}</span>
                <span class="ml-auto hidden shrink-0 items-center gap-1.5 whitespace-nowrap font-mono text-[11px] uppercase tracking-wide text-mute sm:inline-flex">
                  <span aria-hidden="true" class="size-1.5 rounded-full" style={`background:${categoryAccent[t.category]}`} />
                  {t.category}
                </span>
                <span aria-hidden="true" class="shrink-0 text-mute transition-transform duration-150 ease-out group-hover:translate-x-0.5 group-hover:text-brand-strong">
                  &rarr;
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="mt-10 flex justify-center">
      <a
        href={toolsHref}
        class="group inline-flex items-center gap-2 rounded-md border border-hairline bg-canvas px-6 py-3 text-link shadow-soft transition-colors duration-150 ease-out hover:border-brand-strong"
      >
        <span class="body-md font-medium"><slot name="browseAll" /></span>
        <span aria-hidden="true" class="transition-transform duration-150 ease-out group-hover:translate-x-0.5">&rarr;</span>
      </a>
    </div>
  </div>
</section>
