---
/**
 * ProofStrip — the homepage trust/value band, extracted to a shared component
 * (its markup previously lived in all 5 locale index files). The translated
 * `principles` data + section aria-label arrive as props; the field-manual
 * layout — a dense bordered readout with amber mono indices (matching
 * ToolPipeline) instead of decorative icon chips — lives here once.
 */
interface Principle {
  label: string;
  title: string;
  body: string;
  icon?: string;
}
interface Props {
  principles: Principle[];
  ariaLabel: string;
}
const { principles, ariaLabel } = Astro.props;
---

<section class="section-pad-sm bg-canvas" aria-label={ariaLabel}>
  <div class="container-page">
    <ul class="grid grid-cols-1 gap-x-8 gap-y-8 border-t border-hairline pt-12 sm:grid-cols-2 lg:grid-cols-4 sm:pt-14">
      {
        principles.map((p, i) => (
          <li class="flex min-w-0 flex-col gap-1.5 sm:[&:not(:first-child)]:border-l sm:[&:not(:first-child)]:border-hairline sm:[&:not(:first-child)]:pl-8">
            <span class="code-mono text-[13px] text-accent-ink" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="eyebrow">{p.label}</span>
            <span class="body-md font-medium text-ink">{p.title}</span>
            <span class="body-sm text-pretty text-mute">{p.body}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
