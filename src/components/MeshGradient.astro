---
/**
 * MeshGradient — the brand's signature multi-color mesh gradient backdrop.
 *
 * This is the ONLY decorative chrome in the OpsCanopy system and lives at HERO
 * scale only (never miniaturised, never reduced to a single color). It composes
 * the three brand gradient pairs — develop (#007cf0 → #00dfd8), preview
 * (#7928ca → #ff0080), and ship (#ff4d4d → #f9cb28) — as a field of soft,
 * heavily-blurred, partially-transparent radial blobs so the result reads as
 * ambient light rather than a solid block.
 *
 * It renders an aria-hidden decorative element. The CONSUMER is responsible for
 * positioning it behind content, e.g.:
 *   <div class="relative isolate overflow-hidden">
 *     <MeshGradient class="absolute inset-0 -z-10" />
 *     …hero content…
 *   </div>
 *
 * A very subtle slow drift animates only transform/opacity (no layout thrash)
 * and is fully disabled under prefers-reduced-motion.
 */
export interface Props {
  /** Extra classes for positioning/sizing from the consumer (e.g. "absolute inset-0 -z-10"). */
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['mesh', className]} aria-hidden="true">
  <span class="mesh__blob mesh__blob--develop"></span>
  <span class="mesh__blob mesh__blob--preview"></span>
  <span class="mesh__blob mesh__blob--ship"></span>
</div>

<style>
  /* Brand gradient stops are inlined as literal hex so this component is
     self-contained and does not depend on theme-var resolution. */

  .mesh {
    position: relative;
    overflow: hidden;
    pointer-events: none;
    /* Layered radial blobs painted directly on the container as the base
       atmospheric field — soft edges, partial transparency. */
    background-image:
      radial-gradient(38% 52% at 24% 30%, rgba(0, 124, 240, 0.55) 0%, rgba(0, 124, 240, 0) 70%),
      radial-gradient(40% 50% at 70% 24%, rgba(0, 223, 216, 0.5) 0%, rgba(0, 223, 216, 0) 70%),
      radial-gradient(44% 56% at 52% 70%, rgba(121, 40, 202, 0.45) 0%, rgba(121, 40, 202, 0) 72%),
      radial-gradient(40% 52% at 82% 64%, rgba(255, 0, 128, 0.42) 0%, rgba(255, 0, 128, 0) 70%),
      radial-gradient(46% 56% at 18% 74%, rgba(255, 77, 77, 0.4) 0%, rgba(255, 77, 77, 0) 72%),
      radial-gradient(38% 48% at 64% 12%, rgba(249, 203, 40, 0.42) 0%, rgba(249, 203, 40, 0) 70%);
    background-repeat: no-repeat;
    /* Softens the whole base field into ambient light. */
    filter: blur(48px) saturate(112%);
    /* Promote to its own compositing layer so the blurred field + drifting
       children composite together without repainting (no permanent
       will-change hint on this static container — only the blobs animate). */
    transform: translateZ(0);
  }

  /* Three drifting accent blobs — one per brand pair — float above the base
     field to give the gradient gentle, organic life. Each is a soft conic-free
     radial blob, heavily blurred and semi-transparent. */
  .mesh__blob {
    position: absolute;
    border-radius: 9999px;
    opacity: 0.7;
    filter: blur(64px);
    will-change: transform, opacity;
    transform: translateZ(0);
  }

  .mesh__blob--develop {
    top: -12%;
    left: -8%;
    width: 60%;
    height: 60%;
    background: radial-gradient(
      circle at 50% 50%,
      #007cf0 0%,
      #00dfd8 45%,
      rgba(0, 223, 216, 0) 72%
    );
    animation: mesh-drift-a 26s ease-in-out infinite alternate;
  }

  .mesh__blob--preview {
    top: 24%;
    right: -12%;
    width: 62%;
    height: 66%;
    background: radial-gradient(
      circle at 50% 50%,
      #7928ca 0%,
      #ff0080 48%,
      rgba(255, 0, 128, 0) 74%
    );
    animation: mesh-drift-b 32s ease-in-out infinite alternate;
  }

  .mesh__blob--ship {
    bottom: -16%;
    left: 18%;
    width: 64%;
    height: 64%;
    background: radial-gradient(
      circle at 50% 50%,
      #ff4d4d 0%,
      #f9cb28 50%,
      rgba(249, 203, 40, 0) 74%
    );
    animation: mesh-drift-c 38s ease-in-out infinite alternate;
  }

  /* Slow, low-amplitude drift — transform + opacity only (compositor-friendly). */
  @keyframes mesh-drift-a {
    0% {
      transform: translate3d(0, 0, 0) scale(1);
      opacity: 0.62;
    }
    100% {
      transform: translate3d(6%, 4%, 0) scale(1.08);
      opacity: 0.78;
    }
  }

  @keyframes mesh-drift-b {
    0% {
      transform: translate3d(0, 0, 0) scale(1.04);
      opacity: 0.72;
    }
    100% {
      transform: translate3d(-5%, 6%, 0) scale(0.96);
      opacity: 0.58;
    }
  }

  @keyframes mesh-drift-c {
    0% {
      transform: translate3d(0, 0, 0) scale(0.98);
      opacity: 0.6;
    }
    100% {
      transform: translate3d(4%, -5%, 0) scale(1.1);
      opacity: 0.74;
    }
  }

  /* Honor reduced-motion: hold the blobs perfectly still and release the
     compositing hint (nothing animates, so the GPU layer is unnecessary). */
  @media (prefers-reduced-motion: reduce) {
    .mesh__blob {
      animation: none;
      will-change: auto;
    }
  }
</style>
