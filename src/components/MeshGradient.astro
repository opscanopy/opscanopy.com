---
/**
 * CanopyField — the brand's signature backdrop texture (Field Manual system).
 *
 * NOTE: the file is still named MeshGradient.astro so its ~10 consumers keep
 * working with zero import churn; a mechanical rename to CanopyField.astro is a
 * later cleanup. The old multi-color mesh blobs are retired — they were the peak
 * "AI-generated site" tell. This replacement is an ARC LATTICE derived from the
 * OpsCanopy logo's three nested canopy arcs, tiled as a fine engineering-grid
 * field and faded through a top-biased radial mask. It reads as blueprint /
 * topographic texture, themes automatically (drawn in `currentColor` off the ink
 * token), costs ~1.5KB, is fully static (reduced-motion-safe by construction),
 * and carries no scanline (CRT residue would contradict the paper metaphor).
 *
 * Same contract as before — an aria-hidden decorative element the CONSUMER
 * positions behind content:
 *   <div class="relative isolate overflow-hidden">
 *     <MeshGradient class="absolute inset-0 -z-10" />
 *     …hero content…
 *   </div>
 * The `class` prop (positioning + any opacity-* utility) is applied to the root.
 */
export interface Props {
  /** Extra classes for positioning/sizing from the consumer (e.g. "absolute inset-0 -z-10"). */
  class?: string;
}

const { class: className } = Astro.props;

// Per-instance ids so multiple CanopyFields on one page never collide on
// <pattern>/<mask> ids. Build-time only; no client JS, so no hydration concern.
const uid = Math.random().toString(36).slice(2, 8);
const tileId = `cf-tile-${uid}`;
const maskId = `cf-mask-${uid}`;
const fadeId = `cf-fade-${uid}`;
---

<div class:list={['canopy-field', className]} aria-hidden="true">
  <svg
    class="canopy-field__svg"
    width="100%"
    height="100%"
    preserveAspectRatio="xMidYMid slice"
    focusable="false"
  >
    <defs>
      <!-- One tile = three nested canopy domes (the logo's arc family). Tiled,
           it becomes a lattice of sheltering arcs. -->
      <pattern id={tileId} width="72" height="60" patternUnits="userSpaceOnUse">
        <g fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round">
          <path d="M8 40 C 16 16, 56 16, 64 40" />
          <path d="M16 42 C 22 25, 50 25, 56 42" opacity="0.85" />
          <path d="M24 44 C 28 33, 44 33, 48 44" opacity="0.7" />
        </g>
      </pattern>
      <!-- Top-biased fade so the texture is strongest near section tops and
           dissolves before dense content below. -->
      <radialGradient id={fadeId} cx="50%" cy="0%" r="120%">
        <stop offset="0%" stop-color="#fff" stop-opacity="1" />
        <stop offset="42%" stop-color="#fff" stop-opacity="0.7" />
        <stop offset="82%" stop-color="#fff" stop-opacity="0" />
      </radialGradient>
      <mask id={maskId}>
        <rect x="0" y="0" width="100%" height="100%" fill={`url(#${fadeId})`} />
      </mask>
    </defs>
    <rect x="0" y="0" width="100%" height="100%" fill={`url(#${tileId})`} mask={`url(#${maskId})`} />
  </svg>
</div>

<style>
  .canopy-field {
    pointer-events: none;
    overflow: hidden;
    /* Arcs inherit this via currentColor — ink-derived, so it themes itself.
       Kept faint so it reads as texture, not content. */
    color: color-mix(in srgb, var(--color-ink) 34%, transparent);
  }
  .canopy-field__svg {
    display: block;
    width: 100%;
    height: 100%;
  }
  /* Dark theme: ink is light, so arcs already invert. Trim intensity a touch so
     it stays ambient on the warm charcoal canvas. */
  :global(html[data-theme='dark']) .canopy-field {
    color: color-mix(in srgb, var(--color-ink) 22%, transparent);
  }
</style>
