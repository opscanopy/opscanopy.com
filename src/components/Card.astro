---
/**
 * Card — typed wrapper over the brand card chrome (global.css `.card` / `.card-soft`).
 *
 * Variants map to FULL literal class strings (Tailwind v4 scans source as text,
 * so no runtime-concatenated fragments):
 *   - marketing → "card p-6"            (canvas, rounded-md, Level-2 subtle stack)
 *   - large     → "card p-8 rounded-lg" (canvas, rounded-lg, Level-2 stack, roomier)
 *   - soft      → "card-soft p-6"       (canvas-soft, rounded-md, inset hairline)
 *
 * When `href` is set the whole card becomes a single <a> link with a subtle hover
 * lift (transform + box-shadow only, reduced-motion safe). Otherwise it renders a
 * non-interactive <div>. Content goes in the default slot; optional "media" (top)
 * and "footer" (bottom) named slots are rendered only when filled.
 */
export interface Props {
  variant?: 'marketing' | 'large' | 'soft';
  href?: string;
  class?: string;
}

const { variant = 'marketing', href, class: className } = Astro.props;

const VARIANT_CLASS: Record<NonNullable<Props['variant']>, string> = {
  marketing: 'card p-6',
  large: 'card p-8 rounded-lg',
  soft: 'card-soft p-6',
};

const base = VARIANT_CLASS[variant];
const isLink = typeof href === 'string' && href.length > 0;

// Whole-card link affordance: block layout + subtle hover lift handled in <style>.
const classList = [base, isLink ? 'card-link' : null, className]
  .filter(Boolean)
  .join(' ');

const hasMedia = Astro.slots.has('media');
const hasFooter = Astro.slots.has('footer');
---

{
  isLink ? (
    <a href={href} class={classList}>
      {hasMedia && (
        <div class="card-media">
          <slot name="media" />
        </div>
      )}
      <slot />
      {hasFooter && (
        <div class="card-footer">
          <slot name="footer" />
        </div>
      )}
    </a>
  ) : (
    <div class={classList}>
      {hasMedia && (
        <div class="card-media">
          <slot name="media" />
        </div>
      )}
      <slot />
      {hasFooter && (
        <div class="card-footer">
          <slot name="footer" />
        </div>
      )}
    </div>
  )
}

<style>
  @reference '../styles/global.css';

  /* Whole-card link: inherit text color, no underline, lift on hover. */
  .card-link {
    display: block;
    color: inherit;
    text-decoration: none;
    /* Kill tap delay / double-tap zoom on the whole-card tap target. */
    touch-action: manipulation;
    /* Animate only transform + box-shadow (never `all`); reduced-motion handled
       globally in global.css base layer. */
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .card-link:hover {
    transform: translateY(-2px);
    /* Upgrade elevation one step on hover (subtle → float). */
    box-shadow: var(--shadow-float);
  }

  /* Tactile press — settle back down on click (transform only). */
  .card-link:active {
    transform: translateY(0);
  }

  /* Let the global :focus-visible ring hug the card's own corner radius
     (md/lg) instead of the default 4px, and clear the chrome — never strip it. */
  .card-link:focus-visible {
    border-radius: inherit;
    outline-offset: 3px;
  }

  /* Media cap sits flush above the body copy. */
  .card-media {
    margin-bottom: 1rem;
  }

  /* Footer separated from body with a touch of breathing room. */
  .card-footer {
    margin-top: 1rem;
  }
</style>
