---
/**
 * ToolArt — the per-tool mini-scene illustration tile.
 *
 * Renders the transparent illustration at public/tool-art/<slug>.svg on a soft,
 * category-tinted backdrop (so it reads on both light and dark themes). Used by
 * the homepage tool grid + hero preview, ToolCard (catalog / category pages),
 * and ToolHero (detail header). Path is derived from the slug — no registry
 * field needed. Place inside a `group` element to get the hover zoom.
 */
interface Props {
  slug: string;
  /** Category accent hex (from categoryAccent) — tints the backdrop. */
  accent: string;
  /** Extra classes on the tile wrapper (e.g. rounded corners to match the card). */
  class?: string;
  /** Eager-load (above-the-fold hero); defaults to lazy. */
  eager?: boolean;
  /** Decorative by default; pass a label when the tile is the only thing naming the tool. */
  alt?: string;
}
const { slug, accent, class: className, eager = false, alt = '' } = Astro.props;
---

<div
  class:list={[
    'flex aspect-[2/1] items-center justify-center overflow-hidden p-5',
    className,
  ]}
  style={`background: color-mix(in srgb, ${accent} 8%, transparent)`}
>
  <img
    src={`/tool-art/${slug}.svg`}
    alt={alt}
    width="400"
    height="200"
    loading={eager ? 'eager' : 'lazy'}
    fetchpriority={eager ? 'high' : 'auto'}
    decoding="async"
    class="h-full w-full object-contain transition-transform duration-300 ease-out group-hover:scale-[1.05] motion-reduce:transform-none"
  />
</div>
