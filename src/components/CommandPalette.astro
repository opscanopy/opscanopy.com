---
/**
 * CommandPalette — global Ctrl/⌘+K quick-jump to any live tool.
 *
 * Mounted once per page (in Header.astro, alongside MegaMenu). The dialog
 * shell below is cheap, static markup rendered on every page; the matcher
 * (../lib/palette/match), the tool registry (../data/tools), tool-prefs
 * (pin/recency boost), and the leaf ../i18n/paths module are all dynamically
 * imported on FIRST open, so none of that ships in the page's initial JS.
 *
 * Also opened by a custom `opencommandpalette` window event — dispatched by
 * ToolCrossLinks' brand-recall hint button, so mouse-only users have a way
 * in besides the keyboard shortcut.
 */
import { useTranslations } from '../i18n/utils';
import { DEFAULT_LOCALE, type Locale } from '../i18n/config';

const lang: Locale = (Astro.currentLocale as Locale) ?? DEFAULT_LOCALE;
const t = useTranslations(lang);
---

<div id="cmdk-backdrop" class="cmdk-backdrop" hidden></div>
<div id="cmdk" role="dialog" aria-modal="true" aria-label={t('palette.dialogLabel')} class="cmdk" hidden>
  <div class="cmdk-panel">
    <div class="cmdk-input-row">
      <svg
        class="cmdk-search-icon"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.35-4.35"></path>
      </svg>
      <input
        id="cmdk-input"
        type="text"
        class="cmdk-input"
        placeholder={t('palette.placeholder')}
        aria-label={t('palette.searchLabel')}
        autocomplete="off"
        spellcheck="false"
        role="combobox"
        aria-expanded="true"
        aria-controls="cmdk-results"
        aria-autocomplete="list"
      />
      <kbd class="cmdk-kbd">Esc</kbd>
    </div>
    <div id="cmdk-results" class="cmdk-results" role="listbox" aria-label={t('palette.searchLabel')}></div>
    <p id="cmdk-empty" class="cmdk-empty" hidden>{t('palette.empty')}</p>
    <div class="cmdk-footer">
      <span class="cmdk-footer-hint"><kbd class="cmdk-kbd">&uarr;</kbd><kbd class="cmdk-kbd">&darr;</kbd> {t('palette.hintNav')}</span>
      <span class="cmdk-footer-hint"><kbd class="cmdk-kbd">&crarr;</kbd> {t('palette.hintSelect')}</span>
      <span class="cmdk-footer-hint"><kbd class="cmdk-kbd">Esc</kbd> {t('palette.hintClose')}</span>
    </div>
  </div>
</div>

<style>
  @reference "../styles/global.css";

  .cmdk-backdrop {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: rgba(0, 0, 0, 0.4);
  }

  .cmdk {
    position: fixed;
    inset: 0;
    z-index: 61;
    display: flex;
    justify-content: center;
    padding: 12vh 16px 0;
    pointer-events: none;
  }

  .cmdk-panel {
    width: 100%;
    max-width: 560px;
    max-height: min(60vh, 480px);
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg, var(--radius-md));
    background: var(--color-canvas);
    box-shadow: var(--shadow-modal);
    overflow: hidden;
    pointer-events: auto;
    animation: cmdk-in 0.14s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes cmdk-in {
    from {
      opacity: 0;
      transform: translateY(-6px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .cmdk-panel {
      animation: none;
    }
  }

  .cmdk-input-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-hairline);
  }
  .cmdk-search-icon {
    flex: 0 0 auto;
    color: var(--color-mute);
  }
  .cmdk-input {
    flex: 1 1 auto;
    min-width: 0;
    border: none;
    background: transparent;
    color: var(--color-ink);
    font-size: 15px;
    line-height: 24px;
  }
  .cmdk-input:focus {
    outline: none;
  }
  .cmdk-input::placeholder {
    color: var(--color-mute);
  }
  .cmdk-kbd {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 5px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas-soft);
    box-shadow: var(--shadow-hairline);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-mute);
  }

  .cmdk-results {
    flex: 1 1 auto;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 6px;
  }
  .cmdk-empty {
    padding: 28px 16px;
    text-align: center;
    font-size: 14px;
    color: var(--color-mute);
  }

  :global(.cmdk-item) {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    text-decoration: none;
  }
  :global(.cmdk-item.is-active) {
    background: var(--color-canvas-soft-2, var(--color-hairline));
  }
  :global(.cmdk-item-name) {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-ink);
  }
  :global(.cmdk-item-tagline) {
    font-size: 12.5px;
    color: var(--color-mute);
    text-overflow: ellipsis;
    overflow: hidden;
    white-space: nowrap;
  }

  .cmdk-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    padding: 8px 14px;
    border-top: 1px solid var(--color-hairline);
    background: var(--color-canvas-soft);
  }
  .cmdk-footer-hint {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11.5px;
    color: var(--color-mute);
  }

  @media (max-width: 640px) {
    .cmdk {
      padding-top: 8vh;
    }
    .cmdk-footer .cmdk-footer-hint:first-child {
      display: none;
    }
  }
</style>

<script>
  import type { PaletteItem, PaletteMatch } from '../lib/palette/match';

  const KNOWN_LOCALES = ['en', 'es', 'de', 'fr', 'pt-br'];

  type Boost = { pinned?: string[]; recents?: string[] };
  type ToolMeta = { name: string; tagline: string; category: string };

  let wired = false;
  let loaded = false;
  let loading: Promise<void> | null = null;

  let matchPaletteFn:
    | ((items: PaletteItem[], query: string, boost?: Boost) => PaletteMatch[])
    | null = null;
  let localizeKeyFn: ((key: string, locale: string) => string) | null = null;
  let paletteItems: PaletteItem[] = [];
  let toolMeta = new Map<string, ToolMeta>();
  let boost: Boost = {};
  let locale = 'en';

  let activeIndex = -1;
  let currentIds: string[] = [];

  function el<T extends HTMLElement>(id: string): T | null {
    return document.getElementById(id) as T | null;
  }

  const backdrop = el<HTMLElement>('cmdk-backdrop');
  const dialog = el<HTMLElement>('cmdk');
  const input = el<HTMLInputElement>('cmdk-input');
  const resultsEl = el<HTMLElement>('cmdk-results');
  const emptyEl = el<HTMLElement>('cmdk-empty');

  function currentDocLocale(): string {
    const raw = (document.documentElement.getAttribute('lang') || 'en').toLowerCase();
    return KNOWN_LOCALES.includes(raw) ? raw : 'en';
  }

  function escapeHtmlLite(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  async function ensureLoaded(): Promise<void> {
    if (loaded) return;
    if (loading) return loading;
    loading = (async () => {
      const [matchMod, toolsMod, prefsMod, pathsMod] = await Promise.all([
        import('../lib/palette/match'),
        import('../data/tools'),
        import('../lib/tool-prefs/prefs'),
        import('../i18n/paths'),
      ]);
      matchPaletteFn = matchMod.matchPalette;
      localizeKeyFn = pathsMod.localizeKey as (key: string, locale: string) => string;
      paletteItems = toolsMod.liveTools.map((tool) => ({
        id: tool.slug,
        name: tool.name,
        keywords: tool.keywords,
        tagline: tool.tagline,
        category: tool.category,
      }));
      toolMeta = new Map(
        toolsMod.liveTools.map((tool) => [
          tool.slug,
          { name: tool.name, tagline: tool.tagline, category: tool.category },
        ]),
      );
      let prefs;
      try {
        prefs = prefsMod.parseToolPrefs(localStorage.getItem(prefsMod.TOOL_PREFS_KEY));
      } catch {
        prefs = prefsMod.parseToolPrefs(null);
      }
      boost = { pinned: prefs.pins, recents: prefs.recents.map((r) => r.slug) };
      locale = currentDocLocale();
      loaded = true;
    })();
    return loading;
  }

  function renderEmpty(): void {
    if (resultsEl) resultsEl.innerHTML = '';
    if (emptyEl) emptyEl.hidden = false;
    currentIds = [];
    activeIndex = -1;
  }

  function renderResults(query: string): void {
    if (!matchPaletteFn || !localizeKeyFn || !resultsEl) return;
    const matches = matchPaletteFn(paletteItems, query, boost).slice(0, 8);
    if (matches.length === 0) {
      renderEmpty();
      return;
    }
    if (emptyEl) emptyEl.hidden = true;
    currentIds = matches.map((m) => m.id);
    activeIndex = 0;
    resultsEl.innerHTML = matches
      .map((m, i) => {
        const meta = toolMeta.get(m.id);
        if (!meta) return '';
        const href = localizeKeyFn!(`/${m.id}`, locale);
        return (
          `<a href="${href}" id="cmdk-opt-${i}" role="option" aria-selected="${i === 0}" class="cmdk-item${i === 0 ? ' is-active' : ''}" data-idx="${i}">` +
          `<span class="cmdk-item-name">${escapeHtmlLite(meta.name)}</span>` +
          `<span class="cmdk-item-tagline">${escapeHtmlLite(meta.tagline)}</span>` +
          `</a>`
        );
      })
      .join('');
  }

  function setActive(idx: number): void {
    if (!resultsEl || currentIds.length === 0) return;
    const clamped = ((idx % currentIds.length) + currentIds.length) % currentIds.length;
    activeIndex = clamped;
    resultsEl.querySelectorAll<HTMLElement>('.cmdk-item').forEach((elm) => {
      const isActive = elm.dataset.idx === String(clamped);
      elm.classList.toggle('is-active', isActive);
      elm.setAttribute('aria-selected', String(isActive));
    });
    resultsEl.querySelector<HTMLElement>(`[data-idx="${clamped}"]`)?.scrollIntoView({ block: 'nearest' });
    input?.setAttribute('aria-activedescendant', `cmdk-opt-${clamped}`);
  }

  function focusables(): HTMLElement[] {
    if (!dialog) return [];
    return Array.from(dialog.querySelectorAll<HTMLElement>('a[href], input, button:not([disabled])'));
  }

  function isOpen(): boolean {
    return !!dialog && !dialog.hidden;
  }

  async function openPalette(): Promise<void> {
    if (!dialog || !backdrop || !input) return;
    await ensureLoaded();
    backdrop.hidden = false;
    dialog.hidden = false;
    document.documentElement.style.overflow = 'hidden';
    input.value = '';
    renderResults('');
    setTimeout(() => input.focus(), 10);
  }

  function closePalette(): void {
    if (!dialog || !backdrop) return;
    dialog.hidden = true;
    backdrop.hidden = true;
    document.documentElement.style.overflow = '';
  }

  function boot(): void {
    if (wired) return;
    wired = true;

    document.addEventListener('keydown', (e) => {
      const key = e.key.toLowerCase();
      if ((e.metaKey || e.ctrlKey) && key === 'k') {
        e.preventDefault();
        if (isOpen()) closePalette();
        else void openPalette();
        return;
      }
      if (!isOpen()) return;

      if (e.key === 'Escape') {
        e.preventDefault();
        closePalette();
        return;
      }
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActive(activeIndex + 1);
        return;
      }
      if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActive(activeIndex - 1);
        return;
      }
      if (e.key === 'Enter' && document.activeElement === input && currentIds.length > 0) {
        e.preventDefault();
        resultsEl?.querySelector<HTMLAnchorElement>(`[data-idx="${activeIndex}"]`)?.click();
        return;
      }
      if (e.key === 'Tab') {
        const tabbable = focusables();
        if (tabbable.length === 0) return;
        const first = tabbable[0];
        const last = tabbable[tabbable.length - 1];
        const active = document.activeElement;
        if (e.shiftKey && active === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && active === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    backdrop?.addEventListener('click', closePalette);
    input?.addEventListener('input', () => renderResults(input.value));
    window.addEventListener('opencommandpalette', () => void openPalette());
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
