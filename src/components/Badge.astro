---
/**
 * Badge — inline status pill for tool-catalog rows (homepage + /tools).
 * Base `.badge` chrome (canvas-soft fill, hairline ring, 12px) plus a tiny
 * leading status dot and a label supplied via the default slot.
 *
 * Variants map to FULL literal class strings (Tailwind v4 scans source as text,
 * so no runtime concatenation of fragments).
 */
export interface Props {
  variant?: 'neutral' | 'live' | 'beta' | 'planned' | 'high' | 'medium';
  class?: string;
}

const { variant = 'neutral', class: className = '' } = Astro.props;

/* Each variant resolves to a complete, static class string. */
const dotClass: Record<NonNullable<Props['variant']>, string> = {
  neutral: 'bg-mute',
  live: 'bg-link',
  beta: 'bg-warning',
  planned: 'bg-hairline-strong',
  high: 'bg-error',
  medium: 'bg-warning',
};

const textClass: Record<NonNullable<Props['variant']>, string> = {
  neutral: 'text-body',
  live: 'text-link',
  beta: 'text-warning-deep',
  planned: 'text-mute',
  high: 'text-error-deep',
  medium: 'text-warning-deep',
};
---

<span class:list={['badge whitespace-nowrap align-middle', textClass[variant], className]}>
  <span
    class:list={['inline-block size-1.5 shrink-0 rounded-full', dotClass[variant]]}
    aria-hidden="true"
  ></span>
  <slot />
</span>
