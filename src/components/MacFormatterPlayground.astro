---
/**
 * MacFormatterPlayground — the interactive MAC Address Formatter island.
 *
 * Single-input, live tool: type a MAC address in any common form (colon,
 * hyphen, Cisco dotted, or bare hex) and every representation is rendered,
 * along with the OUI, transmission/administration bits, and the derived IPv6
 * link-local (modified EUI-64). No button, fully client-side.
 *
 * Runtime contract (lazy-imported):
 *   ../lib/mac-formatter/engine   → format(input: string): MacResult
 *   ../lib/mac-formatter/examples → examples: { id; label; input }[]
 */
---

<section class="mac-pg" aria-label="MAC Address Formatter playground">
  <div class="card shadow-float overflow-hidden rounded-lg">
    <div class="flex flex-col gap-1 border-b border-hairline px-4 py-3 sm:px-5">
      <label class="eyebrow shrink-0" for="mac-example">Example</label>
      <div class="mac-select-wrap relative min-w-0">
        <select id="mac-example" class="mac-select code-mono" autocomplete="off">
          <option value="">Loading examples…</option>
        </select>
        <svg
          class="mac-select-caret pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-mute"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 6l4 4 4-4"></path>
        </svg>
      </div>
    </div>

    <div class="border-b border-hairline px-4 py-4 sm:px-5">
      <label class="eyebrow mb-2 block" for="mac-input">MAC address <span class="mac-sample-cue">(sample)</span></label>
      <div class="mac-input-wrap">
        <svg
          class="mac-input-icon pointer-events-none"
          viewBox="0 0 20 20"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 10h12M10 4v12"></path>
          <circle cx="10" cy="10" r="7.25"></circle>
        </svg>
        <input
          id="mac-input"
          type="text"
          class="mac-input code-mono"
          spellcheck="false"
          autocapitalize="off"
          autocorrect="off"
          autocomplete="off"
          placeholder="00:1a:2b:3c:4d:5e"
          aria-describedby="mac-input-hint"
        />
      </div>
      <p id="mac-input-hint" class="mac-hint caption text-mute">
        Any form — colon <span class="code-mono">00:1a:2b:3c:4d:5e</span>, hyphen
        <span class="code-mono">00-1A-2B-3C-4D-5E</span>, Cisco dot
        <span class="code-mono">001a.2b3c.4d5e</span>, or bare <span class="code-mono">001a2b3c4d5e</span>.
      </p>
      <div class="mac-snap-row mt-3 flex flex-wrap items-center gap-2">
        <button id="mac-snap-save" type="button" class="mac-snap-btn">Save snapshot</button>
        <select id="mac-snap-select" class="mac-snap-select" aria-label="Load a saved snapshot" disabled>
          <option value="">No snapshots yet</option>
        </select>
        <button id="mac-snap-delete" type="button" class="mac-snap-delete" aria-label="Delete this snapshot" hidden>&times;</button>
      </div>
    </div>

    <div class="bg-canvas-soft px-4 py-4 sm:px-5">
      <div class="mb-3 flex flex-wrap items-center justify-between gap-x-3 gap-y-1">
        <span class="flex items-center gap-2">
          <span class="eyebrow">Result</span>
          <button id="mac-share" type="button" class="mac-share-btn" data-copy="" hidden>
            <svg
              class="mac-share-icon"
              width="13"
              height="13"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M6.75 9.25l2.5-2.5"></path>
              <path d="M8.75 4.25l1.5-1.5a2.47 2.47 0 0 1 3.5 3.5l-1.5 1.5"></path>
              <path d="M7.25 11.75l-1.5 1.5a2.47 2.47 0 0 1-3.5-3.5l1.5-1.5"></path>
            </svg>
            <span class="mac-share-label">Copy link</span>
          </button>
          <button id="mac-md" type="button" class="mac-share-btn" data-copy="" hidden>
            <svg
              class="mac-share-icon"
              width="13"
              height="13"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M2.5 4.5h11v7h-11z"></path>
              <path d="M4.5 10V6l1.75 2L8 6v4"></path>
              <path d="M9.75 6.5v3.25M9.75 9.75l1.25-1.25M9.75 9.75l-1.25-1.25"></path>
            </svg>
            <span class="mac-md-label">Copy as Markdown</span>
          </button>
        </span>
        <span id="mac-summary" class="mac-summary code-mono text-mute" role="status" aria-live="polite"></span>
      </div>
      <div id="mac-results" class="mac-results" aria-live="polite" aria-atomic="false">
        <p class="mac-empty body-sm text-mute">
          Type a MAC in any form or pick an example to see every separator form, the OUI, the
          transmission and administration bits, and the IPv6 link-local here.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../styles/global.css";

  .mac-select {
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    height: 32px;
    min-width: 0;
    max-width: 320px;
    padding: 0 32px 0 12px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-hairline);
    font-size: 13px;
    line-height: 20px;
    cursor: pointer;
    text-overflow: ellipsis;
    touch-action: manipulation;
    transition: box-shadow 0.15s ease;
  }
  @media (min-width: 640px) {
    .mac-select {
      width: auto;
      min-width: 260px;
    }
  }
  .mac-select:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .mac-select:disabled {
    cursor: not-allowed;
    color: var(--color-mute);
    opacity: 0.7;
  }
  .mac-select-wrap:hover .mac-select-caret {
    color: var(--color-body);
  }

  .mac-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .mac-input-icon {
    position: absolute;
    left: 14px;
    width: 18px;
    height: 18px;
    color: var(--color-mute);
    pointer-events: none;
  }
  .mac-input {
    width: 100%;
    height: 48px;
    padding: 0 16px 0 42px;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-hairline);
    font-size: 15px;
    line-height: 24px;
    letter-spacing: 0.01em;
    transition: box-shadow 0.15s ease;
  }
  .mac-input::placeholder {
    color: var(--color-mute);
  }
  .mac-input:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .mac-input:focus {
    outline: none;
  }
  .mac-input:focus-visible {
    box-shadow: inset 0 0 0 2px var(--color-link);
    outline: none;
  }
  .mac-input.mac-input--error {
    box-shadow: inset 0 0 0 1px var(--color-error);
  }
  .mac-input.mac-input--error:focus-visible {
    box-shadow: inset 0 0 0 2px var(--color-error);
  }
  .mac-sample-cue {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    color: var(--color-mute);
    font-family: var(--font-sans);
  }
  .mac-sample-cue.is-hidden {
    display: none;
  }
  .mac-hint {
    margin-top: 8px;
    text-wrap: pretty;
  }
  .mac-snap-btn {
    flex: 0 0 auto;
    height: 30px;
    padding: 0 12px;
    border-radius: var(--radius-sm);
    border: none;
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    color: var(--color-body);
    font-size: 12.5px;
    cursor: pointer;
    transition: background 0.12s ease, box-shadow 0.12s ease;
  }
  .mac-snap-btn:hover {
    background: var(--color-canvas-soft);
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .mac-snap-select {
    height: 30px;
    max-width: 220px;
    padding: 0 8px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    color: var(--color-body);
    font-size: 12.5px;
  }
  .mac-snap-select:disabled {
    color: var(--color-mute);
    cursor: not-allowed;
  }
  .mac-snap-delete {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    border: none;
    background: transparent;
    color: var(--color-mute);
    cursor: pointer;
    transition: background 0.12s ease, color 0.12s ease;
  }
  .mac-snap-delete:hover {
    background: var(--color-error-soft);
    color: var(--color-error-deep);
  }
  .mac-summary {
    white-space: nowrap;
  }
  .mac-share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 26px;
    padding: 0 10px;
    border-radius: var(--radius-sm);
    border: none;
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    color: var(--color-mute);
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 16px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 0.12s ease, background 0.12s ease;
  }
  .mac-share-btn:hover {
    color: var(--color-brand-strong);
    background: var(--color-hairline);
  }
  .mac-share-btn:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 1px;
  }
  .mac-share-btn.mac-share-btn--copied {
    color: var(--color-brand-strong);
    background: var(--color-brand-soft);
  }
  @media (pointer: coarse) {
    .mac-share-btn {
      height: auto;
      min-height: 36px;
    }
  }
  .mac-results {
    min-height: 44px;
  }

  :global(.mac-card) {
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    overflow: hidden;
    animation: mac-rise 0.18s ease both;
  }
  :global(.mac-title) {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-hairline);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 18px;
    color: var(--color-mute);
  }
  :global(.mac-title__badge) {
    flex: 0 0 auto;
    font-size: 11px;
    line-height: 16px;
    padding: 1px 8px;
    border-radius: 9999px;
    background: var(--color-brand-soft);
    color: var(--color-brand-strong);
  }
  :global(.mac-row) {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr) auto;
    gap: 12px;
    padding: 9px 14px;
    align-items: center;
  }
  :global(.mac-row + .mac-row) {
    border-top: 1px solid var(--color-hairline);
  }
  :global(.mac-row__k) {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 18px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-mute);
  }
  :global(.mac-row__v) {
    min-width: 0;
    font-size: 14px;
    line-height: 20px;
    color: var(--color-ink);
    word-break: break-word;
  }
  :global(.mac-row__v.is-mono) {
    font-family: var(--font-mono);
    font-size: 13px;
    font-variant-numeric: tabular-nums;
    font-feature-settings: 'tnum';
  }
  :global(.mac-copy-btn) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    border: none;
    background: transparent;
    color: var(--color-mute);
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.12s ease, color 0.12s ease;
  }
  :global(.mac-copy-btn:hover) {
    background: var(--color-canvas-soft, rgba(0,0,0,0.05));
    color: var(--color-ink);
  }
  :global(.mac-copy-btn.is-copied) {
    color: var(--color-brand-strong);
  }
  :global(.mac-copy-btn svg) {
    pointer-events: none;
  }

  @keyframes mac-rise {
    from {
      opacity: 0;
      transform: translateY(3px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.mac-card) {
      animation: none;
    }
  }

  :global(.mac-error) {
    display: flex;
    gap: 10px;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    background: var(--color-error-soft);
    box-shadow: inset 0 0 0 1px var(--color-error);
    color: var(--color-error-deep);
  }
  :global(.mac-error__icon) {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
    margin-top: 1px;
  }
  :global(.mac-error__title) {
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
  }
  :global(.mac-error__detail) {
    margin-top: 2px;
    font-size: 13px;
    line-height: 18px;
    text-wrap: pretty;
  }
  :global(.mac-empty) {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 64px;
    padding: 20px 16px;
    text-align: center;
    text-wrap: pretty;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
  }

  :global(.mac-chips) {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }
  :global(.mac-chip) {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    font-size: 12px;
    line-height: 18px;
    color: var(--color-brand-strong);
    text-decoration: none;
    transition: background 0.12s ease, box-shadow 0.12s ease;
  }
  :global(.mac-chip:hover) {
    background: var(--color-brand-soft);
    box-shadow: inset 0 0 0 1px var(--color-brand);
  }
</style>

<script>
  import { escapeHtml } from '../lib/escape-html';
  import { copyTextToClipboard } from '../lib/clipboard';
  import { createHashState } from '../lib/hash-state';
  import { buildMarkdownBlock } from '../lib/share-md';
  import { buildIpHash } from '../lib/ip-hash';
  import { getRestoredLastInput, recordToolLastInput, wireSnapshotUI } from '../lib/tool-state/wire';

  type Row = { label: string; value: string; mono?: boolean };
  type Result = { valid: boolean; error?: string; rows: Row[] };
  type Example = { id: string; label: string; input: string };
  type EngineModule = { format: (input: string) => Result };

  const ROOT_SEL = '.mac-pg';
  const DEBOUNCE_MS = 140;

  function boot(): void {
    document.querySelectorAll<HTMLElement>(ROOT_SEL).forEach((root) => {
      if (root.dataset.macWired === 'true') return;
      root.dataset.macWired = 'true';
      void init(root);
    });
  }

  function el<T extends HTMLElement>(root: HTMLElement, sel: string): T | null {
    return root.querySelector<T>(sel);
  }

  function normaliseExamples(raw: unknown): Example[] {
    if (!Array.isArray(raw)) return [];
    return raw
      .map((item, i) => {
        const o = (item ?? {}) as Record<string, unknown>;
        return {
          id: typeof o.id === 'string' && o.id ? o.id : `example-${i + 1}`,
          label: typeof o.label === 'string' && o.label ? o.label : `Example ${i + 1}`,
          input: typeof o.input === 'string' ? o.input : '',
        } satisfies Example;
      })
      .filter((e) => e.input.length > 0);
  }

  const ALERT_SVG =
    '<svg class="mac-error__icon" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 2.5L18.5 17H1.5z"></path><path d="M10 8v4"></path><path d="M10 14.6v.01"></path></svg>';

  const COPY_SVG =
    '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="5" width="9" height="9" rx="1.5"></rect><path d="M3 11H2a1 1 0 01-1-1V2a1 1 0 011-1h8a1 1 0 011 1v1"></path></svg>';
  const CHECK_SVG =
    '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.5 8l4 4 7-7"></path></svg>';

  function attachCopyHandlers(container: HTMLElement): void {
    container.querySelectorAll<HTMLButtonElement>('.mac-copy-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const text = btn.dataset.copyValue ?? '';
        void copyTextToClipboard(text).then((ok) => {
          if (!ok) return;
          btn.innerHTML = CHECK_SVG;
          btn.classList.add('is-copied');
          setTimeout(() => {
            btn.innerHTML = COPY_SVG;
            btn.classList.remove('is-copied');
          }, 1500);
        });
      });
    });
  }

  function renderEmpty(container: HTMLElement, summary: HTMLElement): void {
    summary.textContent = '';
    summary.classList.remove('text-error');
    summary.classList.add('text-mute');
    container.innerHTML =
      '<p class="mac-empty body-sm text-mute">Type a MAC in any form or pick an example to see every separator form, the OUI, the transmission and administration bits, and the IPv6 link-local here.</p>';
  }

  function renderError(container: HTMLElement, summary: HTMLElement, message: string): void {
    summary.textContent = 'Invalid';
    summary.classList.remove('text-mute');
    summary.classList.add('text-error');
    container.innerHTML =
      '<div class="mac-error" role="alert">' +
      ALERT_SVG +
      '<div><p class="mac-error__title">Could not read that address</p>' +
      `<p class="mac-error__detail">${escapeHtml(message)}</p></div></div>`;
  }

  /** Cross-tool chain chip — MAC Address Formatter → IP Address Converter. */
  function localePath(p: string): string {
    const m = window.location.pathname.match(/^\/(de|es|fr|pt-br)\//);
    return m ? `/${m[1]}${p}` : p;
  }

  function chainHtml(rows: Row[]): string {
    const linkLocal = rows.find((r) => r.label === 'IPv6 link-local (EUI-64)');
    if (!linkLocal || typeof linkLocal.value !== 'string' || !linkLocal.value) return '';
    const href = localePath('/ip-address-converter/') + buildIpHash(linkLocal.value);
    return `<div class="mac-chips"><a class="mac-chip" href="${escapeHtml(href)}">Open in IP Address Converter</a></div>`;
  }

  function renderResult(container: HTMLElement, summary: HTMLElement, result: Result): void {
    summary.textContent = 'EUI-48';
    summary.classList.remove('text-error');
    summary.classList.add('text-mute');
    const rows = Array.isArray(result.rows) ? result.rows : [];
    const rowsHtml = rows
      .map((r) => {
        const v = typeof r.value === 'string' ? r.value : '';
        const cls = r.mono ? 'mac-row__v is-mono' : 'mac-row__v';
        const copyBtn = v
          ? `<button class="mac-copy-btn" data-copy-value="${escapeHtml(v)}" title="Copy" aria-label="Copy ${escapeHtml(r.label ?? '')}">${COPY_SVG}</button>`
          : '<span></span>';
        return (
          '<div class="mac-row">' +
          `<span class="mac-row__k">${escapeHtml(r.label ?? '')}</span>` +
          `<span class="${cls}">${escapeHtml(v)}</span>` +
          copyBtn +
          '</div>'
        );
      })
      .join('');
    const count = `${rows.length} ${rows.length === 1 ? 'representation' : 'representations'}`;
    container.innerHTML =
      '<div class="mac-card">' +
      `<div class="mac-title"><span class="mac-title__badge">EUI-48</span><span>${escapeHtml(count)}</span></div>` +
      rowsHtml +
      '</div>' +
      chainHtml(rows);
    attachCopyHandlers(container);
  }

  async function init(root: HTMLElement): Promise<void> {
    const input = el<HTMLInputElement>(root, '#mac-input');
    const exampleSel = el<HTMLSelectElement>(root, '#mac-example');
    const resultsBox = el<HTMLElement>(root, '#mac-results');
    const summaryEl = el<HTMLElement>(root, '#mac-summary');
    const shareBtn = el<HTMLButtonElement>(root, '#mac-share');
    const mdBtn = el<HTMLButtonElement>(root, '#mac-md');
    const snapSaveBtn = el<HTMLButtonElement>(root, '#mac-snap-save');
    const snapSelect = el<HTMLSelectElement>(root, '#mac-snap-select');
    const snapDeleteBtn = el<HTMLButtonElement>(root, '#mac-snap-delete');
    if (
      !input ||
      !exampleSel ||
      !resultsBox ||
      !summaryEl ||
      !shareBtn ||
      !mdBtn ||
      !snapSaveBtn ||
      !snapSelect ||
      !snapDeleteBtn
    ) {
      return;
    }

    const hashState = createHashState('mac');

    function hideShare(): void {
      shareBtn!.hidden = true;
      shareBtn!.dataset.copy = '';
      mdBtn!.hidden = true;
    }

    let shareCopyTimer: number | undefined;
    shareBtn.addEventListener('click', () => {
      const text = shareBtn.dataset.copy ?? '';
      void copyTextToClipboard(text).then((ok) => {
        if (!ok) return;
        shareBtn.classList.add('mac-share-btn--copied');
        const label = shareBtn.querySelector('.mac-share-label');
        if (label) label.textContent = 'Copied';
        window.clearTimeout(shareCopyTimer);
        shareCopyTimer = window.setTimeout(() => {
          shareBtn.classList.remove('mac-share-btn--copied');
          if (label) label.textContent = 'Copy link';
        }, 1500);
      });
    });

    let mdCopyTimer: number | undefined;
    mdBtn.addEventListener('click', () => {
      const text = mdBtn.dataset.copy ?? '';
      void copyTextToClipboard(text).then((ok) => {
        if (!ok) return;
        mdBtn.classList.add('mac-share-btn--copied');
        const label = mdBtn.querySelector('.mac-md-label');
        if (label) label.textContent = 'Copied';
        window.clearTimeout(mdCopyTimer);
        mdCopyTimer = window.setTimeout(() => {
          mdBtn.classList.remove('mac-share-btn--copied');
          if (label) label.textContent = 'Copy as Markdown';
        }, 1500);
      });
    });

    let engine: EngineModule;
    let examples: Example[] = [];
    try {
      const [engineMod, examplesMod] = await Promise.all([
        import('../lib/mac-formatter/engine'),
        import('../lib/mac-formatter/examples'),
      ]);
      engine = engineMod as unknown as EngineModule;
      examples = normaliseExamples((examplesMod as { examples?: unknown }).examples);
    } catch (err) {
      renderError(resultsBox, summaryEl, 'The formatter engine failed to load. Reload the page to try again.');
      console.error('[MacFormatter] engine import failed:', err);
      return;
    }

    exampleSel.innerHTML = '';
    const customOpt = document.createElement('option');
    customOpt.value = '-1';
    customOpt.textContent = examples.length ? 'Custom input' : 'No examples';
    exampleSel.appendChild(customOpt);
    examples.forEach((ex, i) => {
      const opt = document.createElement('option');
      opt.value = String(i);
      opt.textContent = ex.label;
      exampleSel.appendChild(opt);
    });
    if (!examples.length) exampleSel.disabled = true;

    function evaluate(userInitiated = true): void {
      const value = input!.value.trim();
      if (value.length === 0) {
        input!.classList.remove('mac-input--error');
        hideShare();
        renderEmpty(resultsBox!, summaryEl!);
        if (userInitiated) hashState.write(null);
        return;
      }
      let result: Result | null = null;
      try {
        result = engine.format(value);
      } catch {
        input!.classList.add('mac-input--error');
        hideShare();
        renderError(resultsBox!, summaryEl!, 'Unexpected error while formatting.');
        if (userInitiated) hashState.write(null);
        return;
      }
      if (!result || result.valid === false) {
        input!.classList.add('mac-input--error');
        hideShare();
        renderError(resultsBox!, summaryEl!, result?.error ?? 'This is not a valid MAC address.');
        if (userInitiated) hashState.write(null);
        return;
      }
      input!.classList.remove('mac-input--error');
      renderResult(resultsBox!, summaryEl!, result);
      shareBtn!.hidden = false;
      shareBtn!.dataset.copy = location.origin + location.pathname + location.search + hashState.build(value);
      if (userInitiated) hashState.write(value);
      if (userInitiated) recordToolLastInput('mac-address-formatter', value);

      mdBtn!.hidden = false;
      const rows = Array.isArray(result.rows) ? result.rows : [];
      mdBtn!.dataset.copy = buildMarkdownBlock('MAC Address Formatter', [
        { label: 'Input', value },
        ...rows.map((r) => ({ label: r.label ?? '', value: typeof r.value === 'string' ? r.value : '' })),
      ]);
    }

    let timer: number | undefined;
    function scheduleEvaluate(): void {
      window.clearTimeout(timer);
      timer = window.setTimeout(evaluate, DEBOUNCE_MS);
    }

    const sampleCue = root.querySelector<HTMLElement>('.mac-sample-cue');
    input.addEventListener('input', () => {
      if (exampleSel.value !== '-1') exampleSel.value = '-1';
      if (sampleCue) sampleCue.classList.add('is-hidden');
      scheduleEvaluate();
    });
    exampleSel.addEventListener('change', () => {
      const idx = Number(exampleSel.value);
      if (!Number.isInteger(idx) || idx < 0 || idx >= examples.length) return;
      input.value = examples[idx].input;
      window.clearTimeout(timer);
      evaluate();
    });

    wireSnapshotUI({
      slug: 'mac-address-formatter',
      saveBtn: snapSaveBtn,
      snapshotSelect: snapSelect,
      deleteBtn: snapDeleteBtn,
      getValue: () => input!.value.trim(),
      setValue: (value) => {
        input!.value = value;
        exampleSel!.value = '-1';
        const cue = root.querySelector<HTMLElement>('.mac-sample-cue');
        if (cue) cue.classList.add('is-hidden');
        window.clearTimeout(timer);
        evaluate();
      },
    });

    // Seed priority: #mac= deep link > restored last input > seeded example.
    // Neither seed path writes the hash or records a last-input — only
    // user-initiated evaluations do.
    const hashValue = hashState.read();
    const restored = getRestoredLastInput('mac-address-formatter');
    if (hashValue) {
      input.value = hashValue;
      exampleSel.value = '-1';
      evaluate(false);
    } else if (restored) {
      input.value = restored;
      exampleSel.value = '-1';
      evaluate(false);
    } else {
      const seed = examples[0];
      if (seed) {
        input.value = seed.input;
        exampleSel.value = '0';
        evaluate(false);
      } else {
        renderEmpty(resultsBox, summaryEl);
      }
    }
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
