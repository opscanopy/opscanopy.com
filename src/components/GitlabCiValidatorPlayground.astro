---
/**
 * GitlabCiValidatorPlayground — the interactive GitLab CI Validator island.
 *
 * A no-framework, server-rendered shell hydrated by a single module <script>
 * that lazily boots ONE CodeMirror 6 editor (YAML), wires an example picker,
 * a "Validate" action, plus Copy + Share. It runs entirely client-side and is
 * fully usable offline once loaded.
 *
 * Runtime contract (imported lazily in the script):
 *   ../lib/gitlab-ci-validator/engine →
 *     validate(yamlText: string) => ValidateResult
 *       ValidateResult = {
 *         ok: boolean
 *         error?: string
 *         findings: Array<{
 *           id: string
 *           severity: 'error' | 'warning' | 'info'
 *           title: string
 *           detail: string
 *           line?: number
 *           remediation?: string
 *         }>
 *         summary: { errors: number; warnings: number; infos: number }
 *       }
 *   ../lib/gitlab-ci-validator/examples →
 *     examples: Array<{ id: string; label: string; yaml: string }>
 *
 * The dark editor surface follows DESIGN.md `code-editor-mockup`; findings use
 * the semantic error / warning tokens and mute/neutral for info. Headlines stay
 * sentence-case, weight 600. All runtime-injected result markup is styled via
 * :global(...) because Astro scoped styles do not reach innerHTML-injected nodes.
 */
---

<section class="glci" aria-label="GitLab CI Validator playground">
  <div class="card shadow-float rounded-lg overflow-hidden">
    {/* ── Toolbar ──────────────────────────────────────────────────────── */}
    <div
      class="flex flex-col gap-3 border-b border-hairline px-4 py-3 sm:flex-row sm:items-center sm:justify-between sm:px-5"
    >
      <div class="flex min-w-0 items-center gap-3">
        <label class="eyebrow shrink-0" for="glci-example">Example</label>
        <div class="glci-select-wrap relative min-w-0">
          <select id="glci-example" class="glci-select code-mono" autocomplete="off">
            {/* Options injected by the hydration script from `examples`. */}
            <option value="">Loading examples…</option>
          </select>
          <svg
            class="glci-select-caret pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-mute"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 6l4 4 4-4"></path>
          </svg>
        </div>
      </div>

      <div class="flex shrink-0 flex-wrap items-center gap-2">
        <span class="caption text-mute hidden items-center sm:inline-flex">⌘/Ctrl + Enter</span>
        <button
          id="glci-copy"
          type="button"
          class="btn btn-secondary btn-sm glci-tap"
          data-default-label="Copy"
        >
          <svg
            class="h-4 w-4 shrink-0"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="5.5" y="5.5" width="8" height="8" rx="1.5"></rect>
            <path d="M3.5 10.5h-.5a1.5 1.5 0 0 1-1.5-1.5v-6A1.5 1.5 0 0 1 3 1.5h6A1.5 1.5 0 0 1 10.5 3v.5"></path>
          </svg>
          <span class="glci-copy-label">Copy</span>
        </button>
        <button
          id="glci-share"
          type="button"
          class="btn btn-secondary btn-sm glci-tap"
          data-default-label="Share Link"
          title="This link encodes your full .gitlab-ci.yml — review before sharing"
        >
          <svg
            class="h-4 w-4 shrink-0"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M6 8.5l4-1.5M6 8.5l4 1.5"></path>
            <circle cx="4" cy="8" r="1.6"></circle>
            <circle cx="11.5" cy="5" r="1.6"></circle>
            <circle cx="11.5" cy="11" r="1.6"></circle>
          </svg>
          <span class="glci-share-label">Share Link</span>
        </button>
        <button
          id="glci-run"
          type="button"
          class="btn btn-primary btn-sm glci-tap"
          title="Validate (⌘/Ctrl + Enter)"
          aria-keyshortcuts="Meta+Enter Control+Enter"
        >
          <svg
            class="glci-run-icon h-4 w-4 shrink-0"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M2.5 8.5l3.5 3.5 7.5-8"></path>
          </svg>
          <span class="glci-run-label">Validate</span>
        </button>
      </div>
    </div>

    {/* ── Editor (single, full-width, dark mockup surface) ─────────────── */}
    <div class="glci-pane flex min-w-0 flex-col bg-inverse">
      <div class="flex items-center gap-2 border-b border-white/10 px-4 py-2.5">
        <span class="flex shrink-0 items-center gap-1.5" aria-hidden="true">
          <span class="h-2.5 w-2.5 rounded-full bg-white/15"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-white/15"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-white/15"></span>
        </span>
        <span class="code-mono text-white/45">.gitlab-ci.yml</span>
      </div>
      <p class="body-sm text-white/55 mb-2">Runs entirely in your browser — nothing is uploaded.</p>
      <div
        id="glci-editor"
        class="glci-editor min-h-80"
        aria-label="GitLab CI pipeline (YAML)"
      >
      </div>
      <p class="text-xs text-white/45 mt-1">Tip: press <kbd style="border:1px solid currentColor;border-radius:3px;padding:0 3px;font-size:0.85em">Esc</kbd> to release keyboard focus from the editor.</p>
      <div class="glci-snap-row mt-2 flex flex-wrap items-center gap-2 px-4 pb-3">
        <button id="glci-snap-save" type="button" class="glci-snap-btn">Save snapshot</button>
        <select id="glci-snap-select" class="glci-snap-select" aria-label="Load a saved snapshot" disabled>
          <option value="">No snapshots yet</option>
        </select>
        <button id="glci-snap-delete" type="button" class="glci-snap-delete" aria-label="Delete this snapshot" hidden>&times;</button>
      </div>
    </div>

    {/* ── Results panel ────────────────────────────────────────────────── */}
    <div class="border-t border-hairline bg-canvas-soft px-4 py-4 sm:px-5">
      <div class="mb-3 flex items-center justify-between gap-3">
        <span class="eyebrow">Results</span>
        <span
          id="glci-summary"
          class="glci-summary code-mono text-mute"
          role="status"
          aria-live="polite"
        ></span>
      </div>

      <div id="glci-results" class="glci-results" aria-live="polite" aria-atomic="false">
        <p class="glci-empty body-sm text-mute">
          Load an example or paste a pipeline, then validate to see YAML errors
          and pipeline checks here.
        </p>
      </div>
    </div>
  </div>

  {/* Polite announcer for clipboard + transient toasts. */}
  <span id="glci-announce" class="sr-only" role="status" aria-live="polite"></span>
</section>

<style>
  @reference "../styles/global.css";

  /* Tap targets opt into fast-tap + no double-tap-zoom on touch. */
  .glci-tap {
    touch-action: manipulation;
  }

  /* The example picker: a 6px-radius in-app form control (form-input-sm scale). */
  .glci-select {
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    height: 32px;
    min-width: 0;
    max-width: 280px;
    padding: 0 32px 0 12px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-hairline);
    font-size: 13px;
    line-height: 20px;
    cursor: pointer;
    text-overflow: ellipsis;
    touch-action: manipulation;
    transition: box-shadow 0.15s ease;
  }
  @media (min-width: 640px) {
    .glci-select {
      width: auto;
      min-width: 220px;
    }
  }
  .glci-select:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .glci-select:disabled {
    cursor: not-allowed;
    color: var(--color-mute);
    opacity: 0.7;
  }
  .glci-select-caret {
    transition: color 0.15s ease;
  }
  .glci-select-wrap:hover .glci-select-caret {
    color: var(--color-body);
  }

  .glci-snap-btn {
    flex: 0 0 auto;
    height: 30px;
    padding: 0 12px;
    border-radius: var(--radius-sm);
    border: none;
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    color: var(--color-body);
    font-size: 12.5px;
    cursor: pointer;
    transition: background 0.12s ease, box-shadow 0.12s ease;
  }
  .glci-snap-btn:hover {
    background: var(--color-canvas-soft);
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .glci-snap-select {
    height: 30px;
    max-width: 220px;
    padding: 0 8px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    color: var(--color-body);
    font-size: 12.5px;
  }
  .glci-snap-select:disabled {
    color: var(--color-mute);
    cursor: not-allowed;
  }
  .glci-snap-delete {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    border: none;
    background: transparent;
    color: var(--color-mute);
    cursor: pointer;
    transition: background 0.12s ease, color 0.12s ease;
  }
  .glci-snap-delete:hover {
    background: var(--color-error-soft);
    color: var(--color-error-deep);
  }

  /* CodeMirror host — fills the dark pane, scrolls internally. */
  .glci-editor {
    overflow: hidden;
  }
  .glci-editor :global(.cm-editor) {
    height: 100%;
    background: transparent;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 20px;
  }
  .glci-editor :global(.cm-editor.cm-focused) {
    /* Replace CM's default outline with a brand-blue ring (a11y: keep a ring). */
    outline: 2px solid var(--color-link);
    outline-offset: -2px;
  }
  .glci-editor :global(.cm-scroller) {
    overflow: auto;
    max-height: 520px;
    font-family: var(--font-mono);
    /* Thin, theme-matched scrollbars on the dark surface. */
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.18) transparent;
  }
  .glci-editor :global(.cm-scroller)::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }
  .glci-editor :global(.cm-scroller)::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.16);
    border-radius: var(--radius-pill);
    border: 3px solid transparent;
    background-clip: content-box;
  }
  .glci-editor :global(.cm-scroller)::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.28);
    background-clip: content-box;
  }
  .glci-editor :global(.cm-gutters) {
    background: transparent;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
  }
  .glci-editor :global(.cm-lineNumbers .cm-gutterElement) {
    color: rgba(255, 255, 255, 0.32);
  }
  .glci-editor :global(.cm-content) {
    padding: 14px 0 16px;
  }
  .glci-editor :global(.cm-line) {
    padding-inline: 4px;
  }

  /* Summary — counts use tabular figures so they don't jitter. */
  .glci-summary {
    font-variant-numeric: tabular-nums;
    font-feature-settings: 'tnum';
    white-space: nowrap;
  }

  /* ── Results container + finding rows (runtime-injected → :global) ───── */
  .glci-results {
    min-height: 44px;
  }
  :global(.glci-group + .glci-group) {
    margin-top: 18px;
  }
  :global(.glci-group__head) {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 16px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-mute);
  }

  :global(.glci-row) {
    display: flex;
    gap: 12px;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    animation: glci-rise 0.18s ease both;
  }
  :global(.glci-row:hover) {
    box-shadow: var(--shadow-subtle);
  }
  :global(.glci-row + .glci-row) {
    margin-top: 8px;
  }
  /* Severity ring on the row, drawn only from contract tokens. */
  :global(.glci-row--error) {
    box-shadow: inset 0 0 0 1px var(--color-error-soft);
  }
  :global(.glci-row--error:hover) {
    box-shadow: inset 0 0 0 1px var(--color-error-soft), var(--shadow-subtle);
  }
  :global(.glci-row--warning) {
    box-shadow: inset 0 0 0 1px var(--color-warning-soft);
  }
  :global(.glci-row--warning:hover) {
    box-shadow: inset 0 0 0 1px var(--color-warning-soft), var(--shadow-subtle);
  }
  @keyframes glci-rise {
    from {
      opacity: 0;
      transform: translateY(3px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.glci-row),
    :global(.glci-error),
    :global(.glci-success) {
      animation: none;
    }
  }

  :global(.glci-row__icon) {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
    margin-top: 1px;
  }
  :global(.glci-row--error .glci-row__icon) {
    color: var(--color-error);
  }
  :global(.glci-row--warning .glci-row__icon) {
    color: var(--color-warning-deep);
  }
  :global(.glci-row--info .glci-row__icon) {
    color: var(--color-mute);
  }

  :global(.glci-row__body) {
    min-width: 0;
    flex: 1 1 auto;
  }
  :global(.glci-row__head) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }
  :global(.glci-row__title) {
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    word-break: break-word;
  }
  :global(.glci-row__detail) {
    margin-top: 4px;
    font-size: 13px;
    line-height: 19px;
    color: var(--color-body);
    word-break: break-word;
    text-wrap: pretty;
  }

  /* Severity pill — tones drawn ONLY from contract tokens. */
  :global(.glci-pill) {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    padding: 1px 8px;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 16px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    box-shadow: var(--shadow-hairline);
  }
  :global(.glci-pill--error) {
    background: var(--color-error-soft);
    color: var(--color-error-deep);
  }
  :global(.glci-pill--warning) {
    background: var(--color-warning-soft);
    color: var(--color-warning-deep);
  }
  :global(.glci-pill--info) {
    background: var(--color-canvas-soft-2);
    color: var(--color-body);
  }

  /* Line reference chip (monospace). */
  :global(.glci-line) {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    padding: 1px 7px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas-soft-2);
    color: var(--color-mute);
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 16px;
    font-variant-numeric: tabular-nums;
    font-feature-settings: 'tnum';
  }

  /* Remediation block. */
  :global(.glci-fix) {
    display: flex;
    gap: 8px;
    margin-top: 8px;
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    background: var(--color-canvas-soft);
    box-shadow: var(--shadow-hairline);
  }
  :global(.glci-fix__icon) {
    flex: 0 0 auto;
    width: 14px;
    height: 14px;
    margin-top: 3px;
    color: var(--color-mute);
  }
  :global(.glci-fix__label) {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 16px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-mute);
  }
  :global(.glci-fix__text) {
    margin-top: 1px;
    font-size: 13px;
    line-height: 18px;
    color: var(--color-body);
    word-break: break-word;
    text-wrap: pretty;
  }
  :global(.glci-fix code) {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--color-canvas-soft-2);
    padding: 1px 5px;
    border-radius: var(--radius-xs);
    color: var(--color-ink);
  }

  /* Parse-error banner (result.error). */
  :global(.glci-error) {
    display: flex;
    gap: 10px;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    background: var(--color-error-soft);
    box-shadow: inset 0 0 0 1px var(--color-error);
    color: var(--color-error-deep);
    animation: glci-rise 0.18s ease both;
  }
  :global(.glci-error__icon) {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
    margin-top: 1px;
  }
  :global(.glci-error__body) {
    min-width: 0;
  }
  :global(.glci-error__title) {
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
  }
  :global(.glci-error__detail) {
    margin-top: 2px;
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 18px;
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* Success state — clean "no issues found" frame. */
  :global(.glci-success) {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 16px;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
    animation: glci-rise 0.18s ease both;
  }
  :global(.glci-success__icon) {
    flex: 0 0 auto;
    width: 22px;
    height: 22px;
    color: var(--color-success);
  }
  :global(.glci-success__title) {
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: var(--color-ink);
  }
  :global(.glci-success__sub) {
    margin-top: 2px;
    font-size: 13px;
    line-height: 18px;
    color: var(--color-mute);
  }

  /* Empty state — generous, centered frame (ex-empty-state-card scale). */
  :global(.glci-empty) {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 64px;
    padding: 20px 16px;
    text-align: center;
    text-wrap: pretty;
    border-radius: var(--radius-md);
    background: var(--color-canvas);
    box-shadow: var(--shadow-hairline);
  }

  /* Loading dots — animate opacity only; reduced-motion handled globally. */
  :global(.glci-loading) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 14px;
    font-size: 14px;
    line-height: 20px;
    color: var(--color-body);
  }
  :global(.glci-loading__dot) {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: var(--color-mute);
    animation: glci-pulse 1.1s ease-in-out infinite;
  }
  :global(.glci-loading__dot:nth-child(2)) {
    animation-delay: 0.18s;
  }
  :global(.glci-loading__dot:nth-child(3)) {
    animation-delay: 0.36s;
  }
  @keyframes glci-pulse {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 1;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.glci-loading__dot) {
      animation: none;
      opacity: 0.6;
    }
  }

  /* Run-button busy state. */
  .is-busy {
    opacity: 0.65;
    pointer-events: none;
    cursor: progress;
  }
  .is-busy .glci-run-icon {
    display: none;
  }
</style>

<script>
  import { copyTextToClipboard as copyText } from '../lib/clipboard';
  import type { EditorView } from '@codemirror/view';
  import { escapeHtml } from '../lib/escape-html';
  import { base64UrlEncode, base64UrlDecode } from '../lib/codec';
  import { getRestoredLastInput, recordToolLastInput, wireSnapshotUI } from '../lib/tool-state/wire';

  /* ---- Types mirrored from the engine contract (structural, not imported). -- */
  type Severity = 'error' | 'warning' | 'info';
  type Finding = {
    id: string;
    severity: Severity | string;
    title: string;
    detail: string;
    line?: number;
    remediation?: string;
  };
  type ValidateSummary = { errors: number; warnings: number; infos: number };
  type ValidateResult = {
    ok: boolean;
    error?: string;
    findings?: Finding[];
    summary?: ValidateSummary;
  };

  type EngineModule = {
    validate: (yamlText: string) => ValidateResult | Promise<ValidateResult>;
  };
  type ExampleRaw = Record<string, unknown>;
  type Example = { id: string; label: string; yaml: string };

  const ROOT_SEL = '.glci';
  const COPIED_RESET_MS = 1800;
  const SHARE_KEY = 'glci';
  const SLUG = 'gitlab-ci-validator';

  /** Boot every (so far un-hydrated) playground instance on the page. */
  function boot(): void {
    document.querySelectorAll<HTMLElement>(ROOT_SEL).forEach((root) => {
      if (root.dataset.glciWired === 'true') return;
      root.dataset.glciWired = 'true';
      void init(root);
    });
  }

  /* ---- Small helpers -------------------------------------------------------- */

  function pick(obj: ExampleRaw, keys: string[]): string {
    for (const k of keys) {
      const v = obj[k];
      if (typeof v === 'string' && v.length > 0) return v;
    }
    return '';
  }

  /** Normalise the sibling `examples` array against likely field names. */
  function normaliseExamples(raw: unknown): Example[] {
    if (!Array.isArray(raw)) return [];
    return raw.map((item, i) => {
      const o = (item ?? {}) as ExampleRaw;
      return {
        id: pick(o, ['id', 'slug', 'key']) || `example-${i + 1}`,
        label: pick(o, ['label', 'name', 'title']) || `Example ${i + 1}`,
        yaml: pick(o, ['yaml', 'pipeline', 'content', 'doc', 'text']),
      };
    });
  }

  function el<T extends HTMLElement>(root: HTMLElement, sel: string): T | null {
    return root.querySelector<T>(sel);
  }

  /** Render remediation text, escaping HTML but rendering `code` spans inline. */
  function remediationHtml(text: string): string {
    return escapeHtml(text).replace(
      /`([^`]+)`/g,
      (_m, code: string) => `<code>${code}</code>`
    );
  }

  const SEV_ORDER: Severity[] = ['error', 'warning', 'info'];
  const SEV_LABEL: Record<Severity, string> = {
    error: 'Errors',
    warning: 'Warnings',
    info: 'Info',
  };

  function normSeverity(s: string): Severity {
    return s === 'error' || s === 'warning' || s === 'info' ? s : 'info';
  }

  /* ---- Severity icons (explicit width/height; decorative) ------------------- */

  const ICON_ERROR =
    '<svg class="glci-row__icon" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="10" cy="10" r="8"></circle><path d="M7.2 7.2l5.6 5.6M12.8 7.2l-5.6 5.6"></path></svg>';
  const ICON_WARNING =
    '<svg class="glci-row__icon" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 2.5L18.5 17H1.5z"></path><path d="M10 8v4"></path><path d="M10 14.6v.01"></path></svg>';
  const ICON_INFO =
    '<svg class="glci-row__icon" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="10" cy="10" r="8"></circle><path d="M10 9v4.5"></path><path d="M10 6.4v.01"></path></svg>';
  const ICON_FIX =
    '<svg class="glci-fix__icon" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.5 2.5a3 3 0 0 0 3.8 3.8l-7 7a1.8 1.8 0 0 1-2.6-2.6z"></path></svg>';
  const ICON_ALERT =
    '<svg class="glci-error__icon" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 2.5L18.5 17H1.5z"></path><path d="M10 8v4"></path><path d="M10 14.6v.01"></path></svg>';
  const ICON_CHECK =
    '<svg class="glci-success__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9.5"></circle><path d="M7.5 12.5l3 3 6-6.5"></path></svg>';

  function severityIcon(sev: Severity): string {
    if (sev === 'error') return ICON_ERROR;
    if (sev === 'warning') return ICON_WARNING;
    return ICON_INFO;
  }

  /* ---- Result rendering ----------------------------------------------------- */

  function renderEmpty(container: HTMLElement, summary: HTMLElement): void {
    summary.textContent = '';
    summary.classList.remove('text-error');
    summary.classList.add('text-mute');
    container.innerHTML =
      '<p class="glci-empty body-sm text-mute">Load an example or paste a pipeline, then validate to see YAML errors and pipeline checks here.</p>';
  }

  function renderLoading(container: HTMLElement, summary: HTMLElement): void {
    summary.textContent = '';
    container.innerHTML =
      '<div class="glci-loading"><span class="glci-loading__dot"></span>' +
      '<span class="glci-loading__dot"></span><span class="glci-loading__dot"></span>' +
      '<span>Validating…</span></div>';
  }

  function renderError(container: HTMLElement, summary: HTMLElement, message: string): void {
    summary.textContent = 'Parse error';
    summary.classList.add('text-error');
    summary.classList.remove('text-mute');
    container.innerHTML =
      '<div class="glci-error" role="alert">' +
      ICON_ALERT +
      '<div class="glci-error__body"><p class="glci-error__title">Could not parse pipeline</p>' +
      `<p class="glci-error__detail">${escapeHtml(message)}</p></div></div>`;
  }

  function renderSuccess(container: HTMLElement, summary: HTMLElement): void {
    summary.textContent = 'No issues';
    summary.classList.remove('text-error');
    summary.classList.add('text-mute');
    container.innerHTML =
      '<div class="glci-success">' +
      ICON_CHECK +
      '<div><p class="glci-success__title">No issues found.</p>' +
      '<p class="glci-success__sub">This pipeline passed every YAML and structural check.</p></div></div>';
  }

  /** Pluralised "N errors · M warnings · K info", omitting zero buckets. */
  function summaryText(s: ValidateSummary): string {
    const parts: string[] = [];
    if (s.errors > 0) parts.push(`${s.errors} ${s.errors === 1 ? 'error' : 'errors'}`);
    if (s.warnings > 0)
      parts.push(`${s.warnings} ${s.warnings === 1 ? 'warning' : 'warnings'}`);
    if (s.infos > 0) parts.push(`${s.infos} info`);
    return parts.length ? parts.join(' · ') : 'No issues';
  }

  function findingHtml(f: Finding): string {
    const sev = normSeverity(String(f.severity));
    const icon = severityIcon(sev);
    const srLabel =
      sev === 'error'
        ? 'Error: '
        : sev === 'warning'
          ? 'Warning: '
          : 'Info: ';
    const pill = `<span class="glci-pill glci-pill--${sev}">${sev}</span>`;
    const line =
      typeof f.line === 'number' && Number.isFinite(f.line)
        ? `<span class="glci-line">Line ${f.line}</span>`
        : '';
    const detail = f.detail
      ? `<p class="glci-row__detail">${escapeHtml(f.detail)}</p>`
      : '';
    const fix = f.remediation
      ? '<div class="glci-fix">' +
        ICON_FIX +
        '<div><span class="glci-fix__label">Fix</span>' +
        `<p class="glci-fix__text">${remediationHtml(f.remediation)}</p></div></div>`
      : '';
    return (
      `<div class="glci-row glci-row--${sev}">${icon}` +
      '<div class="glci-row__body">' +
      `<div class="glci-row__head">${pill}` +
      `<span class="glci-row__title"><span class="sr-only">${srLabel}</span>${escapeHtml(f.title)}</span>` +
      `${line}</div>${detail}${fix}</div></div>`
    );
  }

  function renderResults(
    container: HTMLElement,
    summary: HTMLElement,
    result: ValidateResult
  ): void {
    if (!result || result.ok === false || result.error) {
      renderError(
        container,
        summary,
        result?.error ?? 'Unknown error while validating the pipeline.'
      );
      return;
    }

    const findings = Array.isArray(result.findings) ? result.findings : [];
    if (findings.length === 0) {
      renderSuccess(container, summary);
      return;
    }

    const s =
      result.summary ?? {
        errors: findings.filter((f) => normSeverity(String(f.severity)) === 'error').length,
        warnings: findings.filter((f) => normSeverity(String(f.severity)) === 'warning')
          .length,
        infos: findings.filter((f) => normSeverity(String(f.severity)) === 'info').length,
      };
    summary.textContent = summaryText(s);
    summary.classList.toggle('text-error', s.errors > 0);
    summary.classList.toggle('text-mute', s.errors === 0);

    // Group + sort by severity (error → warning → info), preserving input order within.
    const buckets: Record<Severity, Finding[]> = { error: [], warning: [], info: [] };
    for (const f of findings) buckets[normSeverity(String(f.severity))].push(f);

    const groups = SEV_ORDER.filter((sev) => buckets[sev].length > 0).map((sev) => {
      const rows = buckets[sev].map(findingHtml).join('');
      const count = buckets[sev].length;
      return (
        '<div class="glci-group">' +
        `<p class="glci-group__head">${SEV_LABEL[sev]} <span aria-hidden="true">·</span> ${count}</p>` +
        rows +
        '</div>'
      );
    });
    container.innerHTML = groups.join('');
  }

  /* ---- Clipboard ------------------------------------------------------------ */

  /* ---- Share-state codec (self-contained; no engine dependency) ------------- */

  function encodeShare(yamlText: string): string {
    return `#${SHARE_KEY}=${base64UrlEncode(yamlText)}`;
  }

  function decodeShare(): string | null {
    const hash = window.location.hash.replace(/^#/, '');
    if (!hash) return null;
    const param = hash
      .split('&')
      .map((p) => p.split('='))
      .find(([k]) => k === SHARE_KEY);
    if (!param || !param[1]) return null;
    try {
      return base64UrlDecode(param[1]);
    } catch {
      return null;
    }
  }

  /* ---- Instance init -------------------------------------------------------- */

  async function init(root: HTMLElement): Promise<void> {
    const editorHost = el<HTMLElement>(root, '#glci-editor');
    const select = el<HTMLSelectElement>(root, '#glci-example');
    const runBtn = el<HTMLButtonElement>(root, '#glci-run');
    const copyBtn = el<HTMLButtonElement>(root, '#glci-copy');
    const shareBtn = el<HTMLButtonElement>(root, '#glci-share');
    const resultsBox = el<HTMLElement>(root, '#glci-results');
    const summaryEl = el<HTMLElement>(root, '#glci-summary');
    const announce = el<HTMLElement>(root, '#glci-announce');
    const snapSaveBtn = el<HTMLButtonElement>(root, '#glci-snap-save');
    const snapSelect = el<HTMLSelectElement>(root, '#glci-snap-select');
    const snapDeleteBtn = el<HTMLButtonElement>(root, '#glci-snap-delete');

    if (
      !editorHost ||
      !select ||
      !runBtn ||
      !copyBtn ||
      !shareBtn ||
      !resultsBox ||
      !summaryEl ||
      !snapSaveBtn ||
      !snapSelect ||
      !snapDeleteBtn
    ) {
      return;
    }

    // Lazily load the sibling engine + examples + CodeMirror (kept out of the
    // initial path so CM code-splits into its own chunk).
    let engine: EngineModule;
    let examples: Example[] = [];
    let EditorState: typeof import('@codemirror/state').EditorState;
    let EditorViewCtor: typeof import('@codemirror/view').EditorView;
    let keymap: typeof import('@codemirror/view').keymap;
    let lineNumbers: typeof import('@codemirror/view').lineNumbers;
    let highlightActiveLine: typeof import('@codemirror/view').highlightActiveLine;
    let defaultKeymap: typeof import('@codemirror/commands').defaultKeymap;
    let history: typeof import('@codemirror/commands').history;
    let historyKeymap: typeof import('@codemirror/commands').historyKeymap;
    let indentWithTab: typeof import('@codemirror/commands').indentWithTab;
    let yaml: typeof import('@codemirror/lang-yaml').yaml;
    let oneDark: typeof import('@codemirror/theme-one-dark').oneDark;
    try {
      const [engineMod, examplesMod, stateMod, viewMod, commandsMod, yamlMod, themeMod] =
        await Promise.all([
          import('../lib/gitlab-ci-validator/engine'),
          import('../lib/gitlab-ci-validator/examples'),
          import('@codemirror/state'),
          import('@codemirror/view'),
          import('@codemirror/commands'),
          import('@codemirror/lang-yaml'),
          import('@codemirror/theme-one-dark'),
        ]);
      engine = engineMod as unknown as EngineModule;
      examples = normaliseExamples((examplesMod as { examples?: unknown }).examples);
      ({ EditorState } = stateMod);
      ({ EditorView: EditorViewCtor, keymap, lineNumbers, highlightActiveLine } = viewMod);
      ({ defaultKeymap, history, historyKeymap, indentWithTab } = commandsMod);
      ({ yaml } = yamlMod);
      ({ oneDark } = themeMod);
    } catch (err) {
      renderError(
        resultsBox,
        summaryEl,
        'The validator engine failed to load. Reload the page to try again.'
      );
      // eslint-disable-next-line no-console
      console.error('[GitlabCiValidator] engine/examples import failed:', err);
      return;
    }

    // Seed priority: a shared `#glci=` deep link > the last remembered input
    // for this tool > the first example.
    const seedExample = examples[0] ?? { id: 'example', label: 'Example', yaml: '' };
    let seedYaml = seedExample.yaml;
    let fromShare = false;
    let fromRestored = false;
    const shared = decodeShare();
    if (shared) {
      seedYaml = shared;
      fromShare = true;
    } else {
      const restored = getRestoredLastInput(SLUG);
      if (restored) {
        seedYaml = restored;
        fromRestored = true;
      }
    }

    /* ---- Editor factory (CM symbols now in async scope) --------------------- */

    function makeEditor(host: HTMLElement, doc: string): EditorView {
      const state = EditorState.create({
        doc,
        extensions: [
          lineNumbers(),
          history(),
          highlightActiveLine(),
          yaml(),
          oneDark,
          EditorViewCtor.lineWrapping,
          keymap.of([...defaultKeymap, ...historyKeymap, indentWithTab, { key: "Escape", run: function(view) { view.contentDOM.blur(); return true; } }]),
          EditorViewCtor.theme({
            '&': { color: '#e6e6e6' },
            '.cm-content': { caretColor: '#e6e6e6' },
            '.cm-cursor, .cm-dropCursor': { borderLeftColor: '#e6e6e6' },
            '&.cm-focused .cm-selectionBackground, .cm-selectionBackground, ::selection':
              { backgroundColor: 'rgba(0, 112, 243, 0.32)' },
            '.cm-activeLine': { backgroundColor: 'rgba(255, 255, 255, 0.035)' },
            '.cm-activeLineGutter': { backgroundColor: 'transparent' },
          }),
        ],
      });
      // The host already carries the aria-label/role for screen readers; CM mounts inside.
      return new EditorViewCtor({ state, parent: host });
    }

    function setEditorDoc(view: EditorView, doc: string): void {
      view.dispatch({
        changes: { from: 0, to: view.state.doc.length, insert: doc },
      });
      view.requestMeasure();
    }

    const view = makeEditor(editorHost, seedYaml);
    view.requestMeasure();

    // Populate the example picker.
    select.innerHTML = '';
    if (examples.length === 0) {
      const opt = document.createElement('option');
      opt.value = '';
      opt.textContent = 'No examples available';
      select.appendChild(opt);
      select.disabled = true;
    } else {
      if (fromShare || fromRestored) {
        const opt = document.createElement('option');
        opt.value = '-1';
        opt.textContent = fromShare ? 'Shared pipeline' : 'Restored input';
        select.appendChild(opt);
      }
      examples.forEach((ex, i) => {
        const opt = document.createElement('option');
        opt.value = String(i);
        opt.textContent = ex.label;
        select.appendChild(opt);
      });
      select.value = fromShare || fromRestored ? '-1' : '0';
    }

    // Swap the editor when a different example is chosen.
    select.addEventListener('change', () => {
      const idx = Number(select.value);
      if (!Number.isInteger(idx) || idx < 0 || idx >= examples.length) return;
      setEditorDoc(view, examples[idx].yaml);
      renderEmpty(resultsBox, summaryEl);
    });

    // Run — non-blocking; show loading, yield a frame, then render.
    let running = false;
    const runLabel = runBtn.querySelector<HTMLElement>('.glci-run-label');
    let spinner: HTMLElement | null = null;
    async function run(): Promise<void> {
      if (running) return;
      running = true;
      runBtn.classList.add('is-busy');
      // Keep focus put for keyboard users: mark busy (not disabled) + swap glyph.
      runBtn.setAttribute('aria-disabled', 'true');
      runBtn.setAttribute('aria-busy', 'true');
      if (!spinner) {
        spinner = document.createElement('span');
        spinner.setAttribute('aria-hidden', 'true');
        // Inline the visual so it never depends on Astro's scoped CSS (runtime node).
        spinner.style.cssText =
          'display:inline-block;width:14px;height:14px;flex:0 0 auto;border-radius:9999px;' +
          'border:2px solid currentColor;border-top-color:transparent;';
        if (!window.matchMedia || !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          spinner.animate(
            [{ transform: 'rotate(0deg)' }, { transform: 'rotate(360deg)' }],
            { duration: 700, iterations: Infinity }
          );
        }
        runBtn.insertBefore(spinner, runBtn.firstChild);
      }
      if (runLabel) runLabel.textContent = 'Validating…';
      renderLoading(resultsBox!, summaryEl!);

      // Yield so the loading state paints before (potentially heavy) work runs.
      await new Promise<void>((resolve) => {
        if ('requestAnimationFrame' in window) {
          requestAnimationFrame(() => resolve());
        } else {
          setTimeout(resolve, 0);
        }
      });

      try {
        const doc = view.state.doc.toString();
        const result = await Promise.resolve(engine.validate(doc));
        renderResults(resultsBox!, summaryEl!, result);
        recordToolLastInput(SLUG, doc);
        // Persist current state into the URL hash without a history entry.
        try {
          window.history.replaceState(null, '', encodeShare(doc));
        } catch {
          /* non-fatal: sharing just won't update */
        }
      } catch (err) {
        const msg =
          err instanceof Error ? err.message : 'Unexpected error while validating.';
        renderError(resultsBox!, summaryEl!, msg);
      } finally {
        running = false;
        runBtn.classList.remove('is-busy');
        runBtn.removeAttribute('aria-disabled');
        runBtn.removeAttribute('aria-busy');
        if (spinner) {
          spinner.remove();
          spinner = null;
        }
        if (runLabel) runLabel.textContent = 'Validate';
      }
    }

    runBtn.addEventListener('click', () => void run());

    // Cmd/Ctrl+Enter from inside the editor triggers a run.
    root.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
        e.preventDefault();
        void run();
      }
    });

    // Copy — copy the pipeline YAML to the clipboard.
    const copyLabel = copyBtn.querySelector<HTMLElement>('.glci-copy-label');
    let copyTimer: number | undefined;
    copyBtn.addEventListener('click', async () => {
      const ok = await copyText(view.state.doc.toString());
      if (copyLabel) copyLabel.textContent = ok ? 'Copied' : 'Copy Failed';
      if (announce) {
        announce.textContent = ok
          ? 'Pipeline YAML copied to your clipboard.'
          : 'Could not copy. Select the text in the editor and copy it manually.';
      }
      window.clearTimeout(copyTimer);
      copyTimer = window.setTimeout(() => {
        if (copyLabel) copyLabel.textContent = copyBtn.dataset.defaultLabel ?? 'Copy';
      }, COPIED_RESET_MS);
    });

    // Share — copy a shareable URL (current YAML encoded in the hash).
    const shareLabel = shareBtn.querySelector<HTMLElement>('.glci-share-label');
    let shareTimer: number | undefined;
    shareBtn.addEventListener('click', async () => {
      const frag = encodeShare(view.state.doc.toString());
      const base = window.location.href.split('#')[0];
      const shareUrl = `${base}${frag}`;
      try {
        window.history.replaceState(null, '', frag);
      } catch {
        /* fall back to the current URL */
      }
      const ok = await copyText(shareUrl);
      if (shareLabel) shareLabel.textContent = ok ? 'Link Copied' : 'Copy Failed';
      if (announce) {
        announce.textContent = ok
          ? 'Share link copied to your clipboard.'
          : 'Could not copy the link. Copy the URL from your address bar instead.';
      }
      window.clearTimeout(shareTimer);
      shareTimer = window.setTimeout(() => {
        if (shareLabel) shareLabel.textContent = shareBtn.dataset.defaultLabel ?? 'Share Link';
      }, COPIED_RESET_MS);
    });

    // Snapshot save/restore — reuses the editor's own YAML text as the
    // stored value, same as the share-link serializer above.
    wireSnapshotUI({
      slug: SLUG,
      saveBtn: snapSaveBtn,
      snapshotSelect: snapSelect,
      deleteBtn: snapDeleteBtn,
      getValue: () => view.state.doc.toString(),
      setValue: (value) => {
        setEditorDoc(view, value);
        void run();
      },
    });

    // Initial results state — then auto-validate the loaded content immediately.
    renderEmpty(resultsBox, summaryEl);
    void run();
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
