---
import Card from '../Card.astro';
import type { Track } from '../../data/learn';
import { trackIcon } from '../../data/track-icons';
import { accentGradients } from '../../data/tools';

interface Props { track: Track; guideCount: number; difficulty?: string; minutes?: number; }
const { track, guideCount, difficulty, minutes } = Astro.props;
const href = track.roadmapSlug
  ? `/learn/roadmaps/${track.roadmapSlug}/`
  : (track.guideSlugs[0] ? `/learn/guides/${track.guideSlugs[0]}/` : '/learn/');

const icon = trackIcon(track.slug);
// Use the raw accent hex (not the --color-gradient-* theme token): Tailwind v4
// tree-shakes theme vars that only appear inside inline-style strings, so the var
// resolves to nothing and the wash silently disappears. Mix over `canvas-soft-2`
// (a mid neutral that differs per theme) so the tint reads in BOTH light and dark.
const [g1, g2] = accentGradients[track.accent] ?? accentGradients.develop;
const bannerStyle = `background-image:linear-gradient(135deg, color-mix(in srgb, ${g1} 35%, var(--color-canvas-soft-2)), color-mix(in srgb, ${g2} 35%, var(--color-canvas-soft-2)))`;
// Accent-leaning ink so the icon carries the track color while staying legible in both themes.
const iconStyle = `color:color-mix(in srgb, ${g1} 70%, var(--color-ink))`;

const levelColor: Record<string, string> = {
  beginner: 'var(--color-brand)',
  intermediate: '#f59e0b',
  advanced: '#8b5cf6',
};
const timeLabel = minutes ? (minutes >= 60 ? `~${Math.round(minutes / 60)}h` : `~${minutes}m`) : null;
---
<li class="h-full" id={track.slug} data-track={track.slug}>
  <Card class="card-interactive group relative flex h-full flex-col overflow-hidden shadow-soft">
    <div
      class="-mx-6 -mt-6 mb-5 flex h-24 items-center justify-center border-b border-hairline sm:h-auto sm:aspect-[5/2]"
      style={bannerStyle}
      aria-hidden="true"
    >
      <svg
        width="64" height="64" viewBox="0 0 48 48" fill="none"
        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        style={iconStyle}
        class="transition-transform duration-200 ease-out group-hover:scale-105 motion-reduce:transform-none"
      ><Fragment set:html={icon} /></svg>
    </div>
    <div class="flex items-start justify-between gap-3">
      <h3 class="display-sm text-ink">
        <a href={href} class="rounded-sm outline-none after:absolute after:inset-0 after:content-['']">{track.name}</a>
      </h3>
      {track.startHere && (
        <span class="badge shrink-0 border border-brand/30 bg-brand/10 text-[11px] font-semibold text-brand-strong">
          Start here
        </span>
      )}
    </div>
    <p class="body-sm mt-2 text-pretty text-body">{track.tagline}</p>
    <div class="mt-3 flex flex-wrap items-center gap-1.5">
      {difficulty && (
        <span class="badge code-mono text-[11px] capitalize text-mute">
          <span class="size-1.5 rounded-full" style={`background:${levelColor[difficulty] ?? 'var(--color-mute)'}`} aria-hidden="true"></span>
          {difficulty}
        </span>
      )}
      {timeLabel && <span class="badge code-mono text-[11px] text-mute">{timeLabel}</span>}
      <span class="badge code-mono text-[11px] text-mute">{guideCount} guide{guideCount === 1 ? '' : 's'}</span>
    </div>
    <div class="mt-auto pt-5">
      <span class="link-inline body-sm inline-flex items-center gap-1 font-medium">
        {track.roadmapSlug ? 'View roadmap' : 'Read guide'}
        <span class="transition-transform duration-150 group-hover:translate-x-0.5" aria-hidden="true">&rarr;</span>
      </span>
    </div>
  </Card>
</li>
