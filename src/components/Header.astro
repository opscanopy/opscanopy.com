---
/**
 * Header — sticky top nav (nav-bar): 64px tall, bg-canvas + bottom hairline,
 * sticky top-0 z-40. Logo left, centred nav link row, right cluster with a
 * theme toggle + "Browse Tools" nav CTA. Collapses to a hamburger
 * overlay below 768px. No framework — plain script toggle.
 */
import Logo from './Logo.astro';
import { site, navLinks } from '../data/site';

const pathname = Astro.url.pathname;
/** Normalise trailing slash so "/tools" and "/tools/" both match. */
const normalize = (p: string) => (p !== '/' && p.endsWith('/') ? p.slice(0, -1) : p);
const current = normalize(pathname);
const isCurrent = (href: string) => normalize(href) === current;
---

<header class="sticky top-0 z-40 border-b border-hairline bg-canvas">
  <nav aria-label="Primary" class="container-page flex h-16 items-center justify-between gap-4">
    {/* Left — brand */}
    <a
      href="/"
      class="-ml-1.5 inline-flex shrink-0 items-center rounded-md px-1.5 py-1 transition-colors hover:bg-canvas-soft-2"
      aria-label={`${site.name}, home`}
      translate="no"
    >
      <Logo />
    </a>

    {/* Centre — primary link row (desktop only) */}
    <ul class="hidden min-w-0 flex-1 items-center justify-center gap-1 md:flex">
      {
        navLinks.map((link) => (
          <li class="min-w-0">
            <a
              href={link.href}
              aria-current={isCurrent(link.href) ? 'page' : undefined}
              class:list={[
                'body-sm relative inline-flex max-w-full items-center truncate rounded-full px-3 py-2 transition-colors hover:bg-canvas-soft-2 hover:text-ink',
                isCurrent(link.href)
                  ? "bg-canvas-soft-2 font-medium text-ink after:absolute after:inset-x-3 after:-bottom-px after:h-0.5 after:rounded-full after:bg-brand after:content-['']"
                  : 'text-body',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    {/* Right — theme toggle + CTA (desktop) */}
    <div class="hidden shrink-0 items-center gap-2 md:flex">
      <button
        type="button"
        class="theme-toggle inline-flex h-9 w-9 items-center justify-center rounded-md text-body transition-colors hover:bg-canvas-soft-2 hover:text-ink"
        aria-label="Switch to dark theme"
        aria-pressed="false"
        style="touch-action: manipulation;"
      >
        <svg
          class="theme-icon-moon h-[18px] w-[18px]"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
        </svg>
        <svg
          class="theme-icon-sun h-[18px] w-[18px]"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
          ></path>
        </svg>
      </button>
      <a
        href="/tools"
        aria-current={isCurrent('/tools') ? 'page' : undefined}
        class="btn-nav bg-primary text-on-primary transition-colors hover:bg-primary-hover"
      >
        Browse Tools
      </a>
    </div>

    {/* Right — hamburger (mobile) */}
    <button
      type="button"
      id="nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="-mr-1 inline-flex h-11 w-11 items-center justify-center rounded-md text-ink transition-colors hover:bg-canvas-soft-2 md:hidden"
      style="touch-action: manipulation;"
    >
      <svg
        class="nav-icon-open"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        aria-hidden="true"
        focusable="false"
      >
        <line x1="3" y1="7" x2="21" y2="7"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="17" x2="21" y2="17"></line>
      </svg>
      <svg
        class="nav-icon-close hidden"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        aria-hidden="true"
        focusable="false"
      >
        <line x1="5" y1="5" x2="19" y2="19"></line>
        <line x1="19" y1="5" x2="5" y2="19"></line>
      </svg>
    </button>
  </nav>

  {/* Mobile overlay menu */}
  <div
    id="mobile-menu"
    hidden
    class="nav-overlay border-t border-hairline bg-canvas md:hidden"
    style="overscroll-behavior: contain;"
  >
    <ul class="container-page flex flex-col gap-1 py-4">
      {
        navLinks.map((link) => (
          <li class="min-w-0">
            <a
              href={link.href}
              aria-current={isCurrent(link.href) ? 'page' : undefined}
              class:list={[
                'body-md relative flex min-h-11 items-center truncate rounded-md px-3 py-2.5 transition-colors hover:bg-canvas-soft-2 hover:text-ink',
                isCurrent(link.href)
                  ? "bg-canvas-soft-2 font-medium text-ink after:absolute after:inset-y-2 after:left-0 after:w-0.5 after:rounded-full after:bg-brand after:content-['']"
                  : 'text-body',
              ]}
              style="touch-action: manipulation;"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="mt-2 flex flex-col gap-2 border-t border-hairline pt-4">
        <a
          href="/tools"
          aria-current={isCurrent('/tools') ? 'page' : undefined}
          class="btn btn-primary btn-sm justify-center"
          style="touch-action: manipulation;"
        >
          Browse Tools
        </a>
        <button
          type="button"
          class="theme-toggle btn btn-secondary btn-sm justify-center"
          aria-label="Switch to dark theme"
        aria-pressed="false"
          style="touch-action: manipulation;"
        >
          <svg
            class="theme-icon-moon h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
          </svg>
          <svg
            class="theme-icon-sun h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path
              d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
            ></path>
          </svg>
          <span class="theme-label-dark">Dark theme</span>
          <span class="theme-label-light">Light theme</span>
        </button>
      </li>
    </ul>
  </div>

  <style>
    /* Subtle entrance for the mobile overlay — transform/opacity only. */
    .nav-overlay:not([hidden]) {
      animation: nav-overlay-in 0.16s ease-out;
    }
    @keyframes nav-overlay-in {
      from {
        opacity: 0;
        transform: translateY(-4px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .nav-overlay:not([hidden]) {
        animation: none;
      }
    }

    /* Theme toggle — surface the icon + label for the theme you'll switch TO.
       Light is the default (no attribute) → moon icon + "Dark theme". */
    .theme-icon-sun {
      display: none;
    }
    .theme-label-light {
      display: none;
    }
    :global(html[data-theme='dark']) .theme-icon-moon {
      display: none;
    }
    :global(html[data-theme='dark']) .theme-icon-sun {
      display: inline-block;
    }
    :global(html[data-theme='dark']) .theme-label-dark {
      display: none;
    }
    :global(html[data-theme='dark']) .theme-label-light {
      display: inline;
    }
  </style>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    const iconOpen = toggle.querySelector<SVGElement>('.nav-icon-open');
    const iconClose = toggle.querySelector<SVGElement>('.nav-icon-close');

    const isOpen = () => toggle.getAttribute('aria-expanded') === 'true';

    /** Tabbable controls inside the overlay — used for the focus trap. */
    const focusables = () =>
      Array.from(menu.querySelectorAll<HTMLAnchorElement>('a[href]')).filter(
        (el) => el.offsetParent !== null,
      );

    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      menu.hidden = !open;
      iconOpen?.classList.toggle('hidden', open);
      iconClose?.classList.toggle('hidden', !open);
      // Lock the page behind the overlay so the body doesn't scroll under it.
      document.documentElement.style.overflow = open ? 'hidden' : '';
    };

    toggle.addEventListener('click', () => {
      const next = !isOpen();
      setOpen(next);
      // Move focus into the overlay when it opens (first link).
      if (next) focusables()[0]?.focus();
    });

    // Close on link tap inside the overlay.
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (event) => {
      if (!isOpen()) return;

      // Close on Escape and return focus to the toggle.
      if (event.key === 'Escape') {
        setOpen(false);
        toggle.focus();
        return;
      }

      // Trap Tab focus within the toggle + overlay controls.
      if (event.key === 'Tab') {
        const items = [toggle, ...focusables()];
        const first = items[0];
        const last = items[items.length - 1];
        const active = document.activeElement;
        if (event.shiftKey && active === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && active === last) {
          event.preventDefault();
          first.focus();
        }
      }
    });

    // Collapse the overlay if the viewport grows past the mobile breakpoint.
    const desktop = window.matchMedia('(min-width: 768px)');
    desktop.addEventListener('change', (event) => {
      if (event.matches) setOpen(false);
    });
  }

  // Theme toggle — flip data-theme, persist the choice, keep aria-label +
  // <meta theme-color> in sync. The initial theme is set pre-paint in Layout.
  function wireThemeToggles(): void {
    const root = document.documentElement;
    const meta = document.querySelector<HTMLMetaElement>('meta[name="theme-color"]');
    const buttons = document.querySelectorAll<HTMLButtonElement>('.theme-toggle');

    const sync = (): void => {
      const dark = root.getAttribute('data-theme') === 'dark';
      buttons.forEach((b) => {
        b.setAttribute('aria-label', dark ? 'Switch to light theme' : 'Switch to dark theme');
        b.setAttribute('aria-pressed', String(dark));
      });
      if (meta) meta.setAttribute('content', dark ? '#0a0a0a' : '#fafafa');
    };

    buttons.forEach((btn) => {
      if (btn.dataset.themeWired === 'true') return;
      btn.dataset.themeWired = 'true';
      btn.addEventListener('click', () => {
        const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        try {
          localStorage.setItem('theme', next);
        } catch (e) {
          /* private mode — toggle still works for the session */
        }
        sync();
      });
    });

    sync();
  }

  wireThemeToggles();
  document.addEventListener('astro:page-load', wireThemeToggles);
</script>
