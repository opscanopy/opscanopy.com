---
/**
 * Header — sticky top nav (nav-bar): 64px tall, bg-canvas + bottom hairline,
 * sticky top-0 z-40. Logo left, centred nav link row, right cluster with a
 * theme toggle + "Browse Tools" nav CTA. Collapses to a hamburger
 * overlay below 768px. No framework — plain script toggle.
 */
import Logo from './Logo.astro';
import { site } from '../data/site';
import MegaMenu from './MegaMenu.astro';
import CommandPalette from './CommandPalette.astro';
import LangSwitcher from './LangSwitcher.astro';
import { liveTools, categoryAccent } from '../data/tools';
import { DEFAULT_LOCALE, type Locale } from '../i18n/config';
import { useTranslations, localizeKey, localizeNavHref, stripLocale } from '../i18n/utils';
import { getSiteContent } from '../i18n/site';

interface Props {
  /** Hide the language switcher on English-only pages (404, wasm demo). */
  hideLangSwitcher?: boolean;
}
const { hideLangSwitcher = false } = Astro.props as Props;

const lang: Locale = (Astro.currentLocale as Locale) ?? DEFAULT_LOCALE;
const t = useTranslations(lang);
const { nav: navLinks } = getSiteContent(lang);

/**
 * Desktop: Search renders as an icon-button in the right action cluster, not
 * a fifth text item — measured at the md breakpoint, a fifth label truncates
 * the centre row in every locale (es/pt-br ellipsize up to ~940px). The
 * mobile overlay keeps the full text entry (full-width rows, no constraint).
 */
const searchLink = navLinks.find((link) => link.href === '/search');
const desktopNavLinks = navLinks.filter((link) => link.href !== '/search');

/** Normalise trailing slash so "/tools" and "/tools/" both match. */
const normalize = (p: string) => (p !== '/' && p.endsWith('/') ? p.slice(0, -1) : p);
/** Compare against the locale-neutral page key so /es/tools highlights too. */
const current = normalize(stripLocale(Astro.url.pathname));
const isCurrent = (key: string) => normalize(key) === current;
/** Localize a page-key href for the active locale (English-only sections stay un-prefixed). */
const href = (key: string) => localizeNavHref(key, lang);

/**
 * A short, category-spread sample of live tools for the mobile discovery list.
 * Take one tool per category first (in registry order) so the ~60% mobile
 * audience sees the breadth of the catalog under "Tools", then top up to 6 with
 * the remaining live tools. Tool NAMES are brand marks, never translated.
 */
const seenCategories = new Set<string>();
const firstPerCategory = liveTools.filter((tool) => {
  if (seenCategories.has(tool.category)) return false;
  seenCategories.add(tool.category);
  return true;
});
const discoveryTools = [
  ...firstPerCategory,
  ...liveTools.filter((tool) => !firstPerCategory.includes(tool)),
].slice(0, 6);
---

{/* data-pagefind-ignore: nav chrome must never leak into the site-search index. */}
<header class="sticky top-0 z-40 border-b border-hairline bg-canvas" data-pagefind-ignore>
  <nav aria-label="Primary" class="container-page flex h-16 items-center justify-between gap-4">
    {/* Left — brand */}
    <a
      href={href('/')}
      class="-ml-1.5 inline-flex shrink-0 items-center rounded-md px-1.5 py-1 transition-colors hover:bg-canvas-soft-2"
      aria-label={t('a11y.homeLabel', { name: site.name })}
      translate="no"
    >
      <Logo />
    </a>

    {/* Centre — primary link row (desktop only) */}
    <ul class="hidden min-w-0 flex-1 items-center justify-center gap-1 md:flex">
      {
        desktopNavLinks.map((link) => (
          <li class="min-w-0">
            {link.href === '/tools' ? (
              <button
                id="tools-trigger"
                type="button"
                aria-haspopup="dialog"
                aria-expanded="false"
                aria-controls="mega-menu"
                class:list={[
                  "body-sm relative inline-flex max-w-full items-center gap-1 truncate rounded-full px-3 py-2 transition-colors hover:bg-canvas-soft-2 hover:text-ink",
                  isCurrent("/tools")
                    ? "bg-canvas-soft-2 font-medium text-ink after:absolute after:inset-x-3 after:-bottom-px after:h-0.5 after:rounded-full after:bg-brand after:content-['']"
                    : "text-body",
                ]}
              >
                {link.label}
                <svg id="tools-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform duration-200"><path d="m6 9 6 6 6-6"/></svg>
              </button>
            ) : (
              <a
                href={href(link.href)}
                aria-current={isCurrent(link.href) ? 'page' : undefined}
                class:list={[
                  'body-sm relative inline-flex max-w-full items-center truncate rounded-full px-3 py-2 transition-colors hover:bg-canvas-soft-2 hover:text-ink',
                  isCurrent(link.href)
                    ? "bg-canvas-soft-2 font-medium text-ink after:absolute after:inset-x-3 after:-bottom-px after:h-0.5 after:rounded-full after:bg-brand after:content-['']"
                    : 'text-body',
                ]}
              >
                {link.label}
              </a>
            )}
          </li>
        ))
      }
    </ul>

    {/* Right — language + search + theme toggle + CTA (desktop) */}
    <div class="hidden shrink-0 items-center gap-2 md:flex">
      {!hideLangSwitcher && <LangSwitcher lang={lang} />}
      {searchLink && (
        <a
          href={href(searchLink.href)}
          aria-current={isCurrent(searchLink.href) ? 'page' : undefined}
          aria-label={searchLink.label}
          title={searchLink.label}
          class:list={[
            'icon-btn inline-flex h-9 w-9 items-center justify-center rounded-md transition-colors hover:bg-canvas-soft-2 hover:text-ink',
            isCurrent(searchLink.href) ? 'bg-canvas-soft-2 text-ink' : 'text-body',
          ]}
        >
          <svg
            class="h-[18px] w-[18px]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="7"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
        </a>
      )}
      <button
        type="button"
        class="icon-btn theme-toggle inline-flex h-9 w-9 items-center justify-center rounded-md text-body transition-colors hover:bg-canvas-soft-2 hover:text-ink"
        aria-label={t('a11y.themeToDark')}
        title={t('a11y.themeToDark')}
        data-to-dark={t('a11y.themeToDark')}
        data-to-light={t('a11y.themeToLight')}
        style="touch-action: manipulation;"
      >
        <svg
          class="theme-icon-moon h-[18px] w-[18px]"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
        </svg>
        <svg
          class="theme-icon-sun h-[18px] w-[18px]"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
          ></path>
        </svg>
      </button>
      <a
        href={href('/tools')}
        aria-current={isCurrent('/tools') ? 'page' : undefined}
        class="btn-nav bg-primary text-on-primary transition-colors hover:bg-primary-hover"
      >
        {t('nav.browseTools')}
      </a>
    </div>

    {/* Right — hamburger (mobile) */}
    <button
      type="button"
      id="nav-toggle"
      data-label-open={t('a11y.openMenu')}
      data-label-close={t('a11y.closeMenu')}
      aria-label={t('a11y.openMenu')}
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="-mr-1 inline-flex h-11 w-11 items-center justify-center rounded-md text-ink transition-colors hover:bg-canvas-soft-2 md:hidden"
      style="touch-action: manipulation;"
    >
      <svg
        class="nav-icon-open"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        aria-hidden="true"
        focusable="false"
      >
        <line x1="3" y1="7" x2="21" y2="7"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="17" x2="21" y2="17"></line>
      </svg>
      <svg
        class="nav-icon-close hidden"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        aria-hidden="true"
        focusable="false"
      >
        <line x1="5" y1="5" x2="19" y2="19"></line>
        <line x1="19" y1="5" x2="5" y2="19"></line>
      </svg>
    </button>
  </nav>

  <MegaMenu />
  <CommandPalette />

  {/* Mobile overlay menu */}
  <div
    id="mobile-menu"
    hidden
    class="nav-overlay border-t border-hairline bg-canvas md:hidden"
    style="overscroll-behavior: contain;"
  >
    <ul class="container-page flex flex-col gap-1 py-4">
      {
        navLinks.map((link) => (
          <li class="min-w-0">
            <a
              href={href(link.href)}
              aria-current={isCurrent(link.href) ? 'page' : undefined}
              class:list={[
                'body-md relative flex min-h-11 items-center truncate rounded-md px-3 py-2.5 transition-colors hover:bg-canvas-soft-2 hover:text-ink',
                isCurrent(link.href)
                  ? "bg-canvas-soft-2 font-medium text-ink after:absolute after:inset-y-2 after:left-0 after:w-0.5 after:rounded-full after:bg-brand after:content-['']"
                  : 'text-body',
              ]}
              style="touch-action: manipulation;"
            >
              {link.label}
            </a>
            {link.href === '/tools' && (
              <ul class="mt-0.5 mb-1 flex flex-col border-l border-hairline pl-3 ml-3">
                {discoveryTools.map((tool) => (
                  <li class="min-w-0">
                    <a
                      href={href(`/${tool.slug}`)}
                      class="body-sm flex min-h-11 items-center gap-2 truncate rounded-md px-3 py-2 text-mute transition-colors hover:bg-canvas-soft-2 hover:text-ink"
                      style="touch-action: manipulation;"
                    >
                      <span
                        class="size-1.5 shrink-0 rounded-full"
                        style={`background:${categoryAccent[tool.category]}`}
                        aria-hidden="true"
                      />
                      <span class="truncate" translate="no">{tool.name}</span>
                    </a>
                  </li>
                ))}
                <li class="min-w-0">
                  <a
                    href={href('/tools')}
                    aria-current={isCurrent('/tools') ? 'page' : undefined}
                    class="body-sm flex min-h-11 items-center gap-1 truncate rounded-md px-3 py-2 font-medium text-brand-strong transition-colors hover:bg-canvas-soft-2"
                    style="touch-action: manipulation;"
                  >
                    {t('nav.browseTools')}
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                </li>
              </ul>
            )}
          </li>
        ))
      }
      <li class="mt-2 flex flex-col gap-2 border-t border-hairline pt-4">
        <a
          href={href('/tools')}
          aria-current={isCurrent('/tools') ? 'page' : undefined}
          class="btn btn-primary btn-sm justify-center"
          style="touch-action: manipulation;"
        >
          {t('nav.browseTools')}
        </a>
        <button
          type="button"
          class="theme-toggle btn btn-secondary btn-sm justify-center"
          aria-label={t('a11y.themeToDark')}
          title={t('a11y.themeToDark')}
        data-to-dark={t('a11y.themeToDark')}
        data-to-light={t('a11y.themeToLight')}
          style="touch-action: manipulation;"
        >
          <svg
            class="theme-icon-moon h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
          </svg>
          <svg
            class="theme-icon-sun h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path
              d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
            ></path>
          </svg>
          <span class="theme-label-dark">{t('theme.dark')}</span>
          <span class="theme-label-light">{t('theme.light')}</span>
        </button>
        {!hideLangSwitcher && (
          <div class="flex justify-center pt-1">
            <LangSwitcher lang={lang} />
          </div>
        )}
      </li>
    </ul>
  </div>

  <style>
    /* Subtle entrance for the mobile overlay — transform/opacity only. */
    .nav-overlay:not([hidden]) {
      animation: nav-overlay-in 0.16s ease-out;
    }
    @keyframes nav-overlay-in {
      from {
        opacity: 0;
        transform: translateY(-4px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .nav-overlay:not([hidden]) {
        animation: none;
      }
    }

    /* Theme toggle — surface the icon + label for the theme you'll switch TO.
       Light is the default (no attribute) → moon icon + "Dark theme". */
    .theme-icon-sun {
      display: none;
    }
    .theme-label-light {
      display: none;
    }
    :global(html[data-theme='dark']) .theme-icon-moon {
      display: none;
    }
    :global(html[data-theme='dark']) .theme-icon-sun {
      display: inline-block;
    }
    :global(html[data-theme='dark']) .theme-label-dark {
      display: none;
    }
    :global(html[data-theme='dark']) .theme-label-light {
      display: inline;
    }
  </style>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    const iconOpen = toggle.querySelector<SVGElement>('.nav-icon-open');
    const iconClose = toggle.querySelector<SVGElement>('.nav-icon-close');

    const isOpen = () => toggle.getAttribute('aria-expanded') === 'true';

    /** Tabbable controls inside the overlay — used for the focus trap. Must
        include the theme-toggle <button> and the LangSwitcher <summary>: below
        md the overlay is the only place those controls exist, so an anchor-only
        trap would make them keyboard-unreachable. */
    const focusables = () =>
      Array.from(
        menu.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), summary, select, [tabindex]:not([tabindex="-1"])',
        ),
      ).filter((el) => el.offsetParent !== null);

    const labelOpen = toggle.dataset.labelOpen ?? 'Open menu';
    const labelClose = toggle.dataset.labelClose ?? 'Close menu';

    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? labelClose : labelOpen);
      menu.hidden = !open;
      iconOpen?.classList.toggle('hidden', open);
      iconClose?.classList.toggle('hidden', !open);
      // Lock the page behind the overlay so the body doesn't scroll under it.
      document.documentElement.style.overflow = open ? 'hidden' : '';
    };

    toggle.addEventListener('click', () => {
      const next = !isOpen();
      setOpen(next);
      // Move focus into the overlay when it opens (first link).
      if (next) focusables()[0]?.focus();
    });

    // Close on link tap inside the overlay.
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (event) => {
      if (!isOpen()) return;

      // Close on Escape and return focus to the toggle.
      if (event.key === 'Escape') {
        setOpen(false);
        toggle.focus();
        return;
      }

      // Trap Tab focus within the toggle + overlay controls.
      if (event.key === 'Tab') {
        const items = [toggle, ...focusables()];
        const first = items[0];
        const last = items[items.length - 1];
        const active = document.activeElement;
        if (event.shiftKey && active === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && active === last) {
          event.preventDefault();
          first.focus();
        }
      }
    });

    // Collapse the overlay if the viewport grows past the mobile breakpoint.
    const desktop = window.matchMedia('(min-width: 768px)');
    desktop.addEventListener('change', (event) => {
      if (event.matches) setOpen(false);
    });
  }

  // Theme toggle — flip data-theme, persist the choice, keep aria-label +
  // <meta theme-color> in sync. The initial theme is set pre-paint in Layout.
  function wireThemeToggles(): void {
    const root = document.documentElement;
    const meta = document.querySelector<HTMLMetaElement>('meta[name="theme-color"]');
    const buttons = document.querySelectorAll<HTMLButtonElement>('.theme-toggle');

    const sync = (): void => {
      const dark = root.getAttribute('data-theme') === 'dark';
      buttons.forEach((b) => {
        const toLight = b.dataset.toLight ?? 'Switch to light theme';
        const toDark = b.dataset.toDark ?? 'Switch to dark theme';
        b.setAttribute('aria-label', dark ? toLight : toDark);
        b.setAttribute('title', dark ? toLight : toDark);
      });
      if (meta) meta.setAttribute('content', dark ? '#0a0a0a' : '#fafafa');
    };

    buttons.forEach((btn) => {
      if (btn.dataset.themeWired === 'true') return;
      btn.dataset.themeWired = 'true';
      btn.addEventListener('click', () => {
        const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        try {
          localStorage.setItem('theme', next);
        } catch (e) {
          /* private mode — toggle still works for the session */
        }
        sync();
      });
    });

    sync();
  }

  wireThemeToggles();
  document.addEventListener('astro:page-load', wireThemeToggles);
</script>
