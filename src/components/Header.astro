---
/**
 * Header — sticky top nav (nav-bar): 64px tall, bg-canvas + bottom hairline,
 * sticky top-0 z-40. Logo left, centred nav link row, right cluster with a
 * GitHub icon button + "Browse tools" nav CTA. Collapses to a hamburger
 * overlay below 768px. No framework — plain script toggle.
 */
import Logo from './Logo.astro';
import { site, navLinks } from '../data/site';

const pathname = Astro.url.pathname;
/** Normalise trailing slash so "/tools" and "/tools/" both match. */
const normalize = (p: string) => (p !== '/' && p.endsWith('/') ? p.slice(0, -1) : p);
const current = normalize(pathname);
const isCurrent = (href: string) => normalize(href) === current;
---

<header class="sticky top-0 z-40 border-b border-hairline bg-canvas">
  <nav aria-label="Primary" class="container-page flex h-16 items-center justify-between gap-4">
    {/* Left — brand */}
    <a
      href="/"
      class="-ml-1.5 inline-flex shrink-0 items-center rounded-md px-1.5 py-1 transition-colors hover:bg-canvas-soft-2"
      aria-label={`${site.name}, home`}
      translate="no"
    >
      <Logo />
    </a>

    {/* Centre — primary link row (desktop only) */}
    <ul class="hidden min-w-0 flex-1 items-center justify-center gap-1 md:flex">
      {
        navLinks.map((link) => (
          <li class="min-w-0">
            <a
              href={link.href}
              aria-current={isCurrent(link.href) ? 'page' : undefined}
              class:list={[
                'body-sm inline-flex max-w-full items-center truncate rounded-full px-3 py-2 transition-colors hover:bg-canvas-soft-2 hover:text-ink',
                isCurrent(link.href) ? 'bg-canvas-soft-2 font-medium text-ink' : 'text-body',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    {/* Right — GitHub + CTA (desktop) */}
    <div class="hidden shrink-0 items-center gap-2 md:flex">
      <a
        href={site.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${site.name} on GitHub (opens in a new tab)`}
        class="inline-flex h-9 w-9 items-center justify-center rounded-md text-body transition-colors hover:bg-canvas-soft-2 hover:text-ink"
        style="touch-action: manipulation;"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 16 16"
          fill="currentColor"
          aria-hidden="true"
          focusable="false"
        >
          <path
            fill-rule="evenodd"
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
      </a>
      <a
        href="/tools"
        aria-current={isCurrent('/tools') ? 'page' : undefined}
        class="btn-nav bg-primary text-on-primary transition-colors hover:bg-black"
      >
        Browse Tools
      </a>
    </div>

    {/* Right — hamburger (mobile) */}
    <button
      type="button"
      id="nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="-mr-1 inline-flex h-11 w-11 items-center justify-center rounded-md text-ink transition-colors hover:bg-canvas-soft-2 md:hidden"
      style="touch-action: manipulation;"
    >
      <svg
        class="nav-icon-open"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        aria-hidden="true"
        focusable="false"
      >
        <line x1="3" y1="7" x2="21" y2="7"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="17" x2="21" y2="17"></line>
      </svg>
      <svg
        class="nav-icon-close hidden"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        aria-hidden="true"
        focusable="false"
      >
        <line x1="5" y1="5" x2="19" y2="19"></line>
        <line x1="19" y1="5" x2="5" y2="19"></line>
      </svg>
    </button>
  </nav>

  {/* Mobile overlay menu */}
  <div
    id="mobile-menu"
    hidden
    class="nav-overlay border-t border-hairline bg-canvas md:hidden"
    style="overscroll-behavior: contain;"
  >
    <ul class="container-page flex flex-col gap-1 py-4">
      {
        navLinks.map((link) => (
          <li class="min-w-0">
            <a
              href={link.href}
              aria-current={isCurrent(link.href) ? 'page' : undefined}
              class:list={[
                'body-md flex min-h-11 items-center truncate rounded-md px-3 py-2.5 transition-colors hover:bg-canvas-soft-2 hover:text-ink',
                isCurrent(link.href) ? 'bg-canvas-soft-2 font-medium text-ink' : 'text-body',
              ]}
              style="touch-action: manipulation;"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="mt-2 flex flex-col gap-2 border-t border-hairline pt-4">
        <a
          href="/tools"
          aria-current={isCurrent('/tools') ? 'page' : undefined}
          class="btn btn-primary btn-sm justify-center"
          style="touch-action: manipulation;"
        >
          Browse Tools
        </a>
        <a
          href={site.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${site.name} on GitHub (opens in a new tab)`}
          class="btn btn-secondary btn-sm justify-center"
          style="touch-action: manipulation;"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" focusable="false">
            <path
              fill-rule="evenodd"
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
            ></path>
          </svg>
          View on GitHub
        </a>
      </li>
    </ul>
  </div>

  <style>
    /* Subtle entrance for the mobile overlay — transform/opacity only. */
    .nav-overlay:not([hidden]) {
      animation: nav-overlay-in 0.16s ease-out;
    }
    @keyframes nav-overlay-in {
      from {
        opacity: 0;
        transform: translateY(-4px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .nav-overlay:not([hidden]) {
        animation: none;
      }
    }
  </style>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    const iconOpen = toggle.querySelector<SVGElement>('.nav-icon-open');
    const iconClose = toggle.querySelector<SVGElement>('.nav-icon-close');

    const isOpen = () => toggle.getAttribute('aria-expanded') === 'true';

    /** Tabbable controls inside the overlay — used for the focus trap. */
    const focusables = () =>
      Array.from(menu.querySelectorAll<HTMLAnchorElement>('a[href]')).filter(
        (el) => el.offsetParent !== null,
      );

    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      menu.hidden = !open;
      iconOpen?.classList.toggle('hidden', open);
      iconClose?.classList.toggle('hidden', !open);
      // Lock the page behind the overlay so the body doesn't scroll under it.
      document.documentElement.style.overflow = open ? 'hidden' : '';
    };

    toggle.addEventListener('click', () => {
      const next = !isOpen();
      setOpen(next);
      // Move focus into the overlay when it opens (first link).
      if (next) focusables()[0]?.focus();
    });

    // Close on link tap inside the overlay.
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (event) => {
      if (!isOpen()) return;

      // Close on Escape and return focus to the toggle.
      if (event.key === 'Escape') {
        setOpen(false);
        toggle.focus();
        return;
      }

      // Trap Tab focus within the toggle + overlay controls.
      if (event.key === 'Tab') {
        const items = [toggle, ...focusables()];
        const first = items[0];
        const last = items[items.length - 1];
        const active = document.activeElement;
        if (event.shiftKey && active === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && active === last) {
          event.preventDefault();
          first.focus();
        }
      }
    });

    // Collapse the overlay if the viewport grows past the mobile breakpoint.
    const desktop = window.matchMedia('(min-width: 768px)');
    desktop.addEventListener('change', (event) => {
      if (event.matches) setOpen(false);
    });
  }
</script>
