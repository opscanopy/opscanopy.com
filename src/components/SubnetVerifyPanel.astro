---
/**
 * SubnetVerifyPanel — "Verify the AI" panel for the Subnet Calculator.
 *
 * Rendered inside #playground directly below SubnetCalculatorPlayground, as
 * a collapsed <details id="verify-ai"> — it inherits the #playground
 * tool_engaged/result_copied analytics listener for free (Layout.astro scopes
 * both to any control inside #playground) and needs zero translation
 * (playground-internal UI is English everywhere, by contract).
 *
 * Reads the CIDR currently in the sibling playground's #snc-input (no
 * duplicate address field) and checks it against up to 8 structured claim
 * fields via ../lib/subnet-calculator/verify (lazy-imported in the boot
 * closure). Never writes to the URL hash (V1 has no shareable verify state).
 */
---

<details id="verify-ai" class="svp-panel mt-4 overflow-hidden rounded-lg border border-hairline bg-canvas">
  <summary
    class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-3 sm:px-5"
    style="touch-action: manipulation; min-height: 44px;"
  >
    <span class="flex items-center gap-2">
      <svg
        class="size-4 shrink-0 text-brand-strong"
        viewBox="0 0 20 20"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M4 10.5l3.5 3.5L16 5.5"></path>
      </svg>
      <span class="body-sm font-medium text-ink">Verify an AI's answer</span>
    </span>
    <svg
      class="svp-chevron size-4 shrink-0 text-mute transition-transform duration-200"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </summary>

  <div class="border-t border-hairline px-4 py-4 sm:px-5">
    <p class="caption text-mute">
      Paste what ChatGPT or Claude told you — this recomputes it exactly, locally.
      <a href="/verify-ai/" class="link-inline">Why AI needs checking &rarr;</a>
    </p>

    <div class="mt-3">
      <button
        type="button"
        id="svp-sample"
        class="btn btn-secondary btn-sm"
        style="touch-action: manipulation;"
      >
        Try a common AI mistake
      </button>
    </div>

    <div id="svp-fields" class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="block">
        <span class="caption text-mute">Network address</span>
        <input
          type="text"
          data-field="network"
          class="svp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 font-mono text-sm text-ink"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          placeholder="e.g. 192.168.1.0"
        />
      </label>
      <label class="block">
        <span class="caption text-mute">Broadcast address</span>
        <input
          type="text"
          data-field="broadcast"
          class="svp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 font-mono text-sm text-ink"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          placeholder="e.g. 192.168.1.255"
        />
      </label>
      <label class="block">
        <span class="caption text-mute">Netmask</span>
        <input
          type="text"
          data-field="netmask"
          class="svp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 font-mono text-sm text-ink"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          placeholder="e.g. 255.255.255.0 or /24"
        />
      </label>
      <label class="block">
        <span class="caption text-mute">Wildcard mask</span>
        <input
          type="text"
          data-field="wildcard"
          class="svp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 font-mono text-sm text-ink"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          placeholder="e.g. 0.0.0.255"
        />
      </label>
      <label class="block">
        <span class="caption text-mute">First usable address</span>
        <input
          type="text"
          data-field="first"
          class="svp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 font-mono text-sm text-ink"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          placeholder="e.g. 192.168.1.1"
        />
      </label>
      <label class="block">
        <span class="caption text-mute">Last usable address</span>
        <input
          type="text"
          data-field="last"
          class="svp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 font-mono text-sm text-ink"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          placeholder="e.g. 192.168.1.254"
        />
      </label>
      <label class="block">
        <span class="caption text-mute">Usable hosts</span>
        <input
          type="text"
          data-field="usableHosts"
          class="svp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 font-mono text-sm text-ink"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          placeholder="e.g. 254"
        />
      </label>
      <label class="block">
        <span class="caption text-mute">Total addresses</span>
        <input
          type="text"
          data-field="totalAddresses"
          class="svp-input input-focus mt-1 w-full rounded-lg border border-hairline bg-canvas px-3 py-2 font-mono text-sm text-ink"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          placeholder="e.g. 256"
        />
      </label>
    </div>

    <p id="svp-empty" class="caption mt-4 text-mute">
      Enter an address above, then paste in what an AI told you to check it.
    </p>

    <div id="svp-results" class="mt-4" hidden>
      <div class="svp-table-wrap overflow-x-auto rounded-lg border border-hairline">
        <table class="svp-table w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-hairline bg-canvas-soft text-left">
              <th class="px-3 py-2 caption text-mute">Field</th>
              <th class="px-3 py-2 caption text-mute">Claimed</th>
              <th class="px-3 py-2 caption text-mute">Actual</th>
              <th class="px-3 py-2 caption text-mute text-center">Verdict</th>
            </tr>
          </thead>
          <tbody id="svp-rows"></tbody>
        </table>
      </div>
      <p id="svp-summary" role="status" class="caption mt-2 text-mute"></p>
    </div>
  </div>
</details>

<style>
  @reference "../styles/global.css";

  .svp-panel[open] > summary .svp-chevron {
    transform: rotate(180deg);
  }
  .svp-input:hover {
    box-shadow: inset 0 0 0 1px var(--color-hairline-strong);
  }
  .svp-table th,
  .svp-table td {
    vertical-align: top;
  }
  .svp-table tbody tr + tr {
    border-top: 1px solid var(--color-hairline);
  }
  .svp-table td {
    padding: 8px 12px;
  }
  :global(.svp-pill) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: var(--radius-pill);
  }
  :global(.svp-pill--match) {
    background: var(--color-brand-soft);
    color: var(--color-brand-strong);
  }
  :global(.svp-pill--mismatch) {
    background: var(--color-error-soft);
    color: var(--color-error-deep);
  }
  :global(.svp-pill--unreadable) {
    background: var(--color-hairline);
    color: var(--color-mute);
  }
  :global(.svp-note-row td) {
    padding-top: 0;
    font-size: 12px;
    line-height: 16px;
    color: var(--color-mute);
  }
  :global(.svp-copy) {
    margin-left: 8px;
    font-size: 11px;
    text-decoration: underline;
    text-underline-offset: 2px;
    color: var(--color-mute);
    touch-action: manipulation;
  }
  :global(.svp-copy:hover) {
    color: var(--color-brand-strong);
  }
  @media (pointer: coarse) {
    :global(.svp-copy) {
      display: inline-flex;
      min-height: 32px;
      align-items: center;
    }
  }
</style>

<script>
  import { escapeHtml } from '../lib/escape-html';
  import { copyTextToClipboard } from '../lib/clipboard';
  import { safeGtag } from '../lib/gtag';

  type ClaimVerdict = 'match' | 'mismatch' | 'unreadable';
  interface ClaimCheck {
    field: string;
    label: string;
    claimed: string;
    actual: string;
    verdict: ClaimVerdict;
    note?: string;
  }
  interface VerifyResult {
    valid: boolean;
    error?: string;
    summary: string;
    checks: ClaimCheck[];
    mismatchCount: number;
  }
  type EngineModule = {
    verifyClaims: (cidr: string, claims: Record<string, string>) => VerifyResult;
  };

  const DEBOUNCE_MS = 180;
  const ANALYTICS_THROTTLE_MS = 2000;
  const TOOL = 'subnet-calculator';

  const SAMPLE = {
    cidr: '192.168.1.0/24',
    claims: { network: '192.168.1.0', broadcast: '192.168.2.0', usableHosts: '256' },
  };

  function boot(): void {
    document.querySelectorAll<HTMLDetailsElement>('#verify-ai.svp-panel').forEach((root) => {
      if (root.dataset.svpWired === 'true') return;
      root.dataset.svpWired = 'true';
      init(root);
    });
  }

  function init(root: HTMLDetailsElement): void {
    const fieldsWrap = root.querySelector<HTMLElement>('#svp-fields');
    const emptyEl = root.querySelector<HTMLElement>('#svp-empty');
    const resultsEl = root.querySelector<HTMLElement>('#svp-results');
    const rowsEl = root.querySelector<HTMLElement>('#svp-rows');
    const summaryEl = root.querySelector<HTMLElement>('#svp-summary');
    const sampleBtn = root.querySelector<HTMLButtonElement>('#svp-sample');
    const inputs = fieldsWrap
      ? Array.from(fieldsWrap.querySelectorAll<HTMLInputElement>('input[data-field]'))
      : [];
    if (!fieldsWrap || !emptyEl || !resultsEl || !rowsEl || !summaryEl || !sampleBtn) return;

    let engine: EngineModule | null = null;
    let engineLoad: Promise<EngineModule> | null = null;
    function loadEngine(): Promise<EngineModule> {
      if (!engineLoad) {
        engineLoad = import('../lib/subnet-calculator/verify').then((mod) => {
          engine = mod as unknown as EngineModule;
          return engine;
        });
      }
      return engineLoad;
    }

    function mainInput(): HTMLInputElement | null {
      return document.querySelector<HTMLInputElement>('#snc-input');
    }

    function currentClaims(): Record<string, string> {
      const claims: Record<string, string> = {};
      for (const el of inputs) {
        const v = el.value.trim();
        if (v) claims[el.dataset.field ?? ''] = v;
      }
      return claims;
    }

    function verdictPill(verdict: ClaimVerdict): string {
      if (verdict === 'match') {
        return (
          '<span class="svp-pill svp-pill--match" role="img" aria-label="Match">' +
          '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8.5l3.5 3.5L13 4.5"/></svg></span>'
        );
      }
      if (verdict === 'mismatch') {
        return (
          '<span class="svp-pill svp-pill--mismatch" role="img" aria-label="Mismatch">' +
          '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4l8 8M12 4l-8 8"/></svg></span>'
        );
      }
      return (
        '<span class="svp-pill svp-pill--unreadable" role="img" aria-label="Unreadable">' +
        '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6.2c0-1.1.9-1.9 2-1.9s2 .8 2 1.7c0 1.2-1.3 1.4-1.7 2.3-.1.3-.2.5-.2.9"/><path d="M8 12v.01"/></svg></span>'
      );
    }

    function renderRows(checks: ClaimCheck[]): void {
      rowsEl!.innerHTML = checks
        .map((c) => {
          const noteRow = c.note
            ? `<tr class="svp-note-row"><td colspan="4">${escapeHtml(c.note)}</td></tr>`
            : '';
          return (
            '<tr>' +
            `<td class="body-sm text-ink">${escapeHtml(c.label)}</td>` +
            `<td class="font-mono text-xs text-body">${escapeHtml(c.claimed)}</td>` +
            `<td class="font-mono text-xs text-ink">${escapeHtml(c.actual)}` +
            `<button type="button" class="svp-copy" data-copy="${escapeHtml(c.actual)}">Copy</button></td>` +
            `<td class="text-center">${verdictPill(c.verdict)}</td>` +
            '</tr>' +
            noteRow
          );
        })
        .join('');
    }

    let lastAnalyticsAt = 0;
    function maybeFireAnalytics(checks: number, mismatches: number): void {
      const now = Date.now();
      if (now - lastAnalyticsAt < ANALYTICS_THROTTLE_MS) return;
      lastAnalyticsAt = now;
      safeGtag('event', 'verify_run', { tool: TOOL, claims: checks, mismatches });
    }

    async function runVerify(): Promise<void> {
      const cidr = mainInput()?.value.trim() ?? '';
      const claims = currentClaims();
      if (!cidr) {
        emptyEl!.hidden = false;
        emptyEl!.textContent = 'Enter an address above, then paste in what an AI told you to check it.';
        resultsEl!.hidden = true;
        return;
      }
      let mod: EngineModule;
      try {
        mod = engine ?? (await loadEngine());
      } catch {
        emptyEl!.hidden = false;
        emptyEl!.textContent = 'The verify engine failed to load. Reload the page to try again.';
        resultsEl!.hidden = true;
        return;
      }
      const result = mod.verifyClaims(cidr, claims);
      if (!result.valid) {
        emptyEl!.hidden = false;
        emptyEl!.textContent = result.error || 'Enter a valid address above to check claims against it.';
        resultsEl!.hidden = true;
        return;
      }
      if (result.checks.length === 0) {
        emptyEl!.hidden = false;
        emptyEl!.textContent = 'Fill in at least one field above to check it against this address.';
        resultsEl!.hidden = true;
        return;
      }
      emptyEl!.hidden = true;
      resultsEl!.hidden = false;
      renderRows(result.checks);
      summaryEl!.textContent = result.summary;
      maybeFireAnalytics(result.checks.length, result.mismatchCount);
    }

    let timer: number | undefined;
    function scheduleVerify(): void {
      window.clearTimeout(timer);
      timer = window.setTimeout(() => void runVerify(), DEBOUNCE_MS);
    }

    inputs.forEach((el) => el.addEventListener('input', scheduleVerify));

    // The CIDR itself lives in the sibling playground, not this panel — react
    // to it changing so the checks always run against what's visible above.
    document.addEventListener('input', (e) => {
      if ((e.target as HTMLElement | null)?.id === 'snc-input') scheduleVerify();
    });

    sampleBtn.addEventListener('click', () => {
      const main = mainInput();
      if (main) {
        main.value = SAMPLE.cidr;
        main.dispatchEvent(new Event('input', { bubbles: true }));
      }
      for (const el of inputs) {
        el.value = (SAMPLE.claims as Record<string, string>)[el.dataset.field ?? ''] ?? '';
      }
      root.open = true;
      scheduleVerify();
    });

    root.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.svp-copy');
      if (!btn) return;
      void copyTextToClipboard(btn.dataset.copy ?? '').then((ok) => {
        if (ok) {
          const prev = btn.textContent;
          btn.textContent = 'Copied';
          window.setTimeout(() => {
            btn.textContent = prev;
          }, 1500);
        }
      });
    });

    let openFired = false;
    root.addEventListener('toggle', () => {
      if (root.open && !openFired) {
        openFired = true;
        safeGtag('event', 'cta_click', { cta: 'verify_open' });
        scheduleVerify();
      }
    });

    if (location.hash === '#verify-ai') {
      root.open = true;
      root.scrollIntoView({ block: 'start' });
    }
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
