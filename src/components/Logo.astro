---
/**
 * OpsCanopy brand lockup — minimal geometric canopy mark + wordmark.
 *
 * Renders entirely in `currentColor` so it inherits the surrounding text
 * colour and works unchanged on light (canvas) and dark (primary) bands.
 * The mark is layered sheltering arcs suggesting a tree canopy; the wordmark
 * is Geist (font-sans) at weight 600 with tight negative tracking.
 *
 * Consumed by Header.astro and Footer.astro — keep the default export and the
 * `{ class }` prop contract stable.
 */
interface Props {
  /** Extra classes merged onto the root wrapper (e.g. sizing / colour). */
  class?: string;
}

const { class: className } = Astro.props;
---

<span
  class:list={['inline-flex items-center gap-2.5 h-6 text-ink', className]}
  aria-label="OpsCanopy"
  translate="no"
>
  <svg
    class="h-full w-auto shrink-0 text-brand"
    viewBox="0 0 32 32"
    fill="none"
    aria-hidden="true"
    focusable="false"
  >
    <!-- Three nested sheltering arcs read as a canopy; graduated opacity
         adds depth. Centred on x=16 and optically balanced in the 32 box. -->
    <g
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M4 15.5C6.4 10.3 10.8 7 16 7s9.6 3.3 12 8.5" opacity="0.35" />
      <path d="M6.5 19.5C8.6 15.2 11.9 12.7 16 12.7s7.4 2.5 9.5 6.8" opacity="0.6" />
      <path d="M9 23C10.6 19.9 13.1 18.2 16 18.2s5.4 1.7 7 4.8" opacity="0.95" />
    </g>
    <!-- Slender trunk grounding the canopy, centred on the same axis. -->
    <path
      d="M16 23v3.5"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
    />
  </svg>

  <span class="font-sans text-[17px] font-semibold leading-none tracking-[-0.02em]">
    OpsCanopy
  </span>
</span>
