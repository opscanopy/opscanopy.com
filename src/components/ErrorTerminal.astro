---
/**
 * ErrorTerminal — the shared "instrument slab" chrome for the 404 / 500 / offline
 * pages. A dark terminal plate showing a faux request/response, the CanopyField
 * backdrop, and a slot for CTAs beneath. Single-file pages (no locale clones).
 */
import MeshGradient from './MeshGradient.astro';

interface Props {
  eyebrow: string;
  /** The `$ …` command line (shown after a leaf-green prompt). */
  command: string;
  /** The response status line (e.g. "HTTP/1.1 404 Not Found"). */
  statusLine: string;
  /** A `#` commentary line, rendered in amber annotation ink. */
  note: string;
  /** Accessible heading (visually the slab carries the meaning). */
  srHeading: string;
  /** If set, a tiny script rewrites the command's path to location.pathname. */
  injectPath?: boolean;
}
const { eyebrow, command, statusLine, note, srHeading, injectPath = false } = Astro.props;
---

<section class="relative isolate overflow-hidden">
  <MeshGradient class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[520px] opacity-70" />

  <div class="container-page flex min-h-[68vh] flex-col items-center justify-center py-24 sm:py-28">
    <div class="w-full max-w-xl">
      <p class="eyebrow mb-4">{eyebrow}</p>
      <h1 class="sr-only">{srHeading}</h1>

      <div class="err-term">
        <div class="err-term__cap">
          <span class="err-term__dots" aria-hidden="true"><i></i><i></i><i></i></span>
          <span class="err-term__host">opscanopy.com</span>
        </div>
        <pre class="err-term__pre"><code><span class="err-term__line"><span class="err-term__prompt">$ </span><span data-err-cmd>{command}</span></span>
<span class="err-term__line err-term__out">{statusLine}</span>
<span class="err-term__line err-term__note"># {note}</span></code></pre>
      </div>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
        <slot />
      </div>
    </div>
  </div>
</section>

{
  injectPath && (
    <script is:inline>
      (function () {
        var el = document.querySelector('[data-err-cmd]');
        if (el) el.textContent = 'GET ' + (location.pathname || '/') + ' HTTP/1.1';
      })();
    </script>
  )
}

<style>
  .err-term {
    background: var(--color-inverse);
    color: var(--color-inverse-fg);
    border-radius: var(--radius-lg);
    border: 1px solid #ffffff1f;
    box-shadow: 0 24px 48px -24px #00000066, var(--shadow-hairline);
    overflow: hidden;
  }
  .err-term__cap {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 14px;
    border-bottom: 1px solid #ffffff1f;
    font-family: var(--font-mono);
    font-size: 12px;
    color: #b8b2a4;
  }
  .err-term__dots { display: inline-flex; gap: 6px; }
  .err-term__dots i { width: 11px; height: 11px; border-radius: 9999px; display: block; }
  .err-term__dots i:nth-child(1) { background: #e0685f; }
  .err-term__dots i:nth-child(2) { background: #e0b23f; }
  .err-term__dots i:nth-child(3) { background: #63c079; }
  .err-term__host { margin-left: auto; opacity: 0.85; }
  .err-term__pre {
    margin: 0;
    padding: 18px;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.9;
    color: #b8b2a4;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-all;
  }
  .err-term__line { display: block; }
  .err-term__prompt { color: #8fc97a; }
  .err-term__out { color: var(--color-inverse-fg); }
  .err-term__note { color: var(--color-accent-ink); font-style: italic; }
</style>
