---
/**
 * Button — typed CTA wrapper over the .btn classes in global.css.
 * Renders an <a> when `href` is provided, otherwise a <button> with `type`.
 * Marketing pill scale (100px). For nav-scale actions use .btn-nav directly.
 *
 * Full literal class strings are mapped (never concatenated from fragments)
 * so Tailwind's source scan detects every class.
 */
export interface Props {
  href?: string;
  variant?: 'primary' | 'secondary';
  size?: 'md' | 'sm';
  type?: 'button' | 'submit';
  class?: string;
  rel?: string;
  target?: string;
  ariaLabel?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  class: className,
  rel,
  target,
  ariaLabel,
  ...rest
} = Astro.props;

// Complete static class strings keyed by the full variant+size combination.
const classMap = {
  'primary-md': 'btn btn-primary',
  'primary-sm': 'btn btn-primary btn-sm',
  'secondary-md': 'btn btn-secondary',
  'secondary-sm': 'btn btn-secondary btn-sm',
} as const;

const key = `${variant}-${size}` as keyof typeof classMap;
const classes = [classMap[key], className].filter(Boolean).join(' ');

// Auto-secure external targets unless caller overrides rel.
const computedRel = rel ?? (target === '_blank' ? 'noopener noreferrer' : undefined);
---

{
  href ? (
    <a
      href={href}
      class={classes}
      rel={computedRel}
      target={target}
      aria-label={ariaLabel}
      {...rest}
    >
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} aria-label={ariaLabel} {...rest}>
      <slot />
    </button>
  )
}

<style>
  @reference '../styles/global.css';

  /* Tap-target hygiene: kill the 300 ms tap delay / double-tap zoom on touch.
     The global :focus-visible ring (global.css base layer) is preserved — we
     never strip the outline here. */
  .btn {
    touch-action: manipulation;
  }

  /* Tactile press micro-interaction — transform only, so it composes with the
     .btn color/shadow transition already defined in global.css and is disabled
     under prefers-reduced-motion by the global base layer. */
  .btn:active {
    transform: translateY(0.5px) scale(0.99);
  }
</style>
