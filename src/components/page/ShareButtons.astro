---
/**
 * Share controls for a blog post: X, LinkedIn, and copy-link.
 * Used by BlogPost.astro in two spots — a horizontal row on mobile/tablet and a
 * vertical stack in the desktop right rail (pass orientation). The copy-link
 * button is wired by the page-load script in BlogPost.astro via [data-copy-link].
 */
interface Props {
  orientation?: 'row' | 'col';
  xUrl: string;
  linkedInUrl: string;
  url: string;
  shareXLabel: string;
  shareLinkedInLabel: string;
  copyLinkLabel: string;
  copiedLabel: string;
}
const {
  orientation = 'row',
  xUrl,
  linkedInUrl,
  url,
  shareXLabel,
  shareLinkedInLabel,
  copyLinkLabel,
  copiedLabel,
} = Astro.props;
---

<div
  class:list={[
    'flex gap-2',
    orientation === 'col' ? 'flex-col items-start' : 'flex-wrap items-center',
  ]}
>
  <a href={xUrl} target="_blank" rel="noopener noreferrer" aria-label={shareXLabel} class="share-btn">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path
        d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
      ></path>
    </svg>
  </a>
  <a
    href={linkedInUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={shareLinkedInLabel}
    class="share-btn"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path
        d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"
      ></path>
    </svg>
  </a>
  <button
    type="button"
    data-copy-link
    data-url={url}
    data-label-copied={copiedLabel}
    aria-label={copyLinkLabel}
    class="share-btn"
  >
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </button>
</div>

<style>
  @reference "../../styles/global.css";

  .share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-hairline-strong);
    background: var(--color-canvas);
    color: var(--color-body);
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background-color 0.15s ease;
  }

  .share-btn:hover {
    color: var(--color-brand-strong);
    border-color: var(--color-brand);
  }

  .share-btn:focus-visible {
    outline: 2px solid var(--color-brand);
    outline-offset: 2px;
  }

  .share-btn svg {
    width: 18px;
    height: 18px;
  }

  .share-btn.is-copied {
    color: var(--color-success);
    border-color: var(--color-success);
  }

  @media (prefers-reduced-motion: reduce) {
    .share-btn {
      transition: none;
    }
  }
</style>
