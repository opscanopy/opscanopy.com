---
/**
 * Shared blog index — rendered by the English route (src/pages/blog/index.astro)
 * and per-locale routes (src/pages/<locale>/blog/index.astro). Lists the posts
 * for `lang`, newest first; all chrome comes from the UI dictionary.
 */
import Shell from '../Shell.astro';
import type { Locale } from '../../i18n/config';
import { useTranslations, localizeKey } from '../../i18n/utils';
import { getPostsForLocale, formatPostDate, estimateReadingTime } from '../../i18n/blog';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const posts = await getPostsForLocale(lang);
---

<Shell
  title={`${t('blog.metaTitle')} — OpsCanopy`}
  description={t('blog.metaDescription')}
  canonical="/blog"
>
  <section class="border-b border-hairline bg-canvas-soft">
    <div class="container-page py-16 sm:py-24">
      <header class="max-w-[44rem]">
        <p class="eyebrow">{t('blog.eyebrow')}</p>
        <h1 class="display-xl mt-4 text-ink">{t('blog.indexTitle')}</h1>
        <p class="body-lg mt-6 text-body">{t('blog.indexLead')}</p>
        {posts.length > 0 && (
          <p class="caption mt-6 flex items-center gap-2 text-mute">
            <span class="tabular-nums">{posts.length}</span>
            {posts.length === 1 ? t('blog.countSuffixSingular') : t('blog.countSuffixPlural')}
          </p>
        )}
      </header>

      {
        posts.length === 0 ? (
          <div class="card-soft mt-12 flex flex-col items-center justify-center px-6 py-16 text-center">
            <p class="eyebrow">{t('blog.emptyEyebrow')}</p>
            <p class="display-sm mt-3 text-ink">{t('blog.emptyTitle')}</p>
            <p class="body-md mt-2 max-w-md text-balance text-body">{t('blog.emptyBody')}</p>
            <a href={localizeKey('/tools', lang)} class="btn btn-secondary btn-sm mt-6">{t('blog.emptyCta')}</a>
          </div>
        ) : (
          <ul role="list" class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => (
              <li class="h-full">
                <a
                  href={localizeKey(`/blog/${post.slug}`, lang)}
                  class="card group flex h-full min-w-0 flex-col p-6 transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-soft focus-visible:-translate-y-0.5 focus-visible:shadow-soft motion-reduce:transform-none motion-reduce:hover:translate-y-0"
                >
                  <div class="-mx-6 -mt-6 mb-5 overflow-hidden rounded-t-[var(--radius-md)]">
                    <img
                      src={`/blog/${post.slug}-hero.svg`}
                      alt=""
                      loading="lazy"
                      width="1200"
                      height="630"
                      class="aspect-[1200/630] w-full bg-canvas-soft-2 object-cover transition-transform duration-300 ease-out group-hover:scale-[1.04] motion-reduce:transform-none"
                    />
                  </div>
                  <p class="caption flex flex-wrap items-center gap-x-1.5 gap-y-1 text-mute">
                    <span>{post.entry.data.author}</span>
                    <span aria-hidden="true">·</span>
                    <time datetime={post.entry.data.pubDate.toISOString()} class="tabular-nums">
                      {formatPostDate(lang, post.entry.data.pubDate)}
                    </time>
                    <span aria-hidden="true">·</span>
                    <span class="tabular-nums">
                      {t('blog.readingTime', { minutes: estimateReadingTime(post.entry.body) })}
                    </span>
                  </p>
                  <h2 class="display-sm mt-3 text-balance text-ink">{post.entry.data.title}</h2>
                  <p class="body-sm mt-3 line-clamp-4 grow text-pretty text-body">
                    {post.entry.data.description}
                  </p>
                  {post.entry.data.tags && post.entry.data.tags.length > 0 && (
                    <ul role="list" class="mt-5 flex flex-wrap gap-2">
                      {post.entry.data.tags.map((tag) => (
                        <li class="badge code-mono lowercase">{tag}</li>
                      ))}
                    </ul>
                  )}
                  <span
                    class="body-sm mt-5 inline-flex items-center gap-1 font-medium text-link"
                    aria-hidden="true"
                  >
                    {t('blog.readPost')}
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 16 16"
                      fill="none"
                      class="transition-transform duration-150 ease-out group-hover:translate-x-0.5 group-focus-visible:translate-x-0.5 motion-reduce:transform-none"
                    >
                      <path
                        d="M6 3.5 10.5 8 6 12.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</Shell>
