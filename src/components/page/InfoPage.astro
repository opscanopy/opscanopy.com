---
/**
 * InfoPage — shared template for the standalone info / legal pages (Privacy,
 * About, Terms, Contact). Content is data-driven: a page passes a localized
 * `PageDoc` (from src/i18n/pages) plus the active locale. Layout follows the
 * site design system — a soft hero band, then a single prose column.
 */
import { BCP47, type Locale } from '../../i18n/config';
import type { PageDoc } from '../../i18n/pages/en';

export interface Props {
  doc: PageDoc;
  lang: Locale;
  updatedLabel: string;
}

const { doc, lang, updatedLabel } = Astro.props;

const updatedDisplay = doc.updated
  ? new Intl.DateTimeFormat(BCP47[lang], { year: 'numeric', month: 'long', day: 'numeric' }).format(
      new Date(doc.updated),
    )
  : null;
---

<article>
  <!-- ── Hero band ────────────────────────────────────────────────────── -->
  <section class="border-b border-hairline bg-canvas-soft">
    <div class="container-page py-12 sm:py-16">
      <div class="max-w-3xl">
        <p class="eyebrow">{doc.eyebrow}</p>
        <h1 class="display-lg mt-3 text-balance text-ink">{doc.heading}</h1>
        <p class="body-md mt-4 max-w-2xl text-pretty text-body">{doc.lead}</p>
        {
          updatedDisplay && (
            <p class="body-sm mt-6 text-mute">
              {updatedLabel}: <time datetime={doc.updated}>{updatedDisplay}</time>
            </p>
          )
        }
      </div>
    </div>
  </section>

  <!-- ── Prose column ─────────────────────────────────────────────────── -->
  <section class="bg-canvas">
    <div class="container-page py-14 sm:py-20">
      <div class="mx-auto max-w-3xl space-y-10">
        {
          doc.sections.map((section) => (
            <div>
              <h2 class="display-sm text-balance text-ink">{section.heading}</h2>
              <div class="mt-3 space-y-3">
                {section.body.map((paragraph) => (
                  <p class="body-md text-pretty text-body">{paragraph}</p>
                ))}
              </div>
            </div>
          ))
        }

        {/* Page-specific interactive extras (e.g. the analytics consent toggle
            on /privacy). Empty for pages that pass no children. */}
        <slot />

        {
          doc.links && doc.links.length > 0 && (
            <div class="flex flex-wrap gap-3 pt-2">
              {doc.links.map((link) => (
                <a
                  href={link.href}
                  class="btn btn-secondary"
                  style="touch-action: manipulation;"
                  {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                </a>
              ))}
            </div>
          )
        }
      </div>
    </div>
  </section>
</article>
