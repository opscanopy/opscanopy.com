---
/**
 * Learn guide article. Mirrors BlogPost.astro's reading experience (rich-text
 * prose, sticky TOC scroll-spy, reading progress, code-copy, anchors) but is
 * driven by the `guides` collection and links into related tools + guides.
 */
import { render } from 'astro:content';
import Shell from '../Shell.astro';
import { site } from '../../data/site';
import { tools } from '../../data/tools';
import { getTrack } from '../../data/learn';
import type { Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';
import { breadcrumbLd, techArticleLd, faqPageLd } from '../../lib/jsonld';
import {
  estimateReadingTime,
  getGuidesForLocale,
  getPrevNextInTrack,
  getRelatedGuides,
  type LocalizedGuide,
} from '../../lib/learn/guides';

interface Props {
  guide: LocalizedGuide;
  lang: Locale;
}
const { guide, lang } = Astro.props;
const { entry, slug } = guide;
const d = entry.data;
const { Content, headings } = await render(entry);
const t = useTranslations(lang);

const track = getTrack(d.track);
const trackName = track?.name ?? d.track;

const canonical = `/learn/guides/${slug}/`;
const absoluteUrl = `${site.url}${canonical}`;
const isoPublished = (d.updatedDate ?? new Date('2026-06-27')).toISOString();
const isoModified = d.updatedDate?.toISOString();
const readingTime = d.estMinutes ?? estimateReadingTime(entry.body);
// Long guides run to several hours; a raw "201 min read" reads as alarming, so
// express anything ≥ 1h as "Xh Ym read". Short reads keep the localized string.
const readingLabel =
  readingTime >= 60
    ? `${Math.floor(readingTime / 60)} hr${readingTime % 60 ? ` ${readingTime % 60} min` : ''} read`
    : t('blog.readingTime', { minutes: readingTime });

const all = await getGuidesForLocale(lang);
const { prev, next } = getPrevNextInTrack(guide, all);
const related = getRelatedGuides(guide, all, 3);

const relatedTools = (d.relatedTools ?? [])
  .map((s) => tools.find((tool) => tool.slug === s))
  .filter((x): x is (typeof tools)[number] => Boolean(x));

const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
// Group H3s under their parent H2 so the rail can rest at H2-only and reveal a
// section's H3 children only while it's the active section (accordion TOC).
type TocHeading = (typeof toc)[number];
const tocGroups: { h2: TocHeading; children: TocHeading[] }[] = [];
for (const h of toc) {
  if (h.depth === 2 || tocGroups.length === 0) tocGroups.push({ h2: h, children: [] });
  else tocGroups[tocGroups.length - 1].children.push(h);
}
const difficultyProficiency =
  d.difficulty === 'beginner' ? 'Beginner' : d.difficulty === 'advanced' ? 'Advanced' : 'Intermediate';

// Every guide belongs to a track; surface its roadmap so a finished guide is
// never a dead-end. Tracks without their own roadmap (e.g. projects) fall back
// to the master DevOps roadmap.
const roadmapSlug = track?.roadmapSlug ?? 'devops';
const roadmapHref = `/learn/roadmaps/${roadmapSlug}/`;
const roadmapLinkLabel = track?.roadmapSlug ? `${trackName} roadmap` : 'DevOps roadmap';

const breadcrumbJsonLd = breadcrumbLd([
  { name: 'Home', item: `${site.url}/` },
  { name: 'Learn', item: `${site.url}/learn/` },
  { name: trackName, item: `${site.url}/learn/#${d.track}` },
  { name: d.title, item: absoluteUrl },
]);

const articleJsonLd = techArticleLd({
  headline: d.title,
  description: d.metaDescription ?? d.description,
  url: absoluteUrl,
  datePublished: isoPublished,
  dateModified: isoModified,
  keywords: d.tags?.join(', '),
  proficiencyLevel: difficultyProficiency,
});

const jsonLd: Record<string, unknown>[] = [articleJsonLd];
if (d.faqs && d.faqs.length) jsonLd.push(faqPageLd(d.faqs));
---

<Shell
  title={`${d.seoTitle ?? d.title} — OpsCanopy`}
  description={d.metaDescription ?? d.description}
  canonical={canonical}
  type="article"
  jsonLd={jsonLd}
  noAlternates
>
  <div class="reading-progress" aria-hidden="true"><span class="reading-progress-fill"></span></div>

  <article class="bg-canvas-soft">
    <div class="container-page py-16 sm:py-24">
      <div
        class="mx-auto grid w-full max-w-[var(--container-page)] grid-cols-1 gap-x-10 lg:grid-cols-[13rem_minmax(0,1fr)] xl:grid-cols-[minmax(0,1fr)_44rem_minmax(0,1fr)]"
      >
        {
          toc.length > 1 && (
            <aside class="hidden lg:col-start-1 lg:block xl:col-start-1">
              <nav
                aria-label={t('blog.tocTitle')}
                class="sticky top-24 max-h-[calc(100dvh-7rem)] overflow-y-auto pr-2"
              >
                <p class="eyebrow mb-3 text-mute">{t('blog.tocTitle')}</p>
                <ul role="list" class="toc-rail border-l border-hairline">
                  {tocGroups.map((g) => (
                    <li class="toc-group" data-toc-group={g.h2.slug}>
                      <a
                        href={`#${g.h2.slug}`}
                        data-toc-link={g.h2.slug}
                        class="toc-link toc-h2 -ml-px block border-l-2 border-transparent py-1 pl-4 text-[13px] font-medium leading-snug text-mute transition-colors hover:text-ink"
                      >
                        {g.h2.text}
                      </a>
                      {g.children.length > 0 && (
                        <ul role="list" class="toc-children">
                          {g.children.map((c) => (
                            <li>
                              <a
                                href={`#${c.slug}`}
                                data-toc-link={c.slug}
                                class="toc-link toc-h3 -ml-px block border-l-2 border-transparent py-1 pl-7 text-[13px] leading-snug text-mute transition-colors hover:text-ink"
                              >
                                {c.text}
                              </a>
                            </li>
                          ))}
                        </ul>
                      )}
                    </li>
                  ))}
                </ul>
              </nav>
            </aside>
          )
        }

        <div class="mx-auto w-full min-w-0 max-w-[44rem] lg:col-start-2 xl:col-start-2">
        <nav aria-label={t('blog.breadcrumbAriaLabel')} class="mb-6">
          <ol role="list" class="caption flex flex-wrap items-center gap-x-1.5 gap-y-1 text-mute">
            <li><a href="/" class="rounded px-0.5 transition-colors hover:text-ink">Home</a></li>
            <li aria-hidden="true">/</li>
            <li><a href="/learn/" class="rounded px-0.5 transition-colors hover:text-ink">Learn</a></li>
            <li aria-hidden="true">/</li>
            <li><a href={`/learn/#${d.track}`} class="rounded px-0.5 transition-colors hover:text-ink">{trackName}</a></li>
            <li aria-hidden="true">/</li>
            <li class="min-w-0 truncate text-body" aria-current="page">{d.title}</li>
          </ol>
        </nav>

        <a
          href="/learn/"
          class="body-sm group -ml-1.5 inline-flex items-center gap-1.5 rounded-md px-1.5 py-1 text-mute transition-colors hover:text-ink [touch-action:manipulation]"
        >
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="transition-transform duration-150 ease-out group-hover:-translate-x-0.5 motion-reduce:transform-none"><path d="M10 3.5 5.5 8 10 12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          All guides
        </a>

        <header class="mt-8">
          <p class="caption flex flex-wrap items-center gap-x-2 gap-y-1 text-mute">
            <span class="inline-flex items-center gap-x-2 whitespace-nowrap">
              <span class="badge code-mono lowercase">{d.difficulty}</span>
              <span aria-hidden="true">·</span>
            </span>
            <span class="inline-flex items-center gap-x-2 whitespace-nowrap">
              <span class="tabular-nums">{readingLabel}</span>
              <span aria-hidden="true">·</span>
            </span>
            <a href={roadmapHref} class="whitespace-nowrap font-medium text-link underline-offset-2 hover:underline">
              Part of the {roadmapLinkLabel}
            </a>
            {d.updatedDate && (
              <span class="inline-flex items-center gap-x-2 whitespace-nowrap">
                <span aria-hidden="true">·</span>
                <span>Updated {d.updatedDate.toISOString().slice(0, 10)}</span>
              </span>
            )}
          </p>
          <h1 class="display-lg mt-3 text-balance text-ink">{d.title}</h1>
          <p class="body-lg mt-5 text-pretty text-body">{d.description}</p>
        </header>

        <hr class="my-10 border-0 border-t border-hairline" />

        {/* Mobile/tablet: collapsible TOC (the rails are xl-only). */}
        {
          toc.length > 1 && (
            <details class="group mb-10 rounded-lg border border-hairline bg-canvas px-4 py-3 lg:hidden">
              <summary class="caption flex cursor-pointer list-none items-center justify-between font-medium text-ink [&::-webkit-details-marker]:hidden">
                <span>{t('blog.tocTitle')} <span class="font-normal text-mute">· {tocGroups.length} sections</span></span>
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 16 16"
                  fill="none"
                  aria-hidden="true"
                  class="text-mute transition-transform duration-200 group-open:rotate-180 motion-reduce:transform-none"
                >
                  <path
                    d="M4 6l4 4 4-4"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </summary>
              <ul role="list" class="mt-3 max-h-[60vh] divide-y divide-hairline overflow-y-auto overscroll-contain border-t border-hairline pt-1">
                {tocGroups.map((g) => (
                  <li>
                    <a
                      href={`#${g.h2.slug}`}
                      data-toc-link={g.h2.slug}
                      data-toc-mobile
                      class="toc-mobile-link body-sm flex items-baseline justify-between gap-3 py-2.5 font-medium text-mute transition-colors hover:text-ink"
                    >
                      <span class="min-w-0">{g.h2.text}</span>
                      <span class="toc-mobile-min code-mono shrink-0 text-[11px] text-mute tabular-nums" data-toc-min={g.h2.slug} hidden />
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          )
        }

        <div
          class="rich-text"
          data-guide-slug={slug}
          data-copy-label={t('blog.copyCode')}
          data-copied-label={t('blog.copiedCode')}
          data-copy-aria={t('blog.copyCodeAriaLabel')}
          data-anchor-label={t('blog.headingAnchorLabel')}
        >
          <Content />
        </div>

{
  relatedTools.length > 0 && (
    <aside class="mt-12 rounded-xl border border-brand/30 bg-brand/5 p-6">
      <p class="eyebrow text-brand-strong">Try the tools</p>
      <p class="body-md mt-2 text-pretty text-ink">Practice what you just read with these free, browser-based tools.</p>
      <ul role="list" class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
        {relatedTools.map((tool) => (
          <li>
            <a href={`/${tool.slug}/`} class="card group flex flex-col p-4 transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-soft motion-reduce:transform-none">
              <span class="body-sm font-semibold text-ink group-hover:text-brand-strong">{tool.name}</span>
              <span class="mt-1 text-[13px] text-mute">{tool.tagline}</span>
            </a>
          </li>
        ))}
      </ul>
    </aside>
  )
}

{/* On-page FAQ — renders the same frontmatter Q&A that feeds the FAQPage JSON-LD
    above, so the structured data has visible matching content (Google policy). */}
{
  d.faqs && d.faqs.length > 0 && (
    <section class="mt-16 border-t border-hairline pt-12" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="display-sm text-ink">Frequently asked questions</h2>
      <div class="mt-6 divide-y divide-hairline border-y border-hairline">
        {d.faqs.map((f) => (
          <details class="guide-faq group">
            <summary class="flex cursor-pointer list-none items-start justify-between gap-4 py-4">
              <span class="body-md text-balance font-semibold text-ink transition-colors group-hover:text-link">
                {f.q}
              </span>
              <span
                aria-hidden="true"
                class="mt-0.5 grid size-6 shrink-0 place-items-center rounded-full text-mute transition-colors group-hover:bg-canvas-soft-2 group-hover:text-ink"
              >
                <svg
                  class="guide-faq-chevron size-4 transition-transform duration-200 ease-out"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </span>
            </summary>
            <div class="pb-5">
              <p class="body-sm text-pretty text-body">{f.a}</p>
            </div>
          </details>
        ))}
      </div>
    </section>
  )
}

        {
          related.length > 0 && (
            <section class="mt-16 border-t border-hairline pt-12" aria-labelledby="related-heading">
              <h2 id="related-heading" class="display-sm text-ink">Related guides</h2>
              <ul role="list" class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {related.map((rp) => (
                  <li class="h-full">
                    <a
                      href={`/learn/guides/${rp.slug}/`}
                      class="card group flex h-full min-w-0 flex-col p-6 transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-soft focus-visible:-translate-y-0.5 focus-visible:shadow-soft motion-reduce:transform-none motion-reduce:hover:translate-y-0"
                    >
                      <h3 class="body-lg mt-3 text-balance font-semibold text-ink">
                        {rp.entry.data.title}
                      </h3>
                      <p class="body-sm mt-3 line-clamp-3 grow text-pretty text-body">
                        {rp.entry.data.description}
                      </p>
                      <span
                        class="body-sm mt-5 inline-flex items-center gap-1 font-medium text-link"
                        aria-hidden="true"
                      >
                        {t('blog.readPost')}
                        <svg
                          width="14"
                          height="14"
                          viewBox="0 0 16 16"
                          fill="none"
                          class="transition-transform duration-150 ease-out group-hover:translate-x-0.5 group-focus-visible:translate-x-0.5 motion-reduce:transform-none"
                        >
                          <path
                            d="M6 3.5 10.5 8 6 12.5"
                            stroke="currentColor"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          />
                        </svg>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        {/* Journey-closing CTA: most tracks have a single guide, so the sibling
            pager below is often empty — this always points back to the roadmap
            (the one surface that remembers progress) so a finished guide leads
            somewhere. */}
        <section
          class="mt-16 rounded-xl border border-hairline bg-canvas-soft-2 p-6 sm:p-8"
          aria-labelledby="next-step-heading"
        >
          <p class="eyebrow text-brand-strong">Keep going</p>
          <h2 id="next-step-heading" class="display-sm mt-2 text-balance text-ink">
            Continue your {trackName} path
          </h2>
          <p class="body-sm mt-2 max-w-xl text-pretty text-body">
            Pick the next topic on the roadmap and track what you’ve covered — your progress is
            saved in this browser.
          </p>
          <div class="mt-5 flex flex-wrap gap-3">
            <a href={roadmapHref} class="btn btn-primary btn-sm">Back to the {roadmapLinkLabel}</a>
            {roadmapSlug !== 'devops' && (
              <a href="/learn/roadmaps/devops/" class="btn btn-secondary btn-sm">
                See the full DevOps roadmap
              </a>
            )}
          </div>
        </section>

        {
          (prev || next) && (
            <nav
              aria-label={t('blog.pagerAriaLabel')}
              class="mt-16 grid grid-cols-1 gap-4 border-t border-hairline pt-12 sm:grid-cols-2"
            >
              {prev ? (
                <a
                  href={`/learn/guides/${prev.slug}/`}
                  rel="prev"
                  class="card group flex min-w-0 flex-col p-5 transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-soft focus-visible:-translate-y-0.5 focus-visible:shadow-soft motion-reduce:transform-none motion-reduce:hover:translate-y-0"
                >
                  <span class="caption inline-flex items-center gap-1 text-mute">
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 16 16"
                      fill="none"
                      aria-hidden="true"
                      class="transition-transform duration-150 ease-out group-hover:-translate-x-0.5 motion-reduce:transform-none"
                    >
                      <path
                        d="M10 3.5 5.5 8 10 12.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                    {t('blog.prevPost')}
                  </span>
                  <span class="body-sm mt-2 text-balance font-semibold text-ink">
                    {prev.entry.data.title}
                  </span>
                </a>
              ) : (
                <span aria-hidden="true" class="hidden sm:block" />
              )}
              {next && (
                <a
                  href={`/learn/guides/${next.slug}/`}
                  rel="next"
                  class="card group flex min-w-0 flex-col p-5 text-right transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-soft focus-visible:-translate-y-0.5 focus-visible:shadow-soft motion-reduce:transform-none motion-reduce:hover:translate-y-0"
                >
                  <span class="caption inline-flex items-center justify-end gap-1 text-mute">
                    {t('blog.nextPost')}
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 16 16"
                      fill="none"
                      aria-hidden="true"
                      class="transition-transform duration-150 ease-out group-hover:translate-x-0.5 motion-reduce:transform-none"
                    >
                      <path
                        d="M6 3.5 10.5 8 6 12.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                  <span class="body-sm mt-2 text-balance font-semibold text-ink">
                    {next.entry.data.title}
                  </span>
                </a>
              )}
            </nav>
          )
        }
        </div>

      </div>
    </div>
  </article>

  <button type="button" data-back-to-top aria-label={t('blog.backToTop')} class="back-to-top">
    <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path
        d="M4 10 8 6l4 4"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </button>

  {
    /* Mobile (< lg) "Jump to section" FAB + slide-up panel. The desktop sticky
       rail already covers lg+, so both are hidden there. Stacked above the
       back-to-top button (same right gutter). */
    toc.length > 1 && (
      <>
        <button
          type="button"
          data-sections-fab
          aria-label="Jump to section"
          aria-haspopup="dialog"
          aria-expanded="false"
          aria-controls="guide-sections-panel"
          class="sections-fab lg:hidden"
        >
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2 4h12M2 8h12M2 12h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
        </button>

        <div data-sections-scrim class="sections-scrim lg:hidden" hidden />

        <div
          id="guide-sections-panel"
          data-sections-panel
          role="dialog"
          aria-modal="true"
          aria-label={t('blog.tocTitle')}
          tabindex="-1"
          class="sections-panel lg:hidden"
          hidden
        >
          <div class="sections-panel-head">
            <p class="eyebrow text-mute">
              {t('blog.tocTitle')} <span class="font-normal">· {tocGroups.length} sections</span>
            </p>
            <button type="button" data-sections-close aria-label="Close" class="sections-close">
              <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
              </svg>
            </button>
          </div>
          <ul role="list" class="sections-panel-list">
            {tocGroups.map((g) => (
              <li>
                <a
                  href={`#${g.h2.slug}`}
                  data-toc-link={g.h2.slug}
                  data-toc-mobile
                  data-sections-link
                  class="toc-mobile-link sections-panel-link flex items-baseline justify-between gap-3"
                >
                  <span class="min-w-0">{g.h2.text}</span>
                  <span class="toc-mobile-min code-mono shrink-0 text-[11px] text-mute tabular-nums" data-toc-min={g.h2.slug} hidden />
                </a>
              </li>
            ))}
          </ul>
        </div>
      </>
    )
  }

  {/* Reading-position resume toast (shown on load when a saved position exists). */}
  <div data-resume-toast class="resume-toast" role="status" aria-live="polite" hidden>
    <span class="resume-toast-text">
      Resumed at <span data-resume-title class="resume-toast-section">this section</span>
    </span>
    <button type="button" data-resume-top class="resume-toast-action">Start from top</button>
    <button type="button" data-resume-dismiss class="resume-toast-dismiss" aria-label="Dismiss">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <script>
    import { copyTextToClipboard } from '../../lib/clipboard';

    // Progressive enhancement for the blog post page: code-copy buttons, reading
    // progress bar, table-of-contents scroll-spy, heading anchor links, copy-link
    // share buttons, and the back-to-top button. Re-runs on every astro:page-load
    // (ClientRouter) and first tears down window/observer listeners from the prior
    // page so navigations never stack handlers.
    function initGuidePost() {
      const w = window as unknown as { __guidePostCleanup?: (() => void) | null };
      if (w.__guidePostCleanup) {
        w.__guidePostCleanup();
        w.__guidePostCleanup = null;
      }

      const article = document.querySelector<HTMLElement>('article');
      const root = document.querySelector<HTMLElement>('.rich-text');
      if (!root) return;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const guideSlug = root.dataset.guideSlug ?? '';
      const posKey = guideSlug ? `oc-guide-${guideSlug}-pos` : '';

      // --- Code-copy buttons (per <pre>) ---
      if (navigator.clipboard) {
        const copyLabel = root.dataset.copyLabel ?? 'Copy';
        const copiedLabel = root.dataset.copiedLabel ?? 'Copied';
        const ariaLabel = root.dataset.copyAria ?? 'Copy code to clipboard';
        root.querySelectorAll<HTMLPreElement>('pre').forEach((pre) => {
          if (pre.dataset.copyReady) return;
          pre.dataset.copyReady = 'true';
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'rich-code-copy';
          btn.textContent = copyLabel;
          btn.setAttribute('aria-label', ariaLabel);
          let resetTimer: number | undefined;
          btn.addEventListener('click', async () => {
            const code = pre.querySelector('code');
            const text = (code ?? pre).textContent ?? '';
            if (await copyTextToClipboard(text)) {
              btn.textContent = copiedLabel;
              btn.dataset.copied = 'true';
              window.clearTimeout(resetTimer);
              resetTimer = window.setTimeout(() => {
                btn.textContent = copyLabel;
                delete btn.dataset.copied;
              }, 2000);
            }
          });
          pre.appendChild(btn);
        });
      }

      // --- Heading anchor links (hover-reveal #) ---
      const anchorLabel = root.dataset.anchorLabel ?? 'Link to this section';
      root.querySelectorAll<HTMLElement>('h2[id], h3[id]').forEach((h) => {
        if (h.dataset.anchored) return;
        h.dataset.anchored = 'true';
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.className = 'heading-anchor';
        a.textContent = '#';
        a.setAttribute('aria-label', anchorLabel);
        h.appendChild(a);
      });

      // --- Mobile TOC per-section time hint (from rehype-chapters' .chapter-meta) ---
      // rehype-chapters injects "Section X of Y · ~N min" as a .chapter-meta <p>
      // immediately after each H2. Lift the "~N min" out and surface it next to the
      // matching mobile TOC entry (data-toc-min keyed by the H2 slug). Idempotent.
      const minTargets = document.querySelectorAll<HTMLElement>('[data-toc-min]');
      if (minTargets.length) {
        const minBySlug = new Map<string, string>();
        root.querySelectorAll<HTMLElement>('h2[id]').forEach((h2) => {
          const meta = h2.nextElementSibling;
          if (!meta || !meta.classList.contains('chapter-meta')) return;
          const m = (meta.textContent ?? '').match(/~\s*\d+\s*min/i);
          if (m) minBySlug.set(h2.id, m[0].replace(/\s+/g, ' ').trim());
        });
        minTargets.forEach((el) => {
          const slug = el.dataset.tocMin ?? '';
          const label = minBySlug.get(slug);
          if (label) {
            el.textContent = label;
            el.hidden = false;
          }
        });
      }

      // --- Copy-link share buttons ---
      document.querySelectorAll<HTMLButtonElement>('[data-copy-link]').forEach((btn) => {
        if (btn.dataset.bound) return;
        btn.dataset.bound = 'true';
        const url = btn.dataset.url ?? window.location.href;
        const original = btn.getAttribute('aria-label') ?? '';
        const copied = btn.dataset.labelCopied ?? 'Copied';
        let timer: number | undefined;
        btn.addEventListener('click', async () => {
          if (!navigator.clipboard) return;
          if (await copyTextToClipboard(url)) {
            btn.classList.add('is-copied');
            btn.setAttribute('aria-label', copied);
            window.clearTimeout(timer);
            timer = window.setTimeout(() => {
              btn.classList.remove('is-copied');
              btn.setAttribute('aria-label', original);
            }, 2000);
          }
        });
      });

      // --- Table-of-contents scroll-spy (accordion rail) ---
      const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'));
      const tocGroupEls = Array.from(document.querySelectorAll<HTMLElement>('.toc-group'));
      // Map every heading slug → its parent H2 group slug, so activating an H3
      // opens (and keeps open) its section in the rail.
      const slugToGroup = new Map<string, string>();
      tocGroupEls.forEach((g) => {
        const gid = g.dataset.tocGroup ?? '';
        g.querySelectorAll<HTMLAnchorElement>('[data-toc-link]').forEach((l) => {
          slugToGroup.set(l.dataset.tocLink ?? '', gid);
        });
      });
      // Resume needs the current section's id + human title; the scroll-spy already
      // computes the active id, so reuse it (no second observer). `currentActive`
      // is read by the debounced position writer below.
      let currentActive = '';
      let savePosTimer: number | undefined;
      const persistPos = () => {
        if (!posKey || !currentActive) return;
        try {
          window.localStorage.setItem(posKey, currentActive);
        } catch {
          /* storage blocked (private mode / quota) — resume just won't work. */
        }
      };

      let observer: IntersectionObserver | null = null;
      if (tocLinks.length) {
        let active = '';
        const setActive = (slug: string) => {
          if (slug === active) return;
          active = slug;
          currentActive = slug;
          const groupId = slugToGroup.get(slug);
          tocLinks.forEach((l) => {
            // Desktop rail links match the exact active heading (H2 or H3).
            // The mobile <details>/sheet list only H2s, so highlight them by
            // their group (parent H2) — otherwise the highlight disappears the
            // moment you scroll into any H3 of the section.
            const on =
              l.dataset.tocMobile != null
                ? l.dataset.tocLink === (groupId ?? slug)
                : l.dataset.tocLink === slug;
            l.classList.toggle('is-active', on);
            if (on) l.setAttribute('aria-current', 'true');
            else l.removeAttribute('aria-current');
          });
          tocGroupEls.forEach((g) => {
            g.toggleAttribute('data-open', g.dataset.tocGroup === groupId);
          });
          // Debounced write of the reading position (~400ms after spy settles).
          if (posKey) {
            window.clearTimeout(savePosTimer);
            savePosTimer = window.setTimeout(persistPos, 400);
          }
        };
        const slugs = Array.from(new Set(tocLinks.map((l) => l.dataset.tocLink ?? '')));
        const headingEls = slugs
          .map((s) => document.getElementById(s))
          .filter((el): el is HTMLElement => !!el);
        observer = new IntersectionObserver(
          (entries) => {
            const visible = entries.filter((e) => e.isIntersecting);
            if (visible.length) {
              visible.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
              setActive((visible[0].target as HTMLElement).id);
            }
          },
          { rootMargin: '-88px 0px -70% 0px', threshold: 0 },
        );
        headingEls.forEach((h) => observer!.observe(h));
      }

      // --- Reading progress + back-to-top (one shared scroll handler) ---
      const progress = document.querySelector<HTMLElement>('.reading-progress-fill');
      const toTop = document.querySelector<HTMLElement>('[data-back-to-top]');
      const onScroll = () => {
        if (progress && article) {
          const total = article.offsetHeight - window.innerHeight;
          const scrolled = window.scrollY - article.offsetTop;
          const ratio = total > 0 ? Math.min(1, Math.max(0, scrolled / total)) : 0;
          progress.style.transform = 'scaleX(' + ratio + ')';
        }
        if (toTop) toTop.classList.toggle('is-visible', window.scrollY > 600);
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      if (toTop && !toTop.dataset.bound) {
        toTop.dataset.bound = 'true';
        toTop.addEventListener('click', () =>
          window.scrollTo({ top: 0, behavior: reduceMotion ? 'auto' : 'smooth' }),
        );
      }

      // --- Mobile "Jump to section" FAB + slide-up panel (< lg) ---
      // Accessible bottom sheet (aria-modal): focus moves in on open and is
      // trapped (Tab / Shift+Tab wrap) while open, returning to the FAB on
      // close; Escape + scrim + close button all dismiss; body scroll is locked.
      // Close defers `hidden` until the slide-out transition finishes so it
      // animates out symmetrically with the open (immediate under reduced motion).
      const fab = document.querySelector<HTMLElement>('[data-sections-fab]');
      const panel = document.querySelector<HTMLElement>('[data-sections-panel]');
      const scrim = document.querySelector<HTMLElement>('[data-sections-scrim]');
      let panelKeydown: ((e: KeyboardEvent) => void) | null = null;
      let panelCloseTimer: number | undefined;
      const panelFocusable = (): HTMLElement[] =>
        panel
          ? Array.from(
              panel.querySelectorAll<HTMLElement>('a[href], button:not([disabled])'),
            ).filter((el) => el.offsetParent !== null)
          : [];
      const closeSectionsPanel = () => {
        if (!panel || !fab || fab.getAttribute('aria-expanded') !== 'true') return;
        panel.classList.remove('is-open');
        if (scrim) scrim.classList.remove('is-open');
        fab.setAttribute('aria-expanded', 'false');
        document.body.style.removeProperty('overflow');
        if (panelKeydown) {
          panel.removeEventListener('keydown', panelKeydown);
          panelKeydown = null;
        }
        fab.focus();
        // Wait for the slide-out before hiding (no transition under reduced motion).
        window.clearTimeout(panelCloseTimer);
        const hideNow = () => {
          panel.hidden = true;
          if (scrim) scrim.hidden = true;
        };
        if (reduceMotion) hideNow();
        else panelCloseTimer = window.setTimeout(hideNow, 280);
      };
      const openSectionsPanel = () => {
        if (!panel || !fab) return;
        window.clearTimeout(panelCloseTimer);
        panel.hidden = false;
        if (scrim) scrim.hidden = false;
        // Force a frame so the transition runs from the hidden state.
        requestAnimationFrame(() => {
          panel.classList.add('is-open');
          if (scrim) scrim.classList.add('is-open');
        });
        fab.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        // Move focus into the panel (close button is the first interactive target).
        const first = panel.querySelector<HTMLElement>('[data-sections-close]');
        (first ?? panel).focus();
        panelKeydown = (e: KeyboardEvent) => {
          if (e.key === 'Escape') {
            e.preventDefault();
            closeSectionsPanel();
            return;
          }
          if (e.key === 'Tab') {
            // Keep Tab within the dialog so the aria-modal contract holds.
            const f = panelFocusable();
            if (!f.length) return;
            const firstEl = f[0];
            const lastEl = f[f.length - 1];
            if (e.shiftKey && document.activeElement === firstEl) {
              e.preventDefault();
              lastEl.focus();
            } else if (!e.shiftKey && document.activeElement === lastEl) {
              e.preventDefault();
              firstEl.focus();
            }
          }
        };
        panel.addEventListener('keydown', panelKeydown);
      };
      if (fab && panel && !fab.dataset.bound) {
        fab.dataset.bound = 'true';
        fab.addEventListener('click', () => {
          if (fab.getAttribute('aria-expanded') === 'true') closeSectionsPanel();
          else openSectionsPanel();
        });
        panel.querySelector<HTMLElement>('[data-sections-close]')?.addEventListener('click', closeSectionsPanel);
        scrim?.addEventListener('click', closeSectionsPanel);
        panel.querySelectorAll<HTMLAnchorElement>('[data-sections-link]').forEach((link) => {
          link.addEventListener('click', () => {
            // Native #anchor handles the scroll; just close the sheet.
            closeSectionsPanel();
          });
        });
      }

      // --- Reading-position resume ---
      // On load, if a saved position exists for this guide AND no URL #hash is
      // present (a hash always wins), scroll to the saved section and offer a
      // dismissible toast. Reuses the scroll-spy's heading ids; no extra observer.
      const resumeToast = document.querySelector<HTMLElement>('[data-resume-toast]');
      let resumeTimer: number | undefined;
      const dismissResume = () => {
        if (!resumeToast) return;
        resumeToast.classList.remove('is-visible');
        window.clearTimeout(resumeTimer);
        resumeTimer = window.setTimeout(() => {
          resumeToast.hidden = true;
        }, 250);
      };
      if (resumeToast && posKey && !window.location.hash) {
        let saved = '';
        try {
          saved = window.localStorage.getItem(posKey) ?? '';
        } catch {
          saved = '';
        }
        const target = saved ? document.getElementById(saved) : null;
        // Only resume when there's a real saved section that isn't the very first
        // heading (resuming "at the top" is just noise).
        const firstHeading = root.querySelector<HTMLElement>('h2[id]');
        if (target && target !== firstHeading) {
          // Title for the toast: the injected "#" anchor is always the LAST child,
          // so slice off the final "#" rather than replace() (which strips the
          // FIRST "#", mangling headings that contain one, e.g. "C# basics").
          const anchor = target.querySelector('.heading-anchor');
          const raw = target.textContent ?? '';
          const title = (anchor ? raw.slice(0, raw.lastIndexOf('#')) : raw).trim();
          const titleEl = resumeToast.querySelector<HTMLElement>('[data-resume-title]');
          target.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'start' });
          resumeToast.hidden = false;
          // Set the title AFTER the region is unhidden so the polite aria-live
          // announcement fires (Chrome/Edge skip content present before unhide).
          requestAnimationFrame(() => {
            if (titleEl) titleEl.textContent = title;
            resumeToast.classList.add('is-visible');
          });
          resumeTimer = window.setTimeout(dismissResume, 6000);
        }
      }
      if (resumeToast && !resumeToast.dataset.bound) {
        resumeToast.dataset.bound = 'true';
        resumeToast.querySelector<HTMLElement>('[data-resume-dismiss]')?.addEventListener('click', dismissResume);
        resumeToast.querySelector<HTMLElement>('[data-resume-top]')?.addEventListener('click', () => {
          if (posKey) {
            try {
              window.localStorage.removeItem(posKey);
            } catch {
              /* ignore */
            }
          }
          window.scrollTo({ top: 0, behavior: reduceMotion ? 'auto' : 'smooth' });
          dismissResume();
        });
      }

      w.__guidePostCleanup = () => {
        window.removeEventListener('scroll', onScroll);
        window.removeEventListener('resize', onScroll);
        observer?.disconnect();
        window.clearTimeout(savePosTimer);
        window.clearTimeout(resumeTimer);
        window.clearTimeout(panelCloseTimer);
        if (panel && panelKeydown) panel.removeEventListener('keydown', panelKeydown);
        document.body.style.removeProperty('overflow');
      };
    }
    // Run on initial load too — the site has no ClientRouter, so `astro:page-load`
    // does not fire on a fresh page load; binding only to it would leave code-copy,
    // reading progress, scroll-spy and the accordion TOC dead on direct visits.
    if (document.readyState !== 'loading') initGuidePost();
    else document.addEventListener('DOMContentLoaded', initGuidePost);
    document.addEventListener('astro:page-load', initGuidePost);
  </script>
</Shell>

<style>
  /* On-page FAQ disclosure (authored in this component's template, so scoped
     styles apply). Suppress the native marker and rotate our own chevron. */
  .guide-faq > summary::-webkit-details-marker {
    display: none;
  }
  .guide-faq[open] > summary .guide-faq-chevron {
    transform: rotate(180deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .guide-faq-chevron {
      transition: none;
    }
  }
</style>

<style is:global>
  /*
   * GLOBAL on purpose: the article body is rendered by <Content /> (markdown),
   * and Astro does NOT add the component scope hash to <Content /> output — so
   * scoped `.rich-text x` selectors never match the paragraphs/headings/code.
   * Every selector here is namespaced under `.rich-text` (or a unique class like
   * .reading-progress / .toc-link / .back-to-top), so going global is safe.
   */
  @reference "../../styles/global.css";

  /* --- Reading progress bar (fixed, scroll-driven via scaleX) --- */
  .reading-progress {
    position: fixed;
    inset: 0 0 auto 0;
    height: 3px;
    z-index: 50;
    pointer-events: none;
  }
  .reading-progress-fill {
    display: block;
    height: 100%;
    width: 100%;
    transform: scaleX(0);
    transform-origin: 0 50%;
    background: linear-gradient(90deg, var(--color-brand), var(--color-brand-strong));
  }

  /* --- Table of contents active link --- */
  .toc-link.is-active {
    color: var(--color-ink);
    border-color: var(--color-brand);
    font-weight: 600;
  }
  .toc-h2.is-active {
    background: color-mix(in srgb, var(--color-brand) 7%, transparent);
  }

  /* Accordion rail: H3 children collapse so the resting rail is H2-only; the
     active section's children reveal via the scroll-spy's data-open toggle. */
  .toc-children {
    display: none;
  }
  .toc-group[data-open] .toc-children {
    display: block;
  }

  /* --- Heading anchor links (#) ---
     Below xl: rendered inline after the heading text (static flow, always shown
     but low-key) so the anchor stays reachable on touch/tablet where there is no
     gutter. At xl+: lifted into the left gutter as a hover-reveal "#", matching
     the desktop rails treatment. Keyboard :focus-visible shows it at all widths. */
  .rich-text :is(h2, h3) {
    position: relative;
  }
  .heading-anchor {
    /* < xl default: inline, static, after the heading text. */
    margin-left: 0.4em;
    color: var(--color-mute);
    text-decoration: none;
    font-weight: 400;
    /* Don't let the trailing "#" push the line into horizontal overflow. */
    word-break: keep-all;
    transition:
      opacity 0.15s ease,
      color 0.15s ease;
  }
  .heading-anchor:hover {
    color: var(--color-brand-strong);
  }
  .heading-anchor:focus-visible {
    opacity: 1;
    color: var(--color-brand-strong);
  }
  /* xl+: move the anchor into the left gutter and reveal it only on hover/focus. */
  @media (min-width: 1280px) {
    .heading-anchor {
      position: absolute;
      left: -1.1em;
      top: 0;
      width: 1.1em;
      margin-left: 0;
      text-align: center;
      opacity: 0;
    }
    .rich-text :is(h2, h3):hover > .heading-anchor,
    .heading-anchor:focus-visible {
      opacity: 1;
    }
  }

  /* --- Back-to-top button (fixed, fades in past ~600px) --- */
  .back-to-top {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 50;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 9999px;
    border: 1px solid var(--color-hairline-strong);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.12);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      visibility 0.2s,
      color 0.15s ease,
      border-color 0.15s ease;
  }
  .back-to-top.is-visible {
    opacity: 1;
    visibility: visible;
    transform: none;
  }
  .back-to-top:hover {
    color: var(--color-brand-strong);
    border-color: var(--color-brand);
  }

  /* --- Mobile TOC active highlight (shared by the <details> list + FAB panel) ---
     The desktop rail uses .toc-link.is-active; the mobile entries use a sibling
     class so the rail's left-border treatment doesn't bleed into the flat list. */
  .toc-mobile-link.is-active {
    color: var(--color-ink);
    font-weight: 600;
  }
  .toc-mobile-link.is-active .toc-mobile-min {
    color: var(--color-brand-strong);
  }

  /* --- Mobile "Jump to section" FAB (stacked above back-to-top) --- */
  .sections-fab {
    position: fixed;
    right: 1.25rem;
    /* Sit above the 44px back-to-top button (1.25rem gutter + 44px + 0.625rem gap). */
    bottom: calc(1.25rem + 44px + 0.625rem);
    z-index: 50;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 9999px;
    border: 1px solid var(--color-hairline-strong);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.12);
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }
  .sections-fab:hover {
    color: var(--color-brand-strong);
    border-color: var(--color-brand);
  }
  .sections-fab[aria-expanded='true'] {
    color: var(--color-brand-strong);
    border-color: var(--color-brand);
  }
  /* The desktop sticky rail (lg+) already provides section navigation, so the
     FAB + bottom sheet are mobile-only. This must live in scoped CSS: the
     component's own `.sections-fab { display: … }` rule out-specifies Tailwind's
     `lg:hidden` utility (Astro appends a [data-astro-cid] attribute, raising
     specificity), so the utility alone does NOT hide it on desktop. */
  @media (min-width: 64rem) {
    .sections-fab,
    .sections-scrim,
    .sections-panel {
      display: none !important;
    }
  }

  /* --- Sections bottom sheet: scrim + slide-up panel --- */
  .sections-scrim {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: rgb(0 0 0 / 0.4);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .sections-scrim.is-open {
    opacity: 1;
  }
  .sections-panel {
    position: fixed;
    inset: auto 0 0 0;
    z-index: 61;
    max-height: 75dvh;
    display: flex;
    flex-direction: column;
    background: var(--color-canvas);
    border-top: 1px solid var(--color-hairline-strong);
    border-top-left-radius: var(--radius-lg);
    border-top-right-radius: var(--radius-lg);
    box-shadow: 0 -8px 32px rgb(0 0 0 / 0.18);
    padding: 0.75rem 1rem calc(1rem + env(safe-area-inset-bottom));
    transform: translateY(100%);
    transition: transform 0.25s ease;
  }
  .sections-panel.is-open {
    transform: none;
  }
  .sections-panel:focus {
    outline: none;
  }
  .sections-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-hairline);
  }
  .sections-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    color: var(--color-mute);
    transition:
      color 0.15s ease,
      background-color 0.15s ease;
  }
  .sections-close:hover {
    color: var(--color-ink);
    background: var(--color-canvas-soft-2);
  }
  .sections-panel-list {
    margin-top: 0.25rem;
    overflow-y: auto;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
    display: flex;
    flex-direction: column;
  }
  .sections-panel-list > li + li {
    border-top: 1px solid var(--color-hairline);
  }
  .sections-panel-link {
    padding: 0.7rem 0.25rem;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-mute);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .sections-panel-link:hover {
    color: var(--color-ink);
  }

  /* --- Reading-position resume toast --- */
  .resume-toast {
    position: fixed;
    left: 50%;
    bottom: 1.25rem;
    z-index: 62;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    max-width: calc(100vw - 2rem);
    padding: 0.625rem 0.75rem 0.625rem 1rem;
    border-radius: 9999px;
    border: 1px solid var(--color-hairline-strong);
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: 0 6px 24px rgb(0 0 0 / 0.16);
    font-size: 13px;
    opacity: 0;
    transform: translate(-50%, 8px);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }
  .resume-toast.is-visible {
    opacity: 1;
    transform: translate(-50%, 0);
  }
  /* Keep the toast clear of the right-edge FABs on small screens. */
  @media (max-width: 1023px) {
    .resume-toast {
      left: 1rem;
      right: calc(1.25rem + 44px + 0.75rem);
      max-width: none;
      transform: translateY(8px);
    }
    .resume-toast.is-visible {
      transform: translateY(0);
    }
  }
  .resume-toast-text {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--color-mute);
  }
  .resume-toast-section {
    color: var(--color-ink);
    font-weight: 600;
  }
  .resume-toast-action {
    flex-shrink: 0;
    padding: 0.25rem 0.6rem;
    border-radius: 9999px;
    border: 1px solid var(--color-hairline-strong);
    color: var(--color-brand-strong);
    font-weight: 600;
    white-space: nowrap;
    transition:
      border-color 0.15s ease,
      background-color 0.15s ease;
  }
  .resume-toast-action:hover {
    border-color: var(--color-brand);
