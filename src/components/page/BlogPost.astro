---
/**
 * Shared single blog-post article — rendered by both the English route
 * (src/pages/blog/[...slug].astro) and the per-locale routes
 * (src/pages/<locale>/blog/[...slug].astro). Locale-aware: date formatting,
 * JSON-LD inLanguage, hreflang alternates (only the locales the post exists in)
 * and a language switcher scoped to those locales.
 */
import { render } from 'astro:content';
import { getAbsoluteLocaleUrl } from 'astro:i18n';
import Shell from '../Shell.astro';
import LangSwitcher from '../LangSwitcher.astro';
import { site } from '../../data/site';
import { BCP47, type Locale } from '../../i18n/config';
import { useTranslations, localizeKey } from '../../i18n/utils';
import { formatPostDate, type LocalizedPost } from '../../i18n/blog';

interface Props {
  post: LocalizedPost;
  lang: Locale;
  /** Locales this post is translated into (for hreflang + switcher). */
  available: Locale[];
}

const { post, lang, available } = Astro.props;
const { entry, slug } = post;
const { Content } = await render(entry);
const t = useTranslations(lang);

// Locale-neutral page key; Shell/SEO derive the localized canonical + alternates.
const canonical = `/blog/${slug}`;
const isoDate = entry.data.pubDate.toISOString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: isoDate,
  dateModified: isoDate,
  inLanguage: BCP47[lang],
  keywords: entry.data.tags?.join(', '),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': getAbsoluteLocaleUrl(lang, canonical),
  },
  author: { '@type': 'Organization', name: site.author, url: site.url },
  publisher: { '@type': 'Organization', name: site.name, url: site.url },
};
---

<Shell
  title={`${entry.data.title} — OpsCanopy`}
  description={entry.data.description}
  canonical={canonical}
  type="article"
  jsonLd={jsonLd}
  availableLocales={available}
>
  <article class="bg-canvas-soft">
    <div class="container-page py-16 sm:py-24">
      <div class="mx-auto max-w-[44rem]">
        <div class="flex items-center justify-between gap-4">
          <a
            href={localizeKey('/blog', lang)}
            class="body-sm group -ml-1.5 inline-flex items-center gap-1.5 rounded-md px-1.5 py-1 text-mute transition-colors hover:text-ink [touch-action:manipulation]"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 16 16"
              fill="none"
              aria-hidden="true"
              class="transition-transform duration-150 ease-out group-hover:-translate-x-0.5 motion-reduce:transform-none"
            >
              <path
                d="M10 3.5 5.5 8 10 12.5"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            {t('blog.allPosts')}
          </a>
          {available.length > 1 && <LangSwitcher lang={lang} available={available} />}
        </div>

        <header class="mt-8">
          <time datetime={isoDate} class="eyebrow tabular-nums">{formatPostDate(lang, entry.data.pubDate)}</time>
          <h1 class="display-lg mt-3 text-balance text-ink">{entry.data.title}</h1>
          <p class="body-lg mt-5 text-pretty text-body">{entry.data.description}</p>
          {
            entry.data.tags && entry.data.tags.length > 0 && (
              <ul role="list" class="mt-6 flex flex-wrap gap-2">
                {entry.data.tags.map((tag) => (
                  <li class="badge code-mono lowercase">{tag}</li>
                ))}
              </ul>
            )
          }
        </header>

        <hr class="my-10 border-0 border-t border-hairline" />

        <div class="rich-text">
          <Content />
        </div>
      </div>
    </div>
  </article>
</Shell>

<style>
  @reference "../../styles/global.css";

  /* Scoped to .rich-text — these rules never touch global elements. */
  .rich-text {
    color: var(--color-body);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 28px;
    overflow-wrap: break-word;
  }

  .rich-text > :first-child {
    margin-top: 0;
  }

  .rich-text > :last-child {
    margin-bottom: 0;
  }

  .rich-text p {
    text-wrap: pretty;
  }

  .rich-text :is(h2, h3, h4) {
    color: var(--color-ink);
    font-weight: 600;
    letter-spacing: -0.03em;
    text-wrap: balance;
    scroll-margin-top: 88px;
  }

  .rich-text h2 {
    margin-top: 48px;
    margin-bottom: 16px;
    font-size: 24px;
    line-height: 32px;
    letter-spacing: -0.04em;
  }

  .rich-text h3 {
    margin-top: 36px;
    margin-bottom: 12px;
    font-size: 20px;
    line-height: 28px;
  }

  .rich-text h4 {
    margin-top: 28px;
    margin-bottom: 8px;
    font-size: 16px;
    line-height: 24px;
  }

  .rich-text p {
    margin-block: 20px;
  }

  .rich-text :is(ul, ol) {
    margin-block: 20px;
    padding-left: 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .rich-text ul {
    list-style: disc;
  }

  .rich-text ol {
    list-style: decimal;
  }

  .rich-text li::marker {
    color: var(--color-mute);
  }

  .rich-text li > :is(ul, ol) {
    margin-block: 8px;
  }

  .rich-text a {
    color: var(--color-link);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    overflow-wrap: anywhere;
    transition: color 0.15s ease, text-decoration-color 0.15s ease;
  }

  .rich-text a:hover {
    color: var(--color-link-deep);
  }

  .rich-text strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  .rich-text blockquote {
    margin-block: 24px;
    padding-left: 20px;
    border-left: 2px solid var(--color-hairline-strong);
    color: var(--color-body);
    font-style: normal;
  }

  .rich-text :not(pre) > code {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--color-canvas-soft-2);
    color: var(--color-ink);
    padding: 2px 6px;
    border-radius: var(--radius-xs);
    box-shadow: var(--shadow-hairline);
    overflow-wrap: anywhere;
    overflow-wrap: break-word;
  }

  .rich-text pre {
    margin-block: 24px;
    padding: 20px 24px;
    border-radius: var(--radius-md);
    background: var(--color-primary);
    color: var(--color-on-primary);
    overflow-x: auto;
    overscroll-behavior-x: contain;
    -webkit-overflow-scrolling: touch;
    box-shadow: var(--shadow-subtle);
    tab-size: 2;
  }

  .rich-text pre code {
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 20px;
    background: transparent;
    padding: 0;
    white-space: pre;
    box-shadow: none;
  }

  .rich-text hr {
    margin-block: 40px;
    border: 0;
    border-top: 1px solid var(--color-hairline);
  }

  .rich-text img {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin-block: 24px;
  }
</style>
