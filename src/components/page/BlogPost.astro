---
/**
 * Shared single blog-post article — rendered by both the English route
 * (src/pages/blog/[...slug].astro) and the per-locale routes
 * (src/pages/<locale>/blog/[...slug].astro). Locale-aware: date formatting,
 * JSON-LD inLanguage, hreflang alternates (only the locales the post exists in)
 * and a language switcher scoped to those locales.
 */
import { render } from 'astro:content';
import { getAbsoluteLocaleUrl } from 'astro:i18n';
import Shell from '../Shell.astro';
import LangSwitcher from '../LangSwitcher.astro';
import Button from '../Button.astro';
import ShareButtons from './ShareButtons.astro';
import { site } from '../../data/site';
import { BCP47, DEFAULT_LOCALE, type Locale } from '../../i18n/config';
import { useTranslations, localizeKey } from '../../i18n/utils';
import { breadcrumbLd } from '../../lib/jsonld';
import {
  formatPostDate,
  estimateReadingTime,
  getAllPosts,
  getRelatedPosts,
  getPrevNext,
  type LocalizedPost,
} from '../../i18n/blog';

interface Props {
  post: LocalizedPost;
  lang: Locale;
  /** Locales this post is translated into (for hreflang + switcher). */
  available: Locale[];
}

const { post, lang, available } = Astro.props;
const { entry, slug } = post;
const { Content, headings } = await render(entry);
const t = useTranslations(lang);

// Locale-neutral page key; Shell/SEO derive the localized canonical + alternates.
const canonical = `/blog/${slug}`;
// Per-post social card: the banner rasterized to a 1200x630 PNG (see scripts/gen-og-images.mjs).
const ogImage = `/blog/${slug}-og.png`;
const isoDate = entry.data.pubDate.toISOString();

// Optional revision date — drives the "Last updated" line + JSON-LD dateModified.
const updatedDate = entry.data.updatedDate;
const updatedIso = updatedDate?.toISOString();

// Reading time off the raw markdown body, and the byline line under the date.
const readingTime = estimateReadingTime(entry.body);
const readingLabel = t('blog.readingTime', { minutes: readingTime });

// Optional in-article conversion CTA to the tool this post discusses.
const relatedTool = entry.data.relatedTool;

// Same-language related posts, ranked by shared tags then recency. Fetched here
// (rather than threaded through every route) so all locale routes get it free.
const allPosts = await getAllPosts();
const relatedPosts = getRelatedPosts(post, allPosts, 3);

// Chronological prev/next within the same language (oldest → newest).
const { prev, next } = getPrevNext(post, allPosts);

// Breadcrumb trail (Home / Blog / {title}) — localized hrefs for the links,
// absolute URLs for the BreadcrumbList JSON-LD per the shared contract.
const blogIndexHref = localizeKey('/blog', lang);
const breadcrumbJsonLd = breadcrumbLd([
  { name: t('blog.breadcrumbHome'), item: `${site.url}/` },
  { name: t('blog.breadcrumbBlog'), item: `${site.url}/blog` },
  { name: entry.data.title, item: `${site.url}/blog/${slug}` },
]);

// Table of contents from the post's H2/H3 headings (Astro injects matching ids).
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

// Absolute post URL + share intents for the share buttons.
const shareUrl = getAbsoluteLocaleUrl(lang, canonical);
const shareXUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(entry.data.title)}&url=${encodeURIComponent(shareUrl)}`;
const shareLinkedInUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.description,
  image: `${site.url}${ogImage}`,
  datePublished: isoDate,
  dateModified: updatedIso ?? isoDate,
  inLanguage: BCP47[lang],
  keywords: entry.data.tags?.join(', '),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': getAbsoluteLocaleUrl(lang, canonical),
  },
  author:
    entry.data.author === site.author
      ? { '@type': 'Organization', name: site.author, url: site.url }
      : { '@type': 'Person', name: entry.data.author },
  publisher: { '@type': 'Organization', name: site.name, url: site.url },
};
---

<Shell
  title={`${entry.data.title} — OpsCanopy`}
  description={entry.data.description}
  canonical={canonical}
  image={ogImage}
  type="article"
  jsonLd={jsonLd}
  availableLocales={available}
>
  <div class="reading-progress" aria-hidden="true"><span class="reading-progress-fill"></span></div>

  <article class="bg-canvas-soft">
    <div class="container-page py-16 sm:py-24">
      <div
        class="mx-auto grid w-full max-w-[var(--container-page)] grid-cols-1 gap-x-10 xl:grid-cols-[minmax(0,1fr)_44rem_minmax(0,1fr)]"
      >
        {
          toc.length > 1 && (
            <aside class="hidden xl:col-start-1 xl:block">
              <nav
                aria-label={t('blog.tocTitle')}
                class="sticky top-24 max-h-[calc(100dvh-7rem)] overflow-y-auto pr-2"
              >
                <p class="eyebrow mb-3 text-mute">{t('blog.tocTitle')}</p>
                <ul role="list" class="border-l border-hairline">
                  {toc.map((h) => (
                    <li>
                      <a
                        href={`#${h.slug}`}
                        data-toc-link={h.slug}
                        class:list={[
                          'toc-link -ml-px block border-l-2 border-transparent py-1 leading-snug text-mute transition-colors hover:text-ink',
                          h.depth === 3 ? 'body-sm pl-7' : 'body-sm pl-4 font-medium',
                        ]}
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </aside>
          )
        }

        <div class="mx-auto w-full min-w-0 max-w-[44rem] xl:col-start-2">
        <nav aria-label={t('blog.breadcrumbAriaLabel')} class="mb-6">
          <ol role="list" class="caption flex flex-wrap items-center gap-x-1.5 gap-y-1 text-mute">
            <li>
              <a
                href={localizeKey('/', lang)}
                class="rounded px-0.5 transition-colors hover:text-ink"
              >
                {t('blog.breadcrumbHome')}
              </a>
            </li>
            <li aria-hidden="true">/</li>
            <li>
              <a href={blogIndexHref} class="rounded px-0.5 transition-colors hover:text-ink">
                {t('blog.breadcrumbBlog')}
              </a>
            </li>
            <li aria-hidden="true">/</li>
            <li class="min-w-0 truncate text-body" aria-current="page">{entry.data.title}</li>
          </ol>
        </nav>

        <div class="flex items-center justify-between gap-4">
          <a
            href={localizeKey('/blog', lang)}
            class="body-sm group -ml-1.5 inline-flex items-center gap-1.5 rounded-md px-1.5 py-1 text-mute transition-colors hover:text-ink [touch-action:manipulation]"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 16 16"
              fill="none"
              aria-hidden="true"
              class="transition-transform duration-150 ease-out group-hover:-translate-x-0.5 motion-reduce:transform-none"
            >
              <path
                d="M10 3.5 5.5 8 10 12.5"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            {t('blog.allPosts')}
          </a>
          {available.length > 1 && <LangSwitcher lang={lang} available={available} />}
        </div>

        <header class="mt-8">
          <p class="caption flex flex-wrap items-center gap-x-1.5 gap-y-1 text-mute">
            <span class="text-body">{entry.data.author}</span>
            <span aria-hidden="true">·</span>
            <time datetime={isoDate} class="tabular-nums">{formatPostDate(lang, entry.data.pubDate)}</time>
            <span aria-hidden="true">·</span>
            <span class="tabular-nums">{readingLabel}</span>
          </p>
          {
            updatedDate && updatedIso && (
              <p class="caption mt-1.5 text-mute">
                <time datetime={updatedIso} class="tabular-nums">
                  {t('blog.updatedOn', { date: formatPostDate(lang, updatedDate) })}
                </time>
              </p>
            )
          }
          <h1 class="display-lg mt-3 text-balance text-ink">{entry.data.title}</h1>
          <p class="body-lg mt-5 text-pretty text-body">{entry.data.description}</p>
          {
            entry.data.tags && entry.data.tags.length > 0 && (
              <ul role="list" class="mt-6 flex flex-wrap gap-2">
                {entry.data.tags.map((tag) =>
                  lang === DEFAULT_LOCALE ? (
                    <li>
                      <a
                        href={`/blog/tag/${tag.toLowerCase()}`}
                        class="badge code-mono lowercase transition-colors hover:border-brand/40 hover:text-brand-strong"
                      >
                        {tag}
                      </a>
                    </li>
                  ) : (
                    <li class="badge code-mono lowercase">{tag}</li>
                  ),
                )}
              </ul>
            )
          }
        </header>

        <hr class="my-10 border-0 border-t border-hairline" />

        {/* Mobile/tablet: share row + collapsible TOC (the rails are xl-only). */}
        <div class="mb-8 flex flex-wrap items-center gap-3 xl:hidden">
          <span class="caption text-mute">{t('blog.shareTitle')}</span>
          <ShareButtons
            orientation="row"
            xUrl={shareXUrl}
            linkedInUrl={shareLinkedInUrl}
            url={shareUrl}
            shareXLabel={t('blog.shareX')}
            shareLinkedInLabel={t('blog.shareLinkedIn')}
            copyLinkLabel={t('blog.copyLink')}
            copiedLabel={t('blog.linkCopied')}
          />
        </div>

        {
          toc.length > 1 && (
            <details class="group mb-10 rounded-lg border border-hairline bg-canvas px-4 py-3 xl:hidden">
              <summary class="caption flex cursor-pointer list-none items-center justify-between font-medium text-ink [&::-webkit-details-marker]:hidden">
                {t('blog.tocTitle')}
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 16 16"
                  fill="none"
                  aria-hidden="true"
                  class="text-mute transition-transform duration-200 group-open:rotate-180 motion-reduce:transform-none"
                >
                  <path
                    d="M4 6l4 4 4-4"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </summary>
              <ul role="list" class="mt-3 space-y-1.5 border-t border-hairline pt-3">
                {toc.map((h) => (
                  <li>
                    <a
                      href={`#${h.slug}`}
                      class:list={[
                        'body-sm block text-mute transition-colors hover:text-ink',
                        h.depth === 3 ? 'pl-4' : 'font-medium',
                      ]}
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          )
        }

        <div
          class="rich-text"
          data-copy-label={t('blog.copyCode')}
          data-copied-label={t('blog.copiedCode')}
          data-copy-aria={t('blog.copyCodeAriaLabel')}
          data-anchor-label={t('blog.headingAnchorLabel')}
        >
          <Content />
        </div>

        {
          relatedTool && (
            <aside class="mt-12 rounded-xl border border-brand/30 bg-brand/5 p-6 sm:flex sm:items-center sm:justify-between sm:gap-6">
              <div class="min-w-0">
                <p class="eyebrow text-brand-strong">{t('blog.ctaEyebrow')}</p>
                <p class="body-md mt-2 text-pretty text-ink">
                  {t('blog.ctaLead')}
                </p>
              </div>
              <div class="mt-5 shrink-0 sm:mt-0">
                <Button href={relatedTool.href} size="sm">
                  {t('blog.ctaButton', { name: relatedTool.name })}
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                    class="ml-1.5 inline-block align-[-1px]"
                  >
                    <path
                      d="M6 3.5 10.5 8 6 12.5"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </Button>
              </div>
            </aside>
          )
        }

        {
          relatedPosts.length > 0 && (
            <section class="mt-16 border-t border-hairline pt-12" aria-labelledby="related-heading">
              <h2 id="related-heading" class="display-sm text-ink">{t('blog.relatedTitle')}</h2>
              <ul role="list" class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {relatedPosts.map((rp) => (
                  <li class="h-full">
                    <a
                      href={localizeKey(`/blog/${rp.slug}`, lang)}
                      class="card group flex h-full min-w-0 flex-col p-6 transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-soft focus-visible:-translate-y-0.5 focus-visible:shadow-soft motion-reduce:transform-none motion-reduce:hover:translate-y-0"
                    >
                      <div class="-mx-6 -mt-6 mb-5 overflow-hidden rounded-t-[var(--radius-md)]">
                        <img
                          src={`/blog/${rp.slug}-hero.svg`}
                          alt=""
                          loading="lazy"
                          width="1200"
                          height="630"
                          class="aspect-[1200/630] w-full bg-canvas-soft-2 object-cover transition-transform duration-300 ease-out group-hover:scale-[1.04] motion-reduce:transform-none"
                        />
                      </div>
                      <p class="caption flex flex-wrap items-center gap-x-1.5 gap-y-1 text-mute">
                        <time datetime={rp.entry.data.pubDate.toISOString()} class="tabular-nums">
                          {formatPostDate(lang, rp.entry.data.pubDate)}
                        </time>
                        <span aria-hidden="true">·</span>
                        <span class="tabular-nums">
                          {t('blog.readingTime', { minutes: estimateReadingTime(rp.entry.body) })}
                        </span>
                      </p>
                      <h3 class="body-lg mt-3 text-balance font-semibold text-ink">
                        {rp.entry.data.title}
                      </h3>
                      <p class="body-sm mt-3 line-clamp-3 grow text-pretty text-body">
                        {rp.entry.data.description}
                      </p>
                      <span
                        class="body-sm mt-5 inline-flex items-center gap-1 font-medium text-link"
                        aria-hidden="true"
                      >
                        {t('blog.readPost')}
                        <svg
                          width="14"
                          height="14"
                          viewBox="0 0 16 16"
                          fill="none"
                          class="transition-transform duration-150 ease-out group-hover:translate-x-0.5 group-focus-visible:translate-x-0.5 motion-reduce:transform-none"
                        >
                          <path
                            d="M6 3.5 10.5 8 6 12.5"
                            stroke="currentColor"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          />
                        </svg>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        {
          (prev || next) && (
            <nav
              aria-label={t('blog.pagerAriaLabel')}
              class="mt-16 grid grid-cols-1 gap-4 border-t border-hairline pt-12 sm:grid-cols-2"
            >
              {prev ? (
                <a
                  href={localizeKey(`/blog/${prev.slug}`, lang)}
                  rel="prev"
                  class="card group flex min-w-0 flex-col p-5 transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-soft focus-visible:-translate-y-0.5 focus-visible:shadow-soft motion-reduce:transform-none motion-reduce:hover:translate-y-0"
                >
                  <span class="caption inline-flex items-center gap-1 text-mute">
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 16 16"
                      fill="none"
                      aria-hidden="true"
                      class="transition-transform duration-150 ease-out group-hover:-translate-x-0.5 motion-reduce:transform-none"
                    >
                      <path
                        d="M10 3.5 5.5 8 10 12.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                    {t('blog.prevPost')}
                  </span>
                  <span class="body-sm mt-2 text-balance font-semibold text-ink">
                    {prev.entry.data.title}
                  </span>
                </a>
              ) : (
                <span aria-hidden="true" class="hidden sm:block" />
              )}
              {next && (
                <a
                  href={localizeKey(`/blog/${next.slug}`, lang)}
                  rel="next"
                  class="card group flex min-w-0 flex-col p-5 text-right transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-soft focus-visible:-translate-y-0.5 focus-visible:shadow-soft motion-reduce:transform-none motion-reduce:hover:translate-y-0"
                >
                  <span class="caption inline-flex items-center justify-end gap-1 text-mute">
                    {t('blog.nextPost')}
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 16 16"
                      fill="none"
                      aria-hidden="true"
                      class="transition-transform duration-150 ease-out group-hover:translate-x-0.5 motion-reduce:transform-none"
                    >
                      <path
                        d="M6 3.5 10.5 8 6 12.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                  <span class="body-sm mt-2 text-balance font-semibold text-ink">
                    {next.entry.data.title}
                  </span>
                </a>
              )}
            </nav>
          )
        }
        </div>

        {/* RIGHT RAIL — share (xl+). */}
        <aside class="hidden xl:col-start-3 xl:block">
          <div class="sticky top-24">
            <p class="eyebrow mb-3 text-mute">{t('blog.shareTitle')}</p>
            <ShareButtons
              orientation="col"
              xUrl={shareXUrl}
              linkedInUrl={shareLinkedInUrl}
              url={shareUrl}
              shareXLabel={t('blog.shareX')}
              shareLinkedInLabel={t('blog.shareLinkedIn')}
              copyLinkLabel={t('blog.copyLink')}
              copiedLabel={t('blog.linkCopied')}
            />
          </div>
        </aside>
      </div>
    </div>
  </article>

  <button type="button" data-back-to-top aria-label={t('blog.backToTop')} class="back-to-top">
    <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path
        d="M4 10 8 6l4 4"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </button>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <script>
    // Progressive enhancement for the blog post page: code-copy buttons, reading
    // progress bar, table-of-contents scroll-spy, heading anchor links, copy-link
    // share buttons, and the back-to-top button. Re-runs on every astro:page-load
    // (ClientRouter) and first tears down window/observer listeners from the prior
    // page so navigations never stack handlers.
    function initBlogPost() {
      const w = window as unknown as { __blogPostCleanup?: (() => void) | null };
      if (w.__blogPostCleanup) {
        w.__blogPostCleanup();
        w.__blogPostCleanup = null;
      }

      const article = document.querySelector<HTMLElement>('article');
      const root = document.querySelector<HTMLElement>('.rich-text');
      if (!root) return;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // --- Code-copy buttons (per <pre>) ---
      if (navigator.clipboard) {
        const copyLabel = root.dataset.copyLabel ?? 'Copy';
        const copiedLabel = root.dataset.copiedLabel ?? 'Copied';
        const ariaLabel = root.dataset.copyAria ?? 'Copy code to clipboard';
        root.querySelectorAll<HTMLPreElement>('pre').forEach((pre) => {
          if (pre.dataset.copyReady) return;
          pre.dataset.copyReady = 'true';
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'rich-code-copy';
          btn.textContent = copyLabel;
          btn.setAttribute('aria-label', ariaLabel);
          let resetTimer: number | undefined;
          btn.addEventListener('click', async () => {
            const code = pre.querySelector('code');
            const text = (code ?? pre).textContent ?? '';
            try {
              await navigator.clipboard.writeText(text);
              btn.textContent = copiedLabel;
              btn.dataset.copied = 'true';
              window.clearTimeout(resetTimer);
              resetTimer = window.setTimeout(() => {
                btn.textContent = copyLabel;
                delete btn.dataset.copied;
              }, 2000);
            } catch {
              /* Clipboard blocked — leave the label unchanged. */
            }
          });
          pre.appendChild(btn);
        });
      }

      // --- Heading anchor links (hover-reveal #) ---
      const anchorLabel = root.dataset.anchorLabel ?? 'Link to this section';
      root.querySelectorAll<HTMLElement>('h2[id], h3[id]').forEach((h) => {
        if (h.dataset.anchored) return;
        h.dataset.anchored = 'true';
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.className = 'heading-anchor';
        a.textContent = '#';
        a.setAttribute('aria-label', anchorLabel);
        h.appendChild(a);
      });

      // --- Copy-link share buttons ---
      document.querySelectorAll<HTMLButtonElement>('[data-copy-link]').forEach((btn) => {
        if (btn.dataset.bound) return;
        btn.dataset.bound = 'true';
        const url = btn.dataset.url ?? window.location.href;
        const original = btn.getAttribute('aria-label') ?? '';
        const copied = btn.dataset.labelCopied ?? 'Copied';
        let timer: number | undefined;
        btn.addEventListener('click', async () => {
          if (!navigator.clipboard) return;
          try {
            await navigator.clipboard.writeText(url);
            btn.classList.add('is-copied');
            btn.setAttribute('aria-label', copied);
            window.clearTimeout(timer);
            timer = window.setTimeout(() => {
              btn.classList.remove('is-copied');
              btn.setAttribute('aria-label', original);
            }, 2000);
          } catch {
            /* Clipboard blocked. */
          }
        });
      });

      // --- Table-of-contents scroll-spy ---
      const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'));
      let observer: IntersectionObserver | null = null;
      if (tocLinks.length) {
        let active = '';
        const setActive = (slug: string) => {
          if (slug === active) return;
          active = slug;
          tocLinks.forEach((l) => {
            const on = l.dataset.tocLink === slug;
            l.classList.toggle('is-active', on);
            if (on) l.setAttribute('aria-current', 'true');
            else l.removeAttribute('aria-current');
          });
        };
        const slugs = Array.from(new Set(tocLinks.map((l) => l.dataset.tocLink ?? '')));
        const headingEls = slugs
          .map((s) => document.getElementById(s))
          .filter((el): el is HTMLElement => !!el);
        observer = new IntersectionObserver(
          (entries) => {
            const visible = entries.filter((e) => e.isIntersecting);
            if (visible.length) {
              visible.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
              setActive((visible[0].target as HTMLElement).id);
            }
          },
          { rootMargin: '-88px 0px -70% 0px', threshold: 0 },
        );
        headingEls.forEach((h) => observer!.observe(h));
      }

      // --- Reading progress + back-to-top (one shared scroll handler) ---
      const progress = document.querySelector<HTMLElement>('.reading-progress-fill');
      const toTop = document.querySelector<HTMLElement>('[data-back-to-top]');
      const onScroll = () => {
        if (progress && article) {
          const total = article.offsetHeight - window.innerHeight;
          const scrolled = window.scrollY - article.offsetTop;
          const ratio = total > 0 ? Math.min(1, Math.max(0, scrolled / total)) : 0;
          progress.style.transform = 'scaleX(' + ratio + ')';
        }
        if (toTop) toTop.classList.toggle('is-visible', window.scrollY > 600);
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      if (toTop && !toTop.dataset.bound) {
        toTop.dataset.bound = 'true';
        toTop.addEventListener('click', () =>
          window.scrollTo({ top: 0, behavior: reduceMotion ? 'auto' : 'smooth' }),
        );
      }

      w.__blogPostCleanup = () => {
        window.removeEventListener('scroll', onScroll);
        window.removeEventListener('resize', onScroll);
        observer?.disconnect();
      };
    }
    document.addEventListener('astro:page-load', initBlogPost);
  </script>
</Shell>

