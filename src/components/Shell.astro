---
/**
 * Page shell — composes the platform chrome (Header + Footer) around Layout.
 * Most pages render: <Shell title="…">…page sections…</Shell>.
 * Header.astro and Footer.astro are provided by their own components.
 */
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { DEFAULT_LOCALE, type Locale } from '../i18n/config';
import { useTranslations } from '../i18n/utils';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noAlternates?: boolean;
  availableLocales?: Locale[];
}

const props = Astro.props;
const lang: Locale = (Astro.currentLocale as Locale) ?? DEFAULT_LOCALE;
const t = useTranslations(lang);
---

<Layout {...props}>
  <slot name="head" slot="head" />
  <a
    href="#main"
    class="sr-only body-sm font-medium [touch-action:manipulation] focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-on-primary focus:shadow-modal"
  >
    {t('a11y.skipToContent')}
  </a>
  <Header hideLangSwitcher={props.noAlternates} />
  <main id="main"><slot /></main>
  <Footer />
</Layout>
