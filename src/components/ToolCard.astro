---
/**
 * ToolCard — the single source of truth for a tool's catalog card.
 *
 * Used by BOTH /tools (the filterable catalog) and /tools/{category} (the
 * static category landing pages) so the card markup never drifts between them.
 *
 * Renders the `<li>` wrapper itself, carrying the data-* hooks the catalog's
 * inline filter/sort script reads:
 *   - data-name      → lowercased tool name (search match)
 *   - data-category  → lowercased category  (chip filter)
 *   - data-order     → registry index       ("Default" + "Newest" sort)
 *   - data-added     → ISO addedAt if present, else "" (reserved for sort)
 *
 * Color MEANS category: the solid top bar + the category dot both use
 * categoryAccent[category]. Keyword chips sit ABOVE the description, framed by a
 * small "Try:" label, capped at two, ~11px, truncated, and hidden on mobile.
 */
import Card from './Card.astro';
import Badge from './Badge.astro';
import { categoryAccent, type Tool } from '../data/tools';

export interface Props {
  tool: Tool;
  /** Stable registry index — drives the Default/Newest sort on the catalog. */
  order: number;
}

const { tool, order } = Astro.props;
const accent = categoryAccent[tool.category] ?? 'var(--color-mute)';
---

<li
  class="h-full tool-card"
  data-name={tool.name.toLowerCase()}
  data-category={tool.category.toLowerCase()}
  data-order={order}
  data-added={tool.addedAt ?? ''}
>
  <Card class="card-interactive group relative flex h-full flex-col overflow-hidden rounded-lg p-0 shadow-soft focus-within:shadow-float focus-within:ring-2 focus-within:ring-link focus-within:ring-offset-2">
    <span class="block h-1 w-full" style={`background-color: ${accent}`} aria-hidden="true"></span>
    <div class="flex h-full flex-col p-5">
      <div class="flex items-center justify-between gap-3">
        <span class="inline-flex min-w-0 items-center gap-1.5 text-xs font-semibold uppercase tracking-wide text-body">
          <span class="size-1.5 shrink-0 rounded-full" style={`background-color: ${accent}`} aria-hidden="true"></span>
          <span class="truncate">{tool.category}</span>
        </span>
        <Badge variant="live">Live</Badge>
      </div>

      <h3 class="display-sm mt-4 text-balance text-ink">
        <a
          href={`/${tool.slug}`}
          class="rounded-sm outline-none after:absolute after:inset-0 after:content-['']"
        >
          {tool.name}
        </a>
      </h3>
      <p class="body-md mt-1.5 font-medium text-pretty text-ink">{tool.tagline}</p>

      {
        tool.keywords.length > 0 && (
          <ul role="list" class="mt-3 hidden flex-wrap items-center gap-1.5 sm:flex">
            <li class="text-[11px] font-semibold uppercase tracking-wide text-mute">Try:</li>
            {tool.keywords.slice(0, 2).map((keyword) => (
              <li class="min-w-0 max-w-[14ch]">
                <span class="badge code-mono block truncate text-[11px] leading-none lowercase text-body">
                  {keyword}
                </span>
              </li>
            ))}
          </ul>
        )
      }

      <p class="body-sm mt-3 text-pretty text-body">{tool.description}</p>

      <div class="mt-auto pt-5">
        <span class="link-inline body-sm inline-flex items-center gap-1 font-medium">
          Open tool
          <span class="transition-transform duration-150 group-hover:translate-x-0.5" aria-hidden="true">
            &rarr;
          </span>
        </span>
      </div>
    </div>
  </Card>
</li>
