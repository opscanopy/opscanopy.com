---
/**
 * Banner — the "Introducing X" announcement pill (banner-marketing token).
 * Rounded-full, bg-canvas-soft, body-sm text-body, a small leading sparkle dot,
 * and an optional trailing arrow that appears only when `href` is provided.
 *
 * Renders an <a> (navigation) when `href` is set, otherwise a static <div>.
 * The announcement message is the default slot.
 */
export interface Props {
  href?: string;
  class?: string;
}

const { href, class: className = '' } = Astro.props;

const base =
  'banner-marketing group inline-flex max-w-full items-center gap-2 rounded-full bg-canvas-soft py-1.5 pl-2 pr-3 body-sm text-body shadow-hairline transition-colors duration-150 ease-out';
const interactive =
  'no-underline [touch-action:manipulation] hover:bg-canvas-soft-2 focus-visible:bg-canvas-soft-2';
---

{
  href ? (
    <a href={href} class:list={[base, interactive, className]}>
      <span
        class="grid size-4 shrink-0 place-items-center rounded-full bg-canvas text-brand shadow-hairline"
        aria-hidden="true"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="size-2.5">
          <path d="M12 0c.5 5.7 1.8 7 7.5 7.5C13.8 8 12.5 9.3 12 15c-.5-5.7-1.8-7-7.5-7.5C10.2 7 11.5 5.7 12 0Z" />
        </svg>
      </span>
      <span class="min-w-0 text-ink line-clamp-2 sm:truncate"><slot /></span>
      <svg
        viewBox="0 0 16 16"
        fill="none"
        class="size-3.5 shrink-0 text-mute transition-transform duration-150 ease-out group-hover:translate-x-0.5"
        aria-hidden="true"
      >
        <path
          d="M6 3.5 10.5 8 6 12.5"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>
  ) : (
    <div class:list={[base, className]}>
      <span
        class="grid size-4 shrink-0 place-items-center rounded-full bg-canvas text-brand shadow-hairline"
        aria-hidden="true"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="size-2.5">
          <path d="M12 0c.5 5.7 1.8 7 7.5 7.5C13.8 8 12.5 9.3 12 15c-.5-5.7-1.8-7-7.5-7.5C10.2 7 11.5 5.7 12 0Z" />
        </svg>
      </span>
      <span class="min-w-0 text-ink line-clamp-2 sm:truncate"><slot /></span>
    </div>
  )
}
