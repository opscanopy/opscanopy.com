---
import { liveTools, categoryToSlug } from "../data/tools";
import { DEFAULT_LOCALE, type Locale } from "../i18n/config";
import { useTranslations, localizeKey, localizeNavHref } from "../i18n/utils";
import type { UiKey } from "../i18n/ui/en";

const lang: Locale = (Astro.currentLocale as Locale) ?? DEFAULT_LOCALE;
const t = useTranslations(lang);
/** Localized category label, falling back to the raw key. */
const catLabel = (cat: string) => t(`category.${cat}` as UiKey);
const toolHref = (slug: string) => localizeKey(`/${slug}`, lang);
/** URL for a category landing page (/tools/ci-cd etc.). Category landing pages
 *  only exist in the en tree BY DESIGN (localized copies were evaluated and
 *  rejected as thin near-duplicates — see CLAUDE.md), so do NOT locale-prefix —
 *  a /de/tools/networking link would 404. */
const catHref = (cat: string) => `/tools/${categoryToSlug(cat)}/`;

const categoryOrder = ["Networking", "Security", "Encoding", "Kubernetes", "Observability", "CI/CD", "Scheduling", "Logs", "Config"];

// Group liveTools by category
const grouped = new Map<string, typeof liveTools>();
for (const cat of categoryOrder) {
  const tools = liveTools.filter((t) => t.category === cat);
  if (tools.length > 0) {
    grouped.set(cat, tools);
  }
}
// Append any categories not in preferred order
for (const tool of liveTools) {
  if (!grouped.has(tool.category)) {
    grouped.set(tool.category, liveTools.filter((t) => t.category === tool.category));
  }
}
---

<div
  id="mega-menu"
  hidden
  role="dialog"
  aria-label={t('megamenu.dialogLabel')}
  aria-modal="true"
  class="mega-menu absolute inset-x-0 top-full z-50 border-t border-hairline bg-canvas shadow-modal"
>
  <div class="container-page py-6 sm:py-8">

    <!-- Search row -->
    <div class="relative mb-6">
      <span class="pointer-events-none absolute left-3.5 top-1/2 -translate-y-1/2 text-mute">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </span>
      <input
        id="mega-search"
        type="search"
        placeholder={t('megamenu.searchPlaceholder', { count: liveTools.length })}
        autocomplete="off"
        spellcheck="false"
        class="w-full rounded-lg border border-hairline bg-canvas-soft py-2.5 pl-10 pr-4 text-sm text-ink placeholder:text-mute focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
        aria-label={t('megamenu.searchLabel')}
      />
      <button
        id="mega-search-clear"
        type="button"
        hidden
        class="absolute right-3 top-1/2 -translate-y-1/2 text-mute hover:text-ink"
        aria-label={t('megamenu.clearSearch')}
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Tools grid -->
    <div id="mega-grid" class="grid grid-cols-2 gap-x-6 gap-y-7 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
      {Array.from(grouped.entries()).map(([category, tools]) => (
        <div class="mega-cat" data-cat={category.toLowerCase()}>
          <p class="mb-2.5">
            <a
              href={catHref(category)}
              class="mega-cat-link inline-flex items-center gap-2 rounded focus:outline-none"
              data-mega-cat
            >
              <span class="eyebrow">{catLabel(category)}</span>
              <span class="rounded-full bg-canvas-soft-2 px-1.5 py-0.5 text-[10px] font-medium tabular-nums text-mute">{tools.length}</span>
            </a>
          </p>
          <ul class="space-y-0.5">
            {tools.map((tool) => (
              <li>
                <a
                  href={toolHref(tool.slug)}
                  class="mega-tool group flex flex-col rounded-md px-2.5 py-2 transition-colors hover:bg-canvas-soft-2"
                  title={tool.tagline}
                  data-tool-name={tool.name.toLowerCase()}
                  data-tool-desc={tool.tagline.toLowerCase()}
                  data-cat={tool.category.toLowerCase()}
                >
                  <span class="body-sm font-medium text-ink transition-colors group-hover:text-brand-strong">{tool.name}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- No results -->
    <p id="mega-empty" hidden class="py-8 text-center text-sm text-mute">{t('megamenu.emptyPrefix')} "<span id="mega-empty-q"></span>"{t('megamenu.emptySuffix')} <a href={localizeKey('/tools', lang)} class="link-inline">{t('megamenu.browseAll')}</a>.</p>

    <!-- Footer row -->
    <div class="mt-6 border-t border-hairline pt-4">
      <div class="flex items-center justify-between">
        <p class="text-sm text-mute">{t('megamenu.footerCount', { count: liveTools.length })}</p>
        <a href={localizeKey('/tools', lang)} data-mega-viewall class="body-sm inline-flex items-center gap-1 font-medium text-brand-strong hover:underline">
          {t('megamenu.viewAll')}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <!-- Learn / Blog strip -->
      <div class="mega-lb-strip mt-3 flex items-center gap-4 border-t border-hairline pt-3">
        <span class="text-xs text-mute">Explore</span>
        <a href={localizeNavHref('/learn', lang)} data-mega-lb class="mega-lb-link body-sm inline-flex items-center gap-1.5 text-ink hover:text-brand-strong">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          Learn — roadmaps &amp; guides
        </a>
        <a href={localizeNavHref('/mission-90/', lang)} data-mega-lb class="mega-lb-link body-sm inline-flex items-center gap-1.5 text-ink hover:text-brand-strong">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 21V4"/><path d="M4 5h13l-3 4 3 4H4z"/></svg>
          90 Days DevOps
        </a>
        <a href={localizeKey('/blog', lang)} data-mega-lb class="mega-lb-link body-sm inline-flex items-center gap-1.5 text-ink hover:text-brand-strong">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
          Blog
        </a>
      </div>
    </div>

  </div>
</div>

<style>
  .mega-menu {
    transform-origin: top center;
    max-height: calc(100vh - 64px);
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  .mega-menu:not([hidden]) {
    animation: mega-in 0.18s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes mega-in {
    from { opacity: 0; transform: translateY(-6px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .mega-menu:not([hidden]) { animation: none; }
  }
  /* hide entire category column when all tools in it are filtered out */
  .mega-cat:not(:has(.mega-tool:not([hidden]))) { display: none; }

  /* category heading link — inherits the eyebrow styling, adds a hover state */
  .mega-cat-link {
    text-decoration: none;
    transition: opacity 0.12s ease;
  }
  .mega-cat-link:hover { opacity: 0.75; }
  .mega-cat-link:hover .eyebrow { text-decoration: underline; text-underline-offset: 3px; }
  .mega-cat-link:focus-visible {
    outline: 2px solid var(--color-brand);
    outline-offset: 2px;
  }

  /* learn/blog strip */
  .mega-lb-strip { flex-wrap: wrap; }
  .mega-lb-link {
    text-decoration: none;
    transition: color 0.12s ease;
  }
  .mega-lb-link:focus-visible {
    outline: 2px solid var(--color-brand);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>

<script>
function initMegaMenu() {
  const menu    = document.getElementById("mega-menu") as HTMLElement | null;
  const trigger = document.getElementById("tools-trigger") as HTMLElement | null;
  const chevron = document.getElementById("tools-chevron") as HTMLElement | null;
  const search  = document.getElementById("mega-search") as HTMLInputElement | null;
  const clearBtn = document.getElementById("mega-search-clear") as HTMLButtonElement | null;
  const empty   = document.getElementById("mega-empty") as HTMLElement | null;
  const emptyQ  = document.getElementById("mega-empty-q") as HTMLElement | null;

  if (!menu || !trigger) return;
  // Idempotency: initMegaMenu() runs both at script parse AND on astro:page-load,
  // so guard against double-binding every listener (Escape would otherwise fire
  // twice, search would run twice, etc.). Mirrors the dataset.*Wired pattern used
  // by the playgrounds and Header; the element persists across soft navigations.
  if (menu.dataset.megaWired === "true") return;
  menu.dataset.megaWired = "true";

  // ── Timers ──────────────────────────────────────────────────────────────────
  let hoverOpenTimer: ReturnType<typeof setTimeout> | null = null;
  let hoverCloseTimer: ReturnType<typeof setTimeout> | null = null;

  function cancelOpenTimer()  { if (hoverOpenTimer  !== null) { clearTimeout(hoverOpenTimer);  hoverOpenTimer  = null; } }
  function cancelCloseTimer() { if (hoverCloseTimer !== null) { clearTimeout(hoverCloseTimer); hoverCloseTimer = null; } }

  // ── Helpers ─────────────────────────────────────────────────────────────────
  function isOpen(): boolean {
    return !menu!.hasAttribute("hidden");
  }

  /**
   * Returns the ordered list of currently-focusable controls inside the menu —
   * mirrors the `focusables()` helper in Header.astro's mobile-overlay trap.
   *
   * Visual / DOM order:
   *   1. Search input (always first)
   *   2. Clear button — adjacent to search, only when the field has content
   *   3. Category heading links (data-mega-cat) — one per visible column,
   *      in DOM order (matching column order in the grid)
   *   4. Visible tool links (.mega-tool) — within each column, after its heading
   *   5. View-all footer link
   *   6. Learn link (footer strip)
   *   7. Blog link (footer strip)
   */
  function megaFocusables(): HTMLElement[] {
    const items: HTMLElement[] = [];

    // 1. Search input is always present and visible when the menu is open.
    if (search) items.push(search);

    // 2. Clear button sits beside the search input, so keep it adjacent in Tab
    //    order (only when not hidden, i.e. the search has content).
    if (clearBtn && !clearBtn.hidden) items.push(clearBtn);

    // 3 & 4. Walk each category column in DOM order: add the category heading
    //        link first, then all visible tool links in that column.
    //        Columns whose tools are all hidden by search are also hidden via
    //        CSS (:not(:has(.mega-tool:not([hidden])))), so skip those entirely.
    menu!.querySelectorAll<HTMLElement>(".mega-cat").forEach((col) => {
      // Skip columns where every tool is filtered out.
      const hasVisibleTool = Array.from(
        col.querySelectorAll<HTMLAnchorElement>("a.mega-tool")
      ).some((link) => {
        const li = link.closest("li") as HTMLElement | null;
        return !li?.hidden;
      });
      if (!hasVisibleTool) return;

      // Category heading link for this column.
      const catLink = col.querySelector<HTMLAnchorElement>("a[data-mega-cat]");
      if (catLink) items.push(catLink);

      // Visible tool links in this column.
      col.querySelectorAll<HTMLAnchorElement>("a.mega-tool").forEach((link) => {
        const li = link.closest("li") as HTMLElement | null;
        if (!li?.hidden) items.push(link);
      });
    });

    // 5. View-all footer link.
    const viewAllLink = menu!.querySelector<HTMLAnchorElement>("[data-mega-viewall]");
    if (viewAllLink) items.push(viewAllLink);

    // 6 & 7. Learn + Blog links in the footer strip.
    menu!.querySelectorAll<HTMLAnchorElement>("a[data-mega-lb]").forEach((link) => {
      items.push(link);
    });

    return items;
  }

  function resetSearch() {
    if (search)   search.value = "";
    if (clearBtn) clearBtn.hidden = true;
    if (empty)    empty.hidden = true;
    // re-show all tools and categories
    menu!.querySelectorAll<HTMLElement>(".mega-tool").forEach((link) => {
      const li = link.closest("li") as HTMLElement | null;
      if (li) li.hidden = false;
    });
  }

  // ── Open / Close ────────────────────────────────────────────────────────────
  function openMenu() {
    menu!.removeAttribute("hidden");
    trigger!.setAttribute("aria-expanded", "true");
    chevron?.classList.add("rotate-180");
    document.body.style.overflow = "";
    if (search) {
      setTimeout(() => search.focus(), 50);
    }
  }

  function closeMenu() {
    menu!.setAttribute("hidden", "");
    trigger!.setAttribute("aria-expanded", "false");
    chevron?.classList.remove("rotate-180");
    resetSearch();
  }

  // ── Hover: trigger ──────────────────────────────────────────────────────────
  trigger.addEventListener("mouseenter", () => {
    cancelCloseTimer();
    if (!isOpen()) {
      hoverOpenTimer = setTimeout(openMenu, 150);
    }
  });

  trigger.addEventListener("mouseleave", () => {
    cancelOpenTimer();
    if (isOpen()) {
      hoverCloseTimer = setTimeout(closeMenu, 300);
    }
  });

  // ── Hover: menu panel ───────────────────────────────────────────────────────
  menu.addEventListener("mouseenter", () => {
    cancelCloseTimer();
  });

  menu.addEventListener("mouseleave", () => {
    cancelCloseTimer();
    if (isOpen()) {
      hoverCloseTimer = setTimeout(closeMenu, 200);
    }
  });

  // ── Click: trigger ──────────────────────────────────────────────────────────
  trigger.addEventListener("click", () => {
    cancelOpenTimer();
    cancelCloseTimer();
    if (isOpen()) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  // ── Outside click ────────────────────────────────────────────────────────────
  document.addEventListener("mousedown", (e: MouseEvent) => {
    if (!isOpen()) return;
    const target = e.target as Node | null;
    if (
      target &&
      !trigger!.contains(target) &&
      !menu!.contains(target)
    ) {
      closeMenu();
    }
  });

  // ── Escape + Tab focus-trap ───────────────────────────────────────────────────
  //
  // Mirrors the mobile-overlay trap in Header.astro:
  //   • Escape → close and return focus to the trigger button.
  //   • Tab at last focusable → wrap to first.
  //   • Shift+Tab at first focusable → wrap to last.
  //
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (!isOpen()) return;

    if (e.key === "Escape") {
      closeMenu();
      trigger!.focus();
      return;
    }

    if (e.key === "Tab") {
      const items = megaFocusables();
      if (items.length === 0) return;
      const first = items[0];
      const last  = items[items.length - 1];
      const active = document.activeElement as HTMLElement | null;

      if (e.shiftKey) {
        // Shift+Tab at the first focusable → wrap to last.
        if (active === first) {
          e.preventDefault();
          last.focus();
        }
      } else {
        // Tab at the last focusable → wrap to first.
        if (active === last) {
          e.preventDefault();
          first.focus();
        }
      }
    }
  });

  // ── Close on internal link clicks ────────────────────────────────────────────
  menu.querySelectorAll<HTMLAnchorElement>("a.mega-tool").forEach((link) => {
    link.addEventListener("click", () => closeMenu());
  });

  const viewAll = menu.querySelector<HTMLAnchorElement>('[data-mega-viewall]');
  if (viewAll) {
    viewAll.addEventListener("click", () => closeMenu());
  }

  // Category heading links and Learn / Blog strip links also close the menu.
  menu.querySelectorAll<HTMLAnchorElement>("a[data-mega-cat]").forEach((link) => {
    link.addEventListener("click", () => closeMenu());
  });

  menu.querySelectorAll<HTMLAnchorElement>("a[data-mega-lb]").forEach((link) => {
    link.addEventListener("click", () => closeMenu());
  });

  // ── Search filtering ─────────────────────────────────────────────────────────
  if (search) {
    search.addEventListener("input", () => {
      const q = search.value.toLowerCase().trim();
      const allTools = menu!.querySelectorAll<HTMLAnchorElement>("a.mega-tool");
      let hiddenCount = 0;

      allTools.forEach((link) => {
        const match =
          !q ||
          (link.dataset.toolName ?? "").includes(q) ||
          (link.dataset.toolDesc ?? "").includes(q);
        const li = link.closest("li") as HTMLElement | null;
        if (li) li.hidden = !match;
        if (!match) hiddenCount++;
      });

      const allHidden = hiddenCount === allTools.length;
      if (empty)  empty.hidden  = !allHidden || !q;
      if (emptyQ) emptyQ.textContent = q;
      if (clearBtn) clearBtn.hidden = q.length === 0;
    });
  }

  // ── Clear button ─────────────────────────────────────────────────────────────
  if (clearBtn && search) {
    clearBtn.addEventListener("click", () => {
      search.value = "";
      search.dispatchEvent(new Event("input"));
      search.focus();
    });
  }

  // ── Keyboard navigation inside menu ──────────────────────────────────────────
  menu.addEventListener("keydown", (e: KeyboardEvent) => {
    if (!isOpen()) return;
    if (e.key !== "ArrowDown" && e.key !== "ArrowUp") return;

    const focused = document.activeElement as HTMLElement | null;
    if (!focused || !focused.classList.contains("mega-tool")) return;

    const allTools = Array.from(
      menu!.querySelectorAll<HTMLAnchorElement>("a.mega-tool")
    ).filter((link) => {
      const li = link.closest("li") as HTMLElement | null;
      return !li?.hidden;
    });

    const currentIndex = allTools.indexOf(focused as HTMLAnchorElement);
    if (currentIndex === -1) return;

    e.preventDefault();
    if (e.key === "ArrowDown") {
      const next = allTools[currentIndex + 1];
      if (next) next.focus();
    } else {
      const prev = allTools[currentIndex - 1];
      if (prev) prev.focus();
    }
  });
}

initMegaMenu();
document.addEventListener("astro:page-load", initMegaMenu);
</script>
